    static testMethod void testOTPVerification() {

        Test.startTest();
        Test.setMock(HttpCalloutMock.class, new MockUBOSubmissionCtl());
        User usr = [select id, profileid, contactid from User where isActive = true and profile.name = 'Z' limit 1];
        system.runAs(usr) {
            UBOSubmissionCtl_2 obj = new UBOSubmissionCtl_2();

            obj.mobNum='+971-505334433';
            obj.conEmail='test@gmail.com';
            obj.sendOtp();
            obj.sendEmailOTP();

            obj.validateOtp();

            obj.otpVal = [select id, amsgs__c from g_Req__c where id=:obj.rq.Id limit 1]?.amsgs__c;
            obj.isMobileOTP= false;
            obj.validateOtp();

        }
        Test.stopTest();

    }

