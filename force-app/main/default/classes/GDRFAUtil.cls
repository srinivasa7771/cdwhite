     public static ws_call__c wsCallExpressCheck(Id riid, String wstype, String wsmethod) {
         ws_call__c wscall = null;
         List < ws_call__c > wsLst = [select id, sdt__c from ws_call__c where rq_itm__c =: riid and intsts__c = 'Ready for Integration'
             and ws_typ__c =: wstype and mtd_nm__c =: wsmethod and rq_itm__r.exp__c = true and rq_itm__r.AD__c = 0
         ];
