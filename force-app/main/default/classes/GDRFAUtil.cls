     public static String engToArabicStr(String enName, String gApiToken) {
         try {
             System.debug('enName: ' + enName);
             enName = enName.replace('\\,', '');
             enName = enName.replaceAll('[^a-zA-Z\\s]', '');
             String jso = '{"TextToTranslate" :"' + enName + '","IsEnglishToArabic" : true}';
             String endpointUrl = gU.csStr('GDRFAAPI') + '/scintegration/general/translate';
             HTTPResponse res1 = httpResponse(jso, endpointUrl, 'POST', gApiToken);
            
             gU.FromJSON o = new gU.FromJSON();
             gU.FromJSON obj = o.parse(res1.getBody());
             system.debug('###########arName#################### ' + obj.TranslatedText);
             return obj.TranslatedText;
         } catch (Exception e) {
             System.debug('error line: ' + e.getLineNumber());
             System.debug('error line: ' + e.getMessage());
             return null;
         }
     }
