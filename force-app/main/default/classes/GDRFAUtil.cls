    public static Map<String,Map<String,String>> LookupIdByTypeNname() {
         Map<String,Map<String,String>> getLookupMapId = new Map<String,Map<String,String>>();
         List<GDRFALOOKUP__mdt> lookups = [SELECT type__c,lookupid__c,nameen__c FROM GDRFALOOKUP__mdt ORDER BY type__c ASC];
         for(GDRFALOOKUP__mdt lc : lookups) {
             if(String.isNotBlank(lc.type__c) && String.isNotBlank(lc.nameen__c)) {
                 if(getLookupMapId.containskey(lc.type__c)) {
                     Map<String,String> setTypeValues = getLookupMapId.get(lc.type__c);
                     setTypeValues.put(lc.nameen__c.toUpperCase(),lc.lookupid__c);
                 } else {
                     getLookupMapId.put(lc.type__c, new Map<String,String> {lc.nameen__c.toUpperCase() => lc.lookupid__c});
                 }
             }
         }
         System.debug('lookup size:>>>>> '+getLookupMapId.values().size());
         return getLookupMapId;
     }
     
     public static Map<String,String> getLookupByParentId(String type) {
         List<GDRFALOOKUP__mdt> lookups = [SELECT ParentLookupId__c,type__c,lookupid__c,nameen__c FROM GDRFALOOKUP__mdt WHERE type__c =: type AND nameen__c = 'Unknown' ORDER BY type__c ASC];
         Map<String,String> getLookupByParentId = new Map<String,String>();
         for(GDRFALOOKUP__mdt lc : lookups) {
             getLookupByParentId.put(lc.ParentLookupId__c,lc.lookupid__c);
         }
         return getLookupByParentId;
     }
