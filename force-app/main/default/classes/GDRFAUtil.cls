     public static DateTime noOfWorkingDays(Decimal busHrs) {
         List < BusinessHours > mBH = [select id from BusinessHours where IsDefault = true];
         DateTime dt;
         dt = BusinessHours.add(mBH[0].id, System.now(), 60 * 60 * 1000L * Integer.valueOf(busHrs));
         return dt;
     }
     public static DateTime noOfWorkingDays(Date strDt,integer days) {
         List < BusinessHours > mBH = [select id from BusinessHours where IsDefault = true];
         DateTime dt;
         dt = BusinessHours.add(mBH[0].id, strDt, days * 60 * 60 * 1000L * 8);
         return dt;
     }
