     public static HTTPResponse httpResponse(String requestString, String endpointUrl, String methodType, String gApiToken) {
         HTTPResponse res;
         try{
         HttpRequest req = New HttpRequest();
         req.setHeader('Content-Type', 'application/json');
         // move API to SETTINGS
         req.setHeader('Apikey',gU.csStr('GDRFAAPIKey'));
         req.setHeader('Cache-Control', 'no-cache');
         req.setHeader('Authorization', 'Bearer '+gApiToken);
         if(endpointUrl.contains('/statusInquiry')) {
             req.setHeader('AcceptLanguage', 'en-US');
         }
         req.setTimeout(90000);
         req.setMethod(methodType);
         if(methodType == 'POST' && String.isNotBlank(requestString)) {req.setBody(requestString);}
         else if(methodType == 'GET') req.setHeader('Locale','en-US');
         req.setEndpoint(endpointUrl);
         Http http = new Http();
         system.debug('Grant type header set');
          res = http.send(req);
         }catch(Exception e){system.debug(e.getStackTraceString());}
         return res;
     }
