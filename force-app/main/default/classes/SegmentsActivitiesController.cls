                                             slaXP__c = srvItem.slaXP__c, xcpor__c = req.xppor__c, xspor__c = req.xspor__c,xcpnc__c = req.xpveh__c, xspnc__c = req.xsvn__c,
                                             xceml__c = req.xceml__c, dc__c = srvItem.dc__c, vsc__c=req.spCh__c?srvItem.vspc__c+srvItem.vsc__c:srvItem.vsc__c,
                                             vesch__c=req.spCh__c?srvItem.vspexc__c+srvItem.vesch__c:srvItem.vesch__c, vst__c=srvItem.vst__c,vec__c=srvItem.vec__c,su__c=srvItem.su__c,
                                             vsu__c=srvItem.vsu__c, TAX_CODE__c = srvItem.TAX_CODE__c,TAX_TYPE__c = srvItem.TAX_TYPE__c, extc__c = srvItem.extc__c,
                                             TAXCODE_SC__c = srvItem.TAXCODE_SC__c, extcsc__c = srvItem.extcsc__c));
