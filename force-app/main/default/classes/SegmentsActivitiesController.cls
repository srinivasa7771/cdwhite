    //Update Request object
    public void updateRequest(){

        system.debug('updateRequest::::');
        String segActJson = apexpages.currentpage().getparameters().get('segmentActivityJson');
        system.debug('segActJson:::'+segActJson);

        if (!String.isBlank(segActJson)){
            segActJson = segActJson.replaceAll('&amp;amp;','&'); segActJson = segActJson.replaceAll('&amp;','&');
            req.xadtx2__c = segActJson;
            List <RequestJsonWrapper> reqSegList = (List<RequestJsonWrapper>)System.JSON.deserialize(segActJson,List<RequestJsonWrapper>.class);
            String docs='';
            req.xcddocs__c ='';
            for (RequestJsonWrapper seg : reqSegList){
                for (SegActivities act :seg.SegActivities){
                    for (string docname : act.docs){docs += docname + ';';}
                }
            }
            req.xcddocs__c = docs.removeEnd(';');
        }else{
            req.xadtx2__c = ''; req.xcddocs__c='';
        }
        try{
            update req;
            system.debug('xadtx2__c::::'+req.xadtx2__c);
            system.debug('xcddocs__c::::'+req.xcddocs__c);
            system.debug('xadh__c::::'+req.xadh__c);
            system.debug('req::::'+req);
        }catch (Exception ex){
            system.debug(ex.getMessage());
        }
    }


