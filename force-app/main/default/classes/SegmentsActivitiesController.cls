    //Create Map for selected activity and segments
    public void createMapforSelectedSegAct(String adhocVal){

        System.debug('createMapforSelectedSegAct adhocVal:: ' + adhocVal);
        if (!String.isBlank(adhocVal)){
            getRequestJsonForReview(adhocVal);
            List <RequestJsonWrapper> reqSegList = (List<RequestJsonWrapper>)System.JSON.deserialize(adhocVal, List<RequestJsonWrapper>.class);
            system.debug('reqSegList:::'+reqSegList);
            activityMap = new Map<String,SegActivities>();
            segmentMap = new Map<String,RequestJsonWrapper>();
            for (RequestJsonWrapper seg: reqSegList){
                system.debug('test::'+seg.segId);
                segmentMap.put(seg.segId,seg);
                for (SegActivities act:seg.SegActivities){
                    activityMap.put(act.actId,act);
                }
            }
            system.debug('activityMap::::'+activityMap.size());
            ChkActivityMapKey = string.valueof(activityMap.keyset()).replace('{', '').replace('{', '');
            system.debug('ChkActivityMapKey:::'+ChkActivityMapKey);
            system.debug('segmentMap::::'+segmentMap);
            ChkSegmentMapKey = string.valueof(segmentMap.keyset()).replace('{', '').replace('{', '');
            system.debug('ChkSegmentMapKey:::'+ChkSegmentMapKey);
        }
        if (ChkActivityMapKey != null){
            selected= true;
        }

    }


