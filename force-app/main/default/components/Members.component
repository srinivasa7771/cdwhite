    <script>
    function validAlphaNumeric(e){ // 1.3
        let n = $(e);
        n.val(n.val().replace(/[^0-9a-zA-Z]*$/, ''));
    }
    cs['sourceoffunds']=getC('{!$Component.sourceoffunds}'); //1.1
    var countryNamesOptions= '<option value=""></option>'; //1.1
    for(x=0;x<countryCode_Obj.length;x++){
        var i = countryCode_Obj[x];
        var opt = '<option value="'+i.ddaname+'">'+i.axsname+'</option>';
        countryNamesOptions += opt;
    }
    $('.countryNames').html(countryNamesOptions);
    setTimeout(function(){
        $('.countryNames').select2({allowSearch:true});
    },500);
    
    function updatePEPAssociation(pepValue){ //1.1
        if(pepValue == 'Closely Related to PEP'){
            $('#closlyRelatedPEP').show();
            $('#closelyAssociatedPEP').hide();
            $('#pEPSelf').show();
        }
        else if(pepValue =='Closely Associated to PEP'){
            $('#closelyAssociatedPEP').show();
            $('#closlyRelatedPEP').hide();
            $('#pEPSelf').show();
        }
        else if(pepValue =='PEP (Self)'){
            $('#pEPSelf').show();
            $('#closelyAssociatedPEP').hide();
            $('#closlyRelatedPEP').hide();
        }
        else{
            $('#closelyAssociatedPEP').hide();
            $('#closlyRelatedPEP').hide();
            $('#pEPSelf').hide();
        }
    }
    
    function onChangePepRelated(selectElement,sectionName){ //1.1
        let selectedValues = [];
        for (let i = 0; i < selectElement.options.length; i++) {
            if (selectElement.options[i].selected) {
                selectedValues.push(selectElement.options[i].value);
            }
        }
        if(selectedValues.includes('others: (Please specify details in below text box)')){
            if(sectionName == 'closelyRelatedToPEP'){
                $('#othersCloselyRelated').show();
            }
            else{
                $('#othersCloselyAssociated').show();
            }
        }
        else{
            if(sectionName == 'closelyRelatedToPEP'){
                $('#othersCloselyRelated').hide();
            }
            else{
                $('#othersCloselyAssociated').hide();
            }
        }
    }     
    </script>
