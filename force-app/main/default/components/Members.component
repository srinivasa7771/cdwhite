            <script>
            if('{!gmDec.id}' != null && '{!gmDec.id}' != ''){
                $('#GMDocupload').show();
                $('input[name=gmvs][value="yes"]').prop('checked',true);
            }
            $('input[name=gmvs]').on('change',function () {
                $('.gmvscls').parent().parent().find('.invalid-feedback').html('* This field is required!').hide();
                $('.gmvscls').parent().parent().find('.frmErrMsg').remove();
                console.log('GM flg:'+$(this).val());    
                if ($(this).val() === 'yes') {
                    cs['inUAE__c'].value = true;
                    $('#GMDocupload').show();
                } else {
                    $('#GMDocupload').hide();
                    cs['inUAE__c'].value = false;
                }
            });
            
            
