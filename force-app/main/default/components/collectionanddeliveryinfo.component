<apex:component id="collDelInfo" allowdml="true">
    <apex:attribute name="srv" description="Request" type="g_Srvc__c" required="false"/>
    <apex:attribute name="req" description="Request" type="g_Req__c" required="true"/>
    <apex:attribute name="cmpTitle" description="Component Title" type="String"/>
    <apex:attribute name="noNotes" description="to show notes or not" type="String" required="false"/>
    
    <apex:outputText rendered="{!IF(cmpTitle == '',true,false)}">
        <h4 class="mt-4">Collection &amp; Delivery Information</h4>
    </apex:outputText>
    <apex:outputText rendered="{!IF(cmpTitle == '',false,true)}">
        <h4 class="mt-4">{!cmpTitle}</h4>
    </apex:outputText>
    <div class="row row-lg" id='cllInfor'>
        <div class="col-lg-6">
            <div class="form-group">
                <label>Reference mobile</label>
                <div class="d-flex">
                    <div style="flex-basis: 150px;width: 150px;">
                        <div style="flex-basis: 150px;width: 90px;">
                            <div class="form-control">
                                +971
                            </div>
                        </div>
                    </div>
                    <apex:inputField ignoreEditPermissionForRendering="true" type="text" styleClass="applMob form-control ml-3 numOnly jsnfld" value="{!req.rmob__c}" id="rmob__c"
                                     />
                    <script type="text/javascript">
                    cs['rmob__c']=document.getElementById('{!$Component.rmob__c}');
                    </script>
                </div>
            </div>
        </div>
        <!-- changes for DI starts -->
        <apex:outputText rendered="{!(OR(srv.uid__c=='196',srv.uid__c!='197'))}">
            <div class="col-lg-6">
                <div class="form-group">
                    <!--<label>Delivery Zone</label>-->
                    <Label>Community</Label>
                    <apex:inputField ignoreEditPermissionForRendering="true" onchange="createDepDds()" styleClass="jsnfld ddValidation requiredFld form-control input-select2-tags" value="{!req.xbrnd__c}" id="xbrnd__c"/>
                    <script type="text/javascript">
                    cs['xbrnd__c']=document.getElementById('{!$Component.xbrnd__c}');
                    </script>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="form-group">
                    <label>Building name</label>
                    <apex:inputField ignoreEditPermissionForRendering="true" styleClass="jsnfld ddValidation depDD form-control input-select2-tags" value="{!req.xbn__c}" id="xbn__c"/>
                    <script type="text/javascript">
                    cs['xbn__c']=document.getElementById('{!$Component.xbn__c}');
                    </script>
                </div>
            </div>
        </apex:outputText>
        <apex:outputText rendered="{!srv.uid__c=='197'}">
            <div class="col-lg-6">
                <div class="form-group">
                    <Label>Community</Label>
                    <select id="community_xbrnd" class="form-control input-select2-tags dum requiredFld" 
                            onChange="setToRQFld('xbrnd',this);showDepFld(this);">
                        <option value="">--None--</option>
                        <option value="DI">DI</option>
                        <option value="D3">D3</option>
                        <option value="DHCC">DHCC</option>
                        <option value="DIAC">DIAC</option>
                        <option value="DIC">DIC</option>
                        <option value="DKP">DKP</option>
                        <option value="DMC">DMC</option>
                        <option value="DOZ">DOC</option>
                        <option value="IMPZ">DPC</option>
                        <option value="DSC">DSC</option>
                        <option value="DSP">DSP</option>
                        <option value="TECOM">TECOM</option>
                    </select>
                    <apex:inputHidden id="xbrnd" value="{!req.xbrnd__c}" /> 
                    <script type="text/javascript">
                    cs['xbrnd']=document.getElementById('{!$Component.xbrnd}');
                    if(cs['xbrnd'].value &&cs['xbrnd'].value!='--None--')
                        $('#community_xbrnd').val(cs['xbrnd'].value);
                    </script>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="form-group">
                    <Label>Building name</Label>
                    <select id="bldng_xbn" class="form-control input-select2-tags dum requiredFld" 
                            onChange="setToRQFld('xbn',this)">
                        <option value="">--None--</option>
                    </select>
                    <apex:inputHidden id="xbn" value="{!req.xbn__c}" /> 
                    <script type="text/javascript">
                    cs['xbn']=document.getElementById('{!$Component.xbn}');
                    if(cs['xbn'].value &&cs['xbn'].value!='--None--')
                        $('#bldng_xbn').val(cs['xbn'].value);
                    </script>
                </div>
            </div>
        </apex:outputText>
        <!-- changes for DI ends -->
        <apex:outputText rendered="{!AND(srv.uid__c!='924',srv.uid__c!='196')}">
            <div class="col-lg-6">
                <div class="form-group">
                    <Label>Delivery address</Label>
                    <apex:inputField ignoreEditPermissionForRendering="true" styleClass="jsnfld requiredFld form-control" style="height:52px;" value="{!req.xaloc__c}" id="xaloc__c"/>
                    <script type="text/javascript">
                    cs['xaloc__c']=document.getElementById('{!$Component.xaloc__c}');
                    </script>
                </div>
            </div>
        </apex:outputText>
        <apex:outputText rendered="{!srv.uid__c=='196'}">
            <div class="col-lg-6">
                <div class="form-group">
                    <Label>Delivery and Collection Address</Label>
                    <apex:inputField ignoreEditPermissionForRendering="true" styleClass="jsnfld requiredFld form-control" style="height:52px;" value="{!req.xaloc__c}" id="xaloc_lr__c"/>
                    <script type="text/javascript">
                    cs['xaloc__c']=document.getElementById('{!$Component.xaloc_lr__c}');
                    </script>
                </div>
            </div>
        </apex:outputText>
        <div class="col-lg-12" style="{!IF(noNotes=='true','display:none','')}">
            <div class="form-group">
                <label>Notes (optional)</label>
                <apex:inputField ignoreEditPermissionForRendering="true" styleClass="jsnfld form-control" value="{!req.nt__c}" id="nt__c"/>
                <script type="text/javascript">
                cs['nt__c']=document.getElementById('{!$Component.nt__c}');
                </script>
            </div>
        </div>
    </div>
