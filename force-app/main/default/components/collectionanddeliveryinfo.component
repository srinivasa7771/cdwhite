    function showDepFld(e){
    	let v = $(e).val();
        var options = '<option value="">--None--</option>';
        if(v&&Object.keys(customBuildingbj).includes(v)){
			for([i,j] of customBuildingbj[v].split(',').entries()){
            	if(j)
                    options+= '<option value="'+j+'">'+j+'</option>';
            }
            //options+= '<option value="'+customBuildingbj[v]+'">'+customBuildingbj[v]+'</option>';
        }
        $('#bldng_xbn option').remove();
        $('#bldng_xbn').append(options);
         $('#bldng_xbn').select2();
    }
