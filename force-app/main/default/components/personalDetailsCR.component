            $("#optionallnm").prop('checked',true);
        }else if(typicalCountries.includes(cs["xcnc__c"].value)){
                        $('.fnLbl').text('Full name');
                        //$('.lnLbl').text('Last name');
           /* if(srvcd=='055' || srvcd=='016' || srvcd=='105'|| srvcd=='106' || srvcd=='305' || srvcd=='306'){
                if(!cs['xcfn__c'].value.includes(cs["xcln__c"].value.replaceAll('-',''))){
                    cs['xcfn__c'].value=cs['xcfn__c'].value+' '+ cs['xcmn__c'].value+' '+cs["xcln__c"].value;
                    cs['xcfnar__c'].value=cs['xcfnar__c'].value+' '+cs['xcmnar__c'].value+' '+cs["xclnar__c"].value;
                } 
                
                
                }*/
                        $('.optLn').hide();
                    } 
            else{
                /*if((srvcd=='055' || srvcd=='016' || srvcd=='105'|| srvcd=='106' || srvcd=='305' || srvcd=='306') && cs["xcnc__c"].value!='Philippines'){
                    if(!cs['xcfn__c'].value.includes(cs["xcmn__c"].value.replaceAll('-',''))){
                        cs['xcfn__c'].value=cs['xcfn__c'].value+' '+ cs['xcmn__c'].value;
                        cs['xcfnar__c'].value=cs['xcfnar__c'].value+' '+cs['xcmnar__c'].value;
                    }
                }*/
            $('.optLn').show();
            $("#optionallnm").prop('checked',false);
        }
    }
    
    </script>
    <div class="form-group">
