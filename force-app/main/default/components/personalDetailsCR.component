                <apex:outputPanel style="display:inline-block" rendered="{!title.Value == req.xcslt__c}" styleClass="mb-4">
                    <label class="custom-radio mr-5">
                        <input type="radio" value="{!title.Value}" checked="true" name="salutation" onchange="salutionOnChange();" class="requiredFld"/>
                        <span>{!title.Label}</span>
                    </label>
                </apex:outputPanel>
                <apex:outputPanel style="display:inline-block" rendered="{!title.Value != req.xcslt__c}"  styleClass="mb-4">
                    <label class="custom-radio mr-5">
                        <input type="radio" value="{!title.Value}" name="salutation"  onchange="salutionOnChange();" class=""/>
                        <span>{!title.Label}</span>
                    </label>
                </apex:outputPanel>
            </apex:repeat>
            <apex:inputHidden id="xcslt__c" value="{!req.xcslt__c}" />
            <!-- Salutation-->
            <!-- Martial status-->
            <div class="option-error frmErrMsg" style="display:none">Please select an option!</div>
            <script type="text/javascript">
            cs['xcslt__c']=document.getElementById('{!$Component.xcslt__c}');
            </script>
        </div>
    </div>
