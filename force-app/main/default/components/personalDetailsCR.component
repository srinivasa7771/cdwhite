                cs['xcnc__c']=document.getElementById('{!$Component.xcnc__c}');
                var typicalCountries = cs["firstNameCountries"].value;/*.split(';');*/
                function validateCurrenNationality1(thisElement){
                    var curNat = $(thisElement).val();
                    $('.names i,.lnOptional,.PPNote,.mName').hide();
                    $('.fnLbl').text('Given name');
                    $('.optLn').show();
                    if(typicalCountries.includes(cs["xcnc__c"].value)){
                        $('.fnLbl').text('Full name');
                        //$('.lnLbl').text('Last name');
                        $('.optLn').hide();
                    }
                    if(['India','Nepal','Pakistan','Philippines'].includes(curNat) && shwspousenm){
                        $('.PPNote, i.'+curNat).show();
                        if(curNat == 'India'){
                            $('.lnOptional').show();
                        }
                    }
                    if(curNat=='Philippines' )/*||cs['xcmn__c'].value*/
                        $('.mName').show();
                }
                </script>
            </div>
