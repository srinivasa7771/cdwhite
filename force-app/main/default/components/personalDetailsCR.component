    <script>
    function assignfldVal(val,fldId){cs[fldId].value=val;}
    function lastNameOpt(e){
        console.log($(e).is(':checked'));
        if($(e).is(':checked')==false){
            $('.optLn').show();
            cs["noFnm__c"].value = false; cs["noFnm__c"].checked = false;
            
        }else if($(e).is(':checked')==true){
            $('.optLn').hide();
            //cs["xcln__c"].value = ''; cs["xclnar__c"].value = ''; 
            cs["noFnm__c"].value = true;cs["noFnm__c"].checked = true;
            
        }
    }
    function salutionOnChange(){
        var salutation = $("input[name='salutation']:checked").val();
        $("input[name='salutation']").parent().parent().parent().find('.option-error').hide(); 
        cs['xcslt__c'].value=salutation;
        console.log('salutionOnChange >>'+ cs['xcslt__c'].value);
        
        if(shwspousenm){spNmCheckbox();}
    }
    function martialStatusOnchange(){
        var martialStatus = $("input[name='martialStatus']:checked").val();
        $("input[name='martialStatus']").parent().parent().parent().find('.option-error').hide(); 
        cs['xcms__c'].value=martialStatus;
        console.log('martialStatusOnchange >>'+ cs['xcms__c'].value);
    }
    function spokenLanguageOnchange(){
        var spokenLanguages = $('#spokenLng').val().join(';');
        cs['xclng__c'].value=spokenLanguages;
        console.log('spokenLanguageOnchange >>'+ cs['xclng__c'].value);
    }
    
    function checkSpNm(){ 
        if($("#chspnm").is(':checked')){
            $('.spousename').show();
            cs["spnm__c"].checked = true; cs["spnm__c"].value = true;
        }else if($("#chspnm").is(':checked')==false){
            $('.spousename').hide();
            cs["xspn__c"].value = ''; cs["xspnar__c"].value = '';   
            cs["spnm__c"].checked = false; cs["spnm__c"].value = false;
        }
    }
    
    function checkntknm(){ 
      
    }
    
    function spNmCheckbox(){
        
        //var isVc = cs["xcpic__c"].value == "India" || cs["xcpic__c"].value == "Pakistan" || cs["xcpic__c"].value == "Nepal";
        if(shwspousenm){  
            // spouse name changes only for pakistan
            var ntcArr = ['Pakistan'];
            var isVc = ntcArr.includes(cs["xcnc__c"].value) ;// || xcpic__c
            if(isVc && cs['xcslt__c'].value=='Mrs.'){ 
                $("#spNamechkb").show();
            }else{
                $("#spNamechkb").hide(); $("#chspnm").prop("checked",false); $("#chspnm").trigger("change");
            }

            // next of kin name changes only for nepal            
            if(cs["xcnc__c"].value=="Nepal"){
                $("#nepchkfndiv").show();  $('.ntknm').hide();
                if(cs["afn__c"].value=="true"){ $("#chkntknm").prop("checked",true); $("#chkntknm").trigger("change");}
            }else{
                $("#nepchkfndiv").hide(); $("#chkntknm").prop("checked",false); $("#chkntknm").trigger("change");
            }
        }
        
        
        
    }
    
    function nepchkfnc(){
        /*if($("#nepchkfn").is(':checked')){
            //$('.fthrnm').hide();
            cs["afn__c"].checked= true; cs["afn__c"].value= true;             
            cs["xcfan__c"].value = ''; cs["xcfanar__c"].value = ''; 
        }else if($("#nepchkfn").is(':checked')==false){
            //$('.fthrnm').show();
            cs["afn__c"].checked= false; cs["afn__c"].value= false; 
        }*/
        if($("#chkntknm").is(':checked')){
            $('.ntknm').show();
            cs["afn__c"].checked= true; cs["afn__c"].value= true;
        }else if($("#chkntknm").is(':checked')==false){
            $('.ntknm').hide();
            cs["ntk__c"].value = ''; cs["ntkar__c"].value = ''; 
            cs["afn__c"].checked= false; cs["afn__c"].value= false;
        }
        
    }
    
    var srvcd='{!req.srvc__r.uid__c}';
    function nofname(){
        var typicalCountries = cs["firstNameCountries"].value;
        var nofathername = cs["noFnm__c"].value;
