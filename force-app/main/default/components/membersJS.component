        parentCompData.emailId = (data.ofceml)?data.ofceml:data.emailId,parentCompData.ctgCode = category,parentCompData.ctg = categoryObj[category];
        parentCompData.ctgCode1 = category, parentCompData.isParentComp = 'true';parentCompData.dob = cs['xbtnm__c'].value;
