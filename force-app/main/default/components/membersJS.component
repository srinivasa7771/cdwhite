    function validateMobileNumber(elem) {
        var mobileNumber = $(elem).val();

        if (mobileNumber.startsWith('0')) {
            addValError( $(elem),'Please enter valid mobile number.');
            return true;
        }
        if (mobileNumber.includes('-')) {
            addValError( $(elem),'Please enter valid mobile number.');
            return true;
        }
        if (mobileNumber.length < 8 || mobileNumber.length > 11) {
            addValError( $(elem),'Please enter valid mobile number.');
            return true;
        }
        return false;
    }
    
