    /* to override checkEmail from axs2Customjs to add .llc */
    function checkEmail(elem){
        console.log('checkEmail::::::::::::::::::::::::::');
        var e = $(elem);
        var email = e.val();
        console.log('email:::'+email);
        var regex = /^[-a-z0-9~!$%^&*_=+}{\'?]+(\.[-a-z0-9~!$%^&*_=+}{\'?]+)*@([a-z0-9_][-a-z0-9_]*(\.[-a-z0-9_]+)*\.(aero|ntt|arpa|biz|com|coop|edu|gov|info|int|mil|llc|museum|name|net|org|pro|travel|mobi|[a-z][a-z])|([0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}))(:[0-9]{1,5})?$/;
        var r = (regex.test(email))?true:'invalid';
        showErrMsg(e,'mail',r);
        if(r == 'invalid' && email != ''){
            console.log('invalid:::::::::::::');
            addValError(elem,'Please enter valid email Address');
            return false;
        }else{
            console.log('valid:::::::::::::');
            removeValError(elem);
        }
        
    }
