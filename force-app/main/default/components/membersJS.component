    /* basic validation to check URL */
    var isValidUrl = (url) => {try {new URL(url); } catch (e) { console.log(e); return false; } return true; };    
    function checkUrl(e){
        var url = $(e).val();
        if(isValidUrl(url)){
            removeValError(e);
        }
        else{
            addValError(e,'Please enter a valid URL');
            scrollToDiv($(e).parent());
        }
    }
