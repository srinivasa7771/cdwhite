    function checkPPEdit(e){ 
        var newPP = $(e).val();
        const psNoPattern = /^[a-zA-Z0-9]{6,12}$/;
        if (isCurrentlyEditing && currentlyEditingPP != newPP) { //1.1
            $(e).val(currentlyEditingPP);
            addValError($(e), 'Changing <b>Passport number</b> is not allowed, please delete member and add again.');
        }
        else if(psNoPattern.test(newPP) == false || newPP.length < 6 || newPP.length > 12){ //1.1
            addValError($(e),'Passport Number must be 6-12 characters long and contain only letters and numbers !'); 
        }
    }
