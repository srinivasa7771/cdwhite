    function formatDate(date,ev){
        var d ;
        if(date.includes(' ')){
            date = date.toLowerCase();
            d = date.split(' ');
            if(Object.keys(monthObj).includes(d[1].toUpperCase())){  // case-1: date format -- 01 Jan 2020
                return date.split(d[1].toLowerCase()).join(monthObj[d[1].toUpperCase()]).split(' ').join('/');
            }
            else              // case-2: date format -- 01 01 2020
                return date.split(' ').join('/');
        }
        else if(date.includes('-'))          // case-3: date format -- 01-01-2020
            return date.split(' ').join('/');
            else if(date.length==6){          // case-4: date format -- 200101
                var ds = date.split('');
                date = (ev.includes('issue')||ev.includes('expiry'))? ds[4]+ds[5]+'/'+ds[2]+ds[3]+'/20'+ds[0]+ds[1]:ds[4]+ds[5]+'/'+ds[2]+ds[3]+'/19'+ds[0]+ds[1];
                return date;
            }
                else               // case-5: date format -- 01/01/2020
                    return date;
    }
