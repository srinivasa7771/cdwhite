    var uboChecks = [];
    function setUboData(e){
        $(e).parents('.uboChkPrnt').find('.frmErrMsg').remove();
        var val = $(e).parent().find('span').text().trim();
        if(!val) return;
        uboChecks = uboChecks.filter((v) => {return v != val});
        if($(e).prop('checked'))
            uboChecks.push(val);
        enableUBOSave();
    }
    function enableUBOSave(){
        var enableSave = false;
        if(uboChecks.length>0 && cs["legals"].value)
            enableSave = true;
        if(enableSave == true)
            $('#indToUbo').removeClass('disabled');
        else
            $('#indToUbo').addClass('disabled');
    }
    
    function indMemToUBO(e){
        let invalData = false;
        if($(e).hasClass('disabled'))
            return;

        $('.forEdit:visible').each(function(){
            var elem ='';
            var k = $(this).attr('fldname');
            var v = $(this).val();
            if($(this).hasClass('chkubo')){
                v = $(this).is(":checked");
            }
            if ((!v || v == '--None--') && (!($(this).attr('optional') == 'true')) && k != 'sourceOfwealth' ){
                if($(this).hasClass('foreign'))
                    return;
                if(elem=='') elem = $(this);
                if($(this).is('select'))
                    $(this).next().find('.select2-selection').addClass('is-invalid');
                else
                    $(this).addClass('is-invalid');
                $('.rqrdMsg').addClass('high');
                invalData = true;
            }
            if(elem)
                scrollToDiv(elem);
        });
        console.log('invalData after initiatl valida:'+invalData);
        $('.reqRadio:visible').each(function () { // PJ 1.2
            var checked = false;
            $(this).find(':radio').each(function () {
                if ($(this).is(':checked')) {
                    checked = true;
                    return;
                }
            });
            if (!checked) {
                $(this).find('.option-error').show();
                invalData = true;
            } else
                {
                $(this).find('.option-error').hide();
                    }
        });

        console.log('invalData before starting valida:'+invalData);
        /* 1.3 PJ - Start */
        let incomeSourceElem = $('[id$="incomeSource"]');
        removeValError(incomeSourceElem);

        let incomeSource = incomeSourceElem.val();
        let incomeCountry = $('#incomeCountry').val();
        let detail = $('#detail').val();

        console.log('incomeSource  : '+incomeSource);
        console.log('incomeCountry  :'+incomeCountry);
        console.log('detail  :'+detail);

        let validatePEP = validData(incomeSource,detail,incomeCountry,'Add',true);

        console.log('validatePEP :'+validatePEP);

        invalData = !validatePEP ? true : invalData;
        /* 1.3 PJ - End */
        console.log('invalData :'+invalData);
        
        if (!invalData && cs['sourceoffunds'] == undefined || cs['sourceoffunds'] == '' || cs['sourceoffunds'].value == '' || cs['sourceoffunds'].value == '[]') {
                addValError($('[id$="incomeSource"]'), 'Please select a option!');
                invalData = true;
        }

        if(existMemToUBO && existMemToUBOPP && !invalData){
            var mem = JSON.parse($('#'+existMemToUBOPP).val());
            mem.actingAsNomineeShareholder=nomineeSholder;
            mem.actingAsNomineeDirector=nomineeDirector;
            mem['legals'] = $('[fldname="legals"]').val();
            mem['uboType'] = uboChecks.join(';');


            // PJ 1.2 Start
            mem.pepAssociation = $('[fldname="pepAssociation"]').val();
            mem.pepRelated = mem.pepAssociation == 'Closely Related to PEP'? $('[fldname="pepCloselyRelated"]').val()  : mem.pepRelated;
            mem.pepRelated = mem.pepAssociation == 'Closely Associated to PEP' ? $('[fldname="pepCloselyAssociated"]').val()  : mem.pepRelated;

            mem.pepCloselyRelatedOthers = mem.pepAssociation == 'Closely Related to PEP'  ? $('[fldname="pepCloselyRelatedOthers"]').val() : '';
            mem.pepCloselyAssociatedOthers = mem.pepAssociation == 'Closely Associated to PEP'  ?  $('[fldname="pepCloselyAssociatedOthers"]').val() : '';
            mem.pepCountry = $('[fldname="pepCountry"]').val();
            mem.sourceOfwealth = cs['sourceoffunds'] && cs['sourceoffunds'].value ? JSON.parse(cs['sourceoffunds'].value) : '';  

            if(mem.pepAssociation != 'Closely Related to PEP' && mem.pepAssociation != 'Closely Associated to PEP'){
                mem.pepCloselyAssociatedOthers ='';
                mem.pepCloselyRelatedOthers = '';
                mem.pepRelated = null;
                mem.pepCountry = mem.pepAssociation == 'Not Applicable' ? '' : mem.pepCountry;
            }  

            cs['sourceoffunds'].value = '';
            document.getElementById('tableBody').innerHTML = ''; // PJ 1.2
            console.log('## currentAddingMemData final ## '+JSON.stringify(mem));
            $('#'+existMemToUBOPP).val(JSON.stringify(mem));
            existMemToUBO = false;
            existMemToUBOPP = '';
            // PJ 1.2 End
            
            if(!($.isEmptyObject(mem))){
                addExtraMemWOinput(mem,'ub');
            }
            $('#indToUbo').hide();
            $('#modal_confirm_information').modal('hide');
        }
    }
    
