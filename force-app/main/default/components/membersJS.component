    function createDropdowns(){
        $('.dropdowns').each(function(){
            var elem = this;
            let pctoUBO = '';
            let selcode= $(elem).attr('selcode');
            $(elem).find('option').remove();
            $(elem).append('<option value="" >Select</option>');
            $('.shareholder-box-main input').each(function(e,v){
                if(v.value){
                    var x = JSON.parse(v.value);
                    if(x.isParentComp)
                        return;
                    var shPerc = x["shareNum"]/$('#sharesTotal').val()*100;
                    if(x["type"]=="corp"){
                        var y = x["compName"];
                        var z = x["RegNum"];
                        if($(elem).attr('selcode').includes('ub') && shPerc>=25)
                            $('[selcode="ub"]').append('<option type="'+x["type"]+'" pno="'+z+'" value="'+y+'" >'+y+'</option>');
                        return;
                    }
                    var y = x["fname"]+" "+x["lname"];
                    var z = x["passportNo"];
                    if((x['ctgCode']=='ub' && shPerc>=25) || x['ctgCode']=="bd"){//$(elem).attr('selcode').includes('ub'){
                        var cd = x['ctgCode'];
                        $('[selcode="'+cd+'"]').append('<option type="'+x["type"]+'" disabled="true" pno="'+z+'" value="'+y+'" >'+y+'</option>');
                    }
                    else{
                        if($(elem).attr('selcode').includes('ub')){
                            if(shPerc>=25)
                                $(elem).append('<option pno="'+z+'" value="'+y+'" >'+y+'</option>');
                        }
                        else
                            if($(elem).attr('selcode').includes('gm') && dropDownData['gm']&&dropDownData['gm'].selected&&z==dropDownData['gm'].selected){
                                $(elem).append('<option pno="'+z+'" selected value="'+y+'" >'+y+'</option>');
                            }
                            else
                                $(elem).append('<option pno="'+z+'" value="'+y+'" >'+y+'</option>');
                    }
                    if(x.uboRelatedTo && x.rRegNum && x.isParentCompToUbo){
                        pctoUBO = ' disabled="true" ';
                    }
                }
            });
            if($(elem).attr("selCode")!='ub'){
                $(elem).append('<option value="'+$(elem).attr("selCode")+'">Add New Member</option>');
            }
            else{/*MS 1.1*/
                 if( '{!rq.Acc__r.clt__c}' != 'Land' && '{!rq.xvtyp__c}' != 'DED' && cs['xccn__c']&&cs['rtacn__c']&&cs['xccn__c'].value&&cs['rtacn__c'].value){
                    $('[selcode="ub"]').append('<option'+pctoUBO+' parentcomp="true" type="corp" pno="'+'{!rq.rtacn__c}'+'" value="'+'{!rq.xccn__c}'+'" >'+'{!rq.xccn__c}'+'</option>');
                }
                $(elem).append('<option value="'+$(elem).attr("selCode")+'">Add new UBO</option>');
            }
        });
        let emptyACA = true;
        for(i in addCtgArr){
            if(addCtgArr[i] && addCtgArr[i].length>0)
                emptyACA = false;
        }
        if(!emptyACA){
            for(i in addCtgArr){
                for(let j of addCtgArr[i]){
                    let v = $('#'+j).val();
                    if($('[selcode="'+i+'"]').find('option[pno="'+j+'"]').length>0)
                        $('[selcode="'+i+'"]').find('option[pno="'+j+'"]').attr('disabled',true);
                    else if(v && JSON.parse(v).uboRelatedTo && JSON.parse(v).rRegNum) /*Ms 1.1*/
                        $('[selcode="'+i+'"]').find('option[pno="'+JSON.parse(v).rRegNum+'"]').attr('disabled',true);
                }
            }
        }
        memCompletion();
    }
    
