                        console.log('gm===',i);
                        var proceed  = false,u = 0;
                        if(mandatoryUBO.length>0){
                            for(let i of mandatoryUBO){
                                for(let j of addCtgArr.ub){
                                    let v = JSON.parse($('#'+j).val());
                                    if(i==j || i==v.rRegNum){
                                        u++;            
