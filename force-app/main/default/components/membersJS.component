    function validateDOB(elem,type){
        if(type=='ind'){ // checks when type is individual
            var date = $('#modal_confirm_information').find('[validationName="'+elem+'"]').val();
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            if(elem=='dob')
                return (days>=(365*18)); // 18years for date of birth
            else if(elem=='pid')
                return (days>=1); // atleaset one day old passport
                else if(elem=='ped')
                    return (180<Math.abs(days)); //atleast a 6 month validity for passport
        }
        else{ // checks when type is corporate
            var date = $('#add_corp_shareholder').find('[validationName="'+elem+'"]').val();
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            return (days>=(365*2)); // atlease 2 year old company
        }
    }
    
