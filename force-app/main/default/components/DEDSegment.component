    <script>
    $(document).ready(function(){
        console.log('in rady3434');
        //Hide fields
        setTimeout(function(){
            console.log('in createDedActOption456');
            getRemoteContact();
            // createDedActOption();
        },1000); });
    
    function activitiesOnchange(){
        console.log('activitiesOnchange:::');
        var activities = '';
    }
    
    function checkEmptSel(e){
        //debugger;
        var v = $(e).val();
        console.log(740+' --- '+v);
        if(v!=''&&v!='--None--'&&v!='Select')
            removeValError($(e));
    }
    var segwraper ;
    function getRemoteContact() {
        showTempLoader_input();
        //SaveImage.saveImage('001Ik000005yIpM',imgData,handleResult); 
        Visualforce.remoting.Manager.invokeAction(
            //Invoking controller action getcon
            '{!$RemoteAction.SegmentsActivitiesController.getDedActivities}',
            
            function(result, event){
               //We can access the records through the parameter result
               //event.status determines if there is error or not 
               if(event.status){
                   console.log('result===',result);
                  segwraper = result;
                    console.log('data-json===',segwraper); 
                     createDedActOption();                                     
               }               
            },
            {escape: true}
        );
    }
    
    function checkActivity()
    {
        var isProceedNext = true;
        $('.requiredFld').each(function(){
            let v = $(this).val(); 
            if(!v)
            {
                $(this).parent().find('.invalid-feedback').html('* This field is required!').show();
                // alert('Please fill required value');
                isProceedNext = false;
            }
        });
        
        if(isProceedNext)
        {
            $(this).parent().find('.invalid-feedback').html('').hide();
        }
        var actNum = $('#hpr').val()?.length;
        if(!actNum || actNum < 1)
        {
            $('.activityErrorElement').show();
        }
        else
        {
            $('.activityErrorElement').hide();
            var dedselAct = $('#hpr').val();
            
            cs["xadtx2__c"].value = createDedAct(dedselAct);
            if(isProceedNext == true)
            {
            	nextpg('members'); 
            }
            
        }
    }
        
    function createDedAct(dedselAct)
    {
        
        let segJson = {};
        var segArray=[];
        var activityArray=[];
        for(var j = 0; j < dedselAct.length; j++)
        {
            let delsel = dedselAct[j];
            var segId = delsel.split(':')[1];
            var actId  = delsel.split(':')[0];
            var selectedData = segwraper[segwraper.map(function (item) { return item.segmentId; }).indexOf(segId)];
            console.log('selectedData=====', selectedData);
            console.log('actId=====', actId);
            if(selectedData)
            {
                segJson.name = selectedData.Segment;
                segJson.segId = selectedData.segmentId;
                segJson.allowed = selectedData.AllowedActivites;
                segJson.price = selectedData.Price;
                var act = selectedData.Activities;
                var selact = act[act.map(function (item) { console.log('item.activityId==', item.activityId) ; return item.activityId;  }).indexOf(actId)]
                
                if(selact)
                {
                    let activityJson = {};
                    activityJson.name = selact.Name;
                    activityJson.actId = selact.activityId
                    activityJson.price = selact.Price;
                    activityJson.channel = '';
                    var docList =[];
                    activityJson.docs =docList;
                    activityArray.push(activityJson);
                }                
            }
        }
        segJson.SegActivities = activityArray;
        segArray.push(segJson);
        segJson = JSON.stringify(segArray);
        console.log('segArray:::'+segJson);
        return segJson;
    }
    
    function updateActivityDetailsToSegment()
    {
        var cuval = [];
        var segJson = (cs["xadtx2__c"].value)?JSON.parse(cs["xadtx2__c"].value):[];
        console.log('segJson===', segJson);
        if(segJson)
        {
            for(i of segJson){
                console.log('i===', i);
                if(i.SegActivities && i.SegActivities.length>0){
                    for(j of i.SegActivities){
                        cuval.push( j.actId+':'+i.segId);
                    }
                }
            }
            if(cuval && cuval.length > 0 )
            {
                $('#hpr').val(cuval).trigger('change');
            }
            console.log('cuval===',cuval);
        }
    }
        
                
    </script>    
</apex:component>