                                $('#dedActid').html(strAct);
                                
                                /* var baseUrl = "/user/pages/images/flags";
                  var $state = $(
                    '<span><img class="img-flag" /> <span></span></span>'
                  );
                
                  // Use .text() instead of HTML string concatenation to avoid script injection issues
                  $state.find("span").text(state.text);
                  $state.find("img").attr("src", baseUrl + "/" + state.element.value.toLowerCase() + ".png");*/
                
                return state;
            }
            var searchstr = [];
            function matchVal(params, data)
            {
                
                
                // If there are no search terms, return all of the data
                if ($.trim(params.term) === '') {
                    return data;
                }
                
                // Do not display the item if there is no 'text' property
                if (typeof data.text === 'undefined') {
                    return null;
                }
                
                // `params.term` should be the term that is used for searching
                // `data.text` is the text that is displayed for the data object
                if (data.text.indexOf(params.term) > -1) {
                    var modifiedData = $.extend({}, data, true);
                    //modifiedData.text += ' (matched)';
                    if(!searchstr.includes(modifiedData.activityId))
                    {
                        searchstr.push(modifiedData.activityId);
                        strAct += '<div class="col-md-4 col-6 act">'+
                            '<label class="box-check activityLabel popup" attr="4454">'+
                            '<input type="checkbox" data-actId = "'+modifiedData.activityId+'" name="business_activity" onclick="notify(this)" class="DEDSegment forReadOnly avtivityCheckBox" id="btnShow" >'+
                            '<div class="business-activity box box-center box-hover activityDiv">'+
                            '<span class="ActivityPrice" style="display:none">0</span>'+
                            '<span id ="'+modifiedData.activityId+'" class="box-title ActivitySpan" data-toggle="tooltip" data-placement="bottom" title="'+modifiedData.text+'" data-original-title="'+modifiedData.text+'">'+modifiedData.text+'</span>'+
                            '</div>'+
                            '</input>'+
                            '</label>'+
                            '</div>'
                        $('#dedActid').html(strAct);
                    }
                    // You can return modified objects from here
                    // This includes matching the `children` how you want in nested data sets
                    return modifiedData;
                    //return null;
                }
                
                // Return `null` if the term should not be displayed
                return null;
            }            
            function createDedActOption(){
                var data = [];
                console.log('ChkActivityMapKey==={!ChkActivityMapKey}');
                //var segwraper = $("[data-json]").data("json");
                console.log('activities===',segwraper[0].Activities);
                var activities = segwraper[0].Activities;
                var opts='';
                for(var j = 0; j < activities.length; j++){
                    var c = activities[j];
                    objData = {};
                    objData.Id = c.activityId+':'+c.Name;
                    objData.text = c.Name;
                    objData.activityId = c.activityId;
                    data.push(objData);
                    var c = activities[j];
                    console.log('c===', c);
                    var opt = '<option id="'+c.activityId+'" value="'+c.activityId+':'+segwraper[0].segmentId+'">'+c.Name+'</option>';
                    opts += opt;
                }
                $('#hpr').find('option').remove();
                $('#hpr').append(opts);
                $("#hpr").select2({
                    
                    
                    language: {
                        inputTooShort: function (args) {
                            return "Min 3 chars required to search.";
                        },
                        noResults: function () {
                            return "Not Found.";
                        },
                        searching: function () {
                            return "Searching...";
                        }
                        
                    },
                    minimumInputLength: 3,
                    //  matcher: matchVal,
                    //templateSelection: formatState,
                    
                })
                updateActivityDetailsToSegment();
                removeTempLoader();
                
            }
            var $eventSelect = $('#hpr');
            /*$eventSelect.on("select2:open", function (e) { 
                console.log("select2:open", e); strAct = '';
                   $('#dedActid').html('');  
                searchstr = [];
            });*/
            
            $eventSelect.on("select2:select", function (e) {
                console.log("select2:select", e.params.data.id); 
                $('.activityErrorElement').hide();
            });
            </script>
                            <p class="activityErrorElement" style="display:none; color: red;" >
