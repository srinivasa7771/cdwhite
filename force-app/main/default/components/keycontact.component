                                    function vflds(clsName, checkLookup){
                                        var brk = false;var elem = '';
                                        
                                        $(clsName).each(function(){
                                            var v = $(this).val();
                                            if($(this).is(':visible')){      
                                                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                                                    brk=true; addValError(this,'Value is required!'); 
                                                    if(elem==''){ elem = $(this);}
                                                }else{ removeValError(this);}
                                                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
                                            }
                                        });
                                        
                                        if(checkLookup){ brk = validateLookup('.polookup') || brk;}
                                        return brk;
                                    }
                                    
                                    
                                    function validateLookup(lookupCls, errorMsg){
                                        var brk = false; var elem = '';
                                        errorMsg = (errorMsg==undefined || errorMsg==null) ? 'Value is required!' : errorMsg;
                                        $(lookupCls).each(function(){
                                            let v = $(this).val();
                                            if(v==''||v==null || v==undefined){
                                                brk=true; addValError($(this).parent(),errorMsg);
                                                validated=false;
                                                if(elem=='') elem = $(this).parent();
                                            }else{
                                                removeValError($(this).parent());
                                            }
                                        });
                                        return brk;
                                    }
                                    
