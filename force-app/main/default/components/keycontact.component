                                    function isUAEMobNum(elem){
                                        var mob = $(elem).val();
                                        if(mob==null||mob==undefined||mob=='')
                                            return;
                                        var regex =  /^((?:50|52|54|55|56|58)[0-9]{7})$/; ///^((?:50|52|54|55|56|58)[0-9]{7,})$/;
                                        var r = (regex.test(mob))?true:'invalid';
                                        if(r == 'invalid'){
                                            addValError(elem,'Please enter a valid UAE mobile number!'); 
                                            return false;
                                        }else{
                                            removeValError(elem); 
                                            return true;
                                        }
                                    }
                                    
                                    function removeAllErrors(clsName){
