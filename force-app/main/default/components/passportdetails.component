</div>-->
                    </div>
                    <!-- .row -->
                </div>
                <div class="pb-4"></div>
            </div>
        </div>
    </div>
    <script>
    function check_PED_Date(elem,type,uid,gdr){ /**Ex: <input type="text" onchange="checkDate(this,'dob')" /> second argument is type of date.**/
        var e = $(elem);
        var date;
        var date1 = e.val();
        date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
        var days = new Date(new Date()-new Date(date))/1000/60/60/24;
        var r = true;
        removeValError(elem);
        if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
            addValError(elem,'Invalid date format!');
        }
        if(uid=='016' || uid == '055' || uid == '305'){
            if((days*-1)<(90)){
                addValError(elem,'Validity should be atleast 3 months!');
            }
        }
        else if((days*-1)<(180)){
            addValError(elem,'Validity should be atleast 6 months!');
        }
        if(r!=true){
            e.focus();
        }
    }
    
    </script>
    <!-- .base-collapse -->
</apex:component>