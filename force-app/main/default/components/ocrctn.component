    <div id="imgPrv" title="Image Preview" style="vertical-align:center; text-align:center;" >
     <img id="imP" src="" />
    </div>
    <script type="text/javascript">
  
function openDialogDW(docName,val){    
    //alert(docName);    
    Dynamsoft.WebTwainEnv.Unload();   
    //alert("Unload Done");
    $("#default-popup").load(); 
    //alert("Load Done");  
    $("#dwtcontrolContainer").load();   
    //alert("dwtcontrolContainer Done"); 
    openDialog(docName,val);
    //alert("open dialog Done");
    Dynamsoft.WebTwainEnv.Load();      
    }
   function imgPreview(fName,src){
    
     $("#imgPrv").dialog({autoOpen: false,show: {effect: "scale",duration: 200},hide: {effect: "explode",duration: 400}});
     document.getElementById("imP").src=src;
    $("#imgPrv").dialog("option","title",fName);        
    $('#imgPrv').dialog({height:700,width:1000,maxHeight:750,maxWidth:1000,resizable:true,modal: true});
    $( "#imgPrv" ).dialog({ position: { my: "left", at: "left", of: window } });
    $( "#imgPrv" ).dialog({ position: { my: "top", at: "top", of: window } });
    $("#imgPrv").dialog("open");
       
}   
function printImage(src){    
    var html  = "<html><head>" +
                "</head>" +
                "<body  style ='-webkit-print-color-adjust:exact;'>"+
                "<img src=\"" + src + "\" onload=\"javascript:window.print();\"/>" +
                "</body>";
                var win = window.open("about:blank","_blank");
                win.document.write(html);                
}
</script> 
