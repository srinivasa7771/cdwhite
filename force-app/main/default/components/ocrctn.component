     <script>
        var jQuery = $.noConflict();
        var imageBase64 , reqDocId, docName;
        jQuery(document).ready(function() {  
           if({!CR} && ('{!crctnMsg}' == null || '{!crctnMsg}' == ''))
            runOnLoad();   
            imageBase64=document.getElementById("{!$Component.imageBase64}");            
            reqDocId=document.getElementById("{!$Component.reqDocId}");
            docName=document.getElementById("{!$Component.docName}"); 
            
            //alert(imageBase64.id); 
            imageBase64.value='100000000000000000000000';
            /*alert(reqDocId.id);               
            alert(docName.id);   
            */
        $('.SubtCrc').click(function(){
           
        $( '<div></div>' ).dialog({
            resizable: false,
            height:140,
            modal: true,
            open: function() {
                 var markup = '{!$Label.msgCRConfirm}';
                 $(this).html(markup);
            },
            title: "Confirmation",
            buttons: {
                "Yes": function() {
                    $( this ).dialog( "close" );
                    Submit();
                },
                "No": function() {
                    $( this ).dialog( "close" );
                }
            }
        });
       });      
       $('.SubtPay').click(function(){
        $( '<div></div>' ).dialog({
            resizable: false,
            height:140,
            modal: true,
            open: function() {
                 var markup = '{!$Label.msgCRConfirm}';
                 $(this).html(markup);
            },
            title: "Confirmation",
            buttons: {
                "Yes": function() {
                    $( this ).dialog( "close" );
                    paySubmit();
                },
                "No": function() {
                    $( this ).dialog( "close" );
                }
            }
        });
       });
          
    }); 
    
   
    </script>
