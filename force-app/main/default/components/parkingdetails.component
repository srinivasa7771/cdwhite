    var currentCardSector = '',currentCard='',currentSectorId='';
    function viewVeh(cNum,cSta,cSect,cSectId){//vNum
        if(cSta =='Inactive'){
            //axsConfirmation('Confirm','No users registered yet, Click on yes to register a user.',false,'addVehSer',cNum);
            axsAlert('Alert','Card generation is still in process.');
            return;
        }
        /* else if(cSta=='Under Activation'){
            axsAlert('Alert','No vehicles availble and card <b>Under Activation</b>.');
            return;
        }*/
        //var keysToDisplay = ['vehicleNumber','pPlaceOfReg','cardNum','expDate','BusinessPark','cHolderNm','refMobile','email'];
        var keysToDisplay = ['vehicleNumber','pPlaceOfReg'];
        var elems = '';
        currentCardSector = cSect;
        currentCard = cNum;
        currentSectorId = cSectId;
        for(var [i,v] of allJSONObj.entries()){
            console.log('v===',v);
            if(cNum== v.cardNum ){
                if(v.vDetails.length<1){
                    axsConfirmation('Confirm','No users registered yet, Click on yes to register a user.',false,'addVehSer',cNum);
                    return;
                }
                if(false){//v.vDetails.length<1
                    if(cSta=='Under Activation')
                        axsAlert('Alert','Card status is <b>Under Activation</b>.');
                }
                for(var [a,b] of v.vDetails.entries()){
                    var elem = '<div class="col-12 '+b.VehicleNumber+'">';
                    elem +='<div class="base-collapse pb-2">';
                    elem +='<a aria-expanded="false" class="collapse-toggle collapsed" data-target="#id_'+b.VehicleNumber+'" data-toggle="collapse" href="#"><h3 class="collapse-title mb-2" id="'+b.VehicleNumber+'Det"> Vehicle number - '+b.VehicleNumber+'</h3></a>';
                    elem +='<div class="collapse" id="id_'+b.VehicleNumber+'" style=""><div class="collapse-content"><div class="">';
                    /*elem +='<div class="col-lg-4"><div class="form-group">'+b.VehicleNumber+'</div></div>'; 
                    elem +='<div class="col-lg-4"><div class="form-group">'+b.VehiclePlaceofReg+'</div></div>';
                    elem +='<div class="col-lg-4"><div class="form-group"><a style="color: #bf0000;padding:0px;" class="btn" onclick="inActiveVeh(this)" for='+b.VehicleNumber+'>Deactivate</a></div></div>';*/
                    //elem +='<p><h4 class="mb-2">Vehicle number - '+b.VehicleNumber+'</h4></p>';
                    elem +='<p>Place of registration - '+b.VehiclePlaceofReg+'</p>';
                    elem +='<p><a style="padding:0px;" class="btn text-primary" onclick="inActiveVeh(this)" for='+b.VehicleNumber+'>Click here to deregister</a></p>';
                    elem +='</div></div></div></div></div><div class="separator-dashed"></div></div></div>';
                    elems +=elem;
                    $('#cOwn').html(v.cHolderNm);
                    
                }
                if(v.vDetails.length<5)
                    if(cSta=='Under Activation'){
                        $('.addNewVeh').attr('disabled',true).addClass('disabled');
                        return;
                    }
                    else{
                        $('.addNewVeh').show().unbind('click').on('click',function(){
                            $('#newVehSec').show();
                            $('.addNewVeh').hide();
                        });
                        $('#addMoreInfo').parent().show().find('elem').html('You can add '+(5-v.vDetails.length)+' more vehicle(s)');
                    }
                else if(v.vDetails.length>=5){
                    $('#addMoreInfo').parent().hide();
                    $('.addNewVeh').hide();
                }
            }
        }
        $('#newVehSec').hide();
        $('#vehDetails').html(elems);
        $('#cVh').html(cNum);
        $('#modal_vehDetails').modal('show');
    }
    
    function inActiveVeh(elem){
        var v = $(elem).attr('for');
        axsConfirmation('Confirm','Do you want to deregister vehicle - '+v+'<br><b>Note: </b>Deregistered vehicles will no longer be allowed access.',false,'inActiveVeh1',v);
    }
    
    function inActiveVeh1(elem){
        var reqJson = {"ActionName": "cancelvehicle","VehicleNumber": "","CardNumber": "","Sector": "","SectorLocationId": "","Status": "Cancel"};
        for([i,v1] of allJSONObj.entries()){
            for([x,y] of v1.vDetails.entries()){
                if(elem == y.VehicleNumber){
                    reqJson.CardNumber = v1.cardNum;
                    reqJson.VehicleNumber = elem;
                    reqJson.Sector = v1.sector;
                    reqJson.SectorLocationId = v1.sectorId;
                }
            }
        }
        showGLoader();
        manipulateVeh(JSON.stringify(reqJson));
        $('#vehDetails .'+elem).remove();
        if($('#vehDetails .col-12').length>4){
            $('.addNewVeh').hide();
        }
        else{
            $('.addNewVeh').show();
        }
        
    }
    
    
    
    function checkVeh(e) {
        let pCode = $('#vncdd').val();
        pCode = (pCode == 'Other')?$('#othCode').val():pCode;
        let reqJson = {"ActionName": "checkvehiclevalidity","VehicleNumber": "","CardNumber": "","Sector": "","SectorLocationId":""};
        if(pCode == 'No Code'){
            reqJson['VehicleNumber'] = $('#vehNumber').val();
        }else{
            reqJson['VehicleNumber'] = pCode+''+$('#vehNumber').val();
        }
        
        if($('.'+reqJson['VehicleNumber']).length>0){
            addValError('#vehNumber','Vehicle already added!');
            return;
        }
        reqJson['CardNumber'] = currentCard;
        reqJson['Sector'] = currentCardSector;
        reqJson['SectorLocationId'] = currentSectorId;
        confirmCheckVeh(reqJson);
        //
        
    }
    function confirmCheckVeh(reqJson){
        axsConfirmation('Confirm','You are adding vehicle <b>'+reqJson.VehicleNumber+'</b> to card <b>'+reqJson.CardNumber+'</b>. <br/> Please Confirm.',true,'checkVehCaller',JSON.stringify(reqJson));
    }
    function checkVehCaller(reqJsonStr){
        showTempLoader('#addVeh');
        checkVeh1(reqJsonStr);
    }
    
