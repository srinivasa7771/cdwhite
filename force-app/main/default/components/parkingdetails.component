        if(m){
            axsAlert('Error','vehicle is already registered!');
            return;
        }
        let reqJson = {"ActionName":"addvehicle","OracleID":"","CardNumber":"","PlateNumberCode":"","PlaceOfReg":"","Sector": "","SectorLocationId":""};
        //var veh = $('#vehNum').val();
        //var por = $('#por').val();
        var veh;
        let pCode = $('#vncdd').val();
        pCode = (pCode == 'Other')?$('#othCode').val():pCode;
        if(pCode == 'No Code'){
            veh = $('#vehNumber').val();
        }else{
            veh = pCode+''+$('#vehNumber').val();
        }
        
        var por = $('#por_1').val();
        
        reqJson.OracleID='{!opi}';
        reqJson.CardNumber=currentCard;
        reqJson.PlateNumberCode=veh;
        reqJson.PlaceOfReg=por;
        reqJson.Sector=currentCardSector;
        reqJson['SectorLocationId'] = currentSectorId;
        showGLoader();
        manipulateVeh(JSON.stringify(reqJson));    
    }
    
