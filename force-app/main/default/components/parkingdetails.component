    function getUrlParameter(key){
        var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
        return (res==undefined)?'':res[1];
    }
    
    
    
    function switchLabel(e,l){
        
        var c = $(e).attr('card');
        var v = $(e).attr('for');
        var cardType= $(e).attr('cardtype');
        
        $('[card='+c+']').removeAttr('disabled');
        $('[card='+c+']').parent().removeClass('disabledApex');
        var isChecked = $(e).prop('checked');
        var stroedJson = localStorage.getItem(c);
        if(stroedJson){
            let j = JSON.parse(stroedJson);
            if((Date.now()-j.time)/(60000)<5){
                axsAlert('Your previous request is still in process, please try after 5 mins.');
                undoReserveVeh(c+'&&'+isChecked);
                return;
            }
        }
        if(cardType == 'VIP'){
            axsAlert('Error','<b>VIP</b> Parking cant be unreserved.');
            undoReserveVeh(c+'&&'+isChecked);
        }
        else if($(e).prop('checked')){
            if(tRsrvd==tElg){
                axsAlert('Alert','Reserved cards count is already reached maximum eligibility, please un reserve any card to proceed.');
                undoReserveVeh(c+'&&'+isChecked);
                return;
            }
            if(l<=0){
                axsAlert('Error','You need to add vehicles to mark <b>Reserved</b>');
                undoReserveVeh(c+'&&'+isChecked);
                return;
            }
            axsConfirmation('Please confirm!','By making this action, all the vehicles under the card will be reserved',false,'reserveVeh',c+'&&'+isChecked,'undoReserveVeh',c+'&&'+isChecked);
        }
        else{
            axsConfirmation('Please confirm!','By making this action, Reserved card will be un reserved',false,'reserveVeh',c+'&&'+isChecked,'undoReserveVeh',c+'&&'+isChecked);
        }
        
    }
    
