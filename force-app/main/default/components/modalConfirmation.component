                            cs['xadh__c'].value.split(';').forEach(function(e){
                                if(e && ctgCount[ind]==e){
                                    var c = parseInt(ctgCount[ind].split('sh')[1])+1;
                                    ctgCount[ind] = 'sh'+c;
                                }
                            });
                            //i.ctgCode = ctgCount[ind];
                        }
                        else{
                            ctgCount[ind] = (i.ctgCode+'1');
                            cs['xadh__c'].value.split(';').forEach(function(e){
