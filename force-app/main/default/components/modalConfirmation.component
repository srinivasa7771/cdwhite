                v.ctgCode1 = 'ub'+(ubCodes.length+1);
                ubCodes.push(v.ctgCode1);
            }else if(v.ctgCode == 'bd'){
                v.ctgCode1 = 'bd'+(bdCodes.length+1);
                bdCodes.push(v.ctgCode1);
            }else if(v.ctgCode == 'lr'){
                v.ctgCode1 = 'lr'+(bdCodes.length+1);
                bdCodes.push(v.ctgCode1);
            }else{
                if(!(v.ctgCode1)){
                    v.ctgCode1 = v.ctgCode+(addedAdhocs.length+1);
                }
                console.log('v.ctgCode1-sh -- '+v.ctgCode1);
            }
            // }
            if(!(cs["xadh__c"].value.includes(v.ctgCode1)))
                addedAdhocs.push(v.ctgCode1);
            $(this).val(JSON.stringify(v));
        });
        return addedAdhocs.join(';');
    }
    function setAdhocVal_Old(){
