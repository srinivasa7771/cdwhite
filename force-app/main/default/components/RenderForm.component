<apex:component controller="RenderFormComponentController" allowDML="true">



    <apex:attribute name="formId" description="id of the Web Form to render" type="string" required="true" assignTo="{!formId}"/>

   <script>

            var item = document.getElementsByClassName('contactMenuItem')[0];

            var itemClass = item.className;

            item.className = itemClass + ' current';

        </script> <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.7.2/jquery.min.js"></script>     <script type="text/javascript" src="https://dl.dropboxusercontent.com/u/40036711/Scripts/jquery.ddslick.min.js"></script>

    <style type="text/css">

            .contactMainContainer

            {

                margin-top: 45px;

                display: inline-block;

            }

            .formContainer

            {

                width: 66%;

                float: left;

            }

            .mainContent

            {

                margin:-10% 16% 0;

            }

            .formHeader

            {

                width: 98.5%;

            }

            .messageHeader

            {

                font-family: canaroLight;

                font-size: 30px;

            }

            .messageText

            {

                font-family: canaroLight;

                font-size: 14px;

            }

            input

            {

               border: 1px solid #d7d7d7;

               height: 45px; 

               width: 100% !important;

               box-sizing: border-box;

               font-size: 15px;

               font-family: canaroLight;

               padding: 10px;

            }

            label

            {

                color: #3d4f8b;

                font-family: canaroMedium;

                font-size: 14px;

                display: block;

            }

            .inputField

            {

                display: inline-block;

                margin-top: 30px;

            }

            .textField

            {

                width: 50%;

                box-sizing: border-box;

            }

            .textField:nth-child(2n)

            {

                padding-right: 1.5%;

                padding-left: 1.5%;

                float:left;

            }

            .textField:nth-child(2n+1)

            {

                padding-right: 3%;

                float: left;

            }

            .textField:nth-child(5)

            {

                padding-right: 0px;

                width: 98.5%;

            }

            .form

            {

                margin-top: 5px;

                width: 100%;

            }

            input[type="button"]

            {

                background: #45c5ef;

                color: white;

                border: 0px;

                box-sizing: border-box;

                margin-top: 30px;

                font-family: canaroMedium;

                font-size: 13px;

                padding: 7px 0 0 0;

                cursor: pointer;

                width: 98.5%;

                -webkit-border-radius: 0px;

                border-radius: 0px;

                -webkit-appearance: none;

                appearance: none;

            }

            select, textarea

            {

                width:100%;

                box-sizing: border-box;

                font-size: 15px;

                   font-family: canaroLight;

            }

            .selectField, .descriptionField

            {

                width:98.5%;

            }

            .descriptionField

            {

                height: 185px;

            }

            textarea

            {

                height: 90%;

                padding: 10px;

                font-size: 14px;

                border: 1px solid #d7d7d7;

                resize: none;

            }

            .contactBox

            {

                box-sizing: border-box;

                float:right;

                width: 33%;

                padding: 20px 0px 20px 20px;

            }

            .contactHeader

            {

                font-family: canaroMedium;

                font-size: 16px;

            }

            .contactContent

            {

                font-family: canaroLight;

                font-size: 16px;

                background-color:#edf5fc;

                display: table;

                padding: 16px;

            }

            .contactSubtext

            {

                vertical-align: middle;

                display: table-cell;

                padding-left: 15px;

                width: 100%;

            }

            .contactSubIcon

            {

                vertical-align: middle;

                display: table-cell;  

            }

            .contactSubIcon img

            {

                max-width: 33px;

            }

            .contactSection

            {

                margin-bottom:26px;

            }

            .contactSection.last

            {

                margin-bottom:0px;

            }

            select

            {

                background: transparent;

                font-size: 16px;

                line-height: 1;

                border: 0;

                border-radius: 0;

                height: 45px;

                -webkit-appearance: none;

                -moz-appearance: none;

                appearance: none;

                padding-left: 10px;

                cursor: pointer;

            }

            .selectContainer

            {

                background: #edf5fc;

                border: 1px solid #d7d7d7;

                position: relative;

            }

            .selectImage

            {

                position: absolute;

                width: 11.5px;

                height: 6.5px;

                top: 45%;

                right: 3%;

            }

            .selectImage img

            {

                width: 100%;

            }

            .dd-selected

            {

                height: 45px;

                box-sizing: border-box;

                padding-left: 10px;

                margin-top: 5px;

                font-weight: normal;

            }

            .dd-select

            {

                font-family: canaroLight;

                font-size: 16px;

                border: 0;

                border-radius: 0;

                height: 100%;

                background: #edf5fc !important;

                border: 1px solid #d7d7d7;

                cursor: pointer;

                width: 100% !important;

            }

            .dd-options

            {

                width: 100% !important;

                box-shadow: none;

                height: 300px;

                overflow:auto;

            }

            #industry

            {

                width: 100% !important;

                height: 45px;

            }

            .asterisk

            {

                margin-left: 2px;

            }

            .requiredMessage

            {                

                width: 100%;

                color: #ed1c24;

                list-style: none;

                text-align: center;

                font-size: 14px;

                font-family: canaroLight;

                line-height: 1.3em;

            }

            .requiredMessage li

            {

                margin: 0px;

            }

            @media screen and (max-width: 1025px)

            {

                .formContainer

                {

                    float: none;

                    width: 100%;

                }

                .contactBox

                {

                    float: none;

                    width: 100%;

                    padding-left: 0px;

                    padding-right; 0px;

                }

            }

    </style>

       

    <div class="contactMainContainer">

        <apex:messages styleClass="requiredMessage"/>



        <div class="formContainer">

            <div class="formHeader">

                <div class="messageHeader darkText">Leave us a message</div>

                <div class="messageText greyText">We are more than happy to answer any questions you have. Just send us a message in the form below with any questions you may have.</div>

            </div>

            <div class="form">

                <apex:form >

            

                    <!-- Start of the form fields -->

                    <div class="formFields">

                        <apex:repeat value="{!fields}" var="f">

                        

                            <apex:outputPanel layout="block" rendered="{!(f.Type__c == 'CUSTOMTEXT') && (f.Label__c != null)}">

                                {!f.Label__c}

                            </apex:outputPanel>

                            <apex:outputPanel layout="block" rendered="{!(f.Type__c == 'CUSTOMTEXT') && (f.Label__c == null)}">

                                <tr><td colspan="2"><BR/></td></tr>

                            </apex:outputPanel>

                            

                            <apex:outputPanel styleClass="{!IF(f.Type__c == 'TEXTAREA', 'inputField descriptionField', 'inputField textField')}" layout="block" rendered="{!f.Type__c != 'CUSTOMTEXT' && f.Hidden__c != true}">

                                <apex:outputlabel >

                                    {!IF(f.Hidden__c == true, '', f.Label__c)}

                                    <apex:outputPanel rendered="{!f.Required__c && f.Hidden__c != true}" styleClass="asterisk">*</apex:outputPanel>

                                </apex:outputlabel>

                                <c:inputFormField field="{!f}"/>

                            </apex:outputPanel>

                

                        </apex:repeat>

                    </div>

                    <!-- Again, but now the hidden fields, we create them here to avoid empty TD cells -->

                    <apex:repeat value="{!fields}" var="f">         

                            <apex:outputPanel rendered="{!f.Type__c != 'CUSTOMTEXT' && f.Hidden__c == true}">

                                <c:inputFormField field="{!f}"/>                

                            </apex:outputPanel>

                    </apex:repeat>

                    <input type="button" name="submitButton" onclick="validate();" value="Submit your message"></input>

                    <apex:commandButton styleClass="submitBtn" value="Submit" action="{!saveObject}" style="display:none;"/>

            

                </apex:form>

            </div>

        </div>

        <div class="contactBox darkText">

            <div class="contactSection">

                <div class="contactHeader">Phone</div>

                <div class="contactContent firstLine">

                    <div class="contactSubIcon"><img src="https://ap2.salesforce.com/servlet/servlet.ImageServer?id=01520000002iTLk&oid=00D20000000nb2R&lastMod=1428049693000"/></div>

                    <div class="contactSubtext"><a href="tel://8004297">800 4 AXS(297)</a></div>

                </div>

            </div>

            <div class="contactSection">

                <div class="contactHeader">Email</div>

                <div class="contactContent firstLine">

                    <div class="contactSubIcon"><img src="https://ap2.salesforce.com/servlet/servlet.ImageServer?id=01520000002iTLa&oid=00D20000000nb2R&lastMod=1428049691000"/></div>

                    <div class="contactSubtext"><a href="mailto:support@axs.ae">support@axs.ae</a></div>

                </div>

            </div>

            <div class="contactSection">

                <div class="contactHeader">Youtube Page</div>

                <div class="contactContent firstLine">

                    <div class="contactSubIcon"><img  src="http://www.axs.ae/resource/1431617448000/YouTube_Icon"></img></div>

                    <div class="contactSubtext"><a target="_blank" href="https://www.youtube.com/channel/UCZKbzMF0z1WzOoPLObUtyaA">axs YouTube page</a></div>

                </div>

            </div>

            <div class="contactSection last">

                <div class="contactHeader">Address</div>

                <div class="contactContent firstLine">

                    <div class="contactSubIcon"><img src="https://ap2.salesforce.com/servlet/servlet.ImageServer?id=01520000002iTLV&oid=00D20000000nb2R&lastMod=1428049690000"/></div>

                    <div class="contactSubtext firstLine">

                        <div>Dubai Knowledge Park</div>

                        <div>Block 8</div>

                        <div>Ground Floor</div>

                        <div>Dubai, UAE</div>

                    </div>

                </div>

            </div>

       </div>

    </div>

    <script type="text/javascript">

        $("#industry").ddslick({

            onSelected: function(selectedData){

            console.log(selectedData);

                }

        });  

    $(".dd-selected-value").attr("name", "industry");



    var requiredFields = document.getElementsByClassName("requiredField");    

    var boxShadowValue = "0 0 4px #45c5ef";

    

    function validate()

    {

        var valid = true;

        for (var index = 0; index < requiredFields.length; index++)

        {

            var field = requiredFields[index];

            if (field.value == "" )

            {

                field.style.boxShadow = boxShadowValue;

                valid = false;

            }

            else

                field.style.boxShadow = "none";

        }

        if (valid)

            document.getElementsByClassName('submitBtn')[0].click();

    }



    var addEvents = function()

    {

        for (var index in requiredFields)

        {

            var field = requiredFields[index];

            field.onblur = onBlurEvent;

            field.onfocus = onFocusEvent;

        }

    }();



    function onBlurEvent(event)

    {

        var field = event.target;

        if (field.value == "")

        {

            field.style.boxShadow = boxShadowValue;

        }

    }



    function onFocusEvent(event)

    {

        var field = event.target;

        field.style.boxShadow = "none";

    }

    </script>

</apex:component>