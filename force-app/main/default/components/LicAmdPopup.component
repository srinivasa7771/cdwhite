    }
    function addRow(){
        
        var channelTitle = {};
        var channelJson={};
        console.log(JSON.stringify(obj)+'OBJ');
        addValError($('#addMemBtnC'), '');
        addValError($('#addMemBtn'), '');
        console.log(isRelatedToTitle +'---'+isRelatedtoChannel);
        let errorFlag = false;
        console.log(ammendVal);
        console.log($('#TitleName').val());
        console.log($('#Frequency').val());
        if((ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && !$('#TitleName').val().trim()){ //&& !$('#Frequency').val()
            addValError($('#TitleName'),'Name is mandatory');
            errorFlag = true;
        } else { removeValError($('#TitleName')); }
        if((ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#Frequency').val() == '--None--'){ 
            addValError($('#Frequency'),'Frequency is mandatory');
            errorFlag = true;
        } else { removeValError($('#Frequency')); }
        if((ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#Language').val()==0){
            addValError($('#Language'),'Language is mandatory');
            errorFlag = true;
        } else { removeValError($('#Language')); } 
        if((ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#Genre').val()==0){ 
            addValError($('#Genre'),'Genre is mandatory');
            errorFlag = true;
        } else { removeValError($('#Genre')); }
        if((ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#AOD').val()==0){ 
            addValError($('#AOD'),'Area Of Distribution is mandatory');
            errorFlag = true;
        } else { removeValError($('#AOD')); }
        
        if((ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && !$('#ChannelName').val().trim()){ //&& !$('#Frequency').val()
            addValError($('#ChannelName'),'Name is mandatory');
            errorFlag = true;
        } else { removeValError($('#ChannelName')); }
        if((ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#GenreC').val()==0){ //&& !$('#Frequency').val()
            addValError($('#GenreC'),'Genre is mandatory');
            errorFlag = true;
        } else { removeValError($('#GenreC')); }
        if((ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) && $('#LanguageC').val()==0){ //&& !$('#Frequency').val()
            addValError($('#LanguageC'),'Languauge is mandatory');
            errorFlag = true;
        } else { removeValError($('#LanguageC')); }
        if(errorFlag) {return; }
        
        if(ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){  
            let d = compareExistingTitles($('#TitleName').val().trim()+'-'+$('#Frequency').val()+'-'+$('#Genre').val().join('; ')+'-'+$('#Language').val().join('; ')+'-'+$('#AOD').val().join('; '));
            if(d) {
                //addValError($('#addMemBtn'), 'Duplicate Values');
                axsAlert('ERROR','<b>This title is already added, please add new</b>');
                return;
            } else {
                addValError($('#addMemBtn'), '');
            }
        } else if(ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){ //|| ammendVal=='Add Activity'
            let d = compareExistingTitles($('#ChannelName').val().trim()+'-'+$('#GenreC').val().join('; ')+'-'+$('#LanguageC').val().join('; '));
            if(d) {
                // addValError($('#addMemBtnC'), 'Duplicate Values');
                axsAlert('ERROR','<b>This channel is already added, please add new.</b>');
                return;
            } else {
                addValError($('#addMemBtnC'), '');
            }
        }
        if(ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){
            channelTitle.name = $('#TitleName').val().trim();
            //channelTitle.name = $('#ChannelName').val();
            channelTitle.frequency = $('#Frequency').val(); 
            let languageVal = $('#Language').val();
            channelTitle.languages = languageVal.join('; ');
            let genreVal = $('#Genre').val();
            channelTitle.genre = genreVal.join('; ');
            let aodVal = $('#AOD').val();
            channelTitle.areaOfDistribution = aodVal.join('; ');
            channelTitle.requestType = 'Title';
            channelTitle.licensedTitleChannelDdaId = '';
        }
        if(ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){ //|| ammendVal=='Add Activity'
            channelJson.name=  $('#ChannelName').val().trim();
            let channelLanguageVal = $('#LanguageC').val();
            channelJson.languages = channelLanguageVal.join('; ');
            let channelGenreVal = $('#GenreC').val();
            channelJson.genre = channelGenreVal.join('; ');
            channelJson.requestType = 'Channel';
            channelJson.licensedTitleChannelDdaId = '';
            
        }
        //channelJson
        console.log(JSON.stringify(obj)+'OBJ');
        console.log(selectedDdaId);
        let actList = obj.serviceRequests[0].activities;
        let selectedIndex = 0;
        for(var i=0; i<actList.length;i++) {
            if(actList[i].ddaId == selectedDdaId) {
                selectedIndex = i;
            }
        }console.log(selectedIndex);
        if(ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))) {
            obj.serviceRequests[0].activities[selectedIndex].channelTitles.push(channelTitle);
            tableArr.push(channelTitle);
            $('#addedMems_T').append(createNewAddRow(channelTitle));
            selectedArrValues.push(mergeDataMsg(channelTitle));
        }
        if(ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){
            obj.serviceRequests[0].activities[selectedIndex].channelTitles.push(channelJson);
            tableArr.push(channelJson);
            $('#addedMems_C').append(createNewAddRow(channelJson));
            selectedArrValues.push(mergeDataMsg(channelJson));
        }
        clearFields();
        adhoc3Proto = obj;
        if(ammendVal=='Adding New Publishing Title' || ammendVal=='Adding New Broadcasting Channels'){
            calculateFeeFunc2();
        } else {
            calculateFeeFunc();  
        }
        if(adhoc3Proto.serviceRequests[0].activities[0].channelTitles.length>0){
            $('.base-nav-next').show();
        }
        //rowIndex+=1;
    }
    
    function createNewAddRow(channelTitle){
        var h;
        if(ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){
            h = '<div class="row col-12 addedMem" action="add" for="'+rowIndex+'::'+channelTitle.name+'::'+channelTitle.frequency+'::'+channelTitle.genre+'::'+channelTitle.languages+'::'+channelTitle.areaOfDistribution+'">';
            h += '<div class="col-2 newMemNames frstName">'+channelTitle.name+'</div>';
            h += '<div class="col-2 newMemNames lstName">'+channelTitle.frequency+'</div>';
            h += '<div class="col-2 newMemNames frstName">'+channelTitle.genre+'</div>';
