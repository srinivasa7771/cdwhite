    <script>
    var rowIndex = 0;
    function checkValues(){
        if($('#TitleName').val()){
            removeValError($('#TitleName'));//ChannelName
        }
         if($('#Frequency').val() != '--None--'){
            removeValError($('#Frequency'));//ChannelName
        }
         if($('#Genre').val()!=0){
            removeValError($('#Genre'));//ChannelName
        }
