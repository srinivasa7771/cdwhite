    function removeRow(rowIndex) {
        console.log(rowIndex+'rowIndex');
        console.log(obj);
        let selectedList = rowIndex.split('::');
        console.log('--titleSize--'+adhoc3Proto.serviceRequests[0].activities[0].channelTitles.length);
        $('[for="'+rowIndex+'"]').remove(); // remove from Table.
        let actList = obj.serviceRequests[0].activities;
        let selectedIndex = 0;
        
        for(var i=0; i<actList.length;i++) {
            if(actList[i].ddaId == selectedDdaId) {
                selectedIndex = i;
            }
        }
        let channelTitles = obj.serviceRequests[0].activities[selectedIndex].channelTitles;
        let selectedChannelIndex = 0;
        for(let step=0; step<channelTitles.length; step++) {
            let c = channelTitles[step];
            if(ammendVal=='Adding New Publishing Title' || (isRelatedToTitle && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){
                if(c.name == selectedList[1] && c.frequency == selectedList[2] && c.genre == selectedList[3] && c.languages == selectedList[4] && c.areaOfDistribution == selectedList[5]) {
                    selectedChannelIndex = step;
                }
            } else if(ammendVal=='Adding New Broadcasting Channels' || (isRelatedtoChannel && (ammendVal=='Add Activity' || ammendVal=='Add Segment'))){
                if(c.name == selectedList[1] && c.genre == selectedList[2] && c.languages == selectedList[3]) {
                    selectedChannelIndex = step;
                }
            }  
        }
        console.log(selectedChannelIndex);
        obj.serviceRequests[0].activities[selectedIndex].channelTitles.splice(selectedChannelIndex,1);
        if(ammendVal=='Adding New Publishing Title' || ammendVal=='Adding New Broadcasting Channels'){
            calculateFeeFunc2();
        } else {
            calculateFeeFunc();  
        }
        selectedArrValues = [];
        rowIndex--;
        let channelList = obj.serviceRequests[0].activities[selectedIndex].channelTitles;
        for(let j=0;j<channelList.length;j++) {
            selectedArrValues.push(mergeDataMsg(channelList[j]));
        }
        console.log(obj);
    }
    
