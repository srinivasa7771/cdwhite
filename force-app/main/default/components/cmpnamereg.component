<apex:component allowDML="true" id="cmp">
    <apex:attribute name="rq" description="Request" type="g_Req__c" required="true"/>
    <apex:attribute name="attCoiId" description="Attachment" type="String"/>
    <apex:attribute name="attMOAId" description="Attachment" type="String"/>
     <apex:attribute name="attAOAId" description="Attachment" type="String"/>
    <apex:attribute name="attGCId" description="Attachment" type="String"/>
    <apex:attribute name="attNmId" description="Attachment" type="String"/>
    <apex:attribute name="attMOAAmdId" description="Attachment" type="Attachment[]"/>
    <apex:attribute name="attBPId" description="Attachment" type="String"/> 
    <apex:attribute name="attCPId" description="Attachment" type="String"/>
    <apex:attribute name="tb" description="tab" type="String"/>
    
    <script src="/soap/ajax/58.0/connection.js" type="text/javascript"></script> 
    <script src="/soap/ajax/58.0/apex.js" type="text/javascript"></script>
    
    <style>
        .required { border-left: 5px #E62D38 solid !important;}
        
        .valid-feedback {
        color:green !important;
        word-break: break-word !important;
        }
        
        .invalid-feedback {
        font-size: 1em;
        word-break: break-word !important;
        }
        
    </style>
     	  
    <div class="mt-5">
        <div class="modal fade modal-base" id="modal_validate_name" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog" role="document" style="width: 500px;">
                <div class="modal-content">
                    <div class="modal-body">
                        <div class="process-upload-wrapper">
                            <h2 class="mb-4">Checking Name Availability </h2>
                            <div class="process-upload-image">
                                <apex:image width="75px" value="{!URLFOR($Resource.assets_NUI,'images/process.png')}"/>
                                <!-- <i class="icon-process"></i> -->
                            </div>
                            
                            <p>
                                We are checking availability of the name in our database.
                            </p>
                            <p>
                                This may take a minute.
                            </p>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade modal-base" id="modal_upload_passport"  tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog" role="document" style="width: 993px;">
                <div class="modal-content">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i class="icon-close"></i>
                    </button>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12 order-md-2">
                                <div class="d-flex flex-column h-100">
                                    <div class="mb-auto">
                                        <h2 class="mb-4 upHead">Upload Certificate</h2>
                                       <!-- <p>
                                            Note: Please upload a relevant Certificate
                                        </p>-->
                                        <p>
                                        Please ensure that the uploaded document meets the following guidelines otherwise it may result in the rejection of your application:
                                        <ul>
                                          <li>Image is in full colour</li>
                                          <li>Documents should be in .pdf or .jpg format</li>
                                          <li>Maximum size of 4MB</li>
                                        </ul>
                                         </p>

                                        <p id="saveText" style="display:none">
                                            File uploaded please click on <b>SAVE</b> to Proceed.
                                        </p>
                                        <input type="file" class="files" onchange="checkFile1(this)" id="files" name="files" style="display: none;"/>
                                        <button type="button" class="btn btn-outline-primary mb-2 btn-block-sm"
                                                style="min-width: 304px;max-width: 100%;" onclick="handleBrowseClick1();">
                                            UPLOAD DOCUMENT
                                        </button>
                                    </div>
                                    <div class="text-right d-none d-md-block" >
                                        <a onclick="saveAttachment1(this);" style="color: #fff;" 
                                           class="saveAtt btn btn-primary disabled">
                                            SAVE
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="text-right d-block d-md-none mt-4">
                            <a onclick="saveAttachment1(this);" style="color: #fff;" 
                               class="saveAtt btn btn-primary disabled">
                                SAVE
                            </a>
                        </div>
                    </div>
                    <!-- .modal-body -->
                </div>
            </div>
        </div>
        
        <apex:outputPanel rendered="{!rq.os__c == 'Name Approval Re-Review'}"> 
            <div class="box box-danger box-padding mb-lg-5 mb-4">
                Business Names return for rereview.       
            </div>
        </apex:outputPanel> 
        
        <div id="boforcomp" class="frameworkBlock branchblock" style="display:none;">
