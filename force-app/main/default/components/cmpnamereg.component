                <apex:outputPanel rendered="{!AND(rq.xvtyp__c == 'DED' ,rq.Acc__r.clt__c == 'Land')}">
                    Tell us about your company
                </apex:outputPanel>
                <apex:outputPanel rendered="{!OR (rq.xvtyp__c != 'DED' , rq.Acc__r.clt__c != 'Land')}">
                    Tell us about your parent company
                </apex:outputPanel>


            </h3>
            
            <div class="row form-style">
                <div class="form-group col-md-6">
                    <label class="d-block">
                        <apex:outputPanel rendered="{!AND(rq.xvtyp__c == 'DED' ,rq.Acc__r.clt__c == 'Land')}">
                            Company Name
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!OR (rq.xvtyp__c != 'DED' , rq.Acc__r.clt__c != 'Land')}">
                            Parent Company Name
                        </apex:outputPanel>
                       
                    </label>
                    <input type="text" id="xccn" class="forReadOnly form-control no-blank" oninput="this.value = this.value.toUpperCase();" onkeyup="hideError(this);" maxlength="80" onchange="assignFields(this);" /> <!--required-->
                    <div id="xccnError"  class="invalid-feedback"></div>
                </div>
                
                <!-- Company Arabic name Start Ms1.1 -->
                <div class="form-group col-md-6">
                    <label>Company Arabic Name </label>
                    <input type="text" id="xcna" class="forReadOnly form-control no-blank" onkeyup="hideError(this);" maxlength="80" onchange="assignFields(this);" /> <!--required-->
