                    <script type="text/javascript">
                    cs['xcpic__c']=document.getElementById('{!$Component.xcpic__c}');
                    </script>
                    <div id="rtacnError"  class="invalid-feedback"></div>
                </div>
                
                <div class="form-group col-md-6">
                    <label class="d-block">{!IF(rq.Acc__r.clt__c == 'Land' && rq.xvtyp__c == 'DED', 'Trade License number', 'Registration number')} </label>
                    <input pattern = "^[a-zA-Z0-9]*$" type="text" id="rtacn" class="forReadOnly form-control no-blank" maxLength = "12"  onkeyup="hideError(this);" onchange="assignFields(this);"/>
                    <div id="rtacnError"  class="invalid-feedback"></div>
                </div>
                
                <div class="col-lg-6">
                    <div class="form-group">
                        <label>Name of the issuing authority</label>
                        <apex:outputpanel rendered="{!rq.Acc__r.clt__c != 'Land'}">
                            <input id="issuingauth" type="text" class="forReadOnly form-control no-blank"  maxLength = "80" onkeyup="hideError(this);" onchange="updateParentCompDetails(this);" /> 
                        </apex:outputpanel>
                        <apex:outputpanel rendered="{!rq.Acc__r.clt__c == 'Land'}">
                            <apex:inputField styleClass="forReadOnly form-control dum input-select2-flat no-blank" value="{!rq.License_Authority__c}" id="issuingauth" onkeyup="hideError(this);" onchange="updateParentCompDetails(this);"/>
                            <div id="iaerror"  class="invalid-feedback"></div>
                        </apex:outputpanel>
                    </div>
                </div>
                <div class="form-group col-lg-6" style = "{!IF(OR(AND(rq.Acc__r.clt__c != 'Land' , rq.xvtyp__c != 'DED'), AND(rq.Acc__r.clt__c == 'Land' , rq.xvtyp__c == 'DDA'), AND(rq.Acc__r.clt__c != 'Land' ,OR( rq.xvtyp__c == 'DDA',rq.xvtyp__c == 'DED' ))), 'display:block', 'display:none')}">
