                        <input type="text" id="xbtnm" class="forReadOnly  no-blank form-control input-datepicker" data-toggle="datetimepicker" data-target="#xbtnm"  onchange="dformat2(getC('xbtnm').value,'xbtnm');checkdate2years(this);"/>
                        <div class="input-group-append">
                            <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#xbtnm">
                                <i class="icon-date"></i>
                            </button>
                        </div>
                        <div id="xbtnmError"  class="invalid-feedback"></div>
                    </div>-->
                    <div class="input-datepicker-group input-group">
                        <input id="xbtnm" onchange="dformat2(getC('xbtnm').value,'xbtnm');checkdate2years(this);" type="text" class = "{!IF(OR(AND(rq.Acc__r.clt__c != 'Land' , rq.xvtyp__c != 'DED'), AND(rq.Acc__r.clt__c == 'Land' , rq.xvtyp__c == 'DDA'), AND(rq.Acc__r.clt__c != 'Land' ,OR( rq.xvtyp__c == 'DDA',rq.xvtyp__c == 'DED' ))), 'forReadOnly no-blank form-control input-datepicker', '')}"
