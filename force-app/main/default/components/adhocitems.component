                    <i class="icon-close"></i>
                </button>
                <div class="modal-body">
                    <h2 class="modal-title">VFS Global document attestation services</h2>
                    <p>
                        To avail this service, please fill in all relevant information required. VFS representative may contact you directly if any additional information is needed.
                    </p>
                    
                    <div class="mb-3"></div>
                    <div class="form-style">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Select certification type</label>
                                    <select id="certificate" class="form-control requiredFld certificate-placeholder requiredFldpop input-select2-flat">
                                        <option></option>
                                        <option attr="" value="certificate"></option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Select the issuing country of the certificate</label>
