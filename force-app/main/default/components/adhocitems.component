                                        <apex:selectOptions value="{!countriesOptions}"/>
                                    </apex:selectList>
                                    <script>
                                    cs['country2']=document.getElementById('{!$Component.country}');
                                    </script> 
                                </div>
                            </div>
                            <label class="text-primary col-md-12 " id="Attestation">
                                <span class="fs-14 font-weight-bold my-3 text-underline">Required Documents</span>
                                <span id="Attestation_msg"></span>
                            </label>
                        </div>
                        <div class="row">
                            <div class="col-md-6" id="NumberOfCertif" style="display:none;">
                                <div class="form-group">
                                    <label>Number of certification required</label>
                                    <select id="NumberofcertifOptions" class="form-control requiredFld certificate-placeholder requiredFldpop input-select2-flat">
                                        <option></option>
                                        <script>
                                        let i=1; 
                                        var listOptions = document.getElementById("NumberofcertifOptions");                                       
                                        while (i <= 10) {
                                            var newOption = document.createElement("option");
                                            newOption.text = i;
                                            newOption.value = i; 
                                            listOptions.options.add(newOption);
                                            i++;
                                        }
                                        cs['NumberofcertifOptions'] = getC('{!$Component.NumberofcertifOptions}');
                                        </script>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">    
                                <div class="form-group">
                                    <label>Country of pickup</label>
                                    <apex:selectList styleClass="requiredFld requiredFldpop country-placeholder input-select2-flat" id="countryOfPickup"  multiselect="false"> 
                                        <apex:selectOptions value="{!countriesOptions}"/>
                                    </apex:selectList>
                                    
                                    <script>
                                    cs['countryOfPickup']=document.getElementById('{!$Component.countryOfPickup}');
                                    
                                    </script>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Certificate issuing <elem id="unv">university</elem></label>
                                    <textarea id="university" class="form-control requiredFldpop requiredFld alphaChar"/>
                                    <!--richText="True"-->
                                    <!-- <input type="text" id="university"  class="form-control requiredFldpop requiredFld alphaChar" value=""/> -->
                                </div>
                            </div>
                            <script> 
                            cs['university'] = document.getElementById("{!$Component.university}");
                            </script> 
                            <div class="col-md-6">
                                
                                <div class="form-group">
                                    <label>Address for certificate collection</label>
                                    <textarea id="colladdress" class="form-control requiredFldpop requiredFld"/>
                                    <!--<input type="text" id="colladdress"  class="form-control requiredFldpop requiredFld" value=""/>-->
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Contact number</label>
                                    <div class="d-flex">
                                        <select id="countryCode" class="form-control requiredFld requiredFldpop input-select2-flat">                                                
                                        </select>
                                        <!--<input type="text" class="form-control mr-1" value="+971" disabled="true" style="flex-basis:100px;width:70px;" id="countryCode"/>-->
                                        <input type="text" onchange="checkMob(this);" onkeyup="validDigits(this);"  id="contactnum" class="form-control ml-3 requiredFldpop" value="" />
                                    </div>
                                </div>
                            </div>
                            <!-- script for country code--> 
                            <script type="text/javascript"> 
                            //we have an array countryCodeObj_new of the following format in the static resource AXS2_formValidations : 
                            //------------format example-------------
                            /*  var countryCodeObj_new = [{
                                "name": "United Arab Emirates",
                                "dial_code": "+971",
                                "code": "AE"
                            }, {
                                "name": "Afghanistan",
                                "dial_code": "+93",
                                "code": "AF"
                            },*/
                            //--------------------------------------
                            var countryCodeOptions = ''; 
                            for(i of countryCodeObj_new){
                                var option = ''; 
                                if(i.dial_code && i.name) {                                   
                                    option = '<option value="'+i.dial_code+'">'+i.dial_code+'-'+i.name+'</option>'; 
                                    countryCodeOptions += option; 
                                }
                            }
                            $('#countryCode').html(countryCodeOptions); 
                            //cs['countryCode'] = getC('{!$Component.countryCode}');
                            cs['countryCode'] = document.getElementById('countryCode');
                            console.log('COUNTRY CODE HEREEEE' + cs['countryCode'].value);
                            </script>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Contact person's name</label>
                                    <input name = "contactperson" type="text" id="contactperson"  class="form-control requiredFldpop requiredFld alphaChar"/>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label>Notes</label>
                                    <input type="text" id="additionalDetails"  class="form-control requiredFldpop requiredFld alphaChar" value=""/>
                                </div>
                            </div>
                            
                        </div>
                        
                        <div class="form-group text-right">
                            <label>&nbsp;</label><br/>
                            <button class="btn btn-primary btnConfirmPop" onclick="saveVFSDetails();return false;">CONFIRM</button>
                        </div>
                    </div>
                    
                </div>
                
            </div>
        </div>
    </div>
    <apex:inputHidden id="vfsFlag" value="{!rqDraft.vfsFlag__c}"/>
