<apex:component allowDML="true" controller="gctlInsComp">
    
    <apex:attribute name="adHocItms" description="adHocItms" type="g_srvcitm__c[]"/>
    <apex:attribute name="countriesOptions" description="countriesOptions" type="SelectOption[]"/>
