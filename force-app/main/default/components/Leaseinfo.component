    <apex:outputpanel id="leasepanel" >
        <script>
            $('.ldde')?.hide();
            $(".ldty")?.select2();
             $('.collapse-toggle').addClass('collapsed');
             cs["xadtx5__c"] = document.getElementById("{!$Component.xadtx5__c}");
            if(cs["xadtx5__c"].value  != null && cs["xadtx5__c"].value != '')
            {
                populateSelection(cs["xadtx5__c"].value);
            }
            else
            {
                $('#landType [data-ldVal="il"]').prop('selected', 'true');
                $('#landType').trigger('change');
            }

            function populateSelection(ldinfo)
            {
                var obj = cs["xadtx5__c"].value;//'[{"type":"Industrial Land","tycode":"il","info":{"Size required":"7657656","Connected Power Load Required":"6565465","Anticipated amount of water for your industry":"54445454","Estimated BUA DM range (35-50%)":"38"}}]' ;
                var leaseInfoData = JSON.parse(obj); 
                console.log('leaseInfoData====',leaseInfoData);
                leaseInfoData.forEach((element) => {
                    console.log(element)
                    var tycode = element.tycode;
                    var ldinfo = element.info;
                    console.log('tycode==='+tycode);
                    console.log('ldinfo==='+ldinfo);
                    $('#landType [data-ldVal='+tycode+']').prop('selected', 'true');
                    
                    $('input.'+tycode+'in').each(function(){
                        var ct= $(this).attr('data-label');  
                        console.log('category===',ldinfo[ct]);
                        $(this).val(ldinfo[ct]);
                    });
                    $('#landType').trigger('change');
                    
                });
            }
            
            function hideError(e){
                $(e).parent().find('.invalid-feedback').hide();
                $(e).parent().find('.valid-feedback').hide();
            }
            
            function toggleSec(sec)
            {
            console.log('sec==',sec);
             var ldsec = $(sec).attr('data-target');
            $(ldsec).toggle();
            }
        </script>
