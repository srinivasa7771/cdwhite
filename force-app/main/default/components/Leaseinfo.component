    <script>
    var isError = false;
    function validateField(e){
        var errorDiv = $('#'+e.id+'Error');
        var optional = $(e).attr('data-optional');
        console.log('optional==',optional);
        
        console.log('validity==1=',e.value );
        console.log('validity===',e.validity.valid );
        if ((e.validity.valid && e.value > 0 && optional != 'Yes' ) || (optional == 'Yes' && e.value != '' &&  e.value > 0) || (optional == 'Yes' && e.value == '')) {
            
            isError = false;
            $(errorDiv).hide();
            $(errorDiv).html('');
        }
        else
        {
            isError = true;
            $(errorDiv).show();
            $(errorDiv).html('Please enter valid value');
        }
    }
    
    function checkRange(e){
        var errorDiv = $('#'+e.id+'Error');
        if (e.validity.valid) {
            isError = false;
            $(errorDiv).hide();
            $(errorDiv).html('');
            if(e.value < 35 || e.value > 50)
            {
                 isError = true;
            }
            else
            {
                isError = false;
            }
        }
        else
        {
            isError = true;
        }
        
        if(isError == true)
        {
            $(errorDiv).show();
            $(errorDiv).html('Please enter valid value');
        }
        
    }
    
    
    </script>
