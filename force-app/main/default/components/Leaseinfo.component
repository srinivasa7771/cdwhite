        function showSection(ele)
        {
            $('.ldde').hide();
            $('.collapse-toggle').addClass('collapsed');
            var selOpt = $('#landType').find(":selected");
            let selval = ele.value;
            let ldOptions = ele.options;
            if(selOpt!= null && selOpt.length> 0)
            {
                selOpt.each(function(){
                    var ldsec = $(this).attr('data-ldVal');
                    $('.'+ldsec+'sec').show();
                    $('.'+ldsec+'sec').addClass('show');
                    // $('#'+ldsec+'ac').parent().children("a").click();
                    var alink = $('#'+ldsec+'ac').parent().children("a");
                    $(alink).removeClass('collapsed');
                    $(alink).attr('aria-expanded', true);
                    $('#'+ldsec+'ac').show();
                   
                });
            }
        }

