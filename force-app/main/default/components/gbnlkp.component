            $('#vfslabel,#vfsOpt').show();
            //document.getElementById("vfslabel").style.display='block';
            //document.getElementById("vfsOpt").style.display='block';  
            //check if vfs flag field is yes or no and check the one of them (for draft and open requests) 
            if (cs["vfsFlag__c"].value === 'true'){
                //update the vfs input radio with checked  
                $('#vfsYes').prop('checked',true);
                //var vfsYes = document.getElementById("vfsYes");
                //vfsYes.checked = true;
            }
            if (cs["vfsFlag__c"].value === 'false'){
                //update the vfs input radio with checked
                $('#vfsNo').prop('checked',true);
                //var vfsNo = document.getElementById("vfsNo");
                //vfsNo.checked = true;
            }
        }
        //if(('{!rq.acc__r.Legal_Framework__c}'!='Freelancer')||('{!rq.acc__r.Legal_Framework__c}'=='Freelancer'  && jobData.aff__c == true) ){
        $('#serachVal').val(n);
        $('#modal_lookup_values').modal('hide');
        cs['selectedJobTitle'].value = n;
        cs['xcjb__c'].value = id;
        if(c==true){
            
            //$('.fileAtt').removeClass('hidden_elem');
        }
        else{
            $('.fileAtt').addClass('hidden_elem');
        }
        //('{!rq.acc__r.Legal_Framework__c}'=='Freelancer')?$('#jd').attr('data-target','#modal_lookup_values'):'';
        /*}
        else{
            $('#jd').attr('data-target','#modal_lookup_values');
        }*/
    }
    function delAtt(){
        var f = $('#files')[0].files[0];
        var ch="Are You sure to <b>Delete</b>";
        var cb="Once you delete this attachment, you may need to re upload!";
        axsConfirmation(ch,cb,true,'deleteAtt',[]);
        /*if (r == true) {
            $('body').css('pointer-events','none;');
            deleteAtt();
        }*/
    }
    function sdraft(){
        let v = $('#serachVal').val();
        let v1 = cs['selectedJobTitle'].value;
        
        if(v!=v1){
            $('.jtLkp').find('#frmErrMsg1').html('** Selected look up value has changed!').show();
        }
        else{
            
            $('#preloader').fadeIn();
            sdraft1(cs["xcjb__c"].value);
            $('.jtLkp').find('#frmErrMsg1').hide();
        }
    }
    
    // for document upload
    var base64String;
    function handleBrowseClick_jt(){
        var fileinput = document.getElementById("files");
        fileinput.click();
    }
    function checkFile_jt(e){
        //showPrview(e);
        var f = $('#files')[0].files[0];
        let ext = f.name.split('.')[f.name.split('.').length-1];
        if(ext!='pdf'&&ext!=='jpg'&&ext!=='jpeg'){
            $('#saveText').css('color','#E62D38').html('Only <b>PDF</b>,<b>JPG</b> and <b>JPEG</b> Formats allowed.').fadeIn().fadeOut().fadeIn().fadeOut().fadeIn();
            return;
        }
        $('.saveAtt').removeClass('disabled');
        if(e!=undefined || $(e).length>0){ //showPrview(e);
            $('#saveText').css('color','#000').html('File uploaded please click on <b>SAVE</b> to Proceed.').show();
        }
        else{
            $('#saveText').hide();
        }
        
    }
    function showPrview_jt(elem) {
        var f = $('#files')[0].files[0];
        var t;
        var reader = new FileReader();
        reader.onload = function (theFile) {
            return function (e) {
                t =f.name.split('.')[1];
            }
        }(f);
        reader.readAsBinaryString(f);
    }
    function saveAttachment_jt(elem) {
        if($(elem).hasClass('disabled')) return;
        if (window.File && window.FileReader && window.FileList && window.Blob) {
            handleFileSelect_jt();
            //document.getElementById('files').addEventListener('change', handleFileSelect, false);
        } else {
            alert('The File APIs are not fully supported in this browser.');
        }
    }
    function delAtt(){
        var f = $('#files')[0].files[0];
        var ch="Are You sure to <b>Delete</b>";
        var cb="Once you delete this attachment, you may need to re upload!";
        axsConfirmation(ch,cb,true,'deleteAtt',[]);
    }
    function handleFileSelect_jt(evt) {
        var f = $('#files')[0].files[0];
        $('[forLoad="Attested Certificate"]').find('.loader_img').show();
        var reader = new FileReader();
        reader.onload = function (theFile) {
            return function (e) {
                var binaryData = e.target.result;
                base64String = window.btoa(binaryData);
                cs["imageBase64"].value = base64String;
                $('#fName').html(f.name);
                $('#fileAttDet').show();
                insertAtt();
                $('#modal_upload_passport_jt').modal('hide');
                $('.modal-backdrop').remove();
            }
        }(f);
        reader.readAsBinaryString(f);
    }
    
    
    function vfsOnChange(){ 
        console.log('---------entering on change method------'); 
        var vfsOption = $("input[name='vfsOption']:checked").val();
        cs["vfsFlag__c"] .value=false;
        if(vfsOption=='Yes'){
            cs["vfsFlag__c"] .value=true;
            //July 26 2024
            if (cs['xadh__c'] != null) {
                var adh = cs['xadh__c'].value;
                if (!adh.includes('vfs;')) {
                    cs['xadh__c'].value += 'vfs;';
                    console.log('adhocvalues::' + cs['xadh__c'].value);
                }
            }
        }
        console.log('vfs option returned'+ cs["vfsFlag__c"] .value);
    }
    
    
    </script>
</apex:component>