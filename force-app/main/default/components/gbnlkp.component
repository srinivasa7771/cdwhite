        let bic = $(elem).find('td').eq(2).text();
        let cntry = $(elem).find('td').eq(3).text();
        selectedBankDetails.id = id;
        selectedBankDetails.name = n;
        selectedBankDetails.bic = bic;
        selectedBankDetails.cntry = cntry;
        $('.countryOptions option').each(function(){
            if(cntry == $(this).text().trim()){
                $(this).prop('selected',true);
                $('.countryOptions').trigger('change');
            }
        });
        $('#swiftcode').val(bic);
        $('#serachVal').val(n);
        $('.modal-backdrop').hide();
        $('#modal_lookup_values').modal('hide');
        cs['bandb__c'].value = id;
    }
