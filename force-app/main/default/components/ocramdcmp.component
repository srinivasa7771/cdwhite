            $('#genderid').val('F').trigger('change');
    });
    
    
    /* for modal_confirm_information_LA popup starts U_S*/
    function showEIDfields(e){ 
        $(e).parent().parent().find('.option-error').hide();
        let m = '#modal_confirm_information_LA';
        $('.isvisitedUAE.reqRadio:visible').each(function () {
            $(this).find(':radio').each(function () {
                this.checked = false; 
            });
        });
        
        if($(e).prop('checked')==true && $(e).attr('for')=='yes'){
            $('.ifVisa').show();
            cs['inUAE__c'].value = true;
            $('.insideUAE').css('display','flex');
            $('#isVisited').hide();
            $('.outsideUAE').hide();
            removeValError($(m).find('[name="eid"]'));
        }
        else if( $(e).prop('checked') == true && $(e).attr('for') == 'no')
            {
                $('#isVisited').show();
                $('.ifVisa').hide();
                $('.insideUAE,.ifVisa').find('input,select').val('').trigger('change');
                $('.insideUAE').css('display', 'none');
                //$('.ifVisa').find('select,input').val(''); 
                $('.ifVisa').hide();
                $('#isVisa,.outsideUAE').show();
                $('.outsideUAE').parents('.row').show();
                removeValError($(m).find('[name="eid"]'));
            }
        else{
            cs['inUAE__c'].value = false;
            $('.insideUAE,.ifVisa').find('input,select').val('');
            $('.insideUAE,.ifVisa').find('input,select').val('').trigger('change');
            $('.ifVisa').hide();
            $('.insideUAE').css('display','none');
        }
    }
    function visitedFields(e){
        $(e).parent().parent().find('.option-error').hide();
        if($(e).prop('checked')==true){
            let m = '#modal_confirm_information_LA';
            removeValError($(m).find('[name="vid"]')); 
        }
    }
    /*U_S */
    function revertDateFormat(v){
        if(!v)
            return;
        var dateArr = v.split('/');
        return dateArr[2]+'-'+dateArr[1]+'-'+dateArr[0];
    }
    /*U_S */
