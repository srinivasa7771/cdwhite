    function memNationalityChange(e) {
            if (!$(e).val())
                return;
            var c = nationalityToCountry($(e).val());
            if (c == 'United Arab Emirates' ) {
                $('[name="eid"][for="yes"]').prop('checked',true).trigger('change');
                $('[name="eid"][for="no"]').prop('disabled',true);
                //$('#isVisa input').prop('checked', false); $('#isVisa').hide();
                $('.outsideUAE').find('select,input').val('');
                $('.outsideUAE').parents('.row').hide();
                $('.outsideUAE').hide();
                $('#isVisited').hide();
                $('.insideUAE').parents('.row').show();
                $('.insideUAE').css('display', 'flex');
            }
            else {
                 $('#isVisited').find('input').prop('checked', '').trigger('change');
                 $('#isVisited').hide();
                $('#isVisa input').prop('checked', false);
                $('.ifVisa,.outsideUAE').find('select,input').val(''); $('.ifVisa').hide();
                $('#isVisa,.outsideUAE').show();/* ,.ifVisa*/
                $('.outsideUAE').parents('.row').show();
            }
    }
