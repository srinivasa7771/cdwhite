    <li><label for="img_height"><b>Height :</b>
        <input type="text" id="img_height" style="width:50%;" size="10"/>px</label></li>
    <li><label for="img_width"><b>Width :</b>&nbsp;
        <input type="text" id="img_width" style="width:50%;" size="10"/>px</label></li>
    <li>Interpolation method:
        <select size="1" id="InterpolationMethod"><option value = ""></option></select></li>
    <li style="text-align:center;">
        <input type="button" value="   OK   "  class="btn" id="btnChangeImageSizeOK" onclick ="return btnChangeImageSizeOK_onclick();"/>
        <input type="button" value=" Cancel "  class="btn" id="btnCancelChange" onclick ="return btnCancelChange_onclick();"/></li>
</ul>
<!--
</div>
-->
</td>
</tr>       
        </table>
        <!-- Save Button -->
        <div align="center">
        
        </div>
        </div>
