        </a>
        <a class="hint--bottom" data-hint="Change Image Size" id="btnChangeImageSize" onclick="btnChangeImageSize_onclick()">
        <apex:image url="{!URLFOR($Resource.gso_fileuploadNew, '/images/tools.svg')}"  styleClass="responsiveimagenoborder" style="width:1.786em;height:2.5em"/>
        </a>
        <a class="hint--bottom" data-hint="Delete Image" href="#" onclick="btnRemoveCurrentImage_onclick()">
        <apex:image url="{!URLFOR($Resource.gso_fileuploadNew, '/images/icon-delete.svg')}"  styleClass="responsiveimagenoborder" />
        </a>
        </td>
        </tr>
<tr id="ImgSizeEditor" style="visibility:hidden;">
<td>
