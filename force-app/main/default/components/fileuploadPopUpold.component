        <table class="gridtable">
        <tr>
        <td>
        <label for="title">Select Scanner</label>
        <select id="source" name="title" class="dropdownbox" style="width:165px">           
        </select>
        </td>
        </tr>
        <tr>
        <td align="center">
        <input type="button" value="Scan" class="btn" onclick ="btnScan_onclick();"/>
        </td>
        </tr>
        <tr>
        <td align="center">        
        <input type="button" value="Load an existing image" class="btn" onclick="return btnLoad_onclick()"/>
        </td>
        </tr>
        <tr>
        <td align="center">        
        <input type="button" value=" Save " class="btn" onclick="javascript:btnUpload_onclick('123','300','355','96');closeDialog();sv()"/></td>
        </tr>
        
        </table>
        <!-- Table - Edit Image '175','300','189' --------------------------------------------->
        <table class="gridtable">
        <tr>
        <th>Edit Image</th>
        </tr>
        <tr>
        <td class="edit-button">
        <a class="hint--bottom" data-hint="Crop" href="#" onclick="btnCrop_onclick()">
        <apex:image url="{!URLFOR($Resource.gso_fileuploadNew, '/images/icon-crop.svg')}"  styleClass="responsiveimagenoborder"/>      
        </a>
        <a class="hint--bottom" data-hint="Rotate Left" onclick="btnRotateLeft_onclick()">
        <apex:image url="{!URLFOR($Resource.gso_fileuploadNew, '/images/icon-left.svg')}"  styleClass="responsiveimagenoborder"/>
        </a>
        <a class="hint--bottom" data-hint="Rotate Right" onclick="btnRotateRight_onclick()">
