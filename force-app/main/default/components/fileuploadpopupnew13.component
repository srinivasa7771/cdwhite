        function stopLoaderThis(){
            currentDoc = document.getElementById("udDocType").value;
            console.log('in stopLoaderThis!!! >> '+ currentDoc);
            $('[forLoad="'+currentDoc+'"]').find('.loader_img').hide();
            $('*').removeClass('loadingProgress');
