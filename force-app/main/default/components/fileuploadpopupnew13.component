        function Dynamsoft_OnReady() {
            WebTWAIN = Dynamsoft.WebTwainEnv.GetWebTwain('dwtcontrolContainer'); // Get the Dynamic Web TWAIN object that is embeded in the div with id 'dwtcontrolContainer'
            //console.log('1 WebTWAIN >>'+ JSON.stringify(WebTWAIN));
            // dwtcontrolContainer
            if (WebTWAIN) {
                // to auto crop trailing white spaces
                //WebTWAIN._AutoCropMethod= 1;
                var count = WebTWAIN.SourceCount;
                for (var i = 0; i < count; i++)
                    document.getElementById("source").options.add(new Option(WebTWAIN.GetSourceNameItems(i), i));
                
                var l = '<div class="loader1"></div>';
                $('.dynamsoft-dwt-dialogProgress').html(l);
                
            }
            
            WebTWAIN.RegisterEvent("OnPostTransfer", Dynamsoft_OnPostTransfer);
            WebTWAIN.RegisterEvent("OnPostLoad", Dynamsoft_OnPostLoadfunction);
            WebTWAIN.RegisterEvent("OnPostAllTransfers", Dynamsoft_OnPostAllTransfers);
            WebTWAIN.RegisterEvent("OnMouseClick", Dynamsoft_OnMouseClick);
            WebTWAIN.RegisterEvent("OnImageAreaSelected", Dynamsoft_OnImageAreaSelected);
            WebTWAIN.RegisterEvent("OnImageAreaDeSelected", Dynamsoft_OnImageAreaDeselected);
            WebTWAIN.RegisterEvent("OnTopImageInTheViewChanged", Dynamsoft_OnTopImageInTheViewChanged);
            
            // console.log('2 WebTWAIN >>'+ JSON.stringify(WebTWAIN));
            
        }
        
        function LoadImage() {
            WebTWAIN = Dynamsoft.WebTwainEnv.GetWebTwain('dwtcontrolContainer');
            if (WebTWAIN) {
                WebTWAIN.IfShowFileDialog = true; // Open the system's file dialog to load image
                WebTWAIN.LoadImageEx("", EnumDWT_ImageType.IT_ALL, OnSuccess, OnFailure); // Load images in all supported formats (.bmp, .jpg, .tif, .png, .pdf). OnSuccess or OnFailure will be called after the operation
            }
        }
