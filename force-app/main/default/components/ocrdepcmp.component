    function formatDate(date){
        var d ;
        
        if(date.includes(' ')){
            date = date.toLowerCase();
            d = date.split(' ');
            
            if(Object.keys(monthObj).includes((d[1].substring(0,3)).toUpperCase())){    // case-1: date format -- 01 Jan 2020
                
                return date.split(d[1].toLowerCase()).join(monthObj[(d[1].substring(0,3)).toUpperCase()]).split(' ').join('/');
            }
            else                                                        // case-2: date format -- 01 01 2020
                return date.split(' ').join('/');
        }
        else if(date.includes('-'))                                     // case-3: date format -- 01-01-2020
            return date.split('-').join('/');
            else if(date.includes('.'))                                   // case-4: date format -- 01.01.2020
