    function validAlphaNumeric(e){  /**Ex: <input type="text" onkeyup="validAlphaNumeric(this)" />**/
        let n = $(e);
        n.val(n.val().replace(/[^0-9a-zA-Z]*$/, ''));
    }
    function validAlphaOnly(e){ /**Ex: <input type="text" onkeyup="validAlphaOnly(this)" />**/
        let n = $(e);
        n.val(n.val().replace(/[^a-zA-Z ]*$/, ''));
    }
