    <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/fonts/icomoon/style.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/style.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-ddd.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.axs2MandateCss)}" />
        
    <script type="text/javascript" src="/resource/1/assets_NUI/js/script.js?v=1.2.0-2">
    </script> 
    
