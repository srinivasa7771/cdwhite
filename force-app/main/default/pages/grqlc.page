var ispu={!ispu},lcl='{!JSENCODE(lcl)}',sta='{!JSENCODE(rq.STA__c)}',cs={}, pbsBoat, pbsRta;
var lf='',af='',adf='',lif,aif,adif,cif,cnf,fnxPg;
function vfrm(nSTA){return hsSnc(nSTA)?!1:hRq(nSTA)?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):hErr(nSTA)?(alrt("{!$Label.msgCRR}","{!$Label.msgCRRD}"),!1):!0}
function hsSnc(nSTA){return false;}
function hErr(nSTA){return false;}
function hRq(nSTA){
    fldErr('xltr__c',null,!0);fldErr('xla2__c',null,!0);
    fldErr('xbtnm__c',null,!0);fldErr('xbdt__c',null,!0);fldErr('xcst__c',null,!0);
    fldErr('xln__c',null,!0);fldErr('xengp__c',null,!0);fldErr('xneng__c',null,!0);
    fldErr('xengt__c',null,!0);
    //fldErr('xeng__c',null,!0);
    fldErr('xvbr__c',null,!0);fldErr('xvn__c',null,!0);fldErr('xvch__c',null,!0);
    fldErr('xvtyp__c',null,!0);fldErr('xtr2__c',null,!0);fldErr('xvown__c',null,!0);
    cs['xltr__c']=getC(lif);cs['xla2__c']=getC(aif);cs['xla2d__c']=getC(adif);
    var brq=!1;
    if(lf==""||lf=="__"){lf=cs["xltr__c"].value;}
    if(af==""||af=="__"){af=cs["xla2__c"].value;}
    if(adf==""||adf=="__"){adf=cs["xla2d__c"].value;}
    if(""==lf||"__"==lf)fldErr("xltr__c","Value is required",!0),brq=!0;
    1<cs['xla2__c'].options.length&&(""==af||"__"==af)&&(fldErr("xla2__c","Value is required",!0),brq=!0);
    1<cs['xla2d__c'].options.length&&(""==adf||"__"==adf)&&(fldErr("xla2__c","Value is required",!0),brq=!0);
    if(getC(pbsBoat).style.display==''&&nSTA!='Draft'){brq=fldReq('xbtnm__c',cs)||brq;brq=fldReq('xbdt__c',cs)||brq;brq=fldReq('xcst__c',cs)||brq;brq=fldReq('xln__c',cs)||brq;brq=fldReq('xengp__c',cs)||brq;brq=fldReq('xneng__c',cs)||brq;brq=fldReq('xengt__c',cs)||brq;}
    //brq=fldReq('xeng__c',cs)||brq;
    if(getC(pbsRta).style.display==''&&nSTA!='Draft'){brq=fldReq('xvbr__c',cs)||brq;brq=fldReq('xvn__c',cs)||brq;brq=fldReq('xvch__c',cs)||brq;brq=fldReq('xvtyp__c',cs)||brq;brq=fldReq('xtr2__c',cs)||brq;brq=fldReq('xvown__c',cs)||brq;}
    if( lf=='Boat Registration'||
        lf=='Boat Registration - Personal'||
        lf=='RTA - Heavy Vehicle - New'||
        lf=='RTA - Heavy Vehicle - Renewal'||
        lf=='Employment Certificate'||
        lf=='Immigration PRO Card - New'||
        lf=='Immigration PRO Card - Renewal'||
        lf=='PRO Card for Personnel Services - New'||
        lf=='PRO Card for Personnel Services - Renewal'){
        fnxPg='grqei';
    } else{
        fnxPg='grqpy';
    }   
    return brq;
    
}
function ifrm(){if({!pgHide}||{!md.isView}){return;}if('{!JSENCODE(srv.uid__c)}'=='ltp'){cs['xlt__c'].value="Personal";} else {cs['xlt__c'].value="Corporate";}displayFields();}
function displayFields(){         
    if(!{!pgHide}&&!{!md.isView}){fldErr('xbtnm__c',null,!0);fldErr('xbdt__c',null,!0);fldErr('xcst__c',null,!0);fldErr('xln__c',null,!0);fldErr('xengp__c',null,!0);fldErr('xneng__c',null,!0);fldErr('xengt__c',null,!0);fldErr('xvbr__c',null,!0);fldErr('xvn__c',null,!0);fldErr('xvch__c',null,!0);fldErr('xeng__c',null,!0);fldErr('xvtyp__c',null,!0);fldErr('xtr2__c',null,!0);fldErr('xvown__c',null,!0);}   
    getC(pbsBoat).style.display='none';getC(pbsRta).style.display='none';    
    if(lf=='Boat Registration'||lf=='Boat Registration - Personal'){getC(pbsBoat).style.display='';}
    else if(lf=='RTA - Vehicle Sale'||lf=='RTA - Vehicle Sale � Boat'||lf=='RTA - Vehicle Sale � Bus'||lf=='RTA - Vehicle Sale - Motor Bike'||lf=='RTA - Vehicle Sale � Truck'||lf=='RTA - Vehicle Transfer'||lf=='RTA - Vehicle Transfer - Motor Bike'||lf=='RTA - Vehicle Transfer � Truck'){getC(pbsRta).style.display='';}   
                                                                                                                                                                                                                                                                    
    }
function dftA2(){cs['xla2__c']=getC(aif);if(2==cs['xla2__c'].options.length){cs['xla2__c'].value=cs['xla2__c'].options[1].value;af=cs['xla2__c'].value;}}
function dftA2d(){cs['xla2d__c']=getC(adif);if(2==cs['xla2d__c'].options.length){cs['xla2d__c'].value=cs['xla2d__c'].options[1].value;adf=cs['xla2d__c'].value;}}
</script>
