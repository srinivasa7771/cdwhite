                            </div>
                            <script type="text/javascript" charset="utf8">
                            var oTable;var currentNumberDisplayed = 500;
                            $(document).ready(function() {
                                $('#load').click( function () {
                                    var oSettings = oTable.fnSettings();currentNumberDisplayed += 2;oSettings._iDisplayLength = currentNumberDisplayed;oTable.fnDraw();});
                                oTable = $('[id$=testTable]').dataTable({"iDisplayLength": 200}); 
                                
                            });
                            </script>
                            
                        <apex:actionstatus id="sts">
                                <apex:facet name="start">
                                    <div class="slds-spinner_container">
                                        <div id="mySpinner" role="status" class="slds-spinner slds-spinner_medium">
                                            <span class="slds-assistive-text">Loading</span>
                                            <div class="slds-spinner__dot-a"></div>
                                            <div class="slds-spinner__dot-b"></div>
                                        </div>
                                    </div>
                                </apex:facet>
                            </apex:actionstatus> 
                            
                            <apex:dataTable value="{!finalListRqItm}" var="record" rendered="{! IF(ISBLANK(finalListRqItm), false, true) }" captionClass="testTable" styleClass="slds-table slds-table--bordered slds-table--striped" id="testTable" cellspacing="5%" columnsWidth="11%" style="width:100%;float:left;" >                 
                                <apex:column >
                                    <apex:inputCheckbox onclick="openNewTab('{!record.ri.RQ__r.id}');" /> 
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Request" /></apex:facet>
                                    <apex:outputField value="{!record.ri.RQ__c}"/>
                                </apex:column>
                               <apex:column >
                                    <apex:facet name="header"><apex:outputLabel value=" Manage Request" /></apex:facet>
                                    <apex:outputField value="{!record.ri.RQ__r.xmgr__c}"/>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header"><apex:outputLabel value="Account Name" /></apex:facet>
                                     <apex:outputLabel value="{!IF(record.ri.RQ__r.Account_Name__c=='test identity 1', 'DED Account',record.ri.RQ__r.Account_Name__c)}"/>

                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Applicant Name" /></apex:facet>
                                    
                                    <apex:outputField value="{!record.ri.RQ__r.Full_Name__c}"/>
                                </apex:column>
                                 <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Passport#" /></apex:facet>
                                    
                                    <apex:outputField value="{!record.ri.RQ__r.xcp__c}"/>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Nationality" /></apex:facet>
                                    
                                    <apex:outputField value="{!record.ri.RQ__r.xcnc__c}"/>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Priority" /></apex:facet>
                                    
                                    <apex:outputField value="{!record.ri.RQ__r.prio__c}"/>
                                </apex:column>
                                 <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Payment Date" /></apex:facet>
                                      <apex:outputField value="{!record.ri.First_Payment__c}"/>
                                       
                                </apex:column>
                           

                                 <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Date of Action" /></apex:facet>
                                     
                                 <apex:outputText value="{0,date,dd-MM-yyyy}"> <apex:param value="{!record.dateofAction}" /> </apex:outputText>
                                    
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="Duration" /></apex:facet>
                                      <apex:outputText value="{!record.duration}"/>
                                   </apex:column>  
                                <apex:column >
                                    <apex:facet name="header" ><apex:outputLabel value="SLA Status" /></apex:facet>
                                    <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration > 9),AND(record.ri.RQ__r.expflg__c,record.duration > 4))}">
                                      <apex:outputText value="Outside SLA"/>
                                    </apex:outputText>
                                    <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration > 6,record.duration < 9))}">
                                      <apex:outputText value="About to Expire"/>
                                    </apex:outputText>
                                    <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration <= 6),AND(record.ri.RQ__r.expflg__c,record.duration <= 5))}">
                                      <apex:outputText value="Within SLA"/>
                                    </apex:outputText>
                                </apex:column>
                                 <apex:column >
                                <apex:facet name="header" ><apex:outputLabel value="Remarks " /></apex:facet>
                                    
                                    <apex:outputField value="{!record.ri.nt__c}"/>
                                </apex:column>
                               
                               
                                
