    function valDates(){ 
        if('{!srv.uid__c}'=='ltc'){
            cs['xcpid__c'].value = getC('xcpid').value.replace(/ /g, "");; 
            cs['xcped__c'].value = getC('xcped').value.replace(/ /g, "");;        
            removeValError(getC('xcpid')); removeValError(getC('xcped'));
            
            var stDate = cs['xcpid__c'].value;var splitDt = stDate.split("/"); if(splitDt!="" && splitDt.length==3){ stDate = splitDt[2].trim()+'-'+splitDt[1].trim()+'-'+splitDt[0].trim(); console.log(stDate);}
            var date = new Date();var today1 = date.getTime(); stDate = new Date(stDate).getTime(); 
            
            if(stDate < today1){ addValError(getC('xcpid'),'Start date should be future date!'); return true;}
            
            var expDate = cs['xcped__c'].value;var splitDt2 = expDate.split("/"); if(splitDt2!="" && splitDt2.length==3){ expDate = splitDt2[2].trim()+'-'+splitDt2[1].trim()+'-'+splitDt2[0].trim(); console.log(expDate);}
            expDate = new Date(expDate).getTime(); 
            
            if(expDate < stDate){addValError(getC('xcped'),'End date should be greater than start date!'); return true;}
            if(expDate == stDate){ addValError(getC('xcped'),'End date cannot be same as the start date!'); return true;}
            
            var stDate1 = cs['xcpid__c'].value;var splitDt = stDate1.split("/"); if(splitDt!="" && splitDt.length==3){ stDate1 = splitDt[2].trim()+'-'+splitDt[1].trim()+'-'+splitDt[0].trim(); }
            stDate1 =  new Date(stDate1); stDate1.setFullYear(stDate1.getFullYear() + 1); 
            if(expDate > stDate1){ addValError(getC('xcped'),"End date should to be less than one year from start date!"); return true;} 
        }
        return false;
    }
    
