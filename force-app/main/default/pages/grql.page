            getC('cdoc').style.display='none'; cs['xccn__c'].style.display='none'; 
            getC('cpps').style.display='none'; getC('cppe').style.display='none';cs['locDetails'].style.display='none';
            cs['locAdd2'].style.display='none'; getC('cateringdetails').style.display='none';
            getC('loclabel2').style.display='none';
        }
        
        if(getC(cs['xltr__c'].id).value == 'Permit for catering service'){
