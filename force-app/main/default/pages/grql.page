    })
    
    function dispMOF(){
        
        var paidAmount = '{!rq.AP__c}';  paidAmount = parseFloat(paidAmount);  
        if (isNaN(paidAmount)){paidAmount=0;}
        if (!paidAmount>0) {
            dispMOF1();
            var ltrType = getC(cs['xltr__c'].id).value;
            if(ltrType=="Certificate of incumbency (Branch)" || ltrType=="Certificate of incumbency(FZ LLC)"){
                cs['panelmof1'].style.display='';  getC("label_lat").innerHTML = "Select the language for the letter";
            }else{
                cs['panelmof1'].style.display='none';  cs['xoca__c'].checked = false;
                if(ltrType=="Permit for catering service"){
                    getC("label_lat").innerHTML = "Permit type";
                }else{
                    //if(ltrType!="Dubai Custom "){
                        getC("label_lat").innerHTML = "Letter addressed to";
                    // }
                }
            }
        }else{  
            if('{!rq.xoca__c}'=='true'){
                cs['panelmof1'].style.display=''; getC("insyes").checked = true;
            }else{
                cs['panelmof1'].style.display='none'; getC("insno").checked = true;
            }
        }
        
        // if payment is done, dont allow users to update the type
        if(paidAmount>0){getC("insyes").disabled = true; getC("insno").disabled = true;}
    }
    
    function dispMOF1(){ 
        var ltrType = cs['xoca__c'].checked;  getC("insyes").checked = cs['xoca__c'].checked;
        if(ltrType==true){ 
            getC("panelmof").style.display=''; cs['collDelcmp'].style.display='';
            cs['embC'].value = cs['xadh__c'].value.replace(';','');
        }else{ 
            getC("panelmof").style.display='none'; cs['collDelcmp'].style.display='none';
            cs['xcnc__c'].value=''; cs['xadh__c'].value='';
        } 
    }
    
    function findSelection(type) { 
        if (type == 'insyes') {
            if (getC("insyes").checked) {
                getC("insno").checked = false;cs['xoca__c'].checked = true;cs['xoca__c'].onclick();
            } else {cs['xoca__c'].checked = false; cs['xoca__c'].onclick();}
        } else if (type == 'insno') {
            if (getC("insno").checked) {getC("insyes").checked = false;cs['xoca__c'].checked = false;cs['xoca__c'].onclick();}
        }
        getC("insyes").checked = cs['xoca__c'].checked;
    }
    
    function chkAttestation() { return false;}
    
    function chkcmof(e){
        if(cs['embC'].value =='xsa'){ cs['xla2__c'].value = 'Arabic';}
        if (cs['embC'].value!='' && cs['embC'].value!=null){ 
            cs['xcnc__c'].value =  cs['embC'].options[cs['embC'].selectedIndex].text;
            cs['xadh__c'].value=cs['embC'].value+';';    
        }else{ cs['xadh__c'].value='';   cs['xcnc__c'].value='';}
    }
    
    function dformat(dt,id){
        var d = new Date(dt);//alert(d);
        var m=d.getMonth()+1;
        var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
        var mm=m>9?m:'0'+m;
        var yy=d.getFullYear();
        document.getElementById(id).value=dd+'/'+mm+'/'+yy;
    }
    
    //toDo : update the logic for removing piclist vals
    function removeMulti(x){
        var selobj=document.getElementById('availableDocs');
        var flg = 'false';
        if('{!brnchincubflag}' == 'false' && '{!fzllcflag}' == 'true'  ){   
            for (var i = 0; i < selobj.length; i++) { 
                if (selobj.options[i].value == '0' ) {selobj.remove(i);}
                if (selobj.options[i].value == '1' ) {selobj.remove(i);}
                if (selobj.options[i].value == '4' ) {selobj.remove(i);}
            }
        }
        if('{!brnchincubflag}' == 'true' && '{!fzllcflag}' == 'false'){
            for (var i = 0; i < selobj.length; i++) { 
                if (selobj.options[i].value == '0' ) {selobj.remove(i);}
                if (selobj.options[i].value == '1' ) {selobj.remove(i);flg ='true';}
                if (selobj.options[i].value == '2' ) {selobj.remove(i);flg ='true';}
                if (selobj.options[i].value == '3' ) {selobj.remove(i);flg ='true';}
                if (selobj.options[i].value == '5' ) {selobj.remove(i);flg ='true';}
            }
        }
    }
    
    function removepdoc(ltr){
        var selectobject= getC(nld);
        var ind = null;
        var ind2=[] ;
        
        if('{!brnchincubflag}' == 'false' && '{!fzllcflag}' == 'true'  ){
            for (var i = 0; i < selectobject.length; i++) { 
                if (selectobject.options[i].value == 'Certificate of Branch Registration') { ind = i; break;}
            }
            if(typeof(selectobject.options[ind])!='undefined' && selectobject.options[ind].value == 'Certificate of Branch Registration'  ){
                selectobject.remove(ind);
            }
        }
        
        if('{!brnchincubflag}' == 'true' && '{!fzllcflag}' == 'false' &&  selectobject.length!=2 ){
            var option1 = document.createElement('option');option1.text = option1.value ='Commercial License';selectobject.add(option1,0);
            var option2 = document.createElement('option');option2.text = option2.value ='Certificate of Branch Registration';selectobject.add(option2,1);
            
            if(selectobject.length>2){ for(var i=2; i<selectobject.length; i++){selectobject.remove(i);i--;}}
        }
    }
    
    
    function removeletterto(ltr){
        var selectobject= getC(aif); var ind = null; var ind1 = null;   
        if('{!incubflag}' == 'true'){
            for (var i = 0; i < selectobject.length; i++) { 
                if('{!brnchincubflag}' == 'true'){
                    if (selectobject.options[i].value == 'Corporate Person FZ-LLC' ) { ind = i;break;}
                }else {
                    if (selectobject.options[i].value == 'Branch' ) { ind = i; break;}
                }
            }
        }
        if(typeof(selectobject.options[ind])!='undefined' && selectobject.options[ind].value == 'Corporate Person FZ-LLC' && '{!brnchincubflag}' == 'true' ){selectobject.remove(ind);}
        if(typeof(selectobject.options[ind])!='undefined' && selectobject.options[ind].value == 'Branch' && '{!brnchincubflag}' == 'false' ){selectobject.remove(ind);}
        
    }
    
    function removeVal(ltr){   
        var breakflag = 'true';var selectobject= getC(lif); var ind = null; var ind1 = null; var locsize ;  
        var fzllcflag = '{!fzllcflag}'; var brnchincubflag = '{!brnchincubflag}';
        console.log('fzllcflag: '+fzllcflag+'  brnchincubflag:'+brnchincubflag);
        if('{!fzllcflag}' == 'true' && '{!brnchincubflag}' == 'false'){ 
            for (var i = 0; i < selectobject.length; i++) { 
                if (selectobject.options[i].value == 'Certificate of incumbency (Branch)' ) {
                    selectobject.remove(i);
                }
            }
        }
        
        if('{!fzllcflag}' == 'false' && '{!brnchincubflag}' == 'false'){
            for (var i = 1; i < selectobject.length; i++) { 
                if (selectobject.options[i].value == 'Certificate of incumbency (Branch)' ) { selectobject.remove(i);}
                if (selectobject.options[i].value == 'Certificate of incumbency(FZ LLC)' ) { selectobject.remove(i);}
            }
        }
        
        if('{!fzllcflag}' == 'false' && '{!brnchincubflag}' == 'true'){
            for (var i = 1; i < selectobject.length; i++) { 
                console.log('selectobject.options[i].value: '+ selectobject.options[i].value);
                if (selectobject.options[i].value == 'NOC to DED (Partake as Shareholder)' ) { selectobject.remove(i);}
                if (selectobject.options[i].value == 'Certificate of incumbency(FZ LLC)' ) { selectobject.remove(i);}
            }
        }      
        
        if('{!locList}'!=null){
            locsize ='{!locList.size}';
            if(ltr =='Ramadan Permit' && locsize == 1 ) {alrt('Alert','Letter for all location have been generated, Please check your log book.',!1);}
        }
        
        var logflag = '{!locflag}'; 
        if(ltr =='Ramadan Permit' && logflag == 'true' ) {
            alrt('Alert','Locations are not present for the Account , Please contact AXS Support.',!1);
            cs['locAdd'].style.display='none'; cs['loclabel'].style.display='none';  getC(cs['xltr__c'].id).value = "";
        }
        
        for (var i = 0; i < selectobject.length; i++) {  if (selectobject.options[i].value == 'Ramadan Permit' ) {  ind = i; break;}}
        var segf = '{!segflag}';
        if (segf == 'false' && ltr !='Ramadan Permit'  && typeof(selectobject.options[ind])!='undefined' && selectobject.options[ind].value == 'Ramadan Permit' ) { 
            selectobject.remove(ind); breakflag= false;
        } 
        
        if('{!incubflag}' == 'false'){
            for (var i = 0; i < selectobject.length; i++) { 
                if (selectobject.options[i].value == 'Certificate of Incumbency') { ind = i; break;}
            }
        }
        if(typeof(selectobject.options[ind])!='undefined' && selectobject.options[ind].value == 'Certificate of Incumbency'){
            selectobject.remove(ind);
        }
    }
    
    
    function showLoc(ltr){
        console.log(ltr);
        if(typeof(getC('emrts'))!='undefined'){
            if(ltr=="NOC to DED (Partake as Shareholder)"){  getC('emrts').style.display='block';}
            if(ltr!="NOC to DED (Partake as Shareholder)"){ getC('emrts').style.display='none';}
        }
        
        if(typeof(cs['xnld__c'])!='undefined'){
            if(ltr=="Letter to Dubai Police"){ getC('nold').style.display='block';}
            if(ltr!="Letter to Dubai Police"){getC('nold').style.display='none';}
        }
        
        if(typeof(cs['locAdd2'])!='undefined'){
            if( ltr=="Permit for catering service"){ 
                getC('cateringdetails').style.display='block';
                cs['locAdd2'].style.display='block';getC('loclabel2').style.display='block';getC('cdoc').style.display='block';cs['xccn__c'].style.display='block';
                cs['xcpid__c'].style.display='block';getC('cpps').style.display='block'; cs['xcped__c'].style.display='block'; getC('cppe').style.display='block';   
            }else{
                getC('cateringdetails').style.display='none';
                cs['locAdd2'].style.display='none';getC('loclabel2').style.display='none';getC('cdoc').style.display='none';cs['xccn__c'].style.display='none';
                cs['xcpid__c'].style.display='none';getC('cpps').style.display='none';cs['xcped__c'].style.display='none';getC('cppe').style.display='none';
            }
        }
        
        if(typeof(cs['locAdd'])!='undefined'){
            if(ltr=="Ramadan Permit") { cs['locAdd'].style.display='block';cs['loclabel'].style.display='block';cs['termId'].style.display='block'; 
            }else{cs['locAdd'].style.display='none';cs['loclabel'].style.display='none';cs['termId'].style.display='none';   }
        }    
    }
    
