    //validateData
    function vflds(){
        var brk = false;var elem = '';
        $('.requiredFld').each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){         
                if(v==''||v==null||v==undefined||v.length<1){
                    brk=true; addValError(this,'This field is required!'); 
                    //test12 += $(this).parent().parent().find('label').text() + ' ; ';
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);  }
                
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        
        if('{!srv.uid__c}'=='lts' || '{!srv.uid__c}'=='ltp'){
            $('.lookup').each(function(){
                let v = $(this).val();
                if(v==''||v==null || v==undefined){
                    brk=true; addValError($(this).parent(),'This field is required!');
                    if(elem=='') elem = $(this).parent();
                }else{
                    removeValError($(this).parent());
                }
            });
        }
        
        if(lf=="Permit for catering service" && !$("#cat_tnc").prop("checked")){
            $('#lab_tnc').css('color','#E62D38').fadeOut().fadeIn().fadeOut().fadeIn();
            brk=true;
        }
        return brk;
    }
    
    function removeValError(thiselem){
        var elem = $(thiselem);
        elem.parent().find('.frmErrMsg').remove();
        elem.parent().parent().find('.frmErrMsg').remove();
    }
    
    function addValError(thiselem,message){
        var elem = $(thiselem);
        elem.parent().find('.frmErrMsg').remove();
        elem.parent().parent().find('.frmErrMsg').remove();
        var errElem = '<div class="frmErrMsg">'+message+'</div>';
        if($(thiselem).attr('data-toggle') == 'datetimepicker'){
            elem.parent().parent().append(errElem);
        }else{
            elem.parent().append(errElem);
        }
    }
    
    function showTempLoader(e){
        var loader = '<span class="loader_temp">';
        loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
        loader += '</span>';
        $(e).find('.loader_temp').remove();
        $(e).append(loader);
        $('*').addClass('loadingProgress');
    }
    
    function removeTempLoader(){
        $('*').removeClass('loadingProgress');
        $('.loader_temp').remove();
    }    
    
