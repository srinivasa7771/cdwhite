    }
    
    
    function nRefd() {
        var okay = false;
        if(typeof(cs['locAdd'] )!='undefined' && cs['xltr__c'].value == 'Ramadan Permit' ){
            var cbx = document.getElementsByClassName("tnc");
            if (cbx[0].checked) {okay = true;}
            return !okay;
        }
    }  
        
    function chkAccount(accID){
        if(!ispu && !isgu){
            
            var urlParam = getAxsURLParam('m');
            if(urlParam!='edit'){
                isEditBO = false;
                $(".base-nav-next").text('PROCEED TO PAY');
            }
            
            $(cs['acc_lkwgt']).addClass("lookupcc");
            
            if(accID==null || accID==undefined ||accID==""){
                $("#ltrdetsection").hide();
