        if(typeof(cs['xcped__c'])!='undefined' && typeof(getC('cppe'))!='undefined' ){  cs['xcped__c'].style.display='none'; getC('cppe').style.display='none';}
        if(typeof(cs['xaloc__c'])!='undefined'){cs['locDetails'].style.display='none';      }                           
        if(typeof(getC('emrts'))!='undefined'){ getC('emrts').style.display='none';}
        if(typeof(getC('nold'))!='undefined')getC('nold').style.display='none';  
        if(typeof(cs['locAdd2'])!='undefined' && getC(cs['xltr__c'].id).value != 'Permit for catering service' ){  cs['locAdd2'].style.display='none';}
        if(typeof(getC('loclabel2'))!='undefined' && getC(cs['xltr__c'].id).value != 'Permit for catering service') {getC('loclabel2').style.display='none'; getC('cateringdetails').style.display='none';}
        if(typeof(cs['locAdd'] )!='undefined' && getC(cs['xltr__c'].id).value == 'Permit for catering service' )  cs['locAdd2'].value = cs['locHide'].value; 
                 
        if('{!rq.xltr__c}' == 'Letter to Dubai Police')getC('nold').style.display='block';
        if('{!rq.xltr__c}' != 'NOC to DED (Partake as Shareholder)'){getC('emrts').style.display='none';}
        
