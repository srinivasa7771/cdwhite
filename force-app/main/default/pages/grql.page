    $(document).ready(function(){
        // to stop service on emergency - vmkr
            //window.open('/serviceDown','_self');
        if(!Array.prototype.includes){
            Array.prototype.includes = function(a){return-1!=this.indexOf(a)}
        }
        $('.alphaChar').bind('keyup', function(e) {
            $(this).val($(this).val().replace(/[^a-zA-Z]/g, ''));
            if (e.which >= 97 && e.which <= 122) {
                var newKey = e.which - 32;
                e.keyCode = newKey;
                e.charCode = newKey;
            }
            $(this).val(($(this).val()));
        });
        $('.numOnly').keypress(function (event) {
            var charCode = (event.which) ? event.which : event.keyCode;
            if (charCode != 46 && charCode > 31 
                && (charCode < 48 || charCode > 57))
                return false;
            return true;
        });
        
        setDrvLicOnLoad(); dispMOF(); 
        displayXla2d(getC(cs['xltr__c'].id).value);
        
        if('{!srv.uid__c}'=='ltc'){getC("conlookuprow").style.display='none';}
        
        if(typeof(cs['termId'] )!='undefined' && '{!rq.xltr__c}' != 'Ramadan Permit' ){cs['termId'].style.display='none';} 
        if(typeof(cs['locAdd'] )!='undefined' && cs['xltr__c'].value != 'Ramadan Permit' ){ cs['locAdd'].style.display='none';}
        if(typeof(cs['loclabel'])!='undefined' && cs['xltr__c'].value != 'Ramadan Permit') {cs['loclabel'].style.display='none';}
        if(typeof(cs['locAdd'] )!='undefined' && cs['xltr__c'].value == 'Ramadan Permit' ) cs['locAdd'].value = cs['locHide'].value; 
