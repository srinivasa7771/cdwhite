    // set the vehicle letter type on change
    function setDrvLic(vehicle){
        cs['xvcol__c'].value = vehicle;
        if(vehicle=="Light vehicle" && lf=='Driving license new / renewal'){$("#ltpl").show();}else{ $("#ltpl").hide();}
    }
    
    // set the vehicle type on load
    function setDrvLicOnLoad(){
        if(lf.includes("Driving license new / renewal") || lf=="Vehicle sale" || lf=='Vehicle registration new / renewal' || lf=='Vehicle transfer'){
            $("#vehicle").val(cs['xvcol__c'].value).trigger("change"); 
