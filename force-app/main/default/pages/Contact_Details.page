    <script type="text/javascript">
       function testOpenSubtab() {
            //First find the ID of the primary tab to put the new subtab in
            //vals=valsx;
            sforce.console.getEnclosingPrimaryTabId(openSubtab);
        }
        
        function openObjectPrimaryTab(ObjectId,ObjectName,ObjectType) {
            //Open a new primary tab with the Case Details in it
            sforce.console.openPrimaryTab(null, ObjectId, true, ObjectName, openSuccess, ObjectId+'Tab');
        }
        
        function newCaseTab(accountName,contactName,requestNumber) {
            //Open a new primary tab with the Case Details in it
            alert('I am in new Case Tab');
            var params = 'cas4=' + accountName + '&CF00NN0000002KCu6=' + requestNumber + '&cas3=' + contactName;
            var nameer = '{!URLFOR($Action.Case.NewCase)}' + '&' + params;
            alert(nameer);
            sforce.console.openPrimaryTab(null,nameer, true, 'New Case', openSuccess, accountName+'Tab');
        }
        
        var openSubtab = function openSubtab(result) {
            //Now that we have the primary tab ID, we can open a new subtab in it
            var primaryTabId = result.id;
            alert(result.id);
            sforce.console.openSubtab(primaryTabId , '{!URLFOR($Action.Case.NewCase)}', true, 
                'New Case', null, openSuccess, 'salesforceSubtab');
        };
        
        var openSuccess = function openSuccess(result) {
            //Report whether we succeeded in opening the subtab
            if (result.success == true) {
                alert('subtab successfully opened');
            } else {
                alert('subtab cannot be opened');
            }
        };
        
        
  </script>


<script>
 
/*SLDS Tabs JS*/
j$('.slds-tabs--default__link,.slds-tabs--scoped__link').click(function(){
  j$(this).parent().parent().find('.slds-tabs--default__link,.slds-tabs--scoped__link').attr('aria-selected','false');
  j$(this).attr('aria-selected','true');
  j$(this).parent().parent().find('.slds-tabs--default__link,.slds-tabs--scoped__link').attr('tabindex','-1');
  j$(this).attr('tabindex','0');
  j$(this).parent().addClass('slds-active').siblings().removeClass('slds-active');
  j$(this).parent().parent().parent().find('.'+j$(this).parent().parent().parent().find('.slds-tabs--default__content,.slds-tabs--scoped__content')[0].classList[0]).removeClass('slds-show').addClass('slds-hide');
  j$(this).parent().parent().parent().find('#'+j$(this).attr('aria-controls')).removeClass('slds-hide').addClass('slds-show');
}); 
/*SLDS Tabs JS*/
</script>
