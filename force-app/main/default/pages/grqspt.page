                                                                    </script>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <p class="chk" style="vertical-align: middle;font-size: 1em;">
                                                            <label class="custom-checkbox mr-4"><!-- data-value-->
                                                                <input type="checkbox" id="tANDc" onchange="rmErronTC()" />
                                                                <span class="">
I confirm that the entered information is correct, and the student is qualified to get registered in the part-time eligibility list as per the compliance with the Student Eligibility under the article 2.1 of <a href=" https://dda.gov.ae/wp-content/uploads/Student%20Part%20Time%20Employment%20Regulations%20-%20signed.pdf" target="_blank"><u> Order No (1) of 2016</u></a>, concerning Student Part-time Employment”.                                                                </span>
                                                            </label>  
                                                        </p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- .base-main-content -->
                                        <c:saveBtn ispu="{!ispu}" isgu="{!isgu}"/>
                                        
                                    </div>
                                    <!-- .base-main -->
                                    
                                </div>
                                <!-- .base-layout -->
                                
                            </div>
