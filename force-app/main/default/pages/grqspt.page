                                                    <i class="step-icon icon-cash-deposit"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- .steps-mobile -->
                                        
                                        
                                        <b><apex:pageMessages id="msg"  />
                                            
                                            
                                        </b>
                                        
                                        
                                        <!-- .base-collapse -->
                                        <div class="base-collapse">
                                            <a href="#" class="collapse-toggle" data-toggle="collapse" data-target="#application_details">
                                                <div class="collapse-title">Applicant details </div>
                                            </a>
                                            <div id="application_details" class="collapse show">
                                                <div class="collapse-content">
                                                    
                                                        <div class="row row-lg">
                                                            <div class="col-lg-6">
                                                                <div class="form-group">
                                                                    <Label>First Name</Label>
                                                                    <apex:inputField styleClass="form-control" value="{!req.xcfn__c}" id="xcfn__c"/>
                                                                    <script type="text/javascript">
                                                                    cs['xcfn__c']=document.getElementById('{!$Component.xcfn__c}');
                                                                    </script>
                                                                </div>
                                                            </div>
                                                            <div class="col-lg-6">
                                                                <div class="form-group">
                                                                    <Label>Last Name</Label>
                                                                    <apex:inputField styleClass="form-control" value="{!req.xcln__c}" id="xcln__c"/>
                                                                    <script type="text/javascript">
                                                                    cs['xcln__c']=document.getElementById('{!$Component.xcln__c}');
                                                                    </script>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row row-lg">
                                                            <div class="col-lg-6">
                                                                <div class="form-group">
                                                                    <label>Date of birth</label>
                                                                    <div class="input-datepicker-group input-group">
                                                                        <apex:inputHidden id="xcbd" value="{!req.xcbd__c}" />
                                                                        <input type="text" class="requiredFld form-control input-datepicker rorenwl" id="xcbd__c"
                                                                               data-toggle="datetimepicker" data-target="#xcbd__c" value="{!req.xcbd__c}"
                                                                               onchange = "assignfldVal(this.value,'xcbd');checkDate(this,'dob','{!IF(OR(req.srvc__r.uid__c='051',req.srvc__r.uid__c='054'),'onlyPast',req.srvc__r.uid__c)}','{!req.Gender__c}')"  validationname="dob"/>
                                                                        <script type="text/javascript">
                                                                        cs['xcbd__c']=document.getElementById('xcbd__c');
                                                                        dformat('{!req.xcbd__c}','xcbd__c');
                                                                        cs['xcbd']=getC('{!$Component.xcbd}');
                                                                        </script>
                                                                        <div class="input-group-append">
                                                                            <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#xcbd__c">
                                                                                <i class="icon-date"></i>
                                                                            </button>
                                                                        </div>
                                                                    </div>
                                                                    
                                                                </div>
