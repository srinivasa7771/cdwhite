<apex:page sidebar="false" controller="ApplicantDetailController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true" standardStylesheets="false" title="{!srv.sdg__r.slbl__c}">
    <html>
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <meta name="viewport" content="width=device-width, initial-scale=1" /> 
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <script type="text/javascript">
        var cs = {};
        $(document).ready(function() {  
            console.log('document ready::::::');
            
            //Hide fields
            let flds1 = [cs['xclnar__c'],cs['xcfanar__c'],cs['xcfan__c'],cs['xcslt__c'],cs['xcfnar__c'],cs['xcmon__c'],cs['xcmonar__c'],cs['noFnm__c'],cs['xcms__c'],cs['xcbc__c'],cs['xcqemrt__c'],cs['xcnp__c'],cs['xcrlg__c'],cs['xclng__c'],cs['xeidav__c']];
            flds1.forEach(function(i) {
                $(i).parent().parent().hide();
            }); 
            //Disable  fields
            let flds2 =[cs['xcbd__c'],cs['xcnc__c'],cs['xcbp__c'],cs['xcfn__c'],cs['xcln__c'],cs['Gender__c'],cs['xcp__c'],cs['xcpic__c'],cs['xcpid__c'],cs['xcped__c'],cs['xcpip__c'],cs['xceidid__c'],cs['xceidedt__c']];
            flds2.forEach(function(i){ 
                if($(i).val())
                    $(i).attr('disabled',true);
            });
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z ]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
            
        });
        //Validate Data on click of next button
        function validateData(){
            console.log('validateData:::::::::');
            
            var elem = '';
            var validated  = true;
            $('.requiredFld,.applMob').each(function(){
                //if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                //return;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null || v==undefined){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            $('.ddValidation').each(function(){
                //debugger;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                showErrMsg($(this),'rqrd',true);
                var v = $(this).val();
                if(v==''||v==null||v==undefined){
                    if($(this).is('select'))
                        showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                    else
                        showErrMsg($(this),'rqrd','invalid');
                    return false;
                }
            });
            if(elem!=''){
                scrollToDiv(elem);
            }
            if($('#tANDc').prop('checked')){
                removeValError('#tANDc');
            }
            else{
                $('.chk').find('.frmErrMsg').remove();
                var errElem = '<div class="frmErrMsg">Please select Terms and Conditions.</div>';
                $('.chk').append(errElem);
                scrollToDiv($('.chk'));
                validated= false;
            }
            if(checkGPA(cs['GPA__c'])){
                console.log('grqspt checkGPA::::::::');
                scrollToDiv($(cs["xcnc__c"]));
                validated= false;
            }
            console.log('submit validated:::'+validated);
            if(validated == true){
                console.log('Validated true::::')
                console.log('Program__c::::'+cs['Program__c'].value);
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function assignfldVal(val,fldId){cs[fldId].value=val;}
        function rmErronTC(){
            if($('#tANDc').is(':checked')==true)
                $('.chk').find('.frmErrMsg').remove();
            else{
                var errElem = '<div class="frmErrMsg">Please select Terms and Conditions.</div>';
                $('.chk').append(errElem);
            }
        }
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        </script>                  
        <apex:form id="mainForm" styleClass="form-style">
            <apex:pageBlock id="pbMain">
                <apex:outputPanel id="saveRq"> 
                </apex:outputPanel>
                <apex:actionFunction name="next"  action="{!saveReq}" status="theStatus"  reRender="btnid,errmsg,saveRq,msg" oncomplete="$('#preloader').fadeOut();hideTempLoader_input();loadData_jt();"    onbeforedomupdate="javascript: toggle_inputs();"/>
                <apex:actionFunction name="cancelRq" action="{!CancelR}" reRender="errmsg,msg" oncomplete="toggleGLoader();" />
                <apex:actionFunction name="svRDrft2" action="{!saveDraft}" status="theStatus" rerender="msg"  oncomplete="toggleGLoader();showDraftAlert('{!req.Name}')"/>
                <body class="base">
                    
                    <div id="main">
