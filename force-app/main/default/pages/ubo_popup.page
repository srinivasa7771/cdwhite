    function vflds(clsName){
        var brk = true;var elem = '';
         var ubrk = true;var cbrk = true; var ucnt = 6; var ccnt = 4;
        $(clsName).each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=false; addValError(this,'Value is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{
                    removeValError(this);
                }
                
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        $('.urequiredFld').each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    ubrk=false; ucnt = ucnt-1;
                }else 
                removeValError(this);
            }
        });
        $('.crequiredFld').each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    cbrk=false; ccnt=ccnt-1;
                }else{ removeValError(this);}
            }
        });
        
        if(ubrk == false && cbrk == false && (ucnt > 0 || ucnt == 0) && ccnt == 0 ){
           brk = false;
           $('.urequiredFld').each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=false; addValError(this,'Value is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        }
        else if(ubrk == false && cbrk == false && ucnt == 0 && ccnt > 0 ){
           brk = false;
           $('.crequiredFld').each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=false; addValError(this,'Value is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
         });
