            var exp2=document.getElementById('{!$Component.formId.exp2}');
            if(exp2!='' && exp2!=undefined && exp2!=null)
                isExceptionApplied=exp2.value;
            if(isExceptionApplied=="true" || isExceptionApplied==true){
                var stock=document.getElementById('{!$Component.formId.stock}');
                var isStock=false;
                if(stock!='' && stock!=undefined && stock!=null)
                    isStock=stock.checked;
                
                var gov=document.getElementById('{!$Component.formId.gov}');
                var isGov=false;
                if(gov!='' && gov!=undefined && gov!=null)
                    isGov=gov.checked;
                if(!isStock && !isGov)  {
                    brk=false;
                    //addValError(document.getElementsByClassName('exceptionclass')[0],'Please select at leaset one exception');
                    addValError($('.indvInformation'),'Please select at leaset one exception')
                }
