        <script>
        
        $(document).ready(function(){
            $('#preloader').fadeOut();
            $('.selectPay').unbind().on('click',function(e){
                e.stopPropagation();
                $(this).toggleClass('text-success');
                var v = $(this).attr('val');
                var amt = $(this).attr('amt');
                
                if($(this).hasClass('text-success')){
                    selectedPays.push(v); 
                    pAT = parseFloat(pAT) + parseFloat(amt); 
                    
                }
                else{
                    selectedPays = jQuery.grep(selectedPays, function(value) {
                        return value != v;
                    });
                    
                    pAT = parseFloat(pAT) - parseFloat(amt);
                    if(pAT<=0){ $(this).toggleClass('text-success'); pAT=amt;}
                }
                
                document.getElementById('dvTAT').innerHTML = pAT.toFixed(2)+' AED';
            });
            $("input[name='inside_uae']").on('change',function(){
                
                var payMethod = $('[name="inside_uae"]:checked').val();
                $('.pmDivs').hide();
                $('.mdc').hide();//mkr
                getC('mdcRI').style.display = 'none';
                if(payMethod == 'Customer Deposit'){
                    
                    if(parseFloat(pAT) > parseFloat(ADB)){ 
                        getC('mdcRI').innerHTML='Insufficient customer deposit balance. <a href="/apex/grqn?c=tad">Click here to top-up customer deposit</a>';
                    }
                    else{
                        getC('mdcRI').innerText='Amount '+ pAT + ' AED will be deducted from your portal deposit.';
                    }
                    $('.mdc').show();//mkr
                    $('.chk').show();
                    $('#mdcRI').show();
                }else if(payMethod =="Credit / Debit Card"){
                    getC('mdcRI').innerHTML='Please note<br/><ul><li>We accept all UAE and international credit/debit cards except for cards issued in USA , Canada, Brazil, UK, Germany and France.</li><li>All payments will be done in AED and the customer will bear any currency exchange charges levied by the card issuer when using international credit /debit cards.</li></ul>';
                    $('.mdc').show();//mkr
                    $('.chk').show();
                    $('#mdcRI').show();
                }else if(payMethod == 'Cash'){
                    if(parseFloat(pAT) > 55000){ 
                        axsAlert('Payment Method validation','Maximum cash accepted is AED 55,000.Please choose another payment method to proceed');
                        
                        $( '[name="inside_uae"]' ).prop( "checked", false );
                        return;
                    }else{
                        var cd='{!rq.srvc__r.uid__c }';
                        getC('mdcRI').innerHTML='Please note<br/><ul><li>You have selected to ‘pay by cash’. Please visit our office below:</li><ul><li>axs centre, Building 8, Ground Floor, Dubai Knowledge Park, Dubai, UAE</li><li>axs centre, Service Block, Ground Floor, Dubai International Academic City, Dubai, UAE<br/>Tel: 800 4 axs (297)</li></ul><li>Download your payment advice copy and carry it with you for the payment.</li><li>Maximum cash accepted is AED 55,000.</li><li>Your application will be processed further once the payment is confirmed.</li></ul>';
                        if(cd=='208' || cd=='220' || cd=='dnc'){
                            getC('mdcRI').innerHTML='Please note<br/><ul><li>You have selected to ‘pay by cash’. Please visit our office below:</li><ul><li>axs centre, Building 8, Ground Floor, Dubai Knowledge Park, Dubai, UAE</li><li>axs centre, Service Block,Building 1, Ground floor, Dubai Studio City, Dubai, UAE<br/>Tel: 800 4 axs (297)</li></ul><li>Download your payment advice copy and carry it with you for the payment.</li><li>Maximum cash accepted is AED 55,000.</li><li>Your application will be processed further once the payment is confirmed.</li></ul>';
                        } 
                        $('.mdc').show();//mkr
                        $('.chk').show();
                        $('#mdcRI').show();
                    }
                }
                    else if(payMethod == 'Cheque'){
                        //  $('#chD').show(); $('#acD').show();
                        getC('mdcRI').innerHTML='Please note<br/><ul><li>You have selected to ‘pay by cheque’. Please issue all cheques payable to: <b>AXS FZ LLC</b></li><li>All cheques should be issued in AED, payable in the UAE.</li><li>Your application will be processed further once the payment is confirmed. </li></ul>';
                        $('.mdc').show();//mkr
                        $('.chk').show();
                        $('#mdcRI').show();
                    }
                        else if(payMethod == 'Wire Transfer'){
                            getC('mdcRI').innerHTML='Please note that, you have selected to ‘pay by bank transfer’.For International transfers, kindly ensure to include any extra charges from the banks during the transfer to ensure exact amount is transferred. ';/* Please use details below:</li>Tecom Group LLC<br>Emirates NBD, Dubai, UAE  |  IBAN - EBHD16913154213313  |  </br>SWIFT- ENBDAED<li> Your application will proceed further once the amount is reflected in our accounts, this usually takes up to 5 working days from the transfer date.*/
                            $('.mdc').show();//mkr
                            $('.chk').show();
                            $('#mdcRI').show();
                            $('#wrTf').show(); $('#acD').show();}
                            else if(payMethod == 'Debit Memo'){
                                // getC('mdcRI').innerHTML='Please note<br/><ul><li>You have selected to ‘pay by bank transfer’. Please use details below:</li>Tecom Group LLC<br>Emirates NBD, Dubai, UAE  |  IBAN - EBHD16913154213313  |  </br>SWIFT- ENBDAED<li>Your application will be processed further once the payment is confirmed. </li></ul>';
                                // $('.mdc').show();//mkr
                                $('.chk').show();
                                $('#mdcRI').show();
                            }
                
            });
            
            /*for ni issue - mkr - 16thMar */
            //$('input[value="Credit / Debit Card"]').unbind('change');
            $('.comNum').each(function(){
                $(this).text($(this).text().toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","));
            });
        });
        </script>
