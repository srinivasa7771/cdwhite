                var cs={}; var selectedPays = [];
                cs['datepicker11'] = $('#datepicker11'); 
                var ADB=AD=VAT=0;SC=0;SCV=0;pAT=0;var dvChq,dvBD,dvCD;
                function drawAmount(){var divA=document.getElementById("dvTAT");void 0!=divA&&(divA.innerHTML="AED "+c2s(pAT));}
                
                function sv() {           
                    var msg = '';
                    var payMethod = $('[name="inside_uae"]:checked').val();
                    if ( typeof payMethod === "undefined" || payMethod == "") {
                        axsAlert('Payment Method is Missing','Please choose a payment method to proceed');// refer AXS2CustomJs.js
                        //alert('choose a payment method');
                        return false;
                    }
                    if(payMethod == 'Customer Deposit' && parseFloat(pAT) > parseFloat(ADB)){
                        msg = msg + 'Insufficient customer deposit balance. </br>'
                    }
                    if (payMethod == 'Cheque') {
                        
                        if (cs['datepicker1'].value.trim() == '') {
                            msg = msg + 'Please Provide Cheque Maturity Date. </br>';
                        } else {
                            var dt = cs['datepicker1'].value;
                            var q = dt.split('/');
                            console.log('q>>' + q);
                            var mydate = new Date(q[2], q[1] - 1, q[0]);
                            console.log('mydate>>' + mydate);
                            var today = new Date();
                            var todayDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                            console.log('todayDate>>' + todayDate);
                            if (mydate < todayDate) {
                                msg = msg + 'Please Cheque Maturity Date should be in future. </br>';
                            }
                        }
                        if (cs['cq__c'].value.trim() == '') {
                            msg = msg + 'Please Provide Cheque Number. </br>';
                        }
                        if (cs['Bnk__c'].value.trim() == '') {
                            msg = msg + 'Please Provide Bank Name. </br>';
                        }
                    }
                    if (payMethod == 'Wire') {
                        if (cs['datepicker11'].value.trim() == '') {
                            msg = msg + 'Please Provide Transfer Date. </br>';
                        } else {
                            var dt = cs['datepicker11'].value;
                            var q = dt.split('/');
                            console.log('q>>' + q);
                            var mydate = new Date(q[2], q[1] - 1, q[0]);
                            console.log('mydate>>' + mydate);
                            var today = new Date();
                            var todayDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                            console.log('todayDate>>' + todayDate);
                            if (mydate < todayDate) {
                                msg = msg + 'Please Transfer Date should be in future. </br>';
                            }
                        }
                        if (cs['cq__c1'].value.trim() == '') {
                            msg = msg + 'Please Provide Bank Reference Number. </br>';
                        }
                        if (cs['Bnk__c1'].value.trim() == '') {
                            msg = msg + 'Please Provide Bank Name. </br>';
                        }
                        
                    }
                    if (msg != '') {
                        axsAlert('',msg);
                        //alert(msg);
                        return false;
                    } 
                    
                    document.getElementById('{!$Component.selCtgId}').value = selectedPays.toString(); 
                    document.getElementById('{!$Component.md__c}').value = payMethod; 
                    //confirm("I have reviewed the information and the uploaded documents against this service request. By submission, I take full responsibility for the contents of the form plus documents uploaded and attest that the information on this form and uploaded documents are free of errors. In case of errors, I agree to bear all costs required to rectify any such errors or mistakes.") && "function" == typeof afs && (showgLoader();afs())
                    var cb = "I have reviewed the information and the uploaded document(s) against this service request. By submission, I take full responsibility for the contents of the form plus document(s) uploaded and attest that the information on this form and uploaded document(s) are free of errors. In case of errors, I agree to bear all costs required to rectify any such errors or mistakes."
                    if($('#tANDc').is(':checked')==true){
                        if('{!rq.srvc__r.uid__c}' == '076')
                            cb = 'I hereby confirm that the information provided regarding “final settlement” herein is accurate, correct and complete.  Applicant already paid and received the entire final dues in line with standard norms stipulated in UAE Labour Law and the final settlement document submitted along with this application is genuine.';   
                        
                        axsConfirmation('Please Confirm',cb,true,'afsp'); // refer AXS2CustomJs.js 
                    }
                    else{
                        var errElem = '<div class="frmErrMsg">Please select Terms and Conditions.</div>';
                        $('.chk').append(errElem);
                        scrollToDiv($('.chk'));
                    }
                    
                }
                function rmErronTC(){
                    if($('#tANDc').is(':checked')==true)
                        $('.chk').find('.frmErrMsg').remove();
                    else{
                        var errElem = '<div class="frmErrMsg">Please select Terms and Conditions.</div>';
                        $('.chk').append(errElem);
                    }
                }
                </script>
