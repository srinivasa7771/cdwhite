<apex:page sidebar="false" controller="grCtrlCustProfUp" action="{!getMember}" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true"  standardStylesheets="false" title="{!req.srvc__r.lbl__c}">
    <html>
        <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <apex:includeScript value="{!$Resource.assets_NUI1}"/>
        <!-- << For Back office only >> starts  -->
        
        <apex:outputPanel layout="none" rendered="{!NOT(ispu)}">
