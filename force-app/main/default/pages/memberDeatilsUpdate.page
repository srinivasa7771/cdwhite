                    let value = mobileNumber.toString().trim();

                    // Reject if contains country-code style formatting
                    if (value.includes('-')) {
                        return true; // should not include "-"
                    }

                    // Reject if starts with 0
                    if (value.startsWith('0')) {
                        return true;
                    }

                    // Keep only digits for validation
                    let digitsOnly = value.replace(/\D/g, '');

                    // Check length (E.164 max 15 digits, min 5 for sanity)
                    if (digitsOnly.length < 5 || digitsOnly.length > 15) {
                        return true;
                    }

                    return false;
                }
                function createAdhoc3(){
                    $('select:visible,input:visible').each(function(){
                        var l = $(this).attr('for');
                        if(!l)
                            return;
                        var v = $(this).val();
                        if(typeof(this)=='select'){
                            v = $(this).find('option:selected').text()
                        }
                        if($(this).hasClass('input-datepicker')){
                            v = revertDateFormat(v)
                        }
                        var p = $(this).attr('parent');
                        if(!p){
                            if(v!=originalData[l])
                                updatedData[l] = v;
                        }
                        else{
                            if(!updatedData[p]){
                                updatedData[p]={};
                            }
                            if(v!=originalData[p][l])
                                updatedData[p][l] = v;
                            if(p=='contactDetail' && l=='mobileNumber'){ //1.2
                                let countryCode = document.getElementById('countrycode_rmob__c')?.value || '';
                                let referenceNum = document.getElementById("uaeNumber")?.value || '';

                                if (countryCode && referenceNum) {
                                    // --- Normalize country code ---
                                    if (!countryCode.startsWith('+')) {
                                        countryCode = '+' + countryCode.replace(/\D/g, '');
                                    } else {
                                        countryCode = '+' + countryCode.substring(1).replace(/\D/g, '');
                                    }

                                    // --- Normalize number ---
                                    referenceNum = referenceNum.toString().trim();
                                    referenceNum = referenceNum.replace(/\s+/g, '');  // remove spaces
                                    referenceNum = referenceNum.replace(/-+/g, '');   // remove dashes
                                    referenceNum = referenceNum.replace(/\++/g, '');  // remove stray pluses

                                    // Remove leading country code if user entered it again
                                    if (referenceNum.startsWith(countryCode.replace('+',''))) {
                                        referenceNum = referenceNum.slice(countryCode.length - 1);
                                    }

                                    // Remove leading zeros & keep digits only
                                    referenceNum = referenceNum.replace(/^0+/, '');
                                    referenceNum = referenceNum.replace(/\D/g, '');

                                    // --- Final formatted value ---
                                    updatedData[p][l] = `${countryCode}-${referenceNum}`;
                                }

                                if(cs['isMobilePhoneVerified'] == true || cs['isMobilePhoneVerified'] == 'true'){ //1.3
                                    updatedData[p]['isMobilePhoneVerified']  = true;
                                    if(isMobileNumberUpdated){
                                        updatedData[p]['mobilePhoneVerificationDatetime']  = new Date().toISOString();
                                    }
                                }
                                else{
                                    updatedData[p]['isMobilePhoneVerified']  = false;
                                    updatedData[p]['mobilePhoneVerificationDatetime']  = null;
                                }
                            }

                            if(p=='contactDetail' && l=='emailAddress'){ //1.3
                                if(cs['isEmailVerified'] == true || cs['isEmailVerified'] == 'true'){ //1.3
                                    updatedData[p]['isEmailVerified']  = true;
                                    if(isEmailAddressUpdated){
                                        updatedData[p]['emailVerificationDatetime']  = new Date().toISOString();
                                    }
                                    
                                }
                                else{
                                    updatedData[p]['isEmailVerified']  = false;
                                    updatedData[p]['emailVerificationDatetime']  = null;
                                }
                            }
                            if (p === 'addressDetailsInHomeCountryPermanent' && l === 'mobileNo' && updatedData[p][l]) { //1.2
                                let mobileNo = updatedData[p][l].toString().trim();
                                let countryCode = document.getElementById('countrycode_homecountry__c')?.value || '';

                                if (countryCode && mobileNo) {
                                    // Normalize: remove spaces, multiple dashes, pluses
                                    mobileNo = mobileNo.replace(/\s+/g, '');
                                    mobileNo = mobileNo.replace(/-+/g, '-');
                                    mobileNo = mobileNo.replace(/\++/g, '+');

                                    // Strip country code if already present
                                    if (mobileNo.startsWith(countryCode)) {
                                        mobileNo = mobileNo.slice(countryCode.length);
                                    } else if (mobileNo.startsWith(countryCode.substring(1))) {
                                        mobileNo = mobileNo.slice(countryCode.length - 1);
                                    }

                                    // Remove leading 0s & non-digits
                                    mobileNo = mobileNo.replace(/^0+/, '');
                                    mobileNo = mobileNo.replace(/\D/g, '');
                                }

                                // Final formatted value
                                updatedData[p][l] = countryCode ? `${countryCode}-${mobileNo}` : mobileNo;
                            }
                            
                        }
                    });
                    updatedData['contactDetail']['visitedUAE'] = cs['isVisitedUAE'];
                    updatedData['contactDetail']['firstNameArabic'] =  '{!JSENCODE(firstNameArabic)}';
                    updatedData['contactDetail']['lastNameArabic'] =  '{!JSENCODE(lastNameArabic)}';
                    cs['xadtx3__c'].value = JSON.stringify(updatedData);
                }
