                function replaceAllSpChars(){// need to remove here and update community header
                    $('input[type="text"]:visible,textarea:visible').each(function(){
                        if($(this).hasClass('input-datepicker'))
                            spChrs = ['{','}','<','>',"'",'=','$'];
                        else
                            spChrs = ['{','}','<','>',"'",'=','$','/'];
                        let v = $(this).val();
                        for(s of spChrs){
                            if(v.includes(s)){
                                v = v.replaceAll(s,'');
                                $(this).val(v);
                            }
                        }
                    });
                }
                function checkDate(elem){   /** Override from Axs2Customjs**/
                    var e = $(elem);
                    var type = e.attr('validationname');
                    var date;
                    var date1 = e.val();
                    date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
                    var days = new Date(new Date()-new Date(date))/1000/60/60/24;
                    var msg = '';
                    if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                        msg = 'Please enter a valid date!'
                    }
                    else if(type=='eed'){
                        if(days>0){
                            msg = 'EIDA Expiry shoud be a future date';
                        }
                    }
                    if(msg)
                        addValError(e,msg);
                    else
                        removeValError(e);
                }
