            <apex:stylesheet value="{!URLFOR($Resource.AXS2Assets, '/icomoon/style.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Assets, '/css/style.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Assets, '/css/brand-axs.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/font-awesome/css/font-awesome.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/aos/dist/aos.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/swiper/css/swiper.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/daterangepicker/daterangepicker.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/select2/dist/css/select2.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/easy-autocomplete/dist/easy-autocomplete.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/easy-autocomplete/dist/easy-autocomplete.themes.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/chart.js/dist/Chart.min.css') }" />
            <apex:stylesheet value="{!URLFOR($Resource.AXS2Vendors, '/tempusdominus-bootstrap-4/build/css/tempusdominus-bootstrap-4.min.css') }" />
            <!-- JS -->
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"  />
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/bootstrap/dist/js/bootstrap.bundle.min.js')}"  />
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js')}"  />
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/aos/dist/aos.js')}"  />
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/swiper/js/swiper.min.js')}"  />
            <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/select2/dist/js/select2.min.js')}"  />
            <!-- main js -->
            <apex:includeScript value="{!URLFOR($Resource.AXS2Assets, '/js/script.js')}"  />
            <style>
                body{
                zoom: 75% !important;
                }
                .bodyDiv{background-color:#F5F5F5 !important}
                
                .btn {
                display: inline-block !important;
                font-weight: 500 !important;
                color: #241F28 !important;
                text-align: center !important;
                vertical-align: middle !important;
                cursor: pointer !important;
                user-select: none !important;
                background-color: transparent !important;
                border: 1px solid transparent !important;
                padding: 0.5rem 1rem !important;
                font-size: 0.875rem !important;
                line-height: 1.5 !important;
                border-radius: 1.5rem !important;
                transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out !important;
                background-image: none !important;
                }
                
                .btn-outline-primary,.btn-primary {
                color: #fff !important;
                border-color: #3e528a !important;
                background-color: #3e528a !important;
                }
                
                
                
                .btn-outline-primary:hover, .btn-outline-primary:focus, .btn-outline-primary.focus, .btn-outline-primary:active, .btn-outline-primary:active:focus, .btn-outline-primary:not(:disabled):not(.disabled):active {
                color: #FFF !important;
                background-color: #3e528a !important;
                font-weight: bolder !important;
                }
                
                .upload-field .d-flex{
                }

                .left-margin{
                    margin-left: 5%;
                }

                .hidden {
                    display: none;
                }
            </style>
            
        </apex:outputPanel>
        <style>
            #otpSuccess, #otpMsg, #otpBlock,#resendBtn,#eidaOTPBlock,#otpButtonSuccess{
            display:none;
            }
            #ppMissing,#eidMissing,#ppcfrid,#eidacfrid,#riccfrid{
            color: #e62d38;
            font-weight: bold;
            }
            .box-border-dashed {
            min-height: 121px !important;
            }
        </style>
        <apex:form id="mainForm" styleClass="form-style">
            
            <apex:actionFunction action="{!callSMService}" name="callOTP" reRender="otpPanel" oncomplete="$('#otpBlock').show();$('#otpButtonBlock').hide();" >
            </apex:actionFunction>
            <apex:actionFunction action="{!sendOTP}" name="sendOtp1" reRender="otpPanel" oncomplete="$('#otpBlock').show();$('#otpButtonBlock').hide();callOTP();removeTempLoader();" >
                <apex:param assignTo="{!mobNum}" name="mobileNum" value="" />
            </apex:actionFunction>
            <apex:actionFunction action="{!saveEmail}" name="svEm" reRender="otpPanel" oncomplete="$('#otpBlock').show();$('#otpButtonBlock').hide();removeTempLoader();" >
                <apex:param assignTo="{!conEmail}" name="contactEmail" value="" />
            </apex:actionFunction>
            <apex:actionFunction action="{!validateOtp}" name="validateOtp" reRender="otpPanel,updateBtnPanel" oncomplete="postValidateOtp('{!JSENCODE(otpResult)}');$('#eidaOTPBlock').hide();removeTempLoader();" >
                <apex:param assignTo="{!otpfrmPg}" name="otp" value="" />
                <apex:param assignTo="{!isMobileOTP}" name="isMobOTP" value="" /> <!-- 1.3 -->
            </apex:actionFunction>
            <apex:actionFunction action="{!saveAttachment}" name="saveAtt" reRender="eidMissingInfo,ppMissingInfo,ppCFR,eidaCFR,ricCFR,ppPanel,ricPanel,eidaPanel,submitPanel,updateBtnPanel,tncPanel" oncomplete="removeTempLoader();hideShowVisitedPanal();" /><!--eidMissingInfo-->
            <apex:actionFunction name="removeAttch"  action="{!deleteAttach}" rerender="ppPanel,eidaPanel,ricPanel,submitPanel,updateBtnPanel,tncPanel,ppMissingInfo,eidMissingInfo" oncomplete="enableAllatt();removeEmptyLables();$('#eidaOTPBlock').hide();hideShowVisitedPanal();"><!--eidMissingInfo-->
                <apex:param name="attId" value=""/> 
            </apex:actionFunction>
            <apex:actionFunction name="svRDrft1" action="{!saveDraftR}" status="theStatus" rerender="msg,ricPanel" oncomplete="draftComplete('{!JSENCODE(draftMsg)}')">
                <apex:param assignTo="{!draftIns}" name="dreafIns" value="" />
            </apex:actionFunction>
            <apex:actionFunction name="cancelRq" action="{!CancelR}" reRender="errmsg,msg" oncomplete="toggleGLoader();" />
            <!-- 1.2 -->
            <apex:actionFunction name="submitReq" action="{!submitRequest}" reRender="errmsg,msg" oncomplete="hideGLoader();">
                <apex:param name="mobileNumberJson" value="" assignTo="{!mobileNumberJson}"/>
            </apex:actionFunction>
            
            <apex:outputPanel id="rerenderImage">
                <apex:inputHidden id="xadtx3__c" value="{!req.xadtx3__c}" />
                <apex:inputHidden id="xadtx4__c" value="{!req.xadtx4__c}" />
                <apex:inputHidden id="xoca__c" value="{!req.xoca__c}" />
                <apex:inputHidden id="imageBase64" value="{!imageBase64}" />
                <apex:inputHidden id="docname" value="{!docname}" />
                <apex:inputHidden id="parseId" />
                <script>
                var cs = {};
                cs["imageBase64"] = document.getElementById("{!$Component.imageBase64}");
                cs["docname"] = document.getElementById("{!$Component.docname}");
                cs["parseId"] = document.getElementById("{!$Component.parseId}");
                cs["xadtx3__c"] = document.getElementById("{!$Component.xadtx3__c}");
                cs["xadtx4__c"] = document.getElementById("{!$Component.xadtx4__c}");
                cs["xoca__c"] = document.getElementById("{!$Component.xoca__c}");
                </script>
            </apex:outputPanel>
            <body class="base"> 
                <div id="main">
                    
                    <div class="container pt-2 pb-2">
                        <div class="text-right">
                            <apex:outputPanel >
                                <span class="d-inline-block mr-2 align-middle" style="font-size: 1.875rem;line-height: 1;">
                                    SR # <span class="text-000">{!req.Name} </span>
                                </span>
                            </apex:outputPanel>
                            <c:drftCnclBtns req="{!req}" shwCncl="true" shwDraft="{!IF(AND(OR(req.STA__c=='Draft',req.STA__c=='Open'),!req.xoca__c),true,false)}"/>
                        </div>
                    </div>
                    <div class="container">
                        
                        <div class="base-layout">
                            <!--left-side pannel start-->   
                            <div class="base-side">
                                <div class="base-side-content">
                                    <div>
                                        <c:srvdefcmp srv="{!srv}"/>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="base-main">
                                <div class="base-main-content" id='memBody'>
                                    <b><apex:pageMessages id="msg"  /></b>
                                    <!-- Passport details -->
                                    <div class="base-collapse">
