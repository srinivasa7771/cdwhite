                                                    <div class="col-lg-4">
                                                        <div class="data-info">
                                                            <div class="data-label">First name</div>
                                                            <div class="data-value readOnlyVal" id="" style="pointer-events:none;">
                                                                {!info.contactDetail.firstName}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4">
                                                        <div class="data-info">
                                                            <div class="data-label">Middle name</div>
                                                            <div class="data-value readOnlyVal" id="" style="pointer-events:none;">
                                                                {!info.contactDetail.middleName}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4">
                                                        <div class="data-info">
                                                            <div class="data-label">Last name</div>
                                                            <div class="data-value readOnlyVal" id="" style="pointer-events:none;">
                                                                {!info.contactDetail.lastName}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-lg-4">
                                                        <div class="data-info">
                                                            <div class="data-label">Gender</div>
                                                            <div class="data-value readOnlyVal" id="" style="pointer-events:none;">
                                                                {!info.contactDetail.gender}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4">
                                                        <div class="data-info">
                                                            <div class="data-label">Nationality</div>
                                                            <div class="data-value readOnlyVal" id="" style="pointer-events:none;">
                                                                {!info.contactDetail.Nationality}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="base-collapse">
                                        
                                        <a href="#" class="collapse-toggle" data-toggle="collapse" data-target="#passport_details">
                                            <div class="collapse-title">Passport Details </div>
                                        </a> 
                                        <div id="passport_details" class="collapse show">
                                            <div class="collapse-content">
                                                <apex:outputPanel id="ppMissingInfo">
                                                    <apex:outputPanel rendered="{!AND(info.passportInfo.isExpired,ppAttId=='')}">
                                                        <p id='ppMissing'>
                                                            Passport details are missing/invalid please upload your passport copy
                                                        </p>
                                                    </apex:outputPanel>
                                                </apex:outputPanel>
                                                <apex:outputPanel id="ppCFR">
                                                    <apex:outputPanel rendered="{!AND(CONTAINS(bckOfcCmts,'Missing/Incorrect Passport'),req.STA__c=='Open')}">
                                                        <p id='ppcfrid'>
                                                            Please remove existing document, reupload correct passport.  
                                                        </p>
                                                    </apex:outputPanel>
                                                </apex:outputPanel>
                                                <div class="row">
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group names">
                                                            <label>Passport Number</label>
                                                            <!-- 1.2 -->
                                                            <input parent="passportInfo" class="requiredFld disabledApex form-control input-passportNumber ppDetails" for="passportNumber" value="{!info.passportInfo.passportNumber}" id="ppNum"/>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group names">
                                                            <label>Place of Birth</label>
                                                            <input parent="contactDetail" class="requiredFld form-control input-passportNumber ppDetails" for="placeOfBirth" value="{!info.contactDetail.placeOfBirth}" id="pob"/>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4">
                                                        <div class="form-group">
                                                            <div class="form-group">
                                                                <div class="form-group">
                                                                    <label>Birth Country</label>
                                                                    <select class="requiredFld form-control  input-select2-flat forEdit ppDetails" extFld='type'
                                                                            id="bnat" extFld1='Country Code'  fldName="placeBornCountry" ddaKey="birthCountry" parent="contactDetail" for="birthCountry" value="{!info.contactDetail.birthCountry}" >
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group names">
                                                            <label>Passport Issued Place</label>
                                                            <input parent="passportInfo" class="requiredFld disabledApex form-control input-passportNumber ppDetails" for="passportIssuePlace" value="{!info.passportInfo.passportIssuePlace}" id="pip"/>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group">
                                                            <label>Passport Issue Date</label>
                                                            <div class="input-datepicker-group input-group">
                                                                <input for="passportIssueDate" type="text" class="disabledApex requiredFld form-control input-datepicker ppDetails" id="pid"
                                                                       data-toggle="datetimepicker" parent="passportInfo" data-target="#pid" onchange = "checkDate(this,'pid');" validationname="pid" />
                                                                <script type="text/javascript">
                                                                dformat('{!JSENCODE(info.passportInfo.passportIssueDate)}','pid');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="disabledApex btn text-primary" type="button" data-toggle="datetimepicker" data-target="#pid">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group">
                                                            <label>Passport Expiry Date</label>
                                                            <div class="input-datepicker-group input-group">
                                                                <input for="passportExpiryDate" type="text" class="disabledApex requiredFld form-control input-datepicker ppDetails" id="ped"
                                                                       data-toggle="datetimepicker" parent="passportInfo" data-target="#ped" onchange = "checkDate(this,'ped');" validationname="ped" />
                                                                <script type="text/javascript">
                                                                dformat('{!JSENCODE(info.passportInfo.passportExpiryDate)}','ped');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="disabledApex btn text-primary" type="button" data-toggle="datetimepicker" data-target="#ped">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group">
                                                            <label>Date of birth</label>
                                                            <div class="input-datepicker-group input-group">
                                                                <input for="dateOfBirth" type="text" class="requiredFld form-control input-datepicker" id="dob"
                                                                       data-toggle="datetimepicker" parent="contactDetail" data-target="#dob" onchange = "checkDate(this,'dob');" validationname="dob" />
                                                                <script type="text/javascript">
                                                                dformat('{!JSENCODE(info.contactDetail.dateOfBirth)}','dob');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="disabledApex btn text-primary" type="button" data-toggle="datetimepicker" data-target="#dob">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row row-lg">
                                                    <apex:outputPanel id="ppPanel" styleClass="col-lg-6">
                                                        <div forLoad="Passport Copy" id="ppDoc" class="box box-block mb-lg-4 box-border-dashed">
                                                            <label class="fs-18">Passport Copy</label>
                                                            <span class="loader_img" style="float:right;display:none">
                                                                <img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />
                                                            </span>
                                                            <apex:outputPanel rendered="{!ppAttId != ''}">
                                                                <div class="upload-list">
                                                                    <div class="upload-list-item box box-white box-padding">
                                                                        <i class="fa fa-check-circle text-success"></i>
                                                                        <a href="#" class="upload-item-title text-li" onclick="filePreview('Passport Copy','/servlet/servlet.FileDownload?file={!ppattId}');" ><u>Passport Copy</u></a>
                                                                        <a style="{!IF(OR(req.STA__c=='Draft',AND(bckOfcCmts!='',req.STA__c=='In Process')),'display:none;','')}" onclick="removeAttch1('{!JSENCODE(ppAttId)}','Passport Copy');"  class="aBtn upload-item-remove"><i class="fa fa-close"></i></a>
                                                                    </div>
                                                                </div>
                                                            </apex:outputPanel>
                                                            <apex:outputPanel rendered="{!ppAttId==''}" >
                                                                <div class="upload-field d-flex">
                                                                    <div
                                                                         class="upload-field-drop-area box box-white box-padding flex-fill d-flex mr-2 mb-0 text-000">
                                                                        <i class="icon-upload-cloud fs-18 mr-2 mt-1"></i>
                                                                        <span>Choose File to Upload<!--&nbsp;<span class="loader_img"></span>--></span>
                                                                    </div>
                                                                    <div>
                                                                        <a onclick="mobileNumValidate('Passport Copy','true')" class="btn btn-outline-primary btn-outline-primary-3 fff-Font-hover">BROWSE</a>
                                                                    </div>
                                                                </div>
                                                            </apex:outputPanel>
                                                        </div>
                                                        <script>
                                                        var ppAttId = '{!JSENCODE(ppAttId)}';
                                                        </script>
                                                    </apex:outputPanel>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="base-collapse">
                                        
                                        <apex:outputPanel id="eidMissingInfo" >
                                            <apex:outputPanel rendered="{!AND(info.emiratesIdInfo.isExpired,EIDAttId=='')}">
                                                <p id='eidMissing'>
                                                    Emirates ID details are missing/invalid please upload your Emirates id copy
                                                </p>
                                            </apex:outputPanel>
                                        </apex:outputPanel>
                                        <a href="#" class="collapse-toggle" data-toggle="collapse" data-target="#eida_details">
                                            <div class="collapse-title">EIDA Details </div>
                                        </a> 
                                        <apex:outputPanel id="eidaCFR">
                                            <apex:outputPanel rendered="{!AND(CONTAINS(bckOfcCmts,'Missing/Incorrect EIDA'),req.STA__c=='Open')}">
                                                <p id='eidacfrid'>
                                                    Please remove existing document, reupload correct Emirates ID.   
                                                </p>
                                            </apex:outputPanel>
                                        </apex:outputPanel>
                                        <apex:outputPanel id="panelEID" styleClass="row">
                                            <p class="chk1" style="vertical-align: middle;font-size: 1em;">
                                                <label class="custom-checkbox mr-4">
                                                    <input type="checkbox" id="eidC" onchange="eidValidations();" />
                                                    <span class="">
                                                        Do you have a valid residence visa?
                                                    </span>
                                                </label>  
                                            </p>
                                        </apex:outputPanel>
                                        <div id="eida_details" class="collapse show">
                                            <div class="collapse-content">
                                                <div class="row">
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group names">
                                                            <label>EIDA Number</label>
                                                            <input parent="emiratesIdInfo" for="emiratesIdNumber" class="disabledApex form-control" value="{!info.emiratesIdInfo.emiratesIdNumber}" id="eidNum"/>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group">
                                                            <label>EIDA Issue Date</label>
                                                            <div class="input-datepicker-group input-group">
                                                                <input for="emiratesIdIssueDate" parent="emiratesIdInfo" type="text" class="disabledApex form-control input-datepicker" id="eid"
                                                                       data-toggle="datetimepicker" data-target="#eid" onchange = "checkDate(this)" validationname="eid" />
                                                                <script type="text/javascript">
                                                                dformat('{!JSENCODE(info.emiratesIdInfo.emiratesIdIssueDate)}','eid');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="disabledApex btn text-primary" type="button" data-toggle="datetimepicker" data-target="#eid">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4" style="">
                                                        <div class="form-group">
                                                            <label>EIDA Expiry Date</label>
                                                            <div class="input-datepicker-group input-group">
                                                                <input for="emiratesIdExpiryDate" parent="emiratesIdInfo" type="text" class="disabledApex form-control input-datepicker" id="eed"
                                                                       data-toggle="datetimepicker" data-target="#eed" onchange = "checkDate(this)" validationname="eed" />
                                                                <script type="text/javascript">
                                                                dformat('{!JSENCODE(info.emiratesIdInfo.emiratesIdExpiryDate)}','eed');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="disabledApex btn text-primary" type="button" data-toggle="datetimepicker" data-target="#eed">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
