                function dformat1(dt){
                    var d = new Date(new Date(dt).toLocaleString('en-us',{ timeZone: 'Asia/Dubai' }));
                    var m=d.getMonth()+1;
                    var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
                    var mm=m>9?m:'0'+m;
                    var yy=d.getFullYear();
                    return dd+'/'+mm+'/'+yy;
                }
