                function updateMobileFields(mobileNumber, countryCodeId, mobilePhoneId) { //1.2
                    if (!mobileNumber) return;

                    let mobileText = mobileNumber.toString().trim();

                    //Normalize - remove spaces, collapse multiple plus/dash
                    mobileText = mobileText.replace(/\s+/g, '');
                    mobileText = mobileText.replace(/-+/g, '-');
                    mobileText = mobileText.replace(/\++/g, '+');

                    //Replace all leading 00 with +
                    mobileText = mobileText.replace(/^0+/, ''); 

                    let countryCode = '';
                    let number = '';

                    //Detect explicit country code at start
                    let match = mobileText.match(/^\+(\d{1,4})/); // country code = + followed by up to 4 digits
                    if (match) {
                        countryCode = `+${match[1]}`;
                        number = mobileText.slice(countryCode.length);
                    } else {
                        number = mobileText;
                    }

                    if (countryCode) {
                        let plainCode = countryCode.replace('+', '');
                        number = number.replace(new RegExp(`\\+?${plainCode}`, 'g'), '');
                    }
                    
                    // Clean number
                    number = number.replace(/[^0-9]/g, ''); // keep only digits
                    number = number.replace(/^0+/, '');     // remove leading zeros

                    let formatted = countryCode ? `${countryCode}-${number}` : number;

                    const phoneInput = document.getElementById(mobilePhoneId);
                    const countryCodeInput = document.getElementById(countryCodeId);
                    const countryCodeSpan = document.getElementById(`select2-${countryCodeId}-container`);

                    if (phoneInput) phoneInput.value = number;
                    if (countryCodeInput && countryCode) countryCodeInput.value = countryCode;
                    if (countryCodeSpan && countryCode) countryCodeSpan.innerHTML = countryCode;

                    return formatted;
                }
