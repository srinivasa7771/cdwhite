<apex:page controller="rqSummary" applyBodyTag="false"  sidebar="false" showHeader="false" renderAs="PDF" >

    <style type="text/css" media="print">
        
      @page {
            margin: 1.8cm 1cm;
            size: A4;
            padding: 10px;
            @top-left {content: element(header);}
            @bottom-left {content: element(footer);}
            @bottom-right {content: "Page " counter(page) " of " counter(pages);}
            }
            div.header{
            position: running(header);
            padding:5px 7px;
            }
            body { font-family: 'Arial Unicode MS'; }
            .imgContainer img {
            width: 100%;
            }
           
            .empVals div {
            margin: 2px 0 0 0;
            position: relative;
            padding-top: 11px;
            min-height:13px;
            /*margin: 4px 0 0 0;*/
            }
            
            .container{
                position:absolute;
                margin-top: 15px;
            }
            .sign{
            height:38px;
            width:100%;
            }
            .pgHead{
            color:blue;
            font-weight:bold;
            border-bottom: 1px solid black;
            }
            p,li{
            font-size:12px;
            }
            ol { counter-reset: item }
            li { display: block;padding:5.4px 0 5.4px 0; }
            li:before { content: counters(item, ".") ") "; counter-increment: item; }
        
    </style> 
