<apex:page cache="false" controller="gctlPortalAlert" action="{!AccountDetails}"  docType="html-5.0" standardStylesheets="false"  showHeader="false" sidebar="false">
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"  />
    <apex:includeScript value="{!$Resource.jsH}"/>
    <apex:includeScript value="{!$Resource.eiJS}"/>
    <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
    <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
    <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
     <link rel="icon" href="./favicon.ico" />
    <!-- vendors -->
    <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/font-awesome/css/font-awesome.min.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/aos/dist/aos.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/swiper/css/swiper.min.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/enjoyhint.css')}" />

    <style>
    
        .ddaColor{
        color:#0d3c79 !important;
        }
        body {
        background-color: #ffffff !important;
        }
    </style>

    <!-- icons -->
    <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/fonts/icomoon/style.css')}" />
    <!-- main css -->
    <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/style.css')}" />
    
    <apex:outputPanel rendered="{!aPark == 'Dubai Media City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dmc.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Internet City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dic.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai International Academic City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dia.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Knowledge Park'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dkp.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Outsource City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-doc.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Studio City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dsc.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Design District'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-ddd.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Production City'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dpc.css') }" />
    </apex:outputPanel>
    <apex:outputPanel rendered="{!aPark == 'Dubai Science Park'}">
        <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/brand-dsp.css') }" />
    </apex:outputPanel>
    <apex:form >
        <apex:actionFunction name="updateAlertConfirmation_UserJS" action="{!updateAlertConfirmation_User}" reRender="dummy" />
        
        
        
        <div style="">
            <h2 class="modal-title mb-4 content-center text-center ddaColor">
            <b>Dubai Development Authority: Circular 631</b>
        </h2>
        <p style="font-size: 1.2rem;">
            Updating Company Information and Status in Compliance with
            Federal Decree Law No (55) of 2023 and its Executive Regulations
        </p>
        <div id='alert_content'>
            <p>Dear Valued Business Partner,</p>
            <p>
                With reference to
                <u>
                    <a class="ddaColor" href='https://dda.gov.ae/-/media/0195B51CE9234F939EEAF6CEE3286DB8.pdf' target='_blank'>
                        Circular 630
                    </a>
                </u>
                issued by Dubai Development Authority on the obligations and
                requirements set out under Federal Decree-Law No. (55) of 2023 regarding media regulation
                and its executive regulations, and with the aim of contributing to the development of the UAE’s
                media sector, we request you to provide certain information via this
                <u>
                    <a class="ddaColor" href='https://msurvey.government.ae/survey/UAE_Media_Council/mgR' target='_blank'>
                        online form
                    </a>
                </u>
                issued by the UAE Media Council.
            </p>
            <p>
                We also wish to remind you to take any action necessary to adjust your status in line with the
                applicable laws and regulations within a maximum period of seven (7) working days from the
                date of this circular to avoid any potential regulatory infringement or breach.
            </p>
            <p>Regards,</p>
            <p>
                <b>Dubai Development Authority</b>
            </p>
            
        </div>
        <p class="chk" style="vertical-align: middle;font-size: 1em;">
            <label class="custom-checkbox mr-4 data-value">
                <input type="checkbox" id="tANDc" onchange="chkTC()" />
                <span class="">I acknowledge receipt of the Circular and will take the necessary actions as required.</span>
            </label>
        </p>
        <p class="col-xl-12 col-lg-12" style="text-align: right;">
            <button data-dismiss="modal" class="disabledApex col-2 btn btn-outline-primary mr-2" id="close_alert" onclick="closePortalAlert()">CONFIRM</button>
            <br />
        </p>
        </div>
        <script>
        function closePortalAlert(){
            window.parent.closeportal_alert();
            //$('#modal_portal_alert').modal('hide'); 
            updateAlertConfirmation_UserJS();
        }
        function chkTC(){
            if($('#tANDc').is(':checked')==true){
                $('#close_alert').removeClass('disabledApex');
            }
            else
                $('#close_alert').addClass('disabledApex');
        }
        </script>
    </apex:form>
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/bootstrap/dist/js/bootstrap.bundle.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/aos/dist/aos.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/swiper/js/swiper.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/moment/min/moment.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/daterangepicker/daterangepicker.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/select2/dist/js/select2.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/easy-autocomplete/dist/jquery.easy-autocomplete.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/chart.js/dist/Chart.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/tempusdominus-bootstrap-4/build/js/tempusdominus-bootstrap-4.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/tablesorter/dist/js/jquery.tablesorter.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery.scrollto/jquery.scrollTo.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/kinetic.min.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/enjoyhint.min.js')}"  />
    <!-- main js -->
    <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js')}"  />
    <apex:includeScript value="{!URLFOR($Resource.AdnicPopup, '/js/jquery.cookie.js')}" />
</apex:page>