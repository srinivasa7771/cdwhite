<apex:page standardController="g_Req__c" sidebar="false" showHeader="false" applyBodyTag="false" renderAs="pdf" extensions="FitOut_ContractorAppCont" action="{!fetchContData}">
    
    <head>     
        <style>
            p{
            font-size:16px;
            text-align: left;  
            font-family:'Segoe UI', Tahoma, sans-serif;
            }
        </style> 
    </head>
    <body>
        
        <div class="container">
            <div class="firstPage">
               
                <p>Date:06/11/2024</p>
                <p><strong>To </strong></p>
                <p><strong>Dubai Development Authority (DDA) &amp; TECOM Group</strong></p>
                <p><strong>Building Name :{!buildingName} </strong></p>
                <p><strong> Property Unit No. : {!PropertyUnit}</strong></p>
                <p><strong>Subject : PROPOSED FIT-OUT WORKS - CONTRACTOR APPOINTMENT</strong></p>
                <p>Dear Sir,</p>
                <p style="line-height: 200%;">We hereby confirm that M/s. <Strong>{!fitOutReq.xcfan__c}</Strong> are appointed as the Fit-out Contractor for our above premises, to carry out the proposed Fit-out works in accordance with the process, requirements and guidelines of TECOM, DDA and other local authorities. </p>                
                <p style="line-height: 200%;">We request you to extend your cooperation in this regard and facilitate necessary review and approvals. Thank you. </p>
                <p>Yours faithfully, </p><br/><br/><br/><br/>
                <p>(Signature)</p>
                <p>Name</p>
                <p>Position</p>
                <p><strong>Company Name</strong></p>
                <p>(Company Stamp)</p>
            </div>
        </div>
