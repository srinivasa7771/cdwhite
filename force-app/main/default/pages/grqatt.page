        <script type="text/javascript">
        
        //Validation  for UAE Mobile Number
        function isUAEMobNum(elem){
            var mob = $(elem).val();
            // var regex = /^(?:\+971|00971|0)((?:50|52|54|55|56|58)[0-9]{7,})$/;
            var regex = /^((?:50|52|54|55|56|58)[0-9]{7,})$/;
            var r = (regex.test(mob))?true:'invalid';
            if(r == 'invalid'){
                addValError($(elem).parent(),'Please enter a valid UAE mobile number');
                return false;
            }else{
                removeValError(elem);     
            }
        }
        
        function checkEmail(elem){  /**Ex: <input type="text" onchange="checkEmail(this)" />**/
            
            var email = $(elem).val();
            var regex = /^[-a-z0-9~!$%^&*_=+}{\'?]+(\.[-a-z0-9~!$%^&*_=+}{\'?]+)*@([a-z0-9_][-a-z0-9_]*(\.[-a-z0-9_]+)*\.(aero|arpa|biz|com|coop|edu|gov|info|int|mil|museum|name|net|org|pro|travel|mobi|[a-z][a-z])|([0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}))(:[0-9]{1,5})?$/;
            var r = (regex.test(email))?true:'invalid';
            if(r == 'invalid'){
                addValError($(elem).parent(),'Please enter a valid Email Address.');
                return false;
            }else{
                removeValError(elem);     
            }
        }
        
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                $(thisElement).addClass("is-invalid");
                return false;    
            }else{
                removeValError(thisElement);  
                $(thisElement).removeClass("is-invalid");
                return r;
            }
        }
        
