        <script type="text/javascript">
        function changeLabel(elem,val){
            $(elem).parent().find('label').html(val);
        }
        var GCC_Nations = ['Bahrain', 'Kuwait', 'Oman', 'Qatar', 'Saudi Arabia', 'United Arab Emirates'];
        var cs = {};
        function dformat(dt,id){
            var d = new Date(dt);//alert(d);
            var m=d.getMonth()+1;
            var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
            var mm=m>9?m:'0'+m;
            var yy=d.getFullYear();
            document.getElementById(id).value=dd+'/'+mm+'/'+yy;
        }
        function checkPassportnumber(passportId){
            addWarningMsg(passportId,'Please make sure you re-upload your passport');
        }
        $(document).ready(function() {
            changecodes = {'cr':'xcrlg__c','dbc':'xcbd__c','ntc':'xcp__c,xcpic__c,xcpid__c,xcped__c,xcpip__c,xcnc__c','np':'xcp__c,xcpic__c,xcpid__c,xcped__c,xcpip__c','pc':'xcmbs__c,xcma__c,xcmta__c,xcmoa__c','msc':'xcms__c'};            
            //Disabling  fields
            if(cs['xard__c'].value ==  true){
                let flds = ['#spokenLng','#xcbd__c',cs['xcbc__c'],cs['xcbp__c'],cs['xcnc__c'],cs['xcnp__c'],cs['xcrlg__c']];
                flds.forEach(function(i){ 
                    //$(i).val()!=null && $(i).val()!='' && $(i).val()!==void 0?$(i).attr('disabled',true):'';
                    $(i).attr('disabled',true);
                });
            }
            
            let flds1 = [cs['xeidav__c']];  
            flds1.forEach(function(i){   
                $(i).parent().parent().hide();   
            }); 
            hr();
            mr();
            $('[value="Married"]').prop('checked',true);
            cs['xcms__c'].value = 'Married';
            $("input[name='martialStatus']").attr('disabled',true);
            $("input[name='salutation']").attr('disabled',true);
            $(cs['xcp__c']).attr('onchange','checkPassportnumber(this)');
            changeLabel(cs['xceml__c'],"Applicant's email");
             $('#appMobile').html('Applicant&#180;s mobile');
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z ]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
            var val = cs['xadh__c'].value;
            var codes = val.split(";");
            console.log('codes::::'+codes);
            setTimeout(function(){
                $('.ddValidation').on('change',function(){
                    $('select').on('change',function(){
                        var v = $(this).val();
                        if(v!=''&&v!='--None--'&&v!='select'&&v!=undefined)    
                            removeValError($(this));
                    });
                });
                
                $('select').on('change',function(){
                    var v = $(this).val();
                    if(v!=''&&v!='--None--'&&v!='select'&&v!=undefined)    
                        removeValError($(this));
                });
            },3000);
        });
        
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);  
                addValError(thisElement,'Please enter a valid Date(DD/MM/YYYY)');
                return false;   
            }else{
                removeValError(thisElement);  
                return r;
            }
        }
        //Add validation error
        function addValError(thiselem,message){
            var elem = $(thiselem);
            elem.parents('.form-group').eq(0).find('.frmErrMsg').remove();
            var errElem = '<div class="frmErrMsg">'+message+'</div>';
            elem.parents('.form-group').eq(0).append(errElem);
        }
        //Remove validation error
        function removeValError(thiselem){
            var elem = $(thiselem);
            elem.parents('.form-group').eq(0).find('.frmErrMsg').remove();
        }
        //Validate Basic salary
        function validateBasicSalary(thiselem){
            var sal = $(thiselem).val();
            if(sal < 1000){ 
                addValError(thiselem,'Minimum basic salary should be AED 1000.','salVal');
                return false;
            }else{
                // $(thiselem).parent().find('.frmErrMsg').remove();
                removeValError(thiselem);
            }
        }
        //Add  warning message
        function addWarningMsg(thiselem,message){
            console.log('addWarningMsg:::');
            var elem = $(thiselem);
            var warElem = '<div class="warningMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(warElem);
            }else{
                elem.parent().append(warElem);
            }
        }
        //Remove warning error
        function removeWarningMsg(thiselem){
            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
            //elem.parent().find('.warningMsg').remove();
        }
        //Validation for current Nationality if it is syria
        function validateCurrenNationality(thisElement){
            var curNat = $(thisElement).val();
            if(curNat == 'Syria'){
               // addValError(thisElement,'Applicants should be in country, salary should be above 10,000 AED, and job title should be Manager or Above.');
               // return false;
            }else{
                removeValError(thisElement);     
            }
        }
        //Validation  for UAE Mobile Number
        function isUAEMobNum(elem){
            var mob = $(elem).val();
            var regex = /^((?:50|52|54|55|56|58)[0-9]{7})$/;
            var r = (regex.test(mob))?true:'invalid';
            if(r == 'invalid'){
                addValError(elem,'Please enter a valid UAE mobile number');
                return false;
            }else{
                removeValError(elem);     
            }
        }
        //validate mobile number
        function checkMob(thisElem){
            var mobNo = $(thisElem).val();
            if(mobNo.length < 10){
                addValError(thisElem,'Please enter valid mobile Number!!');
            }else{
                removeValError(thisElem);    
            }
        }
        
        
        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //Validate Data on click of next button
        function validateData(){
            var elem = '';
            var validated  = true;
            var val = cs['xadh__c'].value;
            var codes = val.split(";")
            
            $('.requiredFld').each(function(){
                
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    console.log('field::::::'+$(this).attr('id'));
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            if(codes.includes('ntc')){
                if(cs['Nationality'].value == cs['xcnc__c'].value){
                    validated = false;
                    addValError(cs["xcnc__c"],'Old and new Nationality should not be same.');
                    //    addValError($('#xcnc__c').parent(),'Old and new Nationality should not be same.');
                }
                if(cs['ppNo'].value == cs['xcp__c'].value){
                    validated = false;
                    addValError(cs["xcp__c"],'Old and new passport numbers should not be same.');
                }
            }
            if(codes.includes('np')){
                if(cs['ppNo'].value == cs['xcp__c'].value){
                    validated = false;
                    addValError(cs["xcp__c"],'Old and new passport numbers should not be same.');
                }
            }
            console.log('validateData2:::::'+validated);
            if(codes.includes('cr')){
                if(cs['religion'].value == cs['xcrlg__c'].value){
                    validated = false;
                    addValError(cs["xcrlg__c"],'Old and new Religion should not be same.');
                }       
            }
            if(codes.includes('dbc')){
                if(getFormattedDate(cs['dob'].value) == cs['xcbd__c'].value){
                    validated = false;
                    addValError($("#xcbd__c"),'Corrected Date of Birth should not be same as old value.');
                }       
            }
            console.log('validateData3:::::'+validated);
            if(codes.includes('msc')){
                if(cs['marSta'].value == cs['xcms__c'].value){
                    validated = false;
                    $("input[name='martialStatus']").parent().parent().parent().find('.option-error').html('Corrected Martial status should not be same').show();
                }       
            }
            console.log('validateData4:::::'+validated);
            if(codes.includes('nc')){
                if((cs['fName'].value == cs['xcfn__c'].value) && (cs['mName'].value == cs['xcmn__c'].value) && (cs['lName'].value == cs['xcln__c'].value)){
                    validated = false;
                    addValError(cs["xcfn__c"],'Correction of Name should not be same as old value');
                }       
            }
            console.log('validateData5:::::'+validated);
            
            var salutation = $("input[name='salutation']:checked").val();
            var martialStatus = $("input[name='martialStatus']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            //alert('salutation v:'+validated);
            if(martialStatus == undefined){
                $("input[name='martialStatus']").parent().parent().parent().find('.option-error').show();
                //alert('Please select martial status');
                validated =false;
            }//alert('martialStatus v:'+validated);
            
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            
            console.log('submit validated:::'+validated);
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                //   console.log('note:::'+cs['xcma__c'].value);
                //  console.log('Issue Date:::'+cs['xcpid__c'].value);
                //console.log('Expiry Date:::'+cs['xcped__c'].value);
                //console.log('DOB:::'+cs['xcbd__c'].value);
                next();
                //alert("Req Updated::::::::::"); 
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
