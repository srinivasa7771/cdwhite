                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- .col -->
                                                    
                                                    <div class="col-md-8">
                                                        <div class="form-group">
                                                            <label>For visa applications, enter your service request or passport number</label>
                                                            
                                                            <div class="form-group">
                                                                <apex:inputText value="{!searchstring}" label="Input"  styleClass="form-control input-search"   />
                                                            </div>
                                                            <div>
                                                                <apex:outputText rendered="{!codeCheck==false}" >
                                                                    <div class="g-recaptcha mb-3" data-sitekey="{!sitekey}" ></div><!--style="transform:scale(0.90);"-->
                                                                    <script src='https://www.google.com/recaptcha/api.js'>
                                                                    </script>
                                                                </apex:outputText>
                                                            </div>
                                                            <input type="button" value="SEARCH" onclick="search1();" class="btn btn-primary" style="background-color: #434b7f;border-color:#434b7f;{!IF(codeCheck==false,'','display:none;')}"  />
                                                            <!--<apex:commandButton value="SEARCH" action="{!search}" styleClass="btn btn-primary" style="background-color: #434b7f;border-color:#434b7f;" rendered="{! codeCheck==false }"    />-->
                                                        </div>
                                                        <!-- .form-group -->
                                                    </div>
                                                    <!-- .col -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- .row -->
                                </div>
                                <!-- .panel-body -->
                            </div>
                            <!-- .panel-login -->
                        </div>
                        <!-- .container -->
                    </div>
                    
                    <div class="site-footer-wrapper">
                        <div class="container">
                            <div class="site-footer {!IF(pk='','site-footer1','')}"> 
                                <div class="footerImg d-none d-lg-block d-xl-block" style="{!IF(pk!='','display:none !important;','')}">
