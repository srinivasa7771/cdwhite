                                                                </label>
                                                            </div>
                                                            <div class="ml-auto">
                                                                <a target="_blank" href="https://axsstg-axs.cs113.force.com/secur/forgotpassword.jsp?locale=us&amp;startURL=%2Fapex%2Fgpm">Forgot Password?</a>
                                                            </div>
                                                        </div>
                                                        <apex:commandButton action="{!login}" value="SUBMIT" style="{!IF(pk=='','background-color: #434b7f;border-color:#434b7f;','')}" styleClass="btn btn-primary" />
                                                        <!-- .form-group -->
                                                    </div>
                                                    <!-- .col -->
                                                </div>
                                            </div>
                                        </div>
                                        <div class="accordion-item open tab-pane fade" id="status_tab">
                                            <div class="accordion-toggle">
                                                <!--<a href="#" class="collapsed" data-toggle="collapse" data-target="#status_collapse">
                                                    STATUS &amp; ACTIONS
                                                    <i class="fa fa-angle-down"></i>
                                                </a>-->
                                            </div>
                                            <div id="status_collapse" class="accordion-content collapse show" data-parent="#app_accordion">
                                                
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <div class="login-left">
                                                            <div class="login-brand" style="{!IF(pk!='','cursor:pointer;','display:none;')} background-image:url({!URLFOR($Resource.axs2_login_logo)})" onclick="loginClick(this)"></div>
                                                            <div class="login-brand" style="{!IF(pk!='','display:none;','')} background-image:url({!URLFOR($Resource.axs2_login_logo)});" ></div>
                                                            <div class="login-brand-shadow"></div>
