        <script type="text/javascript">
        var tempValue ='';
        tempValue = '{!JSENCODE(pk)}';
        var brands = ['diac','dic','dic2','dkp','dmc','doc','dpc','dsp','dsc','ddd','dia'];
        var brandLogoSrc="{!URLFOR($Resource.assets_NUI, '/images/brands/diac.jpg')}";
        var images = [];
        var websites = {'dmc':'https://dmc.ae/','dsc':'https://www.dsc.gov.ae/','dia':'https://www.diadubai.com/','dic':'https://dic.ae/','dic2':'https://dubaiindustrialcity.ae/','doc':'https://dubaioutsourcecity.ae/','dpc':'https://dpc.ae/','dkp':'https://dkp.ae/','ddd':'https://www.dubaidesigndistrict.com/','dsp':'https://dsp.ae/','in5':'https://infive.ae/'};
        function loginClick(e){
            var bg = $(e).css('background-image');
            if(tempValue=='')
                return;// not clicking for common page
            window.open(websites[tempValue],'_blank');
        }
        function preload() {
            for (i =0; i<preload.arguments.length; i++) {
                images[i] = new Image();
                images[i].src = preload.arguments[i];
            }
        }
        $("link.user").each(function(){
            var h = $(this).attr('href');
            if(h.indexOf('style')<0)
                $(this).attr('disabled','disabled');
        });
        var cssLink = $('#brandCss').attr('href').replace('brand-dmc','brand-'+tempValue);
        $('#brandCss').attr('href',cssLink);
        $(document).ready(function(){
            if (!String.prototype.includes) {
                String.prototype.includes = function() {
                    return String.prototype.indexOf.apply(this, arguments) !== -1;
                };
            }
            //tempValue = '{!JSENCODE(pk)}';
            var url;
            var logUrl;
            if(tempValue!=''){
                //brandLogoSrc = ['ddd','dsc','dia'].includes(tempValue)?"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".png')}":"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".jpg')}";
                if(tempValue!='dmc')
                    url= "url('"+"{!URLFOR($Resource.assets_NUI, '/images/brands/header/"+tempValue+"headerbg.jpg')}"+"')";
                //else
                //  url= "url('"+"{!URLFOR($Resource.assets_NUI, '/images/full-bg.jpg')}"+"')";
                logUrl = "url('"+"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".png')}"+"')";
                //$('#main_login').css('background-image',url);
                $('.login-brand').css('background-image',logUrl);
            }
        });
        function getUrlParameter(key){
            var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
            return (res==undefined)?'':res[1];
        }
        function search1(){
            search2();
        }
        </script>
        <apex:form >
            <apex:actionFunction name="search2" action="{!search}" />
            <!--<apex:inputHidden value="{!CurrentPage.parameters.brand}" id="brandVal"/>-->
