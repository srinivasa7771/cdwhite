        <style>
            
            
            @media (max-width: 767.98px){
            #main_login{background-image:linear-gradient(#434b7f, #77c1ea)!important;
            }
            }
            @media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
            #main_login .site-main-content {
            /*min-height: 85vh;*/
            min-height: calc(100vh - 136px);
            }
            #main_login .site-main-content1 {
            min-height: calc(100vh - 56px);
            }
            .site-footer-wrapper{
            position:relative;
            bottom:0px;
            height:90% !important;
            }
            }

            /* VMKR - 24th Dec */
            .footer-images img {
            margin: 0px 1.6em;
            width: 6em;
            }
            .footer-images {
            text-align: left;
            padding: 0 1em;
            }
            @media (min-width: 576px){
                
                /* VMKR - 12th Jan */
                .panel.panel-login1 {
                border-radius: 3rem;
                margin-left: 40%;
                width: 56% !important;
                }
                .site-footer {
                padding:1rem !important;
                }
                .panel-login {
                width: 50% !important;
                }
            .login-brand{width:70% !important;}
            }
            /* For Status Check */
            
            .nav-tabs .nav-link {
            background-color: #52c3ef;
            font-size: 2.2em;
            /* padding: 1px 12px; */
            }
            
            .nav-tabs .nav-link:nth-child(0) {
