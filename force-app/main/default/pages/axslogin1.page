                                                                <img src="{!URLFOR($Resource.assets_NUI, '/images/logo-axs.png')}"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- .col -->
                                                    
                                                    <div class="col-md-8">
                                                        <div class="form-group">
                                                            <label>Username (Email)</label>
                                                            <div class="input-group">
                                                                <div class="input-group-append"><i class="input-group-text icon-username text-primary"></i></div>
                                                                <apex:inputText styleClass="form-control input-login input-login-username text-primary" style="color: #000 !important;" value="{!username}" id="username"/>
                                                            </div>
                                                        </div>
                                                        <!-- .form-group -->
                                                        <div class="form-group">
                                                            <label>Password</label>
                                                            <div class="input-group">
