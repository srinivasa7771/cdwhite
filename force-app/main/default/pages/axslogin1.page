                                    <img src="{!URLFOR($Resource.axs2_loginFooter)}" />
                                </div>
                                <!--<div class="footer-images d-none d-lg-block d-xl-block" style="{!IF(pk!='','display:none !important;','')}">
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dic.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/doc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dmc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dsc.png')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dpc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dkp.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/diac.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dsp.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/ddd.png')}" />
                                </div>-->
                                <div class="footer-links">
                                    <apex:outputText rendered="{!!invalidPK}">
                                        <a href="/grqerAboutUS?i={!$CurrentPage.parameters.i}" target="_blank">ABOUT axs</a> |
                                        <a href="/grqerContactUs?i={!$CurrentPage.parameters.i}" target="_blank">CONTACT US</a> |
                                        <a href="/grqerTerms?i={!$CurrentPage.parameters.i}" target="_blank">TERMS OF USAGE </a> |
                                        <a href="/grqerPolicy?i={!$CurrentPage.parameters.i}" target="_blank">PRIVACY POLICY</a>    
                                    </apex:outputText>
                                    
                                    <apex:outputText rendered="{!invalidPK}">  
                                        <a href="/grqerAboutUS" target="_blank">ABOUT axs</a> |
                                        <a href="/grqerContactUs" target="_blank">CONTACT US</a> |
                                        <a href="/grqerTerms" target="_blank">TERMS OF USAGE </a> |
                                        <a href="/grqerPolicy" target="_blank">PRIVACY POLICY</a> 
                                    </apex:outputText>
                                </div>
                            </div>
                        </div>
                    </div>
