<apex:page Controller="gctlDv" showHeader="false" standardStylesheets="false" action="{!ckPrfl}">   
    
    <apex:outputPanel >
        <c:HeaderInternal heading="Visa Application" uid="001" con="{!emp}" />
    </apex:outputPanel>
    
    <apex:form >
        <b><apex:pageMessages id="msg"  />
        </b>
        <div id="main" data-aos="zoom-in">
            
            <div id="page_content">
                <div class="container">
                    <div class="base-layout">                        
                        <div class="base-side">
                            <div class="base-side-content">
                                <div>
                                    <h3 class="text-primary d-md-block d-none">ABOUT THIS SERVICE</h3>
                                    
                                    <a class="base-side-collapse-toggle collapsed d-block d-md-none" data-target="#base_side_content_1" data-toggle="collapse" href="#">
                                        <h3 class="text-primary">ABOUT THIS SERVICE</h3>
                                    </a>
                                    <div class="collapse collapse-content-wrapper" id="base_side_content_1">
                                        <div class="collapse-content">
                                            <p class="text-000" id="serDef">Apply for visa renewal for self or any  of the sponsored employee. You can use this service for all registered and non-registered dependents of your sponsored employees approved dependent from HC.
                                                <br/><br/>
                                                <strong> The visa includes:</strong>
                                            </p><ul class="ul-style"><li> Medical screening</li>
                                            <li>Emirates ID application</li>
                                            <li>Residence visa stamping</li></ul>
                                            <p></p>
                                            
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <h3 class="text-primary d-md-block d-none">DOCUMENTS YOU NEED FOR EMPLOYEE RENWAL</h3>
                                    
                                    <a class="base-side-collapse-toggle collapsed d-block d-md-none" data-target="#base_side_content_2" data-toggle="collapse" href="#">
                                        <h3 class="text-primary">DOCUMENTS YOU NEED</h3>
                                    </a>
                                    <div class="collapse collapse-content-wrapper" id="base_side_content_2">
                                        <p>JPG / JPEG / PDF / PNG / TIFF Formats (max 4 MB each)</p>
                                        
                                        <ul class="ul-style">
                                            <li>Recent passport size photo (white background)</li>
                                            <li>Passport - first page (if updated)</li>
                                            <li>Passport - last page (if updated)</li>
                                            <li>Existing residence visa page</li>
                                            <li> Emirates ID - front</li>
                                            <li>Emirates ID - back</li>                                                
                                            <li>Health insurance card or certificate</li>  
                                        </ul>
                                        
                                        <span>  
                                        </span>
                                        
                                        
                                    </div>
                                    
                                    
                                </div>
                                <div class="mt-4">
                                    <h3 class="text-primary d-md-block d-none">DOCUMENTS YOU NEED FOR DEPENDENT RENEWAL</h3>
                                    
                                    <a class="base-side-collapse-toggle collapsed d-block d-md-none" data-target="#base_side_content_2" data-toggle="collapse" href="#">
                                        <h3 class="text-primary">DOCUMENTS YOU NEED</h3>
                                    </a>
                                    <div class="collapse collapse-content-wrapper" id="base_side_content_2">
                                        <p>JPG / JPEG / PDF / PNG / TIFF Formats (max 4 MB each)</p>
                                        
                                        <ul class="ul-style">
                                            <li>Passport - first page</li>
                                            <li> Passport - last page  (if applicable)</li>
                                            <li> Recent passport size photo</li>
                                            <li> Sponsor's residence visa page</li>
                                            <li> Sponsor passport copy </li>
                                            <li>Latest water &amp; electricity bill</li>
                                            <li> Tenancy contract (Ejari attested) or title deed</li>
                                            <li> Unmarried undertaking letter (for female 18 and above)</li>
                                            <li> Letter from school (for male 17 and above)</li>  
                                            <li>Health insurance card or certificate</li>
                                            <li>Salary certificate</li>
                                        </ul>
                                        
                                        <span>  
                                        </span>
                                        
                                        
                                    </div>
                                    
                                    
                                </div>
                                
                            </div>
                            
                            
                        </div>
                        <div class="base-main">
                            <div class="page-header">
                                
                                
                            </div>

                            <!-- .page-header -->
                            
                            <apex:outputPanel id="panelBlock">
                                    <p>
                                    <b>
                                    GDRFA (General Directorate of Residency and Foreigners Affairs) has stopped issuing 3 years of residence visas to the employees and their dependents registered and operating in the free zones. Henceforth, GDRA will issue either 1-year or 2 years residence visas only. 
                                    </b>
                                    </p>
                                <apex:outputPanel id="tableBlock" rendered="true" >
                                    
                                    <div class="panel">
                                        <div class="panel-body pb-1">
                                            <h3 class="capitalize mb-4">Employee And Dependent Detail(s)</h3>
                                            <!--ERR-{!err}-->
                                            <div class="table-responsive table-responsive-lg table-list-wrapper mt-n2 mt-md-0" style="overflow-x: hidden !important;">
                                                <table class="table table-hover table-responsive-sticky table-list m-0" id="reqTable">
                                                    <thead>
                                                        <tr>
                                                            <th field="Name" class="sticky-col">PHOTO</th>
                                                            <th field="Name" class="sticky-col">NAME</th>                                                    
                                                            <th field="Applicant_Name__c">ROLE</th>
                                                            <th field="xcnc__c">RP #</th>
                                                            <th field="xcnc__c">RP EXPIRY DATE</th>
                                                            <th>RP STATUS</th>
                                                            <th field="xcnc__c"></th>
                                                        </tr>
                                                    </thead>
                                                    <!-- end thead -->
                                                    <tbody>
                                                        <apex:repeat value="{!lc}" var="val">
                                                            
                                                            <tr>
                                                                
                                                                <td>
                                                                    <!--<apex:image value="/servlet/servlet.FileDownload?file={!val.Photo_ID__c}" id="someImage" height="50" width="40"/>-->
                                                                    <img src="/servlet/servlet.FileDownload?file={!val.Photo_ID__c}" onerror="imgError(this,'{!val.Gender__c}')" alt="" width="40" />
                                                                </td>
                                                                <td><apex:outputText styleClass="capitalize" value="{!val.name}"/> </td> 
                                                                <td> <apex:outputText value="{!val.rol__c}"/></td>
                                                                <td><apex:outputText value="{!val.rp__c}"/></td>
                                                                <td>
                                                                    <apex:outputText styleClass="text-center" value="{0, date, dd/MM/yyyy}">
                                                                        <apex:param value="{!val.rped__c}" /> 
                                                                    </apex:outputText>
                                                                </td>
                                                                <td>
                                                                    <apex:outputText rendered="{!AND(val.xur__c='Under Renewal',val.STA__c!='Inactive') }">
                                                                        <span style="color:dodgerblue">Under Renewal</span>
                                                                    </apex:outputText>
                                                                    <apex:outputText rendered="{!AND(val.xur__c!='Under Renewal',val.STA__c!='Inactive')}">
                                                                        <apex:outputText rendered="{!AND(val.rped__c != null,val.rped__c-today()<0)}">
                                                                            <b style="color:tomato">Expired</b>
                                                                        </apex:outputText>
                                                                        <apex:outputText rendered="{!AND(val.rped__c != null,val.rped__c-today()<1,val.rped__c-today()>0)}">
                                                                            <span style="color:tomato">Expiring today</span>
                                                                        </apex:outputText>
                                                                        <apex:outputText rendered="{!AND(val.rped__c != null,val.rped__c-today()>1)}">
                                                                            <span style="color:Green">Expiring in {!val.rped__c-today()} days</span>
                                                                        </apex:outputText>
                                                                    </apex:outputText>
                                                                    <apex:outputText rendered="{!val.STA__c=='Inactive'}">
                                                                    <span style="color:tomato">Inactive</span>
                                                                    </apex:outputText>
                                                                </td>
                                                                <td><apex:commandButton action="{!Renew}" styleClass="btn btn btn-primary base-nav-next" value="RENEW" rerender="all" 
                                                                                        rendered="{!AND(val.rped__c != null,val.rped__c -today()<180,val.xur__c!='Under Renewal')}">
                                                                    <apex:param name="pid" value="{!val.id}" assignTo="{!pid}"/>
                                                                    </apex:commandButton> </td>
                                                                
                                                            </tr>
                                                        </apex:repeat>
                                                        
                                                    </tbody>
                                                    <!-- end tbody -->
                                                </table>
                                            </div>
                                            <div class="mt-4"></div>
                                            <!-- .table-responsive -->
                                            <h3 class="capitalize mb-4 mt-4">Submitted Application(s)</h3>
                                            <div class="table-responsive table-responsive-lg table-list-wrapper mt-n2 mt-md-0" style="overflow-x: hidden !important;">
                                                <table class="table table-hover table-responsive-sticky table-list m-0" id="reqTable">
                                                    <thead>
                                                        <tr>
                                                            <th field="Name" class="sticky-col">SR NUMBER</th>
                                                            <th field="Name" class="sticky-col">NAME</th>                                                    
                                                            <th field="Applicant_Name__c">ROLE</th>
                                                            <th field="xcnc__c">STATUS</th>
                                                        </tr>
                                                    </thead>
                                                    <!-- end thead -->
                                                    <tbody>
                                                        <apex:repeat value="{!rq}" var="val">
                                                            
                                                            <tr>
                                                                
                                                                <td>
                                                                    <a style="color:#000;{!if(val.AP__c>0,'display:none;','')}" href="/apex/grqv?id={!val.id}&empid={!empid}&enc={!encid}&pid={!val.Con__c}&sid={!IF(val.Con__r.rol__c=='Child',$Label.ChildSid,if(val.Con__r.rol__c=='Spouse',$Label.SpouseSid,'a0L2y00000Q2QhVEAV'))}">{!val.Name} </a>
                                                                    <a style="color:#000;{!if(val.AP__c>0,'','display:none;')}" href="/apex/grqstatus?id={!val.id}">{!val.Name} </a>
                                                                </td>
                                                                <td><apex:outputText styleClass="capitalize" value="{!val.Con__r.Name}"/> </td> 
                                                                <td> <apex:outputText value="{!val.Con__r.rol__c}"/></td>
                                                                <td>
                                                                    <apex:outputText styleClass="badge-status initialism text-center {!IF(val.STA__c='Completed','badge-status-completed',IF(OR(val.STA__c='In Process',val.STA__c='Under Review'),'badge-status-process',IF(OR(val.STA__c='Rejected',val.STA__c='Cancelled'),'badge-status-urgent','badge-status-draft')))} " value="{!val.STA__c}"/>
                                                                </td>
                                                                
                                                                
                                                            </tr>
                                                        </apex:repeat>
                                                    </tbody>
                                                    <!-- end tbody -->
                                                </table>
                                            </div>
                                        </div>
                                        <!-- .panel-body -->
                                    </div>
                                </apex:outputPanel>
                                
                            </apex:outputPanel>
                            
                            
                        </div>
                        <!-- .container -->
                    </div>
                    
                    
                    <!--<c:addons ></c:addons>-->
                </div>
                
                
            </div>
        </div>
        
        
        
    </apex:form>
    <script>
    
    function imgError(elem,g){
        elem.onerror = "";
        var gen = (g=="Female")?g:"Male";
        elem.src = "../resource/assets_NUI/images/"+gen+"-Default.png";
        return true;
    }
    </script>
</apex:page>