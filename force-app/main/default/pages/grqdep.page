<apex:page sidebar="false" controller="ApplicantDetailController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="{!ispu}" standardStylesheets="false" lightningStylesheets="true" title="{!req.srvc__r.lbl__c}">
    <apex:slds />
    
    
    
    <html>        
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <apex:includeScript value="{!$Resource.AXS2Validations}"/>
        
        
        <script type="text/javascript">
        var GCC_Nations = ['Bahrain', 'Kuwait', 'Oman', 'Qatar', 'Saudi Arabia', 'United Arab Emirates'];
        var cs = {}; var ispu = {!ispu};
        $(document).ready(function() {
            console.log('document ready::::');
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z ]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
            
            //remove current Nationality onchange method
            cs['xcnc__c'].removeAttribute('onchange');
            
            //disable Martial status,Salutation
            var gender = cs['gender__c'].value;
            console.log('gender::::'+gender);
            if(gender == 'Male')
            {
                cs['xcslt__c'].value = 'Mr.';
                $('input[value="Mr."]').prop('checked', true);
            }
            else if(gender == 'Female'){
                $('input[value="Mrs."]').prop('checked', true);
                cs['xcslt__c'].value = 'Mrs.';
            }
            //cs['xcslt__c'].value = 'Mrs.';
            cs['xcms__c'].value = 'Married';
            $('input[value="Married"]').prop('checked', true);
            //$('input[value="Mrs."]').prop('checked', true);
            $("input[name='martialStatus']").attr('disabled',true);
            $("input[name='salutation']").attr('disabled',true);
        });
        function dformat(dt,id){
            var d = new Date(dt);//alert(d);
            var m=d.getMonth()+1;
            var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
            var mm=m>9?m:'0'+m;
            var yy=d.getFullYear();
            document.getElementById(id).value=dd+'/'+mm+'/'+yy;
        }
        //Add  warning message
        function addWarningMsg(thiselem,message){
            console.log('addWarningMsg:::');
            var elem = $(thiselem);
            var warElem = '<div class="warningMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(warElem);
            }else{
                elem.parent().append(warElem);
            }
        }
        //Remove warning error
        function removeWarningMsg(thiselem){
            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
            //elem.parent().find('.warningMsg').remove();
        }
        //Add validation error
        
        function addValError(thiselem,message){
            var elem = $(thiselem);
            elem.parents('.form-group').find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
            var errElem = '<div class="frmErrMsg">'+message+'</div>';
            elem.parents('.form-group').append(errElem);
        }
        
        //Remove validation error
        function removeValError(thiselem){
            var elem = $(thiselem);
            elem.parent().find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
        }
        //Validation  for UAE Mobile Number
        /*function isUAEMobNum(elem){
            var mob = $(elem).val();
            if(mob==null||mob==undefined||mob=='')
                return;
            //var regex = /^((?:50|52|54|55|56|58)[0-9]{7,})$/;
            var regex = /^(?:50|51|52|55|56|2|3|4|6|7|9)\d{7}$/;
            var r = (regex.test(mob))?true:'invalid';
            if(r == 'invalid'){
                $(elem).parent().find('.frmErrMsg').remove();
                $(elem).parent().parent().find('.frmErrMsg').remove();
                var errElem = '<div class="frmErrMsg">Please enter a valid UAE mobile number</div>';
                $(elem).parent().parent().append(errElem);
                return false;
            }else{
                removeValError(elem);     
            }
        }*/
        //validate mobile number
        function checkMob(thisElem){
            var mobNo = $(thisElem).val();
            if(mobNo.length < 10){
                addValError(thisElem,'Please enter valid mobile Number!!');
            }else{
                removeValError(thisElem);    
            }
        }
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                $(thisElement).addClass("is-invalid");
                return false;    
            }else{
                removeValError(thisElement);  
                $(thisElement).removeClass("is-invalid");
                return r;
            }
        }
        //Calulate Age 
        function getAge(dob){
            console.log('getAge::::');
            var parts = dob.split("/");
            var dob = new Date(parts[2], parts[1] - 1, parts[0]);
            console.log('dob:::'+dob);
            var today = new Date(); var nowyear = today.getFullYear(); var nowmonth = today.getMonth();var nowday = today.getDate();
            var birthyear = dob.getFullYear(); var birthmonth = dob.getMonth();var birthday = dob.getDate();
            var age = nowyear - birthyear;
            console.log('age:::'+age);
            return age;
        }
        //Validate DOB
        function validateDOB(thisElement){
            console.log('validateDOB::::');
            if(checkValidDate(thisElement) == true){
                var date = $(thisElement).val();
                var age = getAge(date)
                console.log('age:::'+age);
                if(age<18 || age>60){
                    removeWarningMsg(thisElement);
                    removeValError(thisElement);   
                    addValError(thisElement,'Applicant must be 18 years above.');
                    $(thisElement).addClass("is-invalid");
                    return false;
                }else{
                    console.log('correct::::');
                    removeWarningMsg(thisElement);
                    removeValError(thisElement);
                    $(thisElement).removeClass("is-invalid");
                }
            }
        }
        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //Validate Data on click of next button
        function validateData(){
            var elem = '';
            var validated  = true;
            $('.requiredFld,.applMob').each(function(){
                //if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                //return;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null || v==undefined){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            $('.ddValidation').each(function(){
                //debugger;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                showErrMsg($(this),'rqrd',true);
                var v = $(this).val();
                if(v==''||v==null||v==undefined){
                    if($(this).is('select'))
                        showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                    else
                        showErrMsg($(this),'rqrd','invalid');
                    return false;
                }
            });
            var salutation = $("input[name='salutation']:checked").val();
            var martialStatus = $("input[name='martialStatus']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            //alert('salutation v:'+validated);
            if(martialStatus == undefined){
                $("input[name='martialStatus']").parent().parent().parent().find('.option-error').show();
                //alert('Please select martial status');
                validated =false;
            }//alert('martialStatus v:'+validated);
            if(validateBasicSalary( cs['xcmbs__c']) == false){   
                validated =false;
            }//alert('Basic salary v:'+validated);
            /*if(validateCurrenNationality(cs['xcnc__c']) == false){
                validated =false;
            }//alert('current Nationality v'+validated);*/
            
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            
            console.log('submit validated:::'+validated);
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                if(cs["xcnc__c"] && cs["xcnc__c"].value &&typicalCountries.includes(cs["xcnc__c"].value)){
                    cs["xcfn__c"].value = cs["xcfn__c"].value.split(" ").slice(0, -1).join(" ");
                }
                console.log('Issue Date:::'+cs['xcpid__c'].value);
                //console.log('Expiry Date:::'+cs['xcped__c'].value);
                //console.log('DOB:::'+cs['xcbd__c'].value);
                next();
                //alert("Req Updated::::::::::"); 
            }
        }
        //Validate Basic salary
        function validateBasicSalary(thiselem){
            var sal = $(thiselem).val();
            if(sal < 1000){ 
                addValError(thiselem,'Minimum basic salary should be AED 1000.','salVal');
                return false;
            }else{
                // $(thiselem).parent().find('.frmErrMsg').remove();
                removeValError(thiselem);
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        function showDraftAlert2(){
            if(!ispu){
                var rqNum = '{!JSENCODE(req.Name)}';
                $('#modal_alert_global').remove(); 
                var cBlock = '<div class="modal fade modal-base" id="modal_alert_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <div class="modal-body text-center pt-5 pb-5"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <div class="mb-3 fs-24" style="text-align:center;">Your Request has been saved!</div><div class="mb-3 fs-24">SR # <b>'+rqNum+'</b></div> <div class="col-xl-4"></div> <button class="col-xl-4 col-lg-12 btn btn-outline-primary mr-2 btn-block-sm" id="gDash">CLOSE</button> </div> </div> </div> </div> </div> </div> </div> </div></div>'
                $('body').append(cBlock);
                $('#modal_alert_global').modal('show');
                $('#gDash').on('click',function(){
                    window.opener.location.reload(false);
                    window.close();
                });
            }
        }
        </script>
