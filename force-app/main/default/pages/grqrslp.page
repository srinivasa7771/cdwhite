                    }, 100);
                    elem.focus();
                }
            });
            console.log('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                $('html,body').animate({
                    scrollTop: (elem.offset().top-60)
                }, 250);
                elem.focus();
            }
            
            console.log('Basic salary v:'+validated);
            
