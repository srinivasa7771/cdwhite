            var elem = '';
            var validated  = true;
           
            $('.requiredFld').each(function(){
                var v = $(this).val();
                if(!$(this).is(':visible'))
                    return;
                if(!v||v.lenght<1){
                    addValError(this,'This field is required !!');
                    console.log('blank >>'+$(this).attr("name"));
                    console.dir(this);
                    validated=false;
                    
