            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
        }
        function isUAEMobNum(elem){
            var mob = $(elem).val();
            if(mob==null||mob==undefined||mob=='')
                return;
            var regex = /^((?:50|52|54|55|56|58)[0-9]{7,})$/;
            var r = (regex.test(mob))?true:'invalid';
