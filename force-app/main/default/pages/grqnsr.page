        //Validate expiry and issue date  in the passport
        function checkIssueAndExpiryDate(idElem,edElem){
            var issueDate = new Date($(idElem).val());
            var expiryDate = new Date($(edElem).val());
            var today = new Date();
            removeValError(idElem);  
            removeValError(edElem);  
            if(issueDate == 'Invalid Date' || issueDate>today){
                addValError(idElem,'Please select a valid issue date!');
                return false;
            }else if(expiryDate!= 'Invalid Date' && issueDate.setMonth(issueDate.getMonth()+6)>= expiryDate && issueDate != 'Invalid Date'){
                addValError(edElem,'Passport Expiry should be 6 months after passport Issue !');
                return false;
            }else{
                removeValError(idElem);  
                removeValError(edElem);   
            }
        }
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            var date1 =  date.split('/')[1]+'/'+date.split('/')[0]+'/'+date.split('/')[2];
            var days = new Date(new Date()-new Date(date1))/1000/60/60/24;
            console.log('date:::'+date);
            console.log('days::'+days);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
             if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                return false;    
            }
            else if((days*-1)<(90)){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'"Validity should be atleast 3 months');
                return false;    
             }
            else{
                removeValError(thisElement);   
                return r;
            }
        }
