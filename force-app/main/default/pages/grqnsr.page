        var cs = {};
        function dformat(dt,id){
        var d = new Date(dt);//console.log(d);
            var m=d.getMonth()+1;
            var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
            var mm=m>9?m:'0'+m;
            var yy=d.getFullYear();
            document.getElementById(id).value=dd+'/'+mm+'/'+yy;
        }
        function xddf(ed, sd) {
     var aDaysMonth = [[31, "Jan", "January"], [28, "Feb", "February"], [31, "Mar", "March"], [30, "Apr", "April"], [31, "May", "May"], [30, "Jun", "June"], [31, "Jul", "July"], [31, "Aug", "August"], [30, "Sep", "September"], [31, "Oct", "October"], [30, "Nov", "November"], [31, "Dec", "December"]];
     0 == ed.getYear() % 4 && (aDaysMonth[1][0] = 29);
     0 != ed.getFullYear() % 400 & 0 == ed.getYear() && (aDaysMonth[1][0] = 28);
  var dY = ed.getFullYear() - sd.getFullYear();
  var dM = ed.getMonth() - sd.getMonth();
  var dD = ed.getDate() - sd.getDate();
  0 > dD && (dD += aDaysMonth[sd.getMonth()][0], --dM);
  0 > dM && (dM += 12, --dY);
  return[dM, dY];
}
        function enableFineItem(){
            var expry = '{!JSENCODE(req.Con__r.idedt__c)}';
            //   alert(expry);
           var texpry = new Date(expry);
           var today = new Date();
           var dateArr = xddf(today, texpry);
           var diffyrs = dateArr[1];
           var years = 1;
           if (diffyrs < 1) {
              years = 1;
           } else if (diffyrs >= 1 && diffyrs < 2) {
                    years = 2;
          } else if (diffyrs >= 2 && diffyrs < 3) {
              years = 3;
          } else if (diffyrs >= 3 && diffyrs < 4) {
              years = 4;
          } else if (diffyrs >= 4 && diffyrs < 5) {
              years = 5;
          }
            //  alert(years);
            if(years > 1 && years == 2)
                cs["xadh__c"].value += '2id;';
            else if(years > 1 && years == 3)
                cs["xadh__c"].value += '3id;';
            else if(years > 1 && years == 4)
                cs["xadh__c"].value += '4id;';
            else if(years > 1 && years == 5)
                cs["xadh__c"].value += '5id;';
          
        }
