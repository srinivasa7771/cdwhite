<apex:page Controller="docPrintCtl" showheader="false">
<body>        
    <table>       
        <tr>
        <td>                        
        <apex:pageBlock >
        <apex:pageBlockSection title="Scans ({!totalPhotos})" collapsible="false">                             
            <apex:repeat value="{!attWrapList}" var="a">                                                
                <img src="data:image/jpeg;base64,{!a.attCode}" title="{!a.reqDocName}"/>
            </apex:repeat>
        </apex:pageBlockSection>
        </apex:pageBlock>        
               
        </td>
        </tr>                      
    </table>            
</body>                   
</apex:page>