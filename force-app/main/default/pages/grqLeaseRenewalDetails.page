                                    </div>
                                    <div class="progress-line"></div>
                                    <div class="progress-item completed">
                                        <div class="progress-number">6</div>
                                        <div class="progress-label">Lease Renewed</div>
                                    </div>
                                </div>
                            </apex:outputPanel>
                            <apex:outputPanel rendered="{!NOT(rq.InsChk__c)}">
                                <div class="progress-vertical">
                                    <div class="progress-item completed">
                                        <div class="progress-number">1</div>
                                        <div class="progress-label">Review your lease</div>
                                    </div>
                                    <div class="progress-line"></div>
                                    <div class="progress-item completed">
                                        <div class="progress-number">2</div>
                                        <div class="progress-label">Initiate courier</div>
                                    </div>
                                    <div class="progress-line"></div>
                                    <div class="progress-item completed">
                                        <div class="progress-number">3</div>
                                        <div class="progress-label">Submit lease agreement and cheques</div>
                                    </div>
                                    <div class="progress-line"></div>
                                    <div class="progress-item completed">
                                        <div class="progress-number">4</div>
                                        <div class="progress-label">Leasing team verification</div>
                                    </div>
                                    <div class="progress-line"></div>
                                    <div class="progress-item completed">
                                        <div class="progress-number">5</div>
                                        <div class="progress-label">Lease Renewed</div>
                                    </div>
                                </div>
                            </apex:outputPanel>
                            <div style="height:150%; overflow: auto;" >
                            </div>
                            
                        </div>
                        <div>
                            <apex:outputPanel id="dueAmount" rendered="false" >
                                <div class="onboarding-side-footer" style="padding: 30px 40px;display:block; position: relative;background-color: #DCDCDC;margin-top: 30px">
                                    <apex:outputText >
                                        <a href="#" class="onboarding-side-footer-modal-toggle" style="position: absolute;right: 15px;top: 15px;font-size: 1rem;" data-toggle="modal" data-target="#modal_fees_breakdown">
                                            <i class="icon-popup"></i>
                                        </a>
                                    </apex:outputText> 
                                    <div class="data-info data-info-lg" style="margin-bottom: 10px;">
                                        <h4 class="data-label">Payment Due</h4>
                                        <div class="data-value">  
                                            AED {!rq.xtpa__c}
                                        </div>
                                    </div>
                                </div>
                            </apex:outputPanel>
                        </div>
                    </div>
                </div>
                
                <div class="modal fade modal-base" id="modal_fees_breakdown" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true" style="padding-right: 17px;">
                    <div class="modal-dialog" role="document" style="width: 600px;">
                        <apex:outputPanel id="feeBreak"  >
                            <div class="modal-content">
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <i class="icon-close"></i>
                                </button>
                                <div class="modal-body px-xl-5">
                                    <h2 class="modal-title mb-4">Fees breakdown</h2>
                                    <div class='mb-4'> 
                                        <p>
                                            Below is a summary of the fees and costs calculated for your lease renewal request.
                                        </p>
                                    </div>
                                    <div  class="onboarding-review-table onboarding-review-table-static"> <!-- class="onboarding-review-table onboarding-review-table-static" -->
                                        <div id="othrbrkdwn">
                                            <apex:outputPanel rendered="true">
                                                <apex:repeat value="{!rq.Items__r}" var="itm">
                                                    <apex:outputPanel rendered="{!itm.ATV__c != 0}">
                                                        <div class="onboarding-review-toggle">
                                                            <div class="onboarding-review-row">
                                                                <span class="onboarding-review-label">{!itm.name}</span>
                                                                <span class="onboarding-review-value">AED {!itm.ATV__c}</span>
                                                            </div>
                                                        </div>
