        function validateDate(elem) {
            var value = elem.value.trim();
            if (!value) {
                removeValError(elem); // empty field, no error
            }
            
            // Convert DD/MM/YYYY to Date object
            var parts = value.split('/');
            if(parts.length !== 3) {
                addValError(elem, 'Invalid date format. Use DD/MM/YYYY.');
            }
            
            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            
            var inputDate = new Date(year, month, day);
            
            if (isNaN(inputDate.getTime())) {
                addValError(elem, 'Invalid date.');
            }
            
            // Compare with today's date
            var today = new Date();
            today.setHours(0,0,0,0); // ignore time
            
            if (inputDate <= today) {
                addValError(elem, 'Policy Expire Date must be in the future.');
            } else {
                removeValError(elem);
            }
        }

        function validatePrecedingCheckbox(currentCheckbox) {
            const checkboxes = Array.from(
                document.querySelectorAll('input[type="checkbox"]')
            );
            const currentIndex = checkboxes.indexOf(currentCheckbox);
            
            if (currentIndex > 2 && !checkboxes[currentIndex - 1].checked) {
                axsAlert('Alert!','You must select the earlier payment term first. Payments can only be selected in order of their due dates.');
                currentCheckbox.checked = false;
                return;
            }
        }        


