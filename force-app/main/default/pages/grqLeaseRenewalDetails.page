                                                </apex:repeat>
                                            </apex:outputPanel>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                    </div>
                </div>
                <div class="base-main">
                    <div class="base-main-content">
                        <div class="steps steps-desktop">
                            <div class="step-item completed">
                                <div class="step-item-inner">
                                    <i class="step-icon icon-review"></i>
                                    <div class="step-title">Review Lease Renewal</div>
                                    <i class="step-icon-check fa fa-check"></i>
                                </div>
                            </div>
                            <div class="step-item active">
                                <div class="step-item-inner">
                                    
                                    <i class="step-icon icon-addon"></i>
                                    <div class="step-title">Upload Documents</div>
                                </div>
                            </div>
                            <div class="step-item active">
                                <div class="step-item-inner">
                                    <i class="step-icon icon-cash-deposit"></i>
                                    <div class="step-title">Payment Options</div>
                                </div>
                            </div>
                        </div>
                        
                        <h3 class="base-main-title">Lease Renewal</h3>
                        <apex:outputPanel rendered="{!rq.xled__c < TODAY()}">
                            <p>
                                Your lease expired on <b><apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!rq.xled__c}" /></apex:outputText></b>. Please review the Renewal Agreement shared with you via email and return it at the soonest to help avoid potential compliance issues . We appreciate your prompt action.
                            </p>
                        </apex:outputPanel>
                        
                        <apex:outputPanel rendered="{!rq.xled__c > TODAY()}">
                            <p>
                                Your lease is approaching its renewal on <b><apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!rq.xled__c}" /></apex:outputText></b>. Please review the Renewal Agreement shared with you via email and return it at the soonest to help avoid potential compliance issues. We appreciate your prompt action.
                            </p>
                        </apex:outputPanel>
                        <p>
                            Any changes to your license not included in your previous Lease Agreement will automatically be reflected in the renewed agreement.
                        </p>
                        <p>
                            For any modifications or questions related to your lease and renewal, please contact the Leasing Team by calling 800-4-axs (297).
                        </p>
                        <apex:outputPanel styleClass="col-lg-6">
                            <div id="visiteduaepanel">
                                <apex:outputPanel rendered="true">
                                    <h4>Please provide your lease insurance details</h4>
                                </apex:outputPanel>
                            </div>
                        </apex:outputPanel>
                        
                        <div id="section1" style="display:none;">
                            <h3>Corporate Insurance from ADNIC</h3>
                            <p>
                                Register your interest for the services from below. Some of the services will be added to your
                                payable fees whereas others will be charged by our partners directly at the time of the fulfilment
                                of those services.
                            </p>
                            <c:adnicinscmp rqDraft="{!req}"/>     
                        </div>
                        <div id="section2">
                            <div class="row row-lg">
                                <div class="col-lg-12">
                                    <div class="form-group">
                                        <label id="emailId">Insurance Risk Type</label>
                                        
                                        <select id="insurancetype"
                                                class="form-control select2-service requiredFld"
                                                multiple="multiple"
                                                onchange="updateInsuranceTypeMulti();">
                                            <option value="All Risk Insurance">All Risk Insurance</option>
                                            <option value="Third Party Liability">Third Party Liability</option>
                                            <option value="Employee Compensation">Employee Compensation</option>
                                            
                                        </select>
                                        <script type="text/javascript">

                                        function updateInsuranceTypeMulti() {
                                            var values = $('#insurancetype').val();
                                            cs['xintp__c'].value = values ? values.join(',') : '';
                                            console.log('inusarnce data :'+cs['xintp__c'].value);
                                            toggleInsuranceExpiry(values);
                                        }

                                        function toggleInsuranceExpiry(values) {
                                            if (!values || values.length === 0) {
                                                $('.allRiskBlock, .tplBlock, .ecBlock').hide();
                                                return;
                                            }
                                            if (values.includes('All Risk Insurance')) {
                                                $('.allRiskBlock').show();
                                            }
                                            if (values.includes('Third Party Liability')) {
                                                $('.tplBlock').show();
                                            }
                                            if (values.includes('Employee Compensation')) {
                                                $('.ecBlock').show();
                                            }

                                            if (!values.includes('All Risk Insurance')) {
                                                $('.allRiskBlock').hide();
                                            }
                                            if (!values.includes('Third Party Liability')) {
                                                $('.tplBlock').hide();
                                            }
                                            if (!values.includes('Employee Compensation')) {
                                                $('.ecBlock').hide();
                                            }
                                        }
                                        </script>
                                    </div>
                                    
                                </div>
                                
                                <div class="row allRiskBlock" style="border-bottom: 1px dashed rgba(0, 0, 0, 0.1);">
                                    <div class="col-lg-12">All Risk Policy</div>
                                    <div class="col-lg-4 allRiskBlock" >
                                        <div class="form-group">
                                            <label>Expire Date</label>
                                            <div class="input-datepicker-group input-group">
                                                <input type="text" class="forReadOnly dateCheck form-control input-datepicker forEdit requiredFld" validationName="ped"
                                                       fldName="Date of Expiry" id="datepicker3" value="{!rq.xrpid__c}"
                                                       data-toggle="datetimepicker" data-target="#datepicker3" placeholder="DD/MM/YYYY"   onchange="validateDate(this);" />
                                                <div class="input-group-append">
                                                    <button class="forReadOnly btn text-primary" type="button" data-toggle="datetimepicker" data-target="#datepicker3">
                                                        <i class="icon-date"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 allRiskBlock" >
                                        <div class="form-group">
                                            <label id="MobId">Policy Number</label>
                                            <div class="d-flex">
                                                <apex:inputField styleClass="jsnfld requiredFld form-control" value="{!rq.xdmpn__c}"   onchange="validateInput(this,'xdmpn__c',20)"/> 
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 allRiskBlock" >
                                        <div class="form-group">
                                            <label id="emailId" style="white-space: nowrap">Company Name</label>
                                            <apex:inputField value="{!rq.Insurance_Company__c}" styleClass="jsnfld requiredFld form-control insCompany" id="insCompany" onchange="updateInsuranceCompany(this.value,'All Risk Insurance')"/>
                                            <script type="text/javascript">
                                            cs['Insurance_Company__c'] =document.getElementById('{!$Component.Insurance_Company__c}');
                                            </script> 
                                        </div> 
                                    </div>
                                </div>
                                <div class="row tplBlock" style="border-bottom: 1px dashed rgba(0, 0, 0, 0.1);">
                                    <div class="col-lg-12">Third Party Liability Policy</div>
                                    <div class="col-lg-4 tplBlock">
                                        <div class="form-group">
                                            <label style="white-space: nowrap">Expire Date</label>
                                            <div class="input-datepicker-group input-group">
                                                <input type="text" class="forReadOnly dateCheck form-control input-datepicker forEdit requiredFld" validationName="ped"
                                                       fldName="Date of Expiry" id="datepicker4" value="{!rq.xceidedt__c}"
                                                       data-toggle="datetimepicker" data-target="#datepicker4" placeholder="DD/MM/YYYY"   onchange="validateDate(this);" />
                                                <div class="input-group-append">
                                                    <button class="forReadOnly btn text-primary" type="button" data-toggle="datetimepicker" data-target="#datepicker4">
                                                        <i class="icon-date"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 tplBlock">
                                        <div class="form-group">
                                            <label id="MobId" style="white-space: nowrap">Policy Number</label>
                                            <div class="d-flex">
                                                <apex:inputField styleClass="jsnfld requiredFld form-control" value="{!rq.xsvn__c}"  onchange="validateInput(this,'xsvn__c',20)"/> 
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 tplBlock">
                                        <div class="form-group">
                                            <label id="emailId" style="white-space: nowrap">Company Name</label>
                                            <apex:inputField value="{!rq.Insurance_Company__c}" styleClass="jsnfld requiredFld form-control insCompany1" id="insCompany1" onchange="updateInsuranceCompany(this.value,'Third Party Liability')"/>
                                            <script type="text/javascript">
                                            cs['Insurance_Company__c'] =document.getElementById('{!$Component.Insurance_Company__c}');
                                            </script> 
                                        </div> 
                                    </div>
                                </div>
                                
                                <div class="row ecBlock" style="border-bottom: 1px dashed rgba(0, 0, 0, 0.1);">
                                    <div class="col-lg-12">Employee Compensation Policy</div>
                                    <div class="col-lg-4 ecBlock">
                                        <div class="form-group">
                                            <label style="white-space: nowrap">Expire Date</label>
                                            <div class="input-datepicker-group input-group">
                                                <input type="text" class="forReadOnly dateCheck form-control input-datepicker forEdit requiredFld" validationName="ped"
                                                       fldName="Date of Expiry" id="datepicker5" value="{!rq.xceididt__c}"
                                                       data-toggle="datetimepicker" data-target="#datepicker5" placeholder="DD/MM/YYYY"   onchange="validateDate(this);" />
                                                <div class="input-group-append">
                                                    <button class="forReadOnly btn text-primary" type="button" data-toggle="datetimepicker" data-target="#datepicker5">
                                                        <i class="icon-date"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 ecBlock">
                                        <div class="form-group">
                                            <label id="MobId" style="white-space: nowrap">Policy Number</label>
                                            <div class="d-flex">
                                                <apex:inputField styleClass="jsnfld requiredFld form-control" value="{!rq.xvnum__c}"   onchange="validateInput(this,'xvnum__c',20)"/> 
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 ecBlock">
                                        <div class="form-group">
                                            <label id="emailId" style="white-space: nowrap" >Company Name</label>
                                            <apex:inputField value="{!rq.Insurance_Company__c}" styleClass="jsnfld requiredFld form-control insCompany2" id="insCompany2" onchange="updateInsuranceCompany(this.value,'Employee Compensation')"/>
                                            <script type="text/javascript">
                                            cs['Insurance_Company__c'] =document.getElementById('{!$Component.Insurance_Company__c}');
                                            </script> 
                                        </div> 
                                    </div>
                                </div>

                            </div>
                        </div>  
                        
                        <apex:outputPanel styleClass="col-lg-6">
                            <div id="signdigital">
                                <apex:outputPanel rendered="true">
                                    <h4>How would you like to sign your lease agreement?</h4>
                                    <div class="form-group mt-3 isvisitedUAE reqRadio row">
                                        <div class="col-lg-3 col-sm-6">
                                            <label class="box-check mb-0">
                                                <input type="radio" class="form-control" name="signatureChoice" id="isDigitalSignYes" onchange="updateDigitalSign(true)" />
                                                <div class="box box-center box-hover mb-lg-0" style="min-height: 74px;">
