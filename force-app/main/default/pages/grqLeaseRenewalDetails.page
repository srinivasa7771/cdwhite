        function validateError(clsName) {
            // Find the first visible element with the class
            var firstError = $(clsName + ':visible').first();
        
            if (firstError.length > 0) {
                // Scroll to the element
                $('html, body').animate({ scrollTop: firstError.offset().top - 60 }, 100);
        
                // Focus on it if it can be focused
                if (firstError.is('input, textarea, select, button')) {
                    firstError.focus();
                } else {
                    // If not focusable, try to focus on the first input inside it
                    firstError.find('input, textarea, select').first().focus();
                }
                return false;
            }
            return true; // No visible element found
        }
        
        
