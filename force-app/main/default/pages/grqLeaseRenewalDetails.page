            <apex:inputHidden id="xvnum__c" value="{!rq.xvnum__c}"/>
        </apex:outputPanel>
        
        
        <apex:outputPanel id="rerenderImage">
            <apex:inputHidden id="docname" value="{!docname}" />
            <script>
            var cs = {};
            cs["docname"] = document.getElementById("{!$Component.docname}");
            cs["documentlist"] = document.getElementById("{!$Component.documentlist}");
            cs["xadtx2__c"] = document.getElementById("{!$Component.xadtx2__c}");
            cs["parCat__c"] = document.getElementById("{!$Component.parCat__c}");
            cs["xcamc__c"] = document.getElementById("{!$Component.xcamc__c}");
            cs["xintp__c"] = document.getElementById("{!$Component.xintp__c}");
            cs["xdedc__c"] = document.getElementById("{!$Component.xdedc__c}");
            cs['xrpid__c'] = document.getElementById("{!$Component.xrpid__c}");
            cs['xceidedt__c'] = document.getElementById("{!$Component.xceidedt__c}");
            cs['xceididt__c'] = document.getElementById("{!$Component.xceididt__c}");
            cs["isDigitalSign"] = document.getElementById("{!$Component.xlicd__c}");
            cs["isInsurance"] = document.getElementById("{!$Component.xloccr__c}");
            cs["xaccbrand__c"] = document.getElementById("{!$Component.xaccbrand__c}");
            
            cs["xadtx1__c"] = document.getElementById("{!$Component.xadtx1__c}");
			cs["xadtx4__c"] = document.getElementById("{!$Component.xadtx4__c}");
            
            cs["xsvn__c"] = document.getElementById("{!$Component.xsvn__c}");
            cs["xvnum__c"] = document.getElementById("{!$Component.xvnum__c}");
            
            console.log('doc value :'+cs["documentlist"].value);
            cs["isInsurance"].value = 'false';
            
            function initCourier(){
                initCou();
            }
            
            </script>
        </apex:outputPanel>
        
        <div class="container">
            <div class="container pt-2 pb-2">
                <div class="text-right">
                    <apex:outputPanel >
                        <span class="d-inline-block mr-2 align-middle" style="font-size: 1.875rem;line-height: 1;">
                            SR # <span class="text-000">{!rq.Name} </span>
                        </span>
                    </apex:outputPanel>
                    <c:drftCnclBtns req="{!req}" shwCncl="true" shwDraft="{!IF(AND(OR(req.STA__c=='Draft',req.STA__c=='Open'),!req.xoca__c),true,false)}"/>
                </div>
            </div>
            <div class="base-layout">
