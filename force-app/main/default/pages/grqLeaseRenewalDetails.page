        function populateInsuranceFields() {
            var jsonField = document.getElementById('{!$Component.xadtx2__c}');
            if (!jsonField.value) return; // No JSON stored

            try {
                var insuranceData = JSON.parse(jsonField.value);
                // Update input fields with stored values
                if (insuranceData["All Risk Insurance"] !== undefined) {
                    console.log('first');
                    document.querySelector('.insCompany').value =insuranceData["All Risk Insurance"] ;
                    cs["Insurance_Company1__c"] = insuranceData["All Risk Insurance"] ;
                }
                if (insuranceData["Third Party Liability"] !== undefined) {
                     console.log('second');
                    document.querySelector('.insCompany1').value  = insuranceData["Third Party Liability"];
                    cs["Insurance_Company2__c"] = insuranceData["Third Party Liability"];
                }
                if (insuranceData["Employee Compensation"] !== undefined) {
                    console.log('third');
                    document.querySelector('.insCompany2').value = insuranceData["Employee Compensation"];
                    cs["Insurance_Company3__c"] = insuranceData["Employee Compensation"];
                }
            } catch(e) {
                console.error('Invalid JSON in Insurance_JSON__c:', e);
            }
        }


        function setFormattedDate(fieldValue, fieldApiName, inputId) {
            if (!fieldValue || fieldValue === '') {
                return;
            }
            // Safe date parsing (Salesforce DATE → JS Date)
            var dateObj = new Date(fieldValue + 'T00:00:00');

            if (isNaN(dateObj.getTime())) {
                console.error('Invalid date value:', fieldValue);
                return;
            }

            var dd = String(dateObj.getDate()).padStart(2, '0');
            var mm = String(dateObj.getMonth() + 1).padStart(2, '0');
            var yyyy = dateObj.getFullYear();

            var formattedDate = dd + '/' + mm + '/' + yyyy;

            // Set value to custom state object
            if (fieldApiName) {
                cs[fieldApiName].value = formattedDate;
                cs[fieldApiName+ '_'+ 'OnLoad'] = formattedDate;
            }
            // Set value to input field
            if (inputId && document.getElementById(inputId)) {
                document.getElementById(inputId).value = formattedDate;
            }
            return formattedDate;
        }

