<apex:page sidebar="false" standardController="g_Req__c" extensions="lrCtlReq" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true" standardStylesheets="false" >
    <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"/> 
    <apex:includeScript value="{!$Resource.jsH}"/>
    <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
    <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
    <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
    <style>
        @keyframes blink {
        0% {
        opacity: 0.4;
        }
        50% {
        opacity: 0.8;
        }
        80% {
        opacity: 1;
        }
        100% {
        opacity: 1;
        }
        }
        
        .blinkAny6 {
        animation: blink 2s 6 ease-in-out;
        }
    </style>
    <apex:form id="mainForm" styleClass="form-style">
        
        <apex:actionFunction name="updateRenewalRequest" action="{!updateRequestDetails}" rerender="rerenderImage" >
            
            <apex:param name="pType" assignTo="{!selectedInsuranceType}" value="" />
            <apex:param name="pTypeChange" assignTo="{!isPolicyNumChange}" value="" />
            <apex:param name="pComChange" assignTo="{!isPolicyComChange}" value="" />
            <apex:param name="insTypeChange" assignTo="{!isInsTypeChange}" value="" />
            <apex:param name="pExpireDChange" assignTo="{!isExpireDateChange}" value="" />
            <apex:param name="digitalSignChange" assignTo="{!isDigitalSignChange}" value="" />
        </apex:actionFunction>
        
        <apex:actionFunction name="initCou" status="theStatus"  reRender="msg" action="{!invokeCourier}"  >
        </apex:actionFunction>
        
        
        <apex:actionFunction status="theStatus" reRender="msg" name="callAdnicWS" action="{!calprem}" oncomplete="reassignPolicyInfo('{!JSENCODE(rq.xuvdet__c)}');" />
        
        
        <apex:outputPanel id="rqfldId">
