        const POLICY_CONFIG = {allRiskBlock: { tableName: 'COMMLEASEBUT_InsInfo', fields: [ { name: 'ALLRISKINS', fixedValue: 'Yes' },{ name: 'ALLRISK_EXP', selector: '#datepicker3' }, { name: 'ALLRISK_INS_PLC_NO', selector: '.allRiskBlock input.jsnfld' }, { name: 'ALLRISK_INS_CO_N', selector: '.insCompany' } ] }, tplBlock: { tableName: 'COMMLEASEBUT_InsInfo', fields: [ { name: 'THIRDPARTY_LIAB', fixedValue: 'Yes' }, { name: 'THIRD_EXP', selector: '#datepicker4' }, { name: 'THIRD_INS_PLC_NO', selector: '.tplBlock input.jsnfld' }, { name: 'THIRD_INS_CO_N', selector: '.insCompany1' } ] }, ecBlock: { tableName: 'COMMLEASEBUT_InsInfo', fields: [ { name: 'EMPLCOMP', fixedValue: 'Yes' },{ name: 'EMPL_EXP', selector: '#datepicker5' }, { name: 'EMPL_INS_PLC_NO', selector: '.ecBlock input.jsnfld' }, { name: 'EMPL_INS_CO_N', selector:'.insCompany2' } ] } };
        function PolicypayLoad(blocks, tCode) {

            const config = POLICY_CONFIG[blocks];
            if (!config) return null;

            const fields = [];

            config.fields.forEach(f => {
                let value = '';

                if (f.fixedValue !== undefined) {
                value = f.fixedValue;
                } else {
                const el = document.querySelector(f.selector);
                value = el ? el.value : '';
                }
                if (value && f.selector && f.selector.includes('#date')) {
                    value = formatDateMMDDYYYY(value);
                }

                if (value) {
                fields.push({
                    Field_Name: f.name,
                    Field_Value: value
                });
                }
            });

            if (!fields.length) return null;

            return {
                Table_Name: config.tableName,
                Entity_Record_Code: tCode,
                Fields: fields
            };
        }

        function formatDateMMDDYYYY(dateVal) {
            if (!dateVal) return '';
            let dateSplit = dateVal.split('/');
            return dateSplit[1]+'/'+dateSplit[0]+'/'+dateSplit[2];
        }
         function  InsPayload(tCode) {
            const blocks =[];
            var selectedTypes = $('#insurancetype').val() || [];
            if (selectedTypes.includes('All Risk Insurance')) {
                blocks[0]='allRiskBlock';
            }

            if (selectedTypes.includes('Third Party Liability')) {
                blocks[1]='tplBlock';
            }

            if (selectedTypes.includes('Employee Compensation')) {
                blocks[2]='ecBlock';
            }
            tCode='{!JSENCODE(rq.rtacn__c)}';
        
            const oneToManyData = blocks
                .map(block => PolicypayLoad(block, tCode))
                .filter(Boolean);

            return {
                OneToManyData: oneToManyData
            };
        }

