                    <!-- .main-navbar-mobile ends -->
                    <apex:outputLabel style="width:100%" rendered="{!if((A.snc__c != null),true,false)}">
                        <div class="alert alert-danger alert-icon align-items-center mt-4">
                            <i class="alert-icon icon-exclamation"></i>
                            <div class="alert-body">
                                <!--Your account currently has sanctions against it. This may prevent you from accessing certain functions or perform regular services on the portal. -->
                                <apex:outputPanel rendered="{!mScSize>1}">
                                    <div id="allSnc" style='display:none'>
                                        <apex:repeat value="{!mSnc}" var="mSk" >
                                            <li>  {!mSnc[mSk]} </li>  
                                        </apex:repeat> 
                                    </div>
                                    <span id='sncWarn'>You have more than one sanctions imposed on your account, please click on <b>View Details</b></span>
                                    
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!mScSize=1}">
                                    <apex:repeat value="{!mSnc}" var="mSk" > 
                                        <p>  {!mSnc[mSk]} </p> 
                                    </apex:repeat>
                                    
                                </apex:outputPanel>
                            </div>
                            <apex:outputPanel rendered="{!mScSize>1}">
                                <div class="alert-actions">
                                    <button id='sncBtn' class="btn btn-outline" onclick='showAllSnc()'>VIEW DETAILS</button>
                                </div>
                            </apex:outputPanel>
                        </div>
                    </apex:outputLabel>
                    
                    
                    
                    
                    
                    <div class="pt-3" style="{!IF(OR(A.Legal_Framework__c = 'Freelancer',A.Type='Customer-DED') , 'display:none' , '')}">
                        <div data-swiper-autoplay="2000" class="swiper-container swiper-counter-container" id="{!if(AND(el['stdElg']!=null,el['stdElg']>0,A.vetst__c>0),'dashboard_counter_slider_5',if(OR(AND(el['stdElg']!=null,el['stdElg']>0),A.vetst__c>0),'dashboard_counter_slider','dashboard_counter_slider_3'))}">
                            <div class="swiper-wrapper">
                                <apex:outputPanel styleClass="swiper-slide" rendered="true">
                                    <!-- <div class="swiper-slide">-->
                                    <apex:outputText rendered="{!A.bgnr__c}">
                                        <div class="counter-panel tips-deposit" data-aos="zoom-in" data-aos-once="true">
                                            <i class="text-primary counter-icon icon-money-2" style="font-size: 3.25rem;"></i>
                                            <div class="counter-title">AVAILABLE DEPOSIT (AED)
                                            <i class="icon-plus-circle mobIcons ml-2" v="Portal Deposit" h="/grqn?c=tad"></i>
                                            </div>
                                            <div class="counter-value" title="{!A.adb__c}"> 
                                                <apex:outputText styleClass="comNum" escape="true" value="{!A.adb__c}">
                                                </apex:outputText>
                                            </div>
                                        </div>
                                    </apex:outputText>
                                    <apex:outputText rendered="{!!A.bgnr__c}">
                                        <div class="counter-panel tips-deposit" data-aos="zoom-in" data-aos-once="true">
                                            <i class="text-primary counter-icon icon-money-2" style="font-size: 3.25rem;"></i>
                                            <div class="counter-title" style="margin-bottom: 0.5rem;">AVAILABLE DEPOSIT (AED)
                                            <i class="icon-plus-circle mobIcons ml-2" v="Portal Deposit" h="/grqn?c=tad"></i>
                                                </div>
                                            <div class="counter-subvalue" style="margin-top: 0rem;" title="{!A.adb__c}"> 
                                                <apex:outputText styleClass="comNum" escape="true" value="{!A.adb__c}">
                                                </apex:outputText>
                                            </div>
                                            <div class="separator-dashed" style="margin: 0.25rem 0;"></div>
                                            <div class="counter-title" style="margin-bottom: 0.5rem;">
                                                {!IF(A.bg__c>=125000,'','AVAILABLE ')}BANK GUARANTEE (AED)
                                            <i class="icon-plus-circle mobIcons ml-2" style="{!IF(A.bg__c>=125000,'display:none;','')}" v="Bank Guarantee Deposit" h="/grqn?c=tad"></i>
                                            </div>
                                            <div class="counter-subvalue" style="margin-top: 0rem;" title="{!IF(A.bg__c>=125000,A.bg__c,A.bgb__c)}"> 
                                                <apex:outputText styleClass="comNum" escape="true" value="{!IF(A.bg__c>=125000,A.bg__c,A.bgb__c)}">
                                                </apex:outputText>
                                            </div>                                      
                                        </div>
                                    </apex:outputText>  
                                    <!-- </div> --->
                                </apex:outputPanel>
                                <!-- .swiper-slide -->
                                <apex:outputPanel styleClass="swiper-slide" rendered="true">
                                    <!-- <div class="swiper-slide"> -->
                                    <div class="counter-panel tips-employee-visas" data-aos="zoom-in" data-aos-once="true">
                                        <i class="text-primary counter-icon icon-conference-call"></i>
                                        <div class="counter-title">AVAILABLE EMPLOYEE VISAS</div>
                                        <div class="counter-value">{!A.vbtemp__c}</div>
                                        <div class="counter-subvalue">{!A.vctemp__c+A.voep__c} <span>USED</span> / {!A.vetemp__c} <span>TOTAL</span></div>
                                    </div>
                                    <!-- </div> -->
                                </apex:outputPanel>
                                <apex:outputPanel styleClass="swiper-slide" rendered="{!A.vetst__c>0}">
                                    <!-- <div class="swiper-slide"> -->
                                    <div class="counter-panel" data-aos="zoom-in" data-aos-once="true">
                                        <i class="text-primary counter-icon icon-student"></i>
                                        <div class="counter-title">AVAILABLE STUDENT VISAS</div>
                                        <div class="counter-value">{!A.vbtst__c}</div>
                                        <div class="counter-subvalue">{!A.vctst__c} <span>USED</span> / {!A.vetst__c} <span>TOTAL</span></div>
                                    </div>
                                    <!-- </div> -->
                                </apex:outputPanel>
                                <!-- .swiper-slide -->
                                
                                <apex:outputPanel styleClass="swiper-slide" rendered="{!if(AND(el['stdElg']!=null,el['stdElg']>0),true,false)}">
                                    <!-- <div class="swiper-slide"> -->
                                    <div class="counter-panel tips-parking-slots" data-aos="zoom-in" data-aos-once="true">
                                        <i class="text-primary counter-icon icon-parking"></i>
                                        <div class="counter-title">AVAILABLE PARKING ACCESS</div>
                                        <div class="counter-value">{!el['stdElg'] +  el['AddElg'] -el['paidUtlzd'] - el['freeUtlzd']}</div>
                                        <div class="counter-subvalue">{!el['paidUtlzd'] + el['freeUtlzd']} <span>USED</span> / {!el['stdElg'] + el['AddElg']} <span>TOTAL</span></div>
