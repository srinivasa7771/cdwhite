    <script>
    var enjoyhint_instance;
    var enjoyhint_script_steps;
    function startQuickTour() {
        enjoyhint_instance.run();
    }
    
    function axsConfirmation(ch,cb,loader,onYes,onYesArgs,onNo,onNoArgs){
        //debugger;
        $('#modal_confirm_global').remove();
        if(cb==undefined) cb='';
        var cBlock = '<div class="modal fade modal-base" id="modal_confirm_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <button aria-label="Close" class="close" data-dismiss="modal" type="button"> <i class="icon-close"></i> </button> <div class="modal-body"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <h2 class="mb-4">'+ch+'</h2> <p>'+cb+'<p class="col-xl-12 col-lg-12" style="text-align: right;"> <button class="col-xl-4 col-lg-12 btn btn-primary mr-2 btn-block-sm cBtns" id="cYes"> YES </button> <button class="col-xl-4 col-lg-12 btn btn-outline-primary btn-block-sm cBtns"> NO </button><i class="d-none cBtns text-primary fa fa-times-circle" aria-hidden="true" style="float: left;"><span>NO</span></i><i class="d-none cBtns text-primary fa fa-check-circle" aria-hidden="true"><span>YES</span></i><br class=""> </div> </div> </div> </div> </div> </div> </div> </div></div>'
        $('body').append(cBlock);
        $('#modal_confirm_global').modal('show');
        $('.cBtns').on('click',function(){
            $('#modal_confirm_global').modal('hide');
            if($(this).text().includes('YES')){
                if(loader)
                    showGLoader();
                if(onYes!=undefined&&onYes!=null&&onYes!=''){
                    if(onYesArgs!=undefined&&onYesArgs!=null&&onYesArgs!='')
                        window[''+onYes](onYesArgs);
                    else
                        window[''+onYes]();
                }
            }
            else if($(this).text().includes('NO')){
                if(onNo!=undefined&&onNo!=null&&onNo!=''){
                    if(onNoArgs!=undefined&&onNoArgs!=null&&onNoArgs!='')
                        window[''+onNo](onNoArgs);
                    else
                        window[''+onNo]();
                }
            }
        });
    }

    
    function callHints(){
        enjoyhint_instance = new EnjoyHint({container: '.main'});
        enjoyhint_instance.set(enjoyhint_script_steps);
        $('#modal_quick_tour').modal('show');
        jQuery.cookie('accName','{!A.name}');
        
    }
    
    
    $(document).ready(function(){
        
        if(jQuery.cookie('accName')!='{!A.name}'&& !mobile.test(navigator.userAgent)){
            $('#modal_welcome_AXS2').modal('show');
            //callHints();
        }
        $('#modal_welcome_AXS2').on('hidden.bs.modal',function(){
            callHints();
        });
        $('#modal_quick_tour').on('hidden.bs.modal',function(){
            $('body').css('overflow','auto');
        });
        (function(form){
            $('#sos').on('invalid' , function(event) {
                event.preventDefault();
            });
            
            form.submit( function(event) {
                if(!this.checkValidity())
                    event.preventDefault();
            });
            
            var submitButton =  $('#searchForm').find( "button[type=submit]" );
            submitButton.bind( "click", function(event) {
                $('.error').remove();
                var v = $('#sos').val();
                if(v==undefined||v.length<1){ 
                    form.append("<div class='error frmErrMsg'>Please fill the field</div>" );
                    $('#sos').focus();
                }
            });
        })($('#searchForm'));
        
        $('.comNum').each(function(){
            $(this).text($(this).text().toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","));
        });
        $('.aReq').each(function(){
            var sr = $(this).attr('reqNum');
            var t = $(this).text().replace('#sr',sr).replace('#SR',sr);
            $(this).text(t);
        });
    });
    </script>
