    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        
        @media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
            span.comNum{overflow:hidden;display:block;}
            .request-description{max-width:20em !important;}
        }
        

        .frmErrMsg {
        color: #E62D38;
        font-size: 1rem !important;
        position: absolute;
        font-weight: 500;
        }
        .badge.badge-status-urgent{
            background-color: #D54040 !important;
        }
        .text-grey{
        color: #9B9B9B !important;
        }
        
        div#navbar_mobile_searchform1{
            position: relative;
            padding: 0rem;
        /*background: #67486c;*/
            border: 0.5px solid rgb(192 13 13 / 83%);
            border-radius: 0.5rem;
        }
        .mobile-only {
        background-color: #fff;
        padding: 1em;
        border-radius: 1em;
        margin: 0.5em;
        }
        .mobile-services .ser {background-color: #fff;margin: 0.9em;padding: 1em;border-radius: 1em;/*border: 1px solid #66486c;*/}
        .mobile-services .ser i{
        font-size: 4.5em;
        display: block;
        padding-bottom: 0.3em;
        }
        .mobile-services .ser a {
            font-size: 0.7em;
        }
        .counter-panel.mobile-services {
            min-height: 11rem !important;
        }
        @media only screen and (min-width: 450px) {
            .mobIcons {display:none;}
        }
        @media only screen and (max-width: 450px) {
            .footer-links a {
                font-size: 0.9em;
            }
        }
        #preloader {
        position: fixed;
        display: flex;
        flex-flow: row nowrap;
        justify-content: center;
        align-items: center;
        left: 0;
        top: 0;
        z-index: 9999;
        width: 100%;
        height: 100%;
        overflow: visible;
        background: #e8e9ec;
        
        }
        .loader1 {
        width: 200px;
        height: 50px;
        background-repeat: no-repeat;
        }
        i.cBtns {
        font-size: 4rem;
        }
        
        @media only screen and (max-width: 450px) {
            i.cBtns  {
            display: block !important;
            }
            button.cBtns  {
            display: none !important;
            }
        }
        
        i.cBtns span {
        display: none !important;
        }

    </style>
