                                <apex:outputLabel rendered="{!IF(contains(A.lcsta__c,'Renewal'),true,false)}" styleClass="badge-status badge-status-underrenewal initialism" value="{!A.lcsta__c}"></apex:outputLabel>
                                <apex:outputLabel rendered="{!IF(contains(A.lcsta__c,'Expired'),true,false)}" styleClass="badge-status badge-status-expired initialism" value="{!A.lcsta__c}"></apex:outputLabel>
                                <apex:outputLabel rendered="{!IF(contains(A.lcsta__c,'Approved'),true,false)}" styleClass="badge-status badge-status-approved initialism" value="{!A.lcsta__c}"></apex:outputLabel>
