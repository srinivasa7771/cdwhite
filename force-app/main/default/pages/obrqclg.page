                                                                    <apex:selectOption itemLabel="--None--"  itemvalue="" id="none"  />
                                                                    
                                                                    <apex:selectOption itemLabel="Duplicate account"  itemvalue="Duplicate"   />
                                                                    <apex:selectOption itemLabel="General enquiry and not a account"  itemvalue="General enquiry and not a account"   />
                                                                    <apex:selectOption itemLabel="Segment not available"  itemvalue="Segment not available"   />  
                                                                    <apex:selectOption itemLabel="Not interested"  itemvalue="Not interested"   />
                                                                    <apex:selectOption itemLabel="Price more than budget"  itemvalue="Price more than budget"   />
                                                                    <apex:selectOption itemLabel="Claims never enquired"  itemvalue="Claims never enquired"   />
                                                                    <apex:selectOption itemLabel="Moved with competition"  itemvalue="Moved with competition"   />
                                                                    <apex:selectOption itemLabel="Nonresponsive account"  itemvalue="Nonresponsive account " />
                                                                    <apex:selectOption itemLabel="Incorrect contact number"  itemvalue="Incorrect contact number"   />
                                                                    <apex:selectOption itemLabel="Not yet decided"  itemvalue="Not yet decided"   />
                                                                    <apex:selectOption itemLabel="Not happy with rules / regulations"  itemvalue="Not happy with rules / regulations"   />
                                                                    <apex:selectOption itemLabel="Auto nonresponsive account closure"  itemvalue="Auto nonresponsive account closure"   />
                                                                    <apex:selectOption itemLabel="Test account"  itemvalue="Test account"   />                                
                                                                </apex:selectList> 
