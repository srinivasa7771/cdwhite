                                                                                 styleClass="requiredFld forDraft form-control input-select2-flat" size="1" >
                                                                    <apex:selectOption itemLabel="--None--"  itemvalue=""  />
                                                                    
                                                                    <apex:selectOption itemLabel="Non-Responsive" itemvalue="Non-Responsive"/>
                                                                    <apex:selectOption itemLabel="Contacted and needs follow up" itemvalue="Contacted and needs follow up"/>
                                                                    
                                                                    <apex:selectOption itemLabel="Contacted and interested" itemvalue="Contacted and interested"/>
                                                                    <apex:selectOption itemLabel="Contacted and assigned to PRM" itemvalue="Contacted and assigned to PRM"/>
                                                                    <apex:selectOption itemLabel="Not required" itemvalue="Not required"/>      
                                                                    <apex:selectOption itemLabel="Contacted and not interested" itemvalue="Contacted and not interested"/>                          
                                                                </apex:selectList> 
                                                            </div>
                                                            <div class="m-2 onLogCtgSelect d-none">
                                                                <i class="icon-info-circle text-primary"></i>
                                                                <span id="logDesc" class="m-2"></span>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-12 showForCancel d-none">
