                                                                       data-toggle="datetimepicker" data-target="#rDate" 
                                                                       onchange = "assignfldVal(this.value,'rmdDt');checkDate(this,'fromToday');" validationname="rmdDate" />
                                                                <script type="text/javascript">
                                                                cs['rDate']=document.getElementById('rDate');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#rDate">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                                
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
