                                                        cs['cltp']=getC('{!$Component.cltp}');
                                                        </script>
                                                        <div class="form-group">
                                                            <label class="srvNew custom-radio custom-radio-sm mr-4" id="rmd">
                                                                <input type="radio" bVal="rmd" name="response" name1="reminder" onchange="toggleOnCheck(this,'.showOnRem,.showForLog','.showForCancel,.dup_accs,.showOnExt');" />
                                                                <span>Set Reminder</span>
                                                            </label>
                                                            <label class="srvNew custom-radio custom-radio-sm mr-4{!IF(extFlg,'',' d-none')}" >
                                                                <input type="radio" bVal="ext" name1="extension" onchange="toggleOnCheck(this,'.showOnExt,.showForLog','.showForCancel,.dup_accs,.showOnRem',)" name="response" />
                                                                <span>Extension</span>
                                                            </label>
                                                            <label class="srvNew custom-radio custom-radio-sm mr-4" >
                                                                <input type="radio" bVal="cn" onchange="toggleOnCheck(this,'.showForCancel,.dup_accs','.showOnRem,.showOnExt,.showForLog')" name="response" name1="cancelSR"/>
                                                                <span>Cancel Account</span>
                                                            </label>
                                                            <label class="custom-checkbox custom-checkbox-sm mr-4" >
                                                                <input type="checkbox" onchange="respOnchange(this)" id='resp_check' name="response"/>
                                                                <span>No Response</span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                    
