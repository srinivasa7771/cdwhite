                                                                       onchange = "assignfldVal(this.value,'rmdDt');checkDate(this,'fromTomorrow');" validationname="extDate" />
                                                                <script>
                                                                cs['eDate']=document.getElementById('eDate');
                                                                </script>
                                                                <div class="input-group-append">
                                                                    <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#rDate">
                                                                        <i class="icon-date"></i>
                                                                    </button>
                                                                </div>
                                                                
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    
