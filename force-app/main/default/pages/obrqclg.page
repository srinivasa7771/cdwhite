        </apex:form>
        <script>
        var reasonDesc= {"Duplicate":"These parameters are being defined already with a separate project with IT. This may take some time hence for now any account submitted by client and he claims he has submitted already can be considered duplicate.","General enquiry and not a account":"Not a account but generally enquiring on the facilities and details","Segment not available":"customer is looking for a segment that we do not have.<br/><br/>Example:<br/><ol><li>A freelancer under a management consultant</li><li>Do yoga , dancing etc …. ( we do not have these options) </li></ol>","Not interested":"Customer is reachable but not interested. <span style='color:red'>(Customers to be flagged in this category only if he is not explaining the reason for the same after probing)</span>","Price more than budget":"Customer is not happy with the price","Claims never enquired":"Customer claims he has never enquired for the account","Moved with competition":"Customer moved out to a different competition ( capture the competitor)","Nonresponsive account":"Customer not responding after 3 attempts ","Incorrect contact number":"customer details are not clear and hence not reachable ","Not yet decided":"Customer has not finalised , will confirm. Will raise a new account if the 30 day window is over, else part of follow up","Not happy with rules / regulations":"Customer not comfortable with any rules / regulations ","Auto nonresponsive account closure":"This reason is to be used only when the account is closed in bulk / through system","Test account ":"accounts created for test purpose by internal team","Non-Responsive":"When customer doesn't answer","Contacted and needs follow up":"Customer answered and said he is busy call back later hence attempt is arranged for another day","Contacted and not interested":"Contacted , but the customer is clear of non-interest and hence agent will close the account after tagging it in this category ","Contacted and interested":"Customer interested and supported to go to the next phase","Contacted and assigned to PRM":"Contacted , but customer unable to action and hence assigned to PRM","Not required":"When no call is required (rarely used). This can be to close dummy account or test account"};
        $(document).ready(function(){
            if(window.parent == window){
                $('.main-header,.top-navbar-user').removeClass('d-none');
                $('.onboarding-nav-prev').addClass('d-none');
            }
            else{
                $('.site-header-wrapper').removeClass('site-header-wrapper');
            }
            $('.datesToFormat').each(function(){
                v = $(this).text();
                if(v && v!='NA'){
                    $(this).text(getFormattedDate(v));
                }
            });
            $('#logTable').DataTable({
                dom: 'Alfrtip',
                "pageLength": 5,
                language: {
                    'paginate': {
                        'previous': '<i class="fa fa-long-arrow-left"></i><span> PREV</span>',
                        'next': '<span>NEXT </span><i class="fa fa-long-arrow-right"></i>'
                    }
                }
            });
        });
        
        function closePopup(){
            window.parent.closePopupFromParent();
        } 
        function respOnchange(e){
            removeValError(cs['Description']);
            cs['Description'].value='';
            $('[for="logCtg"] option[value="Not required"]').removeClass('d-none');
            $('[for="logCtg"] option[value="Contacted and not interested"]').removeClass('d-none');
            reConstructSelect2('[for="logCtg"]');
            let v = $(e).is(':checked');
            let t = $(e).parent().text().trim();
            v?cs['Description'].value=t:'';
            $('.onboarding-nav-next').text('Submit').attr('for','log');
            if(v){
                cs['rmdDt'].value=cs['eDate'].value=cs['rDate'].value='';
                cs['cltp'].value = '';
                $('[type="radio"]').prop('checked',false);
                $('.frmErrMsg,.showOnExt,.showOnRem,.showForCancel,.dup_accs').addClass('d-none');//
                $('.showForLog').addClass('d-none');
            }
            else{
                $('.showForLog').removeClass('d-none');
                // $('#eDate,#rDate').removeClass('d-none');
            }
            
        }
        function setReminderDate(e){
            let v = $(e).is(':checked');
            v?$(elem).removeClass('d-none'):$(elem).addClass('d-none');
            if(v){
                $('.showOnRem').removeClass('d-none');
            }
            else{
                $('.showOnRem').addClass('d-none');
            }
        }
        function toggleOnCheck(e,showElem,hideElem){
            $('#resp_check').prop('checked',false).trigger('change');
            let v = $(e).is(':checked');
            let name1 = $(e).attr('name1');
            let bVal = $(e).attr('bVal');
            cs['cltp'].value = bVal;
            if(bVal != null && bVal == 'rmd'){
                // to hide
                $('[for="logCtg"] option[value="Not required"]').addClass('d-none');
                $('[for="logCtg"] option[value="Contacted and not interested"]').addClass('d-none');  
                reConstructSelect2('[for="logCtg"]');
            }
            else{
                $('[for="logCtg"] option[value="Not required"]').removeClass('d-none');
                $('[for="logCtg"] option[value="Contacted and not interested"]').removeClass('d-none');
                reConstructSelect2('[for="logCtg"]');
            }
            $(showElem).addClass('d-none');
            $('[for="logCtg"]').val('').trigger('change');
            $('[for="cnRsn"]').val('').trigger('change');
            if(name1=="cancelSR"){
                $('.onboarding-nav-next').text('Cancel Account').attr('for','cancel');
            }
            else if(name1){//if(name1=="remainder")
                $('.onSelAll').prop('checked',false);
                $('.onboarding-nav-next').text('Submit').attr('for','log');
            }
            
            if(v){
                $(showElem).removeClass('d-none');
            }
            $(hideElem).addClass('d-none');
        }
        function assignfldVal(val,fldId){
            var v = (val);
            cs[fldId].value=(v!=false)?v:val;
        }
        function validateData(e){
            let f = $(e).attr('for');
            let validated = true;
            let proceed = true;
            $('.requiredFld:visible').each(function(){
                let v = $(this).val();
                if(!v || v=='--None--'){
                    addValError($(this),'This field is required!');
                    validated = false;
                }
            });
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if(validated){
                if(f=='cancel'){
                    proceed = confirm('Are you sure to cancel selected Account(s).\nThis action cannot be reverted.');
                }
                if(proceed){
                    showTempLoader();
                    crtsk();
                }
            }
            else{
                return;
            }
        }
        function showDesc(e){
            let v = $(e).val();
            let f = $(e).attr('for');
            $('.onCancelSelect,.onLogCtgSelect').addClass('d-none');
            cs['Description'].value = '';
            $('#cancelDesc').html('');
            if(v){
                removeValError($(e));
                if(f=='logCtg'){
                    $('.onLogCtgSelect').removeClass('d-none');
                    $('#logDesc').html(reasonDesc[v]);
                }
                else{
                    $('.onCancelSelect').removeClass('d-none');
                    $('#cancelDesc').html(reasonDesc[v]);
                }
                cs['Description'].value = reasonDesc[v].replace(/<\/?[^>]+(>|$)/g, "");
                removeValError(cs['Description']);
            }
        }
        function selectAll(e){
            let v = $(e).prop('checked');
            $('.onSelAll').prop('checked',v);
        }
        function reConstructSelect2(elem){
            $(elem).select2('destroy');
            $(elem).select2({
                templateResult: function(option) {
                    var myOption = $(elem).find('option[value="' + option.id + '"]');
                    if (!myOption.hasClass('d-none')) {
                        return option.text;
                    }
                    return false;
                }
            });
        }
        /* to override from AXS2CustomJs */
        function checkDate(elem,type){
            var e = $(elem);
            var date;
            var date1 = e.val();
            var label = $(elem).attr('label');
            var vldName = $(elem).attr('validationname');
            date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
            var days = new Date(new Date(date)-new Date())/1000/60/60/24;
            var r = true;
            console.log('days '+days);
            removeValError(e);
            if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                addValError(e,'Invalid date!');
            }
            else if(type=='fromTomorrow'){
                if(days<0)
                    addValError(e,'Date shouldn\'t be a today/past date!');
            }
                else if(type=='fromToday'){
                    if(days<-1)
                        addValError(e,'Date shouldn\'t be a past date!');
                    if(vldName=='rmdDate'){
                        let days1 = new Date(new Date(date)-new Date('{!accClsDt}'))/1000/60/60/24;
                        if(days1>0)
                            addValError(e,'Date shouldn\'t exceed 30 working days from registration date for '+label+'!');
                    }
                }
        }
        </script>
    </html>    
</apex:page>