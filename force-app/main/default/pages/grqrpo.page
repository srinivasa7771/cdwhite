            .warningMsg{
            color:#004eff;
            font-style: italic;
            padding-left: 0.8rem;
            position: absolute;
            background-color: #d5ded9;
            }
        </style>
        <apex:form id="mainForm" styleClass="form-style" >
            
            <apex:pageBlock id="pbMain" >
                
                <apex:outputPanel >
                    <apex:outputPanel id="saveRq"></apex:outputPanel>
                    <apex:actionFunction name="next"  action="{!saveReq}" status="theStatus"  reRender="pbMain,errmsg,saveRq,msg" oncomplete="$('#preloader').fadeOut();hideGLoader();"    onbeforedomupdate="javascript: toggle_inputs();"/>
