        function checkEmail(elem){
            var t = $(elem).attr('att');
            var email = $(elem).val();
            var regex = /^[-a-z0-9~!$%^&*_=+}{\'?]+(\.[-a-z0-9~!$%^&*_=+}{\'?]+)*@([a-z0-9_][-a-z0-9_]*(\.[-a-z0-9_]+)*\.(aero|arpa|biz|com|coop|edu|gov|info|int|mil|museum|name|net|org|pro|travel|mobi|[a-z][a-z])|([0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}))(:[0-9]{1,5})?$/;
            var r = (regex.test(email))?true:'invalid';
            if(r == 'invalid' && email != ''){
                if(t=='email') addValError(elem,'Please enter valid email Address.');
                //else addValError(elem,'Username should be in valid email format.');
                if(t=='uName'){
                    showTempLoader_input(elem);
                    removeValError(this);
                    cs['username'].value = email;
                    chkUserName();
                }
                return false;
            }else{
                removeValError(elem);
                if(t=='email'){
                    showTempLoader_input(elem);
                    chkUserEmail();
                }
            }
        }
