                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Last name</label>
                                                    <apex:inputText id="emplstName" styleClass="form-control requiredFld" value="{!lastName}" onfocus="clearLastname();" disabled="{!conExist}"/>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Passport number</label>
                                                    <apex:inputText id="passportNumber" styleClass="form-control requiredFld" value="{!passNumber}" onfocus="clearPassNumber();" disabled="{!conExist}">
                                                        <apex:actionSupport event="onchange" action="{!validateUnique}" oncomplete="showConfirmation('{!contactAlreadyExisits}','{!pgMsg}');" reRender="dummyblock">
                                                            <apex:param id="showMsg1" name="showMsg1" value="" assignTo="{!contactAlreadyExisits}"/>
                                                            <apex:param id="msgVal1" name="msgVal1" value="" assignTo="{!pgMsg}"/>
                                                        </apex:actionSupport>
                                                    </apex:inputText>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Nationality</label>
                                                    <apex:selectList value="{!nationality}" id="nationVal" size="1" styleClass="form-control input-select2-flat requiredFld" disabled="{!conExist}">
                                                        <apex:selectOption itemLabel="--None--" itemValue="Select" itemDisabled="true"></apex:selectOption>
                                                        <apex:selectOptions value="{!regions}"/>
                                                        <apex:actionSupport event="onchange" action="{!validateUnique}" oncomplete="showConfirmation('{!contactAlreadyExisits}','{!pgMsg}');" reRender="dummyblock">
                                                            <apex:param id="showMsg2" name="showMsg2" value="" assignTo="{!contactAlreadyExisits}"/>
                                                            <apex:param id="msgVal2" name="msgVal2" value="" assignTo="{!pgMsg}"/>
                                                        </apex:actionSupport>
                                                    </apex:selectList>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            
                                        </div>
                                        <!-- .row -->
                                        
                                        <div class="separator-dashed"></div>
                                        <div class="row">
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Email</label>
                                                    <apex:inputText id="empmail" styleClass="form-control requiredFld" value="{!emailId}" onfocus="clearEmail();">
                                                        <apex:actionSupport event="onchange" onsubmit="showTempLoader_input(this)" action="{!checkUserExistWithAnotherAcc}" oncomplete="showConfirmation('{!UsrExistWithAnotherAcc}','{!pgMsg}');hideTempLoader_input();" reRender="dummyblock">
                                                            <apex:param id="showMsg3" name="showMsg3" value="" assignTo="{!UsrExistWithAnotherAcc}"/>
                                                            <apex:param id="msgVal3" name="msgVal3" value="" assignTo="{!pgMsg}"/>
                                                        </apex:actionSupport>
                                                    </apex:inputText>
                                                </div>
                                            </div>
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Username</label>
                                                    <div class="d-flex">
                                                        <apex:inputText id="usrname" styleClass="form-control requiredFld" html-att="uName" html-placeholder="No special characters allowed." onblur="checkUsername(this)" onkeyup="showUserName(this)" onchange="checkEmail(this)" value="{!username}" /> <!-- onfocus="focusUsername(this)" -->
                                                        <input class="form-control ml-3 requiredFld" value="{!'@'+A.park__c+'.axs'}" style="flex-basis: 110px;width: 110px;" disabled="true"/>
                                                    </div>
                                                    <apex:inputHidden id="username" value="{!username}" />
                                                    <!--<apex:actionSupport event="onchange" onsubmit="removeValError(this);showTempLoader_input(this)" action="{!chkUserName}" oncomplete="showFldErr('{!UsrExistWithAnotherAcc}',document.getElementById('{!$Component.frmDiv:empInfo:usrname}'));hideTempLoader_input();" reRender="usrname">-->
                                                    <apex:actionFunction name="chkUserName" action="{!chkUserName}" oncomplete="showFldErr('{!UsrExistWithAnotherAcc}',document.getElementById('{!$Component.frmDiv:empInfo:usrname}'));hideTempLoader_input();">
                                                        <apex:param id="showMsg4" name="showMsg4" value="" assignTo="{!UsrExistWithAnotherAcc}"/>
                                                        <apex:param id="msgVal4" name="msgVal4" value="" assignTo="{!pgMsg}"/>
                                                    </apex:actionFunction>
                                                    <script>
                                                        cs['username'] = document.getElementById("{!$Component.username}");
                                                    </script>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Mobile number</label>
                                                    <div class="d-flex">
                                                        
                                                        <apex:inputText styleClass="form-control mr-3 requiredFld" value="{!CounCode}" style="flex-basis: 80px;width: 80px;" maxlength="4" disabled="true"/>
                                                        <apex:inputText styleClass="applMob form-control requiredFld ml-3 numOnly jsnfld" value="{!phNo}" id="mobNum" onfocus="clearMobNo();" maxlength="9"/>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Address</label>
                                                    <apex:inputText styleClass="form-control requiredFld" value="{!addVal}" onfocus="clearAddress();" id="addressVal"/>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Work phone</label>
                                                    <div class="d-flex">
                                                        <apex:inputText styleClass="form-control mr-3" value="{!WrkCounCode}" style="flex-basis: 80px;width: 80px;" maxlength="4" disabled="true"/>
                                                        <apex:inputText styleClass="applMob form-control ml-3 numOnly jsnfld" value="{!wrkphNo}" id="wrkNum" onfocus="clearWrkNo();" maxlength="9" />
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- .col -->
                                        </div>
                                        <!-- .row -->
                                        
                                    </div>
                                    <!-- .form-style -->
                                </apex:pageBlock>
                                <div class="separator-dashed"></div>
                                
                                <h2 class="modal-title mb-4">Access Levels</h2>
                                
                                <div class="mb-1">
                                    <label class="custom-checkbox custom-checkbox-sm">
                                        <apex:inputCheckbox value="{!defaultGroupsAccess}" onchange="defaultSelected(this.value);" id="accessCheckBox"/>
                                        <span>Default</span>
                                    </label>
                                </div>
                                <apex:pageBlock id="dataTable">
                                    <div class="form-style">
                                        <div class="row row-lg">
                                            <div class="col-lg-6">
                                            </div>
                                            <div class="col-lg-2" style = "text-align: center;background-color: transparent;border-top: none;border-bottom: 2px solid rgba(103, 109, 120, 0.2);color: #979AA7;font-weight: 500;font-family: Helvetica Neue Cond, Helvetica Neue, Arial, sans-serif;letter-spacing: 0.75px;border: none;vertical-align: bottom;padding: 0.75rem;">
                                                DATA ENTRY
                                            </div>
                                            <div class="col-lg-4" style = "text-align: center;background-color: transparent;border-top: none;border-bottom: 2px solid rgba(103, 109, 120, 0.2);color: #979AA7;font-weight: 500;font-family: Helvetica Neue Cond, Helvetica Neue, Arial, sans-serif;letter-spacing: 0.75px;border: none;vertical-align: bottom;padding: 0.75rem;">
                                                PAYMENT APPROVER
                                            </div>
                                        </div>
                                        <div style="width:100%; height:2px; background: rgba(103, 109, 120, 0.2);"></div>
                                        <apex:variable value="{!0}" var="ind"/>
                                        
                                        <apex:repeat value="{!servOptions}" var="ser1" id="servRepeat1">
                                            <apex:variable var="ind" value="{!ind+1}"/>
                                            <div class="row row-lg" style="border-color: rgba(151, 151, 151, 0.3);border-bottom-style: dashed;border-width: thin;">
                                                <div class="col-sm-1" style="border-color: rgba(151, 151, 151, 0.3);vertical-align: middle;position: relative;padding-top: 20px;padding-bottom: 20px;padding-left: 30px;">
                                                    <img id="{!ind}right" src="{!$Resource.chevronright_60}" onclick="showServices(this);" style="display:inline;"/>
                                                    <img id="{!ind}down" src="{!$Resource.chevrondown_60}" onclick="hideServices(this);" style="display:none;"/>
                                                </div>
                                                <div class="col-lg-5" style="border-color: rgba(151, 151, 151, 0.3);vertical-align: middle;position: relative;padding-top: 20px;padding-bottom: 20px;padding-left: 10px;">
                                                    {!ser1.grpName}
                                                </div>
                                                <div class="col-lg-2" style="text-align: center;border-color: rgba(151, 151, 151, 0.3);vertical-align: middle;position: relative;padding-top: 20px;padding-bottom: 20px;padding-left: 30px;">
                                                    <label class="custom-checkbox custom-checkbox-sm custom-checkbox-no-label mb-0">
                                                        <apex:inputCheckbox value="{!ser1.grpDE}" />
                                                        <span></span>
                                                    </label>
                                                </div>
                                                <div class="col-lg-4" style="text-align: center;border-color: rgba(151, 151, 151, 0.3);vertical-align: middle;position: relative;padding-top: 20px;padding-bottom: 20px;padding-left: 30px;">
                                                    <label class="custom-checkbox custom-checkbox-sm custom-checkbox-no-label mb-0">
                                                        <apex:inputCheckbox value="{!ser1.grpAE}" onchange="checkDependentVal({!ind},this.value);"/>
                                                        <span></span>
                                                    </label>
                                                </div>
                                                <div class="col-lg-6" id="{!ind}serName" style="display:none;padding-left: 40px;">
                                                    <apex:repeat value="{!ser1.groupedSerName}" var="srName" id="servRepeat">
                                                        <ul>{!srName}</ul>
                                                    </apex:repeat>
                                                </div>
                                            </div>
                                            
                                        </apex:repeat>
                                    </div>
                                </apex:pageBlock>
                                <div class="separator-dashed"></div>
                                <div class="text-right" id="addUserButton">
                                    <a href="#" onClick="validateData()" class="btn btn-primary"> ADD USER </a>
                                </div>
                                <div class="text-right" id="ManageUserButton" style="display:none;">
                                    <a href="#" onClick="validateData()" class="btn btn-primary"> MANAGE USER </a>
                                </div>
                                <apex:pageBlock id="dummyblock"></apex:pageBlock>
                            </div>
                            <!-- .modal-body -->
                        </div>
                        <!-- .modal-content -->
                    </div>
                    <!-- .modal-dialog -->
                </div>
                <!-- User Management Modal Ends-->
                
            </apex:form> 
            
            <!-- .connect-buttons -->
            
            <!-- main js -->
            <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js')}"  />
            
        </body>
        
    </html>
</apex:page>