                    cs["xcsrs__c"].value=$(e).val() ;
                }
                function depSelect(e){
                    if($('#depSelId').val()!='Select'){
                        $('#depSelId').parents('.form-group').find('.frmErrMsg').remove();
                    }
                    
                    cs["xard__c"].value=false;
                    if('{!sd.cv__c}' == 'CancelVisaDep' ){
                        $('.depType').hide();
                        
                        if($(e).val() != null && $(e).val() != '' && $(e).val() != 'Add'){
                            cs['Con__c'].value =$(e).val(); 
                            
                        }
                        else{
                            cs['Con__c'].value = ''; cs["xard__c"].value=true;
                            $('.depType').show();
                        }
                    }
                    else if( '{!sd.cv__c}' == 'DepInsCmp'){
                        $('.depType').hide();
                        
                        if($(e).val() != null && $(e).val() != '' && $(e).val() != 'Add'){
                            cs['Con__c'].value =$(e).val();
                            // saveRequest('true','lp',); 
                            cs['xadh__c'].value='inr';
                            
                            cs["srvc__c"].value = $('[name="service_id"]').val();
                            
