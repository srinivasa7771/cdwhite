                function depTypeSelect(e){
                    if($('#depTypeId').val()!='Select'){
                        $('#depTypeId').parents('.form-group').find('.frmErrMsg').remove();
                    }
                    // to skip age validation on DOB for dependent cancellation
                    cs["uid"].value = 'onlyPast';
