                function axsConfirmation_doc(ch,cb,options,doclink,yesBtnText,noBtnText,yesDocId,noDocId){
                    $('#modal_confirm_global').remove();
                    if(cb==undefined) cb='';
                    var cBlock = '<div class="modal fade modal-base" id="modal_confirm_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;">';
                    cBlock+= '<div class="modal-content"><button aria-label="Close" class="close" data-dismiss="modal" type="button"><i class="icon-close"></i></button>';
                    cBlock+= '<div class="modal-body"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto">'; 
                    if(ch)
                        cBlock+= '<h2 class="mb-4">'+ch+'</h2>';
                    if(cb)
                        cBlock+= '<p>'+cb+' </p>';
                    cBlock+= '<p class="row col-xl-12 col-lg-12" style="text-align: right;">';
                    cBlock+= '<button class="col-xl-4 col-lg-12 btn btn-primary mr-2 btn-block-sm cBtns" id="cYes" val1="yes"> '+(yesBtnText?yesBtnText:"YES")+' </button> <br/>';
                    cBlock+= '<button class="col-xl-4 col-lg-12 btn btn-outline-primary btn-block-sm cBtns" val1="no"> '+(noBtnText?noBtnText:"NO")+' </button> <br />';
                    cBlock+= '</div> </div> </div> </div> </div> </div> </div> </div> </div>';
                    $('body').append(cBlock);
                    if(options){
                        $('#modal_confirm_global').modal('show');
                    }
                    else{
                        window.open('/servlet/servlet.FileDownload?file='+doclink,'_blank');
                    }
                    $('.cBtns').on('click',function(){
                        $('#modal_confirm_global').modal('hide');
                        if($(this).attr('val1').includes('yes')){
                            window.open('/servlet/servlet.FileDownload?file='+yesDocId,'_blank');
                        }
                        if($(this).attr('val1').includes('no')){
                            window.open('/servlet/servlet.FileDownload?file='+noDocId,'_blank');
                        }
                    });
                }
                
