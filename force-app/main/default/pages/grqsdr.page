                            else if(cv=='CancelVisa')
                                axsConfirmation_doc('','Kindly select whether the applicant is',true,'','Inside the UAE','Outside the UAE','015Ii000000kU1d','015Ii000000kU1e');
                                else if(cv=='VisaCorrection' && ctg=='Students')
                                    axsConfirmation_doc('','Please choose',false,'015Ii000000kVcY');
                                    else
                                        axsConfirmation_doc('','Please choose',false,'015Ii000000kU1f');
                }
