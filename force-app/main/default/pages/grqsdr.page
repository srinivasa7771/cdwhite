                    if(rqFlg == 'true' && ('{!sd.cv__c}' == 'DepRenewal' || '{!sd.cv__c}' == 'CancelVisaDep') && (cs['Con__c'].value == 'undefined' ||  cs['Con__c'].value == ''))
                        cs["parseId"].value = 'true';
                    //alert('tsts::');
                    //$('#modal_upload_passport').modal('show');
                    $('#modal_fileuploadPopUp').modal('show');
                }
                
                function formatDate(date){
                    var d = date.split('/');
                    var dd = new Date();
                    dd.setFullYear(d[2], (parseInt(d[0]))-1, d[1]);
                    console.log(dd);
                    return dd;
                }
                function formatDate2(date){
                    let d = date.split('/');
                    let dd = d[1]+'/'+d[0]+'/'+d[2];
                    return dd;
                }
                function chkVisaValidity(dt){
                    var days = (new Date(formatDate2(dt))-new Date())/1000/60/60/24;
                    //alert(days);
                    if(days>=90)
                        return true;
                    return false;
                }  
