                        }
                        else{
                            cs['Con__c'].value = ''; cs["xard__c"].value=true;
                            $('.depType').show();
                        }
                    }
                        else if( '{!sd.cv__c}' == 'DepGVTrns'){
                            var lst = $(e).val().split("_");
                            cs['Con__c'].value = lst[1];
                            cs["srvc__c"].value = $('[att1="'+lst[0]+'"]').val();
                            //cs["srvc__c"].value = $('[name="service_id"]').val();
                            toggleGLoader();applicantSave();
                        }
                            else{
                                $('.depSrv').show(); 
                                var lst = $(e).val().split("_");
                                if(lst[0] == 'Spouse'){
                                    cs['Con__c'].value = lst[1];
                                    $('.vSpouse').show();$('.vChild').hide();$('.srvNew').show();$('.srvTransfers').hide();
                                    
                                    
                                }
                                else if(lst[0] == 'Child'){
                                    cs['Con__c'].value = lst[1];
                                    $('.vChild').show();$('.vSpouse').hide();$('.srvNew').hide();$('.srvTransfers').show();
                                }
                                    else{
                                        cs['Con__c'].value = ''; cs["xard__c"].value=true;
                                        $('.vChild').show();$('.vSpouse').show();$('.srvNew').show();
                                    }
                            }
