        function proceedAuditForm(){
            var validated  = true;
            $('.auditFld').each(function(){
                var v = $(this).val();
                console.log('v2:::'+v);
                if(v==''||v==null || v==undefined){
                    addValError(this,'**This field is required!');
                    validated=false;
                    
                }else{
                    removeValError(this);  
                    
                }
            });
            console.log('validated::'+validated);
            if(validated){
                cs['xadtx4__c'].value = cs['auditJustificationId'].value;
                cs['dsgu__c'].value = false;
                $('#modal_AuditJustification').modal('hide');
                //$('#preloader').fadeIn();
                //nxtPg();
                axsConfirmation('Terms & Conditions',tAndC,true,'nxtPg');
                $('#modal_confirm_global .cBtns').text('Decline');
