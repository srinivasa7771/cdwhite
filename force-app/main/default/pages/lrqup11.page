        var invalData = false;
        $('.requiredFld').each(function() {
            if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                return;
            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            if (v == '' || v == null || v == undefined || v.lenght < 1) {
                if ($(this).is('select')) {
                    showErrMsg($(this).next().find('.select2-selection'), 'rqrd', 'invalid');
                } else if ($(this).attr('data-toggle') == 'datetimepicker') {
                    showErrMsg($(this), 'rqrdDate', 'invalid');
                } else
                    showErrMsg($(this), 'rqrd', 'invalid');
                invalData = true;
                $('.rqrdMsg').html('All fields are mandatory').css('color', 'red').fadeOut().fadeIn();
            } else
                showErrMsg($(this), 'rqrd', true);
        });
        for(var x=0;x<$('.modal-body .input-datepicker').length;x++){
            var i = $('.modal-body .input-datepicker')[x]; 
            var vl = $(i).val();
            if($(this).is(':visible')){
                if (vl.length != 10 || vl.match(/\//g) == null) {
                    showErrMsg($(i), 'dob', 'invalid');
                    invalData = true;
                } else if (vl.match(/\//g) != null) {
                    if (vl.match(/\//g).length != 2) {
                        showErrMsg($(i), 'dob', 'invalid');
                        invalData = true;
                    }
                }
            }
        }
        //var uid = cs["uid"].value;
        //checkAllDates('dateCheck', uid,$('#genderid').val());
        checkdobPid($('[validationname="dob"]'), $('[validationname="pid"]'));
        if ($('.frmErrMsg').length > 0 && $('.frmErrMsg').is(':visible')) {
            invalData = true;
        }
        if (invalData) {
            invalData = false;
            return;
        }
        var isGCCnational = false;
        var isAllowedOA = true;
        var country = $('[fldName="country"]').find("option:selected").text();
        if (GCC_Nations.includes(country))
            isGCCnational = true;
        if (!onArrVisa.includes(country))
            isAllowedOA = false;
        if((serviceId=='058'||serviceId=='074')&&onArrVisa.includes(country)){
            $('.rqrdMsg').html(country+' nationality applicants can get the on arrival visa').css('color', 'red').fadeOut().fadeIn();
            return;
        }
        if (isGCCnational && '{!JSENCODE(rq.srvc__r.uid__c)}' != '220'&& serviceId != '068' && serviceId != '123' && serviceId != '149'  && serviceId != '087' && serviceId != '088') {
            if(serviceId=='040')
                $('.rqrdMsg').html('Applicant is a GCC national, please apply for Non-Sponsored ID card').css('color', 'red').fadeOut().fadeIn();
            else 
                $('.rqrdMsg').html('GCC nationals are not allowed for this service').css('color', 'red').fadeOut().fadeIn();
            //axsAlert('Error','Applicant is GCC National');
            return;
        }
        if(serviceId=='181'&&!onArrVisa.includes(country)){
            $('.rqrdMsg').html(country+' nationality applicants are not allowed for this service').css('color', 'red').fadeOut().fadeIn();
            //axsAlert('Error','Applicant is GCC National');
            return;
        }
        if ($('#genderid').val() == 'M' && (serviceId == '018' || serviceId == '117')) {
            $('.rqrdMsg').html('Applicant should be Female to apply for Spouse Visa Transfer').css('color', 'red').fadeOut().fadeIn();
            return;
        }
        $('[forLoad="' + currentDoc + '"]').find('.loader_img').show();
        $('*').addClass('loadingProgress');
        $('#modal_confirm_information1').modal('hide');
        if('{!JSENCODE(rq.srvc__r.uid__c)}'=='220')
         cs["docname"].value = cs["docname"].value +'.pdf';
        saveRequest();
    }
    function saveRequest(){
        saveAtt();
    }
   </script>
