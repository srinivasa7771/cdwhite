            vDebug += "toString(): " + " value: [" + err.toString() + "]";
            alert(vDebug);
        }
      blExecuting = false;  
    }
    function CallObjSet() {
        //alert(cIndx);
        var ReturnVal;
        try {
            if (obj) {                
                ReturnVal = obj.SetBrowser(hwnd);   
            } else {
                alert("Object is not created!");
            }
            if (ReturnVal == 1) { alert("Form Submitted.") }
            else { alert("Issue while Submitting the Form. Please contact administrator.") }
        } catch (ex) {
            alert("Some error happens, error message is: " + ex.Description);
        }
    }        

    function setText(txt) {
        myTextBox.value = txt;
    }

    function appendText(txt) {
        myTextBox.value = myTextBox.value + txt;
    }
    function MyComComponent_onunload() {
        obj.Dispose();
    }   
    function sleep(milliseconds) {
        var start = new Date().getTime();
        for (var i = 0; i < 1e7; i++) {
            if ((new Date().getTime() - start) > milliseconds){
                break;
            }
        }
    }
    window.onload = function() { 
      try {               
        Reset();Execute();drawszlider(100, 0);
