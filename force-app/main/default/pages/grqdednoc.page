        <script type="text/javascript">
        var cs = {};
        var capNotChecked =false ;
        $(document).ready(function(){
            //Hide fields
            setTimeout(function(){
                createDedActOption();
            },1000);
            var Lictype =cs['xltp__c'].value;
            if(Lictype == ''){
                let flds = [cs['xcfn__c'],cs['xcna__c'],cs['xdedln__c'],cs['xzn']];
                flds.forEach(function(i){
                    $(i).parent().parent().hide();
                });
            }
            //show docs based on licencse type
            //showDocList(cs['xltp__c']);
            //show  docs  based on amendment category
            if(cs['xltp__c'].value == 'Amendment' || cs['xltp__c'].value == 'Renewal With Amendment'){
                console.log('Amendment');
                showAmendCatDocList(cs['xcamc']);
                addDocDwndLink(cs['xltp__c'].value);
            }else{
                showDocList(cs['xltp__c']);
            }
            //show description and fields
            shwDescription(cs['xltp__c'].value);
            
            //create activities list
            $('#hpr').val(cs["xuvdet__c"].value.split(';'));
            //try{$('#hpr').select2();}catch(e){}
            
            
            
            //Close the page loader
            setTimeout(function(){
                hideGLoader();
                if('{!ispu}'!='true' && '{!isgu}'!='true')
                    $(cs["xltp"]).trigger('change');
            },400);
            //Date validation
            $(".formatDt").keyup(function(){
                this.value=this.value.replace(/^(\d\d)(\d)$/g,'$1/$2').replace(/^(\d\d\/\d\d)(\d+)$/g,'$1/$2').replace(/[^\d\/]/g,'');
            });
            
        });
        
        //Update docs list based on the License type selected
        function updateDocs(listOfDocs){
            console.log('updateDocs::::::');
            var docs= listOfDocs.split(';');
            for(let i = 0; i < docs.length; i++){ 
                $("#docListUL").append("<li>"+docs[i]+"</li>");
            }
        }
        //show docs based on the License type selected
        function showDocList(thiselem){
            console.log('showDocList::::::');
            $('#docListUL').empty();
            var a= $(thiselem).val();
            console.log('a::::'+a);
            if(a != ''){
                console.log('License type exist:::::');
                $('#docListUL').parent().parent().show();
            }
            if(a=="New Company"){
                var docList='DED initial approval certificate;DED initial trade name reservation certificate;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else if(a=="Relocation from Dubai Main Land" ){
                var docList='DED license copy;Lease contract or Ejari certificate';    
                updateDocs(docList);
            }else if( a=="New Branch"){
                var docList='DED initial approval certificate;DED initial trade name reservation certificate;Lease contract or Ejari certificate'; 
                updateDocs(docList);
            }else if(a=="Renewal" || a=="Amendment" ||a=="Renewal With Amendment"){
                var docList='DED license copy;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else if(a=="Shift Location"|| a=="Cancellation"){
                var docList='DED license copy;Request letter';
                updateDocs(docList);
            }else{
                var docList='DED initial approval certificate (for new registration only);DED initial trade name reservation certificate (if applicable);DED license copy (if applicable);Duly signed DED application form (if applicable);Lease contract or Ejari certificate (if applicable);Request letter (if applicable)';
                updateDocs(docList);
            }
            /*if(a=="New Company" || a=="Relocation from Dubai Main Land" || a=="New Branch"){
                var docList='DED initial approval certificate;DED initial trade name reservation certificate;Duly signed DED application form;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else if(a=="Renewal" || a=="Amendment" ||a=="Renewal With Amendment"){
                var docList='DED license copy;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else if(a=="Shift Location"|| a=="Cancellation"){
                var docList='DED license copy;Request letter';
                updateDocs(docList);
            }else{
                var docList='DED initial approval certificate (for new registration only);DED initial trade name reservation certificate (if applicable);DED license copy (if applicable);Duly signed DED application form (if applicable);Lease contract or Ejari certificate (if applicable);Request letter (if applicable)';
                updateDocs(docList);
            }*/
            addDocDwndLink(a);
        }
        function  showAmendCatDocList(thiselem){
            console.log('showAmendCatDocList::::::');
            $('#docListUL').empty();
            var a= $(thiselem).val();
            console.log('a::::'+a);
            if(a=="Change of Company Name"){
                var docList='DED initial trade name reservation certificate;DED license copy;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else if(a=="Location Change"){
                var docList='DED license copy;Lease contract or Ejari certificate';
                updateDocs(docList);
            }else{
                var docList='DED license copy;Lease contract or Ejari certificate';
                updateDocs(docList);
            }
        }
        function addDocDwndLink(licType){
            console.log('addDocDwndLink::::::'); 
            console.log('licType:::::'+licType);
            if(licType == 'Amendment' ||licType == 'Renewal With Amendment'){
                $('#docDownload').remove();
                $('#docListUL').after('<span id="docDownload" style="color: #3e528a !important">DED application form<a href="https://axsqa-axs.cs72.force.com/servlet/servlet.FileDownload?file=0155D000000NfyA"><i class="icon-download"></i></a></span>');
            }/*else if(licType == 'Renewal'){
                $('#docDownload').remove();
               $('#docListUL').after('<span id="docDownload" style="color: #3e528a !important">DED application form<a href="https://axsqa-axs.cs72.force.com/servlet/servlet.FileDownload?file=0155D000000NfyA"><i class="icon-download"></i></a></span>');  
            }*/else{
                $('#docDownload').remove();
            }
        }
        function addInfo(thiselem){
            var elem = $(thiselem);
            var msg = 'Moving from freezone to mainland';
            var infoElem = '<div class="input-info"><i class="fa fa-exclamation-circle text-warning"></i>&nbsp;' + msg+ '</div>'
            if($(thiselem).val() =="Shift Location"){
                elem.parent().parent().append(infoElem);
            }else{
                elem.parent().parent().find('.input-info').remove();
            }
        }
        function showErrMsg(elem,elemType,errType){
            if(errType == true){
                elem.removeClass('is-invalid');
                if(dateFieldTypes.includes(elemType))
                    elem.parent().parent().find('.frmErrMsg').remove();
                else
                    elem.parent().find('.frmErrMsg').remove();
                
                elem.parents('.form-group').find('.frmErrMsg').remove();
                elem.removeClass('is-invalid');
                elem.next().find('.select2-selection').removeClass('is-invalid');
                return;
            }
            var errElem = '<div class="frmErrMsg">'+formErrMsgs1[elemType][errType]+'</div>';
            elem.parents('.form-group').find('.frmErrMsg').remove();
            elem.parents('.form-group').append(errElem);
            elem.addClass('is-invalid');
            //elem.next().find('.select2-selection, .select2-selection--single, .select2-selection--multiple').addClass('is-invalid')
            return false;
        }
        
        function setToRQFld(id,el){
            if(cs[id]!=undefined)
                cs[id].value=$(el).val();
        }
        //Onchange activities
        function activitiesOnchange(){
            console.log('activitiesOnchange:::');
            var activities = '';
            activities = ($('#hpr').val())?$('#hpr').val().join(';'):'';
            cs['xuvdet__c'].value = activities;
            var val=cs["xuvdet__c"].value.split(';'); 
            var act='';
            val.forEach(function(i){ 
                act += i.split(':')[0]+' ';
            });
            cs['hpr__c'].value =act;
            console.log('act:::'+act);
        }
        
        var correctCaptcha = function(response) {
            console.log('correctCaptcha::::');
            console.log('response::::'+response);
            if (response.length == 0) {
                $('#recaptcha-error').show();
                $('#recaptcha-error').focus();
                //capNotChecked= true;
            }else if(response.length > 0){
                capNotChecked= true;
            }else {
                $('#recaptcha-error').hide();
                capNotChecked = false;
            }
            
            return capNotChecked;
        };
        
        //Validation  for UAE Mobile Number
        function isUAEMobNum(elem){
            console.log('isUAEMobNum:::::');
            var mob = $(elem).val();
            if(mob==null||mob==undefined||mob=='')
                return;
            var regex = /^((50|52|54|55|56|58)[0-9]{7})$/;
            var r = (regex.test(mob))?true:'invalid';
            if(r == 'invalid'){
                $(elem).parent().find('.frmErrMsg').remove();
                $(elem).parent().parent().find('.frmErrMsg').remove();
                var errElem = '<div class="frmErrMsg">Please enter a valid UAE mobile number</div>';
                $(elem).parent().parent().append(errElem);
                return false;
            }else{
                removeValError(elem);     
            }
        }
        //  Method for assignfldVal(dateField)
        function assignfldVal(val,fldId){cs[fldId].value=val;}
        // shwTradeName     
        function shwTradeName(a,md) {
            if(a=="Change of Company Name"){
                $(cs['cmpname']).hide();$(cs['apname']).show();
                $(cs['cmpnamear']).hide(); $(cs['apnamear']).show();
            }else{
                $(cs['cmpname']).show(); $(cs['apname']).hide(); 
                $(cs['cmpnamear']).show(); $(cs['apnamear']).hide();    
            }
        }
        //shwDescription
        function shwDescription(a) {
            console.log('shwDescription:::::');
            console.log('a:::'+a);
            if(a != ''){
                let flds = [cs['xcfn__c'],cs['xcna__c'],cs['xdedln__c'],cs['xzn']];
                flds.forEach(function(i){
                    $(i).parent().parent().show();
                });
            }
            if(a=="New Company" || a=="New Branch"){
                $(cs['cmpname']).hide(); $(cs['lcnum']).hide();
                $(cs['apname']).show(); $(cs['apnum']).show();
                
                $(cs['cmpnamear']).hide(); $(cs['apnamear']).show();
                $(cs['xdedc__c']).show();
            }else{
                $(cs['cmpname']).show();$(cs['lcnum']).show();
                $(cs['apname']).hide();$(cs['apnum']).hide();
                
                $(cs['cmpnamear']).show();$(cs['apnamear']).hide();
                $(cs['xdedc__c']).hide();
            }
            
            if(a=="New Branch"){   
                $('#iad').show();$('#aed').show();$('#pltn').show();$('#pltname').show();
            }else{
                $('#iad').hide();$('#aed').hide();$('#pltn').hide();$('#pltname').hide();
            }
            if(a=="Amendment" || a=='Renewal With Amendment'){
                $('#amdcat').show();
            }else{
                $('#amdcat').hide();
            }
            
            
            cs['xltp__c'].value = a;
            
            cs['xadh__c'].value = (a=="New Company" || a=="Relocation from Dubai Main Land" || a=="New Branch")?"den;lc;":(a=="Renewal")?"der;lc;":(a=="Shift Location")?"des;lc;":(a=="Cancellation")?"dec;":(a=="Amendment")?"dea;lc;":(a=="Renewal With Amendment")?"der;dea;lc;":'';
            
            if(a!="Cancellation" && a!="Shift Location"){
                cs['xadh__c'].value +="inf;kf;";
            }
            console.log('xadh__c:::'+cs['xadh__c'].value);
        }
        //Validate  update request and redirect to next page
        function validateData(){
            console.log('validateData:::');
            
            var elem = '';
            var validated  = true;
            //console.log('capNotChecked:::::'+capNotChecked);
            //uncomment for captcha:::
            if($('.g-recaptcha').length>0 && capNotChecked == false ){
                alert("Please verify you're not a Robot!");
                validated=false;
            }
            // $('.requiredFld').each(function(){
            $('.requiredFld, .applMob').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                var v = $(this).val();
                //console.log('id:::::'+$(this).attr("id"));
                //console.log('v:::::'+v);
                if(v==''||v==null||v==undefined||v.lenght<1){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            console.log('validated1::::'+validated);
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            console.log('validated1::::'+validated);
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated2::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            console.log('validated3::::'+validated);
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        } 
        function showDraftAlert2(){
            var rqNum = '{!req.Name}';
            $('#modal_alert_global').remove(); 
            var cBlock = '<div class="modal fade modal-base" id="modal_alert_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <div class="modal-body text-center pt-5 pb-5"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <div class="mb-3 fs-24" style="text-align:center;">Your Request has been saved!</div><div class="mb-3 fs-24">SR # <b>'+rqNum+'</b></div> <div class="col-xl-4"></div> <button class="col-xl-4 col-lg-12 btn btn-outline-primary mr-2 btn-block-sm" id="gDash">CLOSE</button> </div> </div> </div> </div> </div> </div> </div> </div></div>'
            $('body').append(cBlock);
            $('#modal_alert_global').modal('show');
            $('#gDash').on('click',function(){
                window.opener.location.reload(false);
                window.close();
            });
        }
        </script>
