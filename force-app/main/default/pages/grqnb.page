<apex:page sidebar="false" controller="ApplicantDetailController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true" standardStylesheets="false" title="{!req.srvc__r.lbl__c}" >
    <html>
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <apex:includeScript value="{!$Resource.AXS2Validations}"/>
        
        <script type="text/javascript">
        var GCC_Nations = ['Bahrain', 'Kuwait', 'Oman', 'Qatar', 'Saudi Arabia', 'United Arab Emirates'];
        var cs = {};
        $(document).ready(function() {
            //Hide Mrs. salutation
            $('[value="Mrs."]').parent().parent().hide();
            //remove current Nationality onchange method
            cs['xcnc__c'].removeAttribute('onchange');
            cs['xcnp__c'].value=cs['xcnc__c'].value;
            cs['xcms__c'].value = 'Single';
            //Validate date of birth
                        
            
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z ]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
        });
        
        // add val error
        
        function checkDate(elem,type,uid,gdr){  /**Ex: <input type="text" onchange="checkDate(this,'dob')" /> second argument is type of date.**/
            var e = $(elem);
            var date;
            var date1 = e.val();
            date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            var r = true;
            if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                r = 'invalid'
            }
            else if(type=='fid'){
                console.log('days:::'+days);
                // if(days>-1)
                if(days>-0)
                    r='past';
            }else if(type=='dob'){
                if(days<(1)){
                    r = 'future';
                }
                if(uid=='onlyPast'){}else if(uid =="017"|| uid=="046" || uid =="097" || uid =="074" || uid =="058" || uid =="096" ){
                    
                }else if(uid =="006" || uid =="140" || uid =="017" ||  uid =="118" || uid =="046" || uid =="120" || uid == '057'){
                    if((gdr == 'Male'|| gdr == 'M') && days>(365*18)) 
                        r='nChild';
                }else if(uid == "009"||uid == "014"||uid == "321") { 
                    console.log('newBorn::::');
                    if(days>(365*3)) r='newBorn';  
                }else if(uid =="011" || uid =="044"){
                    console.log('youngStudent::::');
                    if(days<(365*4)) r='youngStudent';
                }else{
                    if(days<(365*18)) r='young';
                    else if(days>(365*80)) r='old';
                }
                //else if() r='invalid';
            }else if(type=='incDate'){
                if(days<(365*2)) r='youngComp';
            }else if(type=='pid'){
                if(days<1) r='youngPassport';
            }else if(type=='arr'){
                if(days<0) r='arrivalDate';
            }else if(type=='ped'){
                if((days*-1)<(180)) r='oldPassport';
            } else if(type=='eed' && (uid =="068" || uid =="123")){
                if((days*-1)<(180)) r='oldPassport';
            }else if(type=='arrInt'){
                if(days<0) r='futureWT';
            }
            showErrMsg(e,type,r);
            if(r!=true){
                e.focus();
            }
        }
        
        function addValError(thiselem,message){
            var elem = $(thiselem);
            elem.parents('.form-group').find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
            var errElem = '<div class="frmErrMsg">'+message+'</div>';
            elem.parents('.form-group').append(errElem);
        }
        // add val error
        
        
        //Validation for Date of birth is 10 year old
        function validateDOB(thisElement){
            console.log('validateDOB::::');
            if(checkValidDate(thisElement) == true){
                var date = $(thisElement).val();
                var age = getAge(date)
                console.log('age:::'+age);
                if(age > 3){
                    //removeWarningMsg(thisElement);
                    removeValError(thisElement);   
                    addValError(thisElement,'Applicant age must be less than 3 years');
                    $(thisElement).addClass("is-invalid");
                    return false;
                }else{
                    console.log('correct::::');
                    //removeWarningMsg(thisElement);
                    removeValError(thisElement);
                    $(thisElement).removeClass("is-invalid");
                    return true;
                }
            }
        }
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                $(thisElement).addClass("is-invalid");
                return false;    
            }else{
                removeValError(thisElement);  
                $(thisElement).removeClass("is-invalid");
                return r;
            }
        }
        //Calulate Age 
        function getAge(dob){
            console.log('getAge::::');
            var parts = dob.split("/");
            var dob = new Date(parts[2], parts[1] - 1, parts[0]);
            console.log('dob:::'+dob);
            var today = new Date(); var nowyear = today.getFullYear(); var nowmonth = today.getMonth();var nowday = today.getDate();
            var birthyear = dob.getFullYear(); var birthmonth = dob.getMonth();var birthday = dob.getDate();
            var age = nowyear - birthyear;
            console.log('age:::'+age);
            return age;
        }
        //Validate Data on click of next button
        function validateData(){
            console.log('validateData:::');
            var elem = '';
            var validated  = true;
            $('.requiredFld, .applMob').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            var salutation = $("input[name='salutation']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            //alert('salutation v:'+validated);
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }//alert('GCC_Nations v'+validated);
            //validate DOB
            if(!validateDOB(cs['xcbd__c'])){
                //console.log('validateDOB:::'+validated);
                validated =false;   
                console.log('validateDOB##############################:::'+validated);
            }
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        }
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        function toggleGLoader(){   // to toggle page loader 
            $('#preloader').fadeToggle();
        }
        </script>
        <style>
            .errField{
            border: 0.5px solid #ff00006e !important;
            }
            .frmErrMsg,.frmErrMsg1 {
            color: #ff0000;
            font-style: italic;
            padding-left: 0.8rem;
            position: absolute;
            }
            .warningMsg{
            color:#004eff;
            font-style: italic;
            padding-left: -0.2rem;
            position: absolute;
            background-color: #d5ded9;
            }
        </style>
        <apex:form id="mainForm" styleClass="form-style">
            <apex:pageBlock id="pbMain">
                <apex:outputPanel id="saveRq"> 
                </apex:outputPanel>
                
                <apex:actionFunction name="svReqDft" action="{!saveDraftR}" oncomplete="toggleGLoader();showDraftAlert2('{!JSENCODE(req.Name)}');" />
                
                <apex:actionFunction name="next"  action="{!saveReq}" status="theStatus"  reRender="btnid,errmsg,saveRq,msg"
                                     oncomplete="$('#preloader').fadeOut();hideTempLoader_input();loadData_jt();"
                                     onbeforedomupdate="javascript: toggle_inputs();"/>
                <apex:actionFunction name="saveReqDraft1" action="{!saveDraft}" oncomplete="toggleGLoader();" />
                <apex:actionFunction name="cancelRq" action="{!CancelR}" reRender="errmsg,msg" oncomplete="toggleGLoader();" />
                <apex:actionFunction name="svRDrft" action="{!saveDraft}" status="theStatus" rerender="msg"  oncomplete="toggleGLoader();showDraftAlert('{!JSENCODE(req.Name)}')"/>
                
                <apex:actionFunction name="saveReqDraft" action="{!saveDraft}" oncomplete="toggleGLoader();" />
                 <apex:outputPanel rendered="{!AND(NOT(ispu),NOT(isgu))}">
                     <c:guheader heading="{!srv.lbl__c}" />
                </apex:outputPanel>
                <body class="base">
                    <div id="main">
                        <div class="container pt-2 pb-2">
