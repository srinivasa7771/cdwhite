<apex:page action="{!gCon}" contentType="text/csv#PeopleReport.csv" standardStylesheets="false"
    applyHtmlTag="false" cache="false" expires="0" readOnly="true" sidebar="false" showHeader="false"  
    title="People Statement" standardController="Account" extensions="gctlPpl" >
  <!-- application/x-excel#ADStatement.xls --> 
    <apex:repeat value="{!lstStr}" rendered="{!!isOS}">
     {!$ObjectType.Contact.fields.Name.label}, {!$ObjectType.Contact.fields.jb__c.label} ,{!$ObjectType.Contact.fields.STA__c.label},{!$ObjectType.Contact.fields.rol__c.label},{!$ObjectType.Contact.fields.nc__c.label},{!$ObjectType.Contact.fields.p__c.label},{!$ObjectType.Contact.fields.ped__c.label},{!$ObjectType.Contact.fields.idtxt__c.label},{!$ObjectType.Contact.fields.rp__c.label},{!$ObjectType.Contact.fields.rped__c.label}, {!$ObjectType.Contact.fields.MobilePhone.label}, <apex:outputText value="Out sourced" escape="true" rendered="{!accType == 'Customer - Outsourcing'}"/> {!newLn}
     
      <apex:repeat value="{!lstCon}" var="con" > 
        <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.Name), ',', ' ')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.jb__r.Name), ',', '')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.STA__c), ',', '')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.rol__c), ',', '')}" escape="true" /> ,  <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.nc__c), ',', '')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.p__c), ',', '')}" escape="true" /> , <apex:outputText value="{0, Date, dd-MM-yyyy}"><apex:param value="{!con.ped__c}"/></apex:outputText>, <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.idtxt__c), ',', '')}" escape="true" /> ,  <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.rp__c), ',', '')}" escape="true" /> , <apex:outputText value="{0, Date, dd-MM-yyyy}"><apex:param value="{!con.rped__c}"/></apex:outputText> , {!con.MobilePhone} , <apex:outputText value="Yes" escape="true" rendered="{!accType == 'Customer - Outsourcing' && con.os__c}" />  {!newLn}
            
      </apex:repeat> 
  </apex:repeat>
  <apex:repeat value="{!lstStr}" rendered="{!isOS}">
     {!$ObjectType.Contact.fields.Name.label}, <apex:outputText value="Source Company" escape="true" /> ,{!$ObjectType.Contact.fields.rol__c.label},{!$ObjectType.Contact.fields.STA__c.label},{!$ObjectType.Contact.fields.p__c.label},{!$ObjectType.Contact.fields.ped__c.label},{!$ObjectType.Contact.fields.idtxt__c.label},{!$ObjectType.Contact.fields.rp__c.label},{!$ObjectType.Contact.fields.rped__c.label}, {!$ObjectType.Contact.fields.MobilePhone.label} {!newLn}
     
      <apex:repeat value="{!lstCon}" var="con" > 
        <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.Name), ',', ' ')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.account.name), ',', ' ')}" escape="true" /> ,<apex:outputText value="{!SUBSTITUTE(JSENCODE(con.rol__c), ',', '')}" escape="true" />, <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.STA__c), ',', '')}" escape="true" /> , <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.p__c), ',', '')}" escape="true" /> , <apex:outputText value="{0, Date, dd-MM-yyyy}"><apex:param value="{!con.ped__c}"/></apex:outputText>, <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.idtxt__c), ',', '')}" escape="true" /> ,  <apex:outputText value="{!SUBSTITUTE(JSENCODE(con.rp__c), ',', '')}" escape="true" /> , <apex:outputText value="{0, Date, dd-MM-yyyy}"><apex:param value="{!con.rped__c}"/></apex:outputText> , {!con.MobilePhone}  {!newLn}
            
      </apex:repeat> 
  </apex:repeat>  
         
</apex:page>