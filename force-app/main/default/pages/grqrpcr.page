        function checkDate(elem,type,uid,gdr){  /**Ex: <input type="text" onchange="checkDate(this,'dob')" /> second argument is type of date.**/
            // if(uid == '011')
            // return;
            var e = $(elem);
            if($(elem).is(':disabled')){
                showErrMsg(e,type,true);
                return;
            }
            var date;
            // var date1 = (getFormattedDate(new Date(e.val())).includes(NaN))?e.val():getFormattedDate(e.val());
            //e.val(date1);
            var date1 = e.val();
            date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            var r = true;
            if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                r = 'invalid'
            }
            else if(type=='fid'){
                console.log('days:::'+days);
                // if(days>-1)
                if(days>-0)
                    r='past';
            }else if(type=='dob'){
                if(days<(1)){
                    r = 'future';
                }
                if(uid=='onlyPast'||uid=='052'){}else if(uid =="017"|| uid=="046" || uid =="097" || uid =="074" || uid =="058" || uid =="096" ){
                    
                }else if(uid =="006" || uid =="140" || uid =="017" ||  uid =="118" || uid =="046" || uid =="120"){
                    if((gdr == 'Male'|| gdr == 'M') && days>(365*18)) 
                        r='nChild';
                }else if(uid == "009") { 
                    console.log('newBorn::::');
                    if(days>(365*3)) r='newBorn';  
                }else if(uid =="011" || uid =="044"){
                    console.log('youngStudent::::');
                    if(days<(365*4)) r='youngStudent';
                }else{
                    if(days<(365*18)) r='young';
                    else if(days>(365*80)) r='old';
                }
                //else if() r='invalid';
            }else if(type=='incDate'){
                if(days<(365*2)) r='youngComp';
            }else if(type=='pid'){
                if(days<1) r='youngPassport';
            }else if(type=='arr'){
                if(days<0) r='arrivalDate';
            }else if(type=='ped'){
                if((!$(elem).is(':disabled')&&(days*-1))<180) r='oldPassport';
            }else if(type=='arrInt'){
                if(days<0) r='futureWT';
            }
            showErrMsg(e,type,r);
            if(r!=true){
                e.focus();
            }
        }
        
        
        function dformat(dt,id){
            var d = new Date(dt);//alert(d);
            var m=d.getMonth()+1;
            var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
            var mm=m>9?m:'0'+m;
            var yy=d.getFullYear();
            document.getElementById(id).value=dd+'/'+mm+'/'+yy;
        }
        
