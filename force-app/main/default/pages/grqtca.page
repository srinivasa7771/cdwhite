        <script type="text/javascript">
        var cs = {}; var selectedDocs = [];
        
        $(document).ready(function() {
            //debugger;
            console.log('{!JSENCODE(framwrk)}');
            let flds = [cs['xcfan__c'],cs['rmob__c'],cs['xcmonar__c'],cs['xeidav__c'],cs['xcnp__c'],cs['xcbp__c'],'#spokenLng'];
            flds.forEach(function(i){ 
                $(i).val()!=null && $(i).val()!='' && $(i).val()!==void 0?$(i).attr('disabled',true):'';
            });
            dr(); hr(); mr();
            getCountry();
            
            if(cs['xtcdl__c'].value!=''&&cs['xtcdl__c'].value!=undefined&&cs['xtcdl__c'].value.split(';').length>0){
                cs['xtcdl__c'].value.split(';').forEach(function(v,i){
                    if(v.trim()!=''){
                        var elem = v.split(':')[0];
                        var val = v.split(':')[1];
                        $('[attr1="'+elem+'"]').val(val);
                    }
                });
            }
            
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
            
            
            $( ".truecopy" ).change(function() {
                var k = $(this).find('p').text();
                var v = $(this).find('input').val();
                if(v>0){
                    console.log(k); 
                    if(!selectedDocs.includes(k)){
                        selectedDocs.push(k);
                        var newOption = new Option(k,k,true, false);
                        $('#docstoatt').append(newOption);
                    }
                }else{
                    $("#docstoatt option[value='"+ k +"']").remove();
                    for (var i = selectedDocs.length; i--;) {
                        if(selectedDocs[i] === k) {
                            selectedDocs.splice(i, 1);
                        }
                    }
                    docsToAtt();
                }
            });
            
            checkAttCntry();
        });
        
        //Add validation error
        function addValError(thiselem,message){
            var elem = $(thiselem);
            elem.parent().find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
            var errElem = '<div class="frmErrMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(errElem);
            }else{
                elem.parent().append(errElem);
            }
        }
        //Remove validation error
        function removeValError(thiselem){
            var elem = $(thiselem);
            elem.parent().find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
        }
        //Add  warning message
        function addWarningMsg(thiselem,message){
            console.log('addWarningMsg:::');
            var elem = $(thiselem);
            var warElem = '<div class="warningMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(warElem);
            }else{
                elem.parent().append(warElem);
            }
        }
        //Remove warning error
        function removeWarningMsg(thiselem){
            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
        }
        function isUAEMobNum(elem){
            var mob = $(elem).val();
            if(mob==null||mob==undefined||mob=='')
                return;
            var regex = /^((?:50|52|54|55|56|58)[0-9]{7,})$/;
            var r = (regex.test(mob))?true:'invalid';
            if(r == 'invalid'){
                $(elem).parent().find('.frmErrMsg').remove();
                $(elem).parent().parent().find('.frmErrMsg').remove();
                var errElem = '<div class="frmErrMsg">Please enter a valid UAE mobile number</div>';
                $(elem).parent().parent().append(errElem);
                return false;
            }else{
                removeValError(elem);     
            }
        }
        //validate mobile number
        function checkMob(thisElem){
            var mobNo = $(thisElem).val();
            if(mobNo.length < 10){
                addValError(thisElem,'Please enter valid mobile Number!!');
            }else{
                removeValError(thisElem);    
            }
        }
        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //validate selected country
        function chkcmof(e){
            if(cs['embC'].value =='xsa'){ cs['xla2__c'].value = 'Arabic';}
            if (cs['embC'].value!='' && cs['embC'].value!=null){ 
                cs['xcnc__c'].value =  cs['embC'].options[cs['embC'].selectedIndex].text;
                cs['xadh__c'].value=cs['embC'].value+';';  
                
                $('.truecopy:visible').each(function(){
                    var val='';
                    var k = $(this).find('p').text();
                    var v = $(this).find('input').val();
                    if(v>0){
                        if(!selectedDocs.includes(k)){
                            selectedDocs.push(k);
                            var isSelectedDoc =  cs['xuvdet__c'].value.includes(k);
                            var newOption = new Option(k,k,true, isSelectedDoc); 
                            $('#docstoatt').append(newOption);
                        }
                    }
                });
                
                $("#divdocstoatt").show();
                
            }else{ 
                cs['xadh__c'].value='';   cs['xcnc__c'].value='';
                //var selectobject= getC('docstoatt');  selectobject.length = 0;
                $('#docstoatt').val(null).trigger('change');
                $("#divdocstoatt").hide();
            }
            
            
        }
        
        function getCountry(){
            if(cs['xadh__c'].value !=''){
                cs['embC'].value = cs['xadh__c'].value.replace(';','');
                $(cs['embC']).select2();
            }
        }
        
        function checkAttCntry(){
            if(cs['xcnc__c'].value){
                $("#divdocstoatt").show();
                chkcmof('xcnc__c');
                
                
            }else{$("#divdocstoatt").hide();}
            //var isSelectedDoc =  cs['xuvdet__c'].value.includes(k);
        }
        
        //Validate Data on click of next button
        function validateData(){
            var fullVal='';
            var elem = '';
            var validated  = true;
            $('.truecopy:visible').each(function(){
                var val='';
                var k = $(this).find('p').text();
                var v = $(this).find('input').val();
                if(v>0){
                    val = k+':'+v;
                    if(!fullVal.includes(val))fullVal+=val+';';
                    $('#attestErr').hide();
                }
            });
            if(fullVal==''){
                $('#attestErr').fadeIn();
                scrollToDiv($('#attestErr'));
                validated = false;
            }
            $('.requiredFld:visible').each(function(){
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            
            console.log('submit validated:::'+validated);
            if(validated == true){
                if(cs['embC'].value =='xsa'){ cs['xla2__c'].value = 'Arabic';}
                if (cs['embC'].value!='' && cs['embC'].value!=null){
                    cs['xadtx1__c'].value=fullVal;
                    cs['xcnc__c'].value =  cs['embC'].options[cs['embC'].selectedIndex].text;
                    cs['xtcdl__c'].value=cs['xadtx1__c'].value+'Embassy of'+' '+cs['xcnc__c'].value+':1'+';';
                }else{
                    cs['xtcdl__c'].value=fullVal+''; 
                    cs['xadtx1__c'].value=fullVal;
                    cs['xcnc__c'].value='';
                }
             
                if(selectedDocs.includes("Commercial / trade license") && !cs['xuvdet__c'].value.includes("Commercial / trade license")){
                    //axsAlert("Commercial / trade license selected without VFS Attestation","The Unified license template is available with the QR code which will enable authentication of the document. Do you still want to continue with the request?"); 
                    var trWarn = "Commercial / trade license";
                    var trMsg = "The Unified license template is available with the QR code which will enable authentication of the document. Do you still want to continue with the request?";
                    axsConfirmation(trWarn,trMsg,false,'processOnConfirm');
                } else{
                   processOnConfirm();
                }
                
            }
            
        }
        
        function processOnConfirm(){
            showTempLoader(event.target);
            toggleGLoader();
            next();
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        function saveReqDraft(){
            alert('save draft');
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        function showDraftAlert1(){
            alert('inside showdraft');
            var rqNum = '{!JSENCODE(req.Name)}';
            $('#modal_alert_global').remove(); 
            var cBlock = '<div class="modal fade modal-base" id="modal_alert_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <div class="modal-body text-center pt-5 pb-5"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <div class="mb-3 fs-24" style="text-align:center;">Your Request has been saved!</div><div class="mb-3 fs-24">SR # <b>'+rqNum+'</b></div> <p style="text-align: center;">You can continue with this request from \'Drafts\' tab on your Dashboard<p class="col-xl-12 col-lg-12" style="font-size: 0.8em;text-align: center;"> <div class="col-xl-4"></div> <button class="col-xl-4 col-lg-12 btn btn-outline-primary mr-2 btn-block-sm" id="gDash">GO TO DASHBOARD</button> </div> </div> </div> </div> </div> </div> </div> </div></div>'
            $('body').append(cBlock);
            $('#modal_alert_global').modal('show');
            $('#gDash').on('click',function(){
                window.open('/gpm','_self');
            });
        }
        
        function formDocsToAtt(){
           
        }
        
        function docsToAtt(){
            cs['xuvdet__c'].value  = $("#docstoatt").val();
        }
