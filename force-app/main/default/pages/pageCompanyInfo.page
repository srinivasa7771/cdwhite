    <script>
    const DQuarters_Exceptions = '{!$Label.DQuarters_Exceptions}';
    const opi = '{!JSENCODE(orclId)}';
    var accEditabledetails= {};
    var tElg = 0;
    var tRsrvd = 0;
    var docPaidParking = 0;
    $(document).ready(function(){
        tRsrvd = parseInt({!el['rsrvd']});
        tElg = parseInt({!el['stdElg']})  + parseInt({!el['AddElg']});
        // tElg = 2;
        /* for DQuarters Exceptions starts*/
        for(i of DQuarters_Exceptions.split(';')){
            if(opi==i)
                $('[for="parking"]').show();
        }
        /* for DQuarters Exceptions ends*/
        
        $('button').click(function (ev) {
            // ev.preventDefault();
        });
        setTimeout(function(){
            if(localStorage.getItem('parkingClicked')=='true'){
                $('[for="parking"] a').trigger('click');
                localStorage.removeItem('parkingClicked');
            }
            if((getUrlParameter('t') &&getUrlParameter('t')=='a5m4n9uu5ns9ih0a' && $('[for="parking"] a').is(':visible'))||('{!JSENCODE(onlyParkingUser)}'=='true')){
                $('[for="parking"] a').trigger('click');
            }
        },500);
        if('{!JSENCODE(A.Legal_Framework__c)}'=='Freelancer'){
            $('div[fl],button[fl],span[fl]').each(function(){
                $(this).html($(this).attr('fl'));
            });
        }
        $('.chk').show();
        $('.editAcc').unbind('change').on('change',function(){
            $('#saveAccDetails').addClass('disabled');
            $('.editAcc').each(function(i,v){
                var v = $(this).val();
                var f = $(this).attr('attr1');
                if(v!=f){
                    $('#saveAccDetails').removeClass('disabled');
                }
            });
        });
        docPaidParking = parseInt({!el['paidStd']})  + parseInt({!el['paidEXC']});
        console.log('--docPaidParking--'+docPaidParking);
        if(docPaidParking>0){
            $('.notForDOC').remove();
        }
        else{
            $('.onlyForDOC').remove();
        }
    });
    
    $('.forActions').unbind().on('click',function(){
        //console.log($(this).index());
        if($(this).find('a').hasClass('disabled') || $(this).find('a').hasClass('disabledApex'))
            return;
        var f = $(this).attr('for');
        $('#panel_actions').find('.actionsElem').hide();
        if(f!='lease')$('#panel_actions').find('[for="'+f+'"]').show();
    });
    $('.data-value').each(function(){
        if($(this).text()=='')
            $(this).html('-');//<span style="color: #E62D38;">Not Available</span>
    });
    $('.comNum').each(function(){
        $(this).text($(this).text().toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","));
    });
    
    /* calling from parkingdetails component*/
    
    function reserveVeh(c1){
        var c = c1.split('&&')[0];
        var isChecked = c1.split('&&')[1];
        var reqJson = {"ActionName":"reservedparkingcards","OracleID":"","CardNumber":"","Eligibility":"","BusinessPark":"","Sector":"","SectorLocationId":"","IsReserved":true};
        for([i,v1] of allJSONObj.entries()){
            if(c == v1.cardNum){
                reqJson.OracleID = '{!JSENCODE(orclId)}';
                reqJson.CardNumber = v1.cardNum;
                reqJson.Eligibility = v1.EligibilityName;
                reqJson.BusinessPark = v1.BusinessPark;
                reqJson.Sector = v1.sector;
                reqJson.SectorLocationId = v1.sectorId;
                reqJson.IsReserved = (isChecked =='true')?true:false;
            }
        }
        var storageJson = {'reserved':isChecked,'time':Date.now()};
        localStorage.setItem(c,JSON.stringify(storageJson));
        /*if(isChecked=='true')
            axsAlert('Success','Access Number - '+c+' marked as <b>RESERVED</b>!');
        if(isChecked=='false')
            axsAlert('Success','Access Number - '+c+' marked as <b>STANDARD</b>!');*/
        showGLoader();
        manipulateVeh(JSON.stringify(reqJson));
    }
    function undoReserveVeh(c1){
        var c = c1.split('&&')[0];
        var isChecked = c1.split('&&')[1];
        $('[for="'+c+'"]').prop('checked',(isChecked=="false"));
    }
    function getUrlParameter(key){
        var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
        return (res==undefined)?'':res[1];
    }
    if(aPhn)
        cs['aPhone'] = aPhn;
    function shwIPField(e){
        var f = $(e).attr('for');
        if(f && f=='aPhone'){
            //cs['aPhone'].value = cs['aPhone'].value.replace('+971','');
            cs['aPhone'].value = cs['aPhone'].value.replaceAll(' ','');
        }
        $(e).parents('.data-info').find('.editAcc1').show();
        //$(e).parent().hide();
        $(e).parents('.data-info').find('.data-value').hide();
        
        $('.editAccBtns').css('display','flex');
    }
    function cancelAccDetails1(){
        removeAllErrors('.editAcc1');
        $('.editAcc1').hide();
        $('.editAcc1').parent().find('.data-value').show();
        $('.editAccBtns').hide();
    }
    function checkTrnComp(res){
        if(res == 'true'){
            addValError('[attr="van__c"]','** Entered TRN is already configured with different account, please check!');
        }
        else{
            removeValError('[attr="van__c"]');
        }
    }
    function editAccDetails(){
        $('#modal_edit_acc').modal('show');
    }
    function saveAccDetails1(e){
        showGLoader();
        showTempLoader(e);
        saveAccDetails();
    }
    function saveAccComplete(){
        $('#modal_edit_acc').modal('hide');
        removeTempLoader();
        $('#saveAccDetails').addClass('disabled');
    }
    function chkRepCount(modalId){
        
        $(modalId).modal('show');
        
    }
    
    function validURL(str) {
        var pattern = new RegExp('^(https?:\\/\\/)?'+ 
                                 '((([a-z\\d]([a-z\\d-]*[a-z\\d])*)\\.)+[a-z]{2,}|'+ 
                                 '((\\d{1,3}\\.){3}\\d{1,3}))'+
                                 '(\\:\\d+)?(\\/[-a-z\\d%_.~+]*)*'+
                                 '(\\?[;&a-z\\d%_.~+=-]*)?'+ 
                                 '(\\#[-a-z\\d_]*)?$','i'); 
        return !!pattern.test(str);
    }
    </script>
