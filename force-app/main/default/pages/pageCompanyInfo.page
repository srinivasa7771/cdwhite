                                                                function convertToLower(e){
                                                                    $(e).val($(e).val().toLowerCase());
                                                                }
                                                                function isUAEMobNum1(elem){
                                                                    var mob = $(elem).val();
                                                                    if(mob==null||mob==undefined||mob=='')
                                                                        return;
                                                                    var regex = /^((?:50|51|52|54|55|56|58|2|3|4|6|7|9)\d{7})$/gm;
                                                                    //var regex =  /^((?:50|52|54|55|56|58|2|3|4|6|7|)[0-9]{7,})$/; /*/^(?:\+971|00971|0)?(?:50|51|52|55|56|2|3|4|6|7|9)\d{7}$/gm; */
                                                                    var r = (regex.test(mob))?true:'invalid';
                                                                    if(r == 'invalid'){
                                                                        addValError(elem,'Please enter a valid UAE number!'); 
                                                                        return false;
                                                                    }else{
                                                                        removeValError(elem); 
                                                                        return true;
                                                                    }
                                                                }
                                                                
                                                                function checkTrn1(e){
                                                                    var r = new RegExp('^((?!(0))[0-9]{15})$');
                                                                    var v = $(e).val();
                                                                    if(!v)
                                                                        return true;
                                                                    removeValError(e);
                                                                    if(!r.test(v) ){
                                                                        addValError(e,'Only numbers allowed!');
                                                                        $(e).addClass('is-invalid');
                                                                        return false;
                                                                    }
                                                                    else if(v=='100487319400003' || v=='100072771700003'){
                                                                        addValError(e,'Invalid TRN Number!');
                                                                        $(e).addClass('is-invalid');
                                                                        return false;
                                                                    }
                                                                    return true;
                                                                }
                                                                </script>
