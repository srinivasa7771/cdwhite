                                                                    $('input.editAcc1').each(function(i,v){
                                                                        var v = $(this).val();
                                                                        var f = $(this).attr('attr1');
                                                                        var fld = $(this).attr('attr');
                                                                        var validate = true;
                                                                        if(fld=='Van__c'){
                                                                            validate = checkTrn1(this);
                                                                        }
                                                                        if(v!=f && validate){
                                                                            $('#saveAccDetails1').removeClass('disabled');
                                                                        }
                                                                        else{
                                                                            //$('#saveAccDetails1').addClass('disabled');
                                                                        }
                                                                        if($('.frmErrMsg').length>0){
