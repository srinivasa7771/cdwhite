<apex:page standardController="g_reqitem__c" extensions="GetRequestDetails">
    <apex:form >
        <apex:pageMessages />
        <p style="font-size:13px;"><b>Please Confirm Your Details</b></p>
    <div>
                
              <apex:pageBlock title="Applicant Details">
        <apex:dataTable value="{!noteWrapperlst[0]}" var="wrapdata" width="100%">
          <p>   <div> <apex:column value="{!wrapdata.servicename}" headerValue="Service Name"/></div></p>
           <p>  <div> <apex:column value="{!wrapdata.applicantname}" headerValue="Applicant Name"/></div></p>
            <p> <div> <apex:column value="{!wrapdata.passportnumber}" headerValue="Passport Number"/></div></p>
           <p>  <div> <apex:column value="{!wrapdata.dateofbirth}" headerValue="Date of Birth"/></div></p>
        </apex:dataTable>
        </apex:pageBlock>
        <apex:pageBlock >
    <p style="font-size:13px;"> Existing Details  </p> 
         <apex:dataTable value="{!noteWrapperlst}" var="wrapdata" id="recTable" width="100%">
              <div> <apex:column value="{!wrapdata.itemname}" headerValue="Item"/></div>
             <div> <apex:column value="{!wrapdata.servicecostold}" headerValue="Service Cost"/></div> 
              <div><apex:column value="{!wrapdata.servicechargeold}" headerValue="Service Charge"/></div>
              <div><apex:column value="{!wrapdata.eservicecostold}" headerValue="Express Service Cost"/></div>
              <div><apex:column value="{!wrapdata.eservicechargeold}" headerValue="Express Service Charge"/></div>
             </apex:dataTable>
        
        
        
   <p style="font-size:13px;">  Updated Details </p>   
       <apex:dataTable value="{!noteWrapperlst}" var="wrapdata" width="100%">
            <div> <apex:column value="{!wrapdata.itemname}" headerValue="Item"/></div>
         <div> <apex:column value="{!wrapdata.servicecostnew}" headerValue="Service Cost"/></div>
              <div><apex:column value="{!wrapdata.servicechargenew}" headerValue="Service Charge"/></div>
              <div><apex:column value="{!wrapdata.eservicecostnew}" headerValue="Express Service Cost"/></div>
              <div><apex:column value="{!wrapdata.eservicechargenew}" headerValue="Express Service Charge"/></div>
      </apex:dataTable>
      </apex:pageBlock>
    </div>
    <apex:pageBlock >
         <apex:pageBlockSection >
             
        <b>Notes</b>
                <apex:inputTextArea value="{!notevalue}" id="notevalue"/>
        <b>Attachment</b>    
                <apex:inputFile value="{!bodyvalue}" id="bodyvalue"/>
                
    </apex:pageBlockSection>
    </apex:pageBlock>
    <div>
<apex:commandButton value="Previous" action="{!navigatePrev}"/>
<apex:commandButton value="Confirm Changes" action="{!submitforapproval}"/>
</div>
</apex:form>
</apex:page>