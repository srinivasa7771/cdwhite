    <script>
     $('.numOnly,.onlyNum').on('keyup',function(){
        validDigits($(this));
    });
    
    /* to override checkEmail from axs2Customjs to add .llc */
    function checkEmail(elem){
        console.log('checkEmail::::::::::::::::::::::::::');
        var e = $(elem);
        var email = e.val();
        console.log('email:::'+email);
        if(email.length<1)
        {
            addValError(elem,'Please enter valid email Address');
        }
        else
        {   
        var regex = /^[-a-z0-9~!$%^&*_=+}{\'?]+(\.[-a-z0-9~!$%^&*_=+}{\'?]+)*@([a-z0-9_][-a-z0-9_]*(\.[-a-z0-9_]+)*\.(film|aero|ntt|arpa|biz|com|coop|edu|gov|info|int|mil|llc|museum|name|net|org|pro|travel|mobi|[a-z][a-z])|([0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}))(:[0-9]{1,5})?$/;
        var r = (regex.test(email))?true:'invalid';
        showErrMsg(e,'mail',r);
        if(r == 'invalid' && email != ''){
            console.log('invalid:::::::::::::');
            addValError(elem,'Please enter valid email Address');
            return false;
        }else{
            console.log('valid:::::::::::::');
            removeValError(elem);
        }
            }
        
    }
    
    var noOfErros = 0;
    function validateAmount(){
        fldErr('amt',null,false);
        noOfErros = 0;
        var amtFld = document.getElementsByClassName('pay_mtd')[0];
        var pay_mtd = amtFld.options[amtFld.selectedIndex].value;
        var amt = document.getElementsByClassName('pay_amt')[0].value;
        console.log('amt===', amt);
        console.log('amt===', pay_mtd);
        console.log('amt===', (pay_mtd == '--None--' ));
        if((pay_mtd == '' || pay_mtd == '--None--' )&& amt !== undefined && amt.length>0){
            fldErr('amt','Please choose package Applied for First.',false);
            noOfErros++;
            document.getElementsByClassName('pay_amt')[0].value = '';
        }
        else{
             console.log('amt=1231==');
            if(!isNaN(amt) && amt>0){
                console.log('amt=123123==');
                amt = parseFloat(amt).toFixed(2);
                var advDepAvailable = parseFloat({!account.adb__c}).toFixed(2);
                var bankgurAvailable = parseFloat({!account.bgb__c}).toFixed(2);
                if((pay_mtd == 'Customer Deposit' && parseFloat(amt)>parseFloat(advDepAvailable)) || (pay_mtd == 'Bank Guarantee' && parseFloat(amt)>parseFloat(bankgurAvailable))){
                    fldErr('amt','The amount entered cannot exceed the balance amount',false);
                    axsAlert('The amount entered cannot exceed the balance amount.');
                    noOfErros++;
                    document.getElementsByClassName('pay_amt')[0].value = '';
                }
                
                if(pay_mtd == 'Bank Guarantee' && parseFloat(amt)%2500!=0){
                     console.log('amt====ere3=23=');
                    axsAlert('The requested refund amount for the Bank Guarantee should be in multiples of 2,500.');
                }
            }
            else{
                 console.log('amt====ere3==');
                fldErr('amt','Please enter valid amount.',false);
                noOfErros++;
                document.getElementsByClassName('pay_amt')[0].value = '';
            }
        }
    }
    
     function hideError(e){
        $(e).parent().find('.invalid-feedback').hide();
        $(e).parent().find('.valid-feedback').hide();
    }
    
      function validateAmunt(e){
        hideError(e);
        noOfErros = 0;
        var amtFld = document.getElementsByClassName('pay_mtd')[0];
        var pay_mtd = amtFld.options[amtFld.selectedIndex].value;
        var amt = document.getElementsByClassName('pay_amt')[0].value;
        console.log('amt===', amt);
        console.log('amt===', pay_mtd);
        console.log('amt===', (pay_mtd == '--None--' ));
        if((pay_mtd == '' || pay_mtd == '--None--' )&& amt !== undefined && amt.length>0){
             addValError(e,'Please choose package Applied for First.');
            $(e).addClass('is-invalid');
            //fldErr('amt','Please choose package Applied for First.',false);
            noOfErros++;
            document.getElementsByClassName('pay_amt')[0].value = '';
        }
        else{
             console.log('amt=1231==');
            if(!isNaN(amt) && amt>0){
                console.log('amt=123123==');
                amt = parseFloat(amt).toFixed(2);
                var advDepAvailable = parseFloat({!account.adb__c}).toFixed(2);
                var bankgurAvailable = parseFloat({!account.bgb__c}).toFixed(2);
                if((pay_mtd == 'Customer Deposit' && parseFloat(amt)>parseFloat(advDepAvailable)) || (pay_mtd == 'Bank Guarantee' && parseFloat(amt)>parseFloat(bankgurAvailable))){
                     addValError(e,'The amount entered cannot exceed the balance amount.');
                    $(e).addClass('is-invalid');
                    //fldErr('amt','The amount entered cannot exceed the balance amount',false);
                    axsAlert('The amount entered cannot exceed the balance amount.');
                    noOfErros++;
                    document.getElementsByClassName('pay_amt')[0].value = '';
                }
                
                if(pay_mtd == 'Bank Guarantee' && parseFloat(amt)%2500!=0){
                     console.log('amt====ere3=23=');
                    axsAlert('The requested refund amount for the Bank Guarantee should be in multiples of 2,500.');
                }
            }
            else{
                 console.log('amt====ere3==');
                 addValError(e,'Please enter valid amount.');
                    $(e).addClass('is-invalid');
                // fldErr('amt','Please enter valid amount.',false);
                noOfErros++;
                document.getElementsByClassName('pay_amt')[0].value = '';
            }
        }
    }
    
     //Validation  for UAE Mobile Number
         function isUAEMobNum(elem){
             
            var mobNo = $(elem).val();
             
             if(mobNo.length<1) 
             {
                 console.log('inone==');
                 addValError(elem,'Please enter a valid UAE mobile number');
                 return false;
             }
            
            if(mobNo.length < 9 || mobNo.length > 13){
                addValError(elem,'Please enter valid mobile Number!!');
            }else{
                removeValError(elem);    
            }
        }
    function calAmt(){
        var amtFld = document.getElementsByClassName('pay_mtd')[0]; 
        var pay_mtd = amtFld.options[amtFld.selectedIndex].value;
        cs['pMtd'].value=pay_mtd;
        if(pay_mtd == '--None--')
        {
            addValError(amtFld,'Please select a value.');
            document.getElementById("amt_rem").innerHTML = '';
        }
        else if(pay_mtd == 'Customer Deposit'){
            removeValError(amtFld);
            document.getElementById("amt_rem").innerHTML = 'Remaining Balance : '+{!account.adb__c};
        }
        else if(pay_mtd == 'Bank Guarantee'){
             removeValError(amtFld);
            document.getElementById("amt_rem").innerHTML = 'Remaining Balance : '+{!account.bgb__c};
        }
            else{
                document.getElementById("amt_rem").innerHTML = '';
            }
       if(document.getElementById('pay_amt')!=null) document.getElementById('pay_amt').value = '';   
    }
    function callgeneratePDF(){
        var isvalidated = validateForm();
        console.log('isvalidated===',isvalidated);
        if(isvalidated)
            {
        if(!$('#vehicleid').val() || $('#vehicleid').val()=='--None--'){
            addValError('#vehicleid','Please select a value');
            return;
        }
        var amt = document.getElementsByClassName('pay_amt')[0].value;
        if(amt === undefined || amt.trim().length==0 || amt==0){
            fldErr('amt','Amount cannot be 0 or blank',false);
            noOfErros++;
        }
        var mn = document.getElementsByClassName('mn_val')[0].value;
        console.log(mn);
        var cdAmt = document.getElementById("vehicleid").value;
         cs["packageChoosenid"].value = cdAmt;
       
        if(mn === undefined || mn.trim().length==0){
            fldErr('mn','Value is Required',false);
            noOfErros++;
        }
        if(noOfErros >0 ){
            noOfErros = 0;
            return;
        } 
        else{
        showGLoader();
            generatePDFAct(); 
                }
                }
    }
    
    function validateForm()
    {
        var isvalidated = true;
        const highlightedItems = document.querySelectorAll(".requiredFld");
        
        if(!$('#vehicleid').val() || $('#vehicleid').val()=='--None--'){
            addValError('#vehicleid','Please select a value');
            isvalidated = false;
        }

        highlightedItems.forEach((userItem) => {
            
            $(userItem).trigger('change'); 
            $(userItem).trigger('blur'); 
            console.log($(userItem).val());
            console.log(document.querySelector("[id$='"+userItem.Id+"']"));
        });
            
       $('.invalid-feedback, .frmErrMsg').each(function(){
            if($(this).is(':visible'))
            {
                isvalidated = false;
            }
        });
            
        return isvalidated;
                
    }
    
    
    </script>
