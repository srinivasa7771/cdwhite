    <script>
    $(document).ready(function(){
        
       var str; /*box status-box bg-white*/
        var ids= document.getElementsByClassName('box status-box aos-init aos-animate');
        for(var i=0;i<ids.length;i++){
            
            str=ids[i].innerHTML;
            str = str.replace('#download','<br/><br/>');
            str = str.replace('#sla1','{!rq.slaN__c}');
            str = str.replace('#sla','{!rq.slaN__c}');
            str = str.replace('#upload','');
            var adhVal = '{!rq.xadh__c}';
            var expflg = '{!rq.expflg__c}';
             if(expflg == 'true')
                str = str.replace('#ptype','Express Priority').replace('#pdays','3');
              else if(adhVal != '' && adhVal.includes('pf;'))
                str = str.replace('#ptype','Platinum Priority').replace('#pdays','1');
              else
                str = str.replace('#ptype','Normal Priority').replace('#pdays','5');
            var md = '{!rq.Acc__r.mtc__c}';
            if(md != 'MOH')
                str = str.replace('#medcet',' Dubai Knowledge Park').replace('#mcet','{!$Label.msgDHALoc}');
            else if(md == 'MOH')
                str = str.replace('#medcet','Dubai International Academic City').replace('#mcet','{!$Label.msgMOHLoc}');
            
            ids[i].innerHTML=str;         
        }
        
        
       
        /*$('.data-value a').css('cursor','default').unbind().on('click',function(e){
            e.preventDefault();
        });*/
    });
    </script>
   
        
