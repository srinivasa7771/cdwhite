    function isNumber(evt) {
        $('.frmErrMsg').remove();
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode=190){
            
        }
        else if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }
    
    function setPayableAmt(){
        $('.frmErrMsg').remove();
        console.log('PAYABLE >>');
        var a= document.getElementById("{!$Component.mFrm.xtpa__c}").value;
        console.log('Value >>> '+a);
        if(a==null || a=='')
            document.getElementById("{!$Component.mFrm.payAmt}").innerHTML = '0 AED';  
        else{
            if(a%2500!=0){
                $('[name="payment_method"]').prop('checked',false);
                $(document.getElementById("x:mFrm:xtpa__c")).parents('.box-check').append('<div class="frmErrMsg">Top-up amount should be multiples of 2500.</div>');
            }
            else
                document.getElementById("{!$Component.mFrm.payAmt}").innerHTML = a+' AED';  
        }
    }
    
