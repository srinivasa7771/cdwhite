        $(document).ready(function() {
            console.log("ready!");
            //alert('Ready');
            //setWireDefault();selectedPayType('Cheque');;
            setPayableAmt();
            $('.comNum').each(function(){
                $(this).text($(this).text().toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","));
            });
        });
        function checkDate(elem){
            var e = $(elem);
            e.parent().parent().find('.frmErrMsg').remove();
            var date = e.val();
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            var r = true;
            if(days>=0){
                var errElem = '<div class="frmErrMsg">Date should be a future date!</div>';
                e.parent().parent().append(errElem);
            }
        }
        function rmErronTC(){
            if($('#tANDc').prop('checked'))
                removeValError('#tANDc');
            else
                addValError('#tANDc','Please select to agree the terms and conditions.');
        }
        </script>
