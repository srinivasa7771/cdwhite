    <script type="text/javascript">
    
    var cs={}, isAdnic = false;  var reqType = '{!JSENCODE(rqTp)}'; var bCallAdnic='{!bCallAdnic}'; var bEnableVFS ={!bEnableVFS}; 
    var isDependentApp={!isDependentApp}; var xadtx3__c = ''; var serviceItemList = '{!JSENCODE(rqDraft.srvc__r.AddOnSrv__c)}';
    var srvUID = '{!JSENCODE(rqDraft.srvc__r.uid__c)}'; var reqstID = '{!JSENCODE(rqDraft.id)}';
    var vfsflg='{!JSENCODE(rqDraft.vfsFlag__c)}';
    
    var vfsDet = [];
    function updatePopupDetails(){ 
        console.log('--------------update popupDetails----------'); 
        console.log('serviceItemList' + serviceItemList); 
        if(cs['xadh__c'].value.includes('vfs')){
            $('#chkvfs').prop('checked',true);
        }
        if(serviceItemList.includes('vfs;')){
            console.log('adhocitem3 DB ' + cs['xadtx3__c'].value); 
            cs['xadtx3__c'].value=xadtx3__c;
            console.log('service item list includes vfs'+ cs['xadtx3__c'].value + 'adhocitems3' + xadtx3__c );
            //save_Vfs_Popup_Details();   
            if($('#chkvfs').prop('checked')){
                if(cs['xadtx3__c'].value!=""){
                    console.log('------------------- updating xadtx3 to new json  value--------' +cs['xadtx3__c'].value);
                    vfsDet = JSON.parse(cs['xadtx3__c'].value);
                    console.log('vfsDetJSON' + vfsDet['university'] + vfsDet['contactperson']);    
                    $('#certificate').val(vfsDet['certificate']); $('#certificate').trigger('change');                            
                    $('#university').val(vfsDet['university']);
                    $('#colladdress').val(vfsDet['colladdress']);
                    $('#contactperson').val(vfsDet['contactperson']);
                    $('#country').val(vfsDet['country']);                
                    $('#contactnum').val(vfsDet['contactnum']);
                    $('#NumberofcertifOptions').val(vfsDet['NumberofcertifOptions']);
                    //$('#country').val(vfsDet['country']);
                    $('#additionalDetails').val(vfsDet['additionalDetails']);
                    
                    
                    console.log('country of pickup val' + cs['countryOfPickup'].options.length);                 
                    for (let i = 0; i < cs['countryOfPickup'].options.length; i++){
                        //  console.log('iteration' + cs['countryOfPickup'].options[i].value); 
                        if(cs['countryOfPickup'].options[i].value === vfsDet['countryOfPickup']){
                            cs['countryOfPickup'].text = cs['countryOfPickup'].options[i].text;
                            cs['countryOfPickup'].value = vfsDet['countryOfPickup']; 
                            break; 
                        }    
                    }
                    //fill the issuing country of certificate
                    console.log('optionslength' + cs['country2'].options.length + 'vfsDetCountry' + vfsDet['country']); 
                    for (let i = 0; i < cs['country2'].options.length; i++){
                        console.log('forloopval' + cs['country2'].options[i].text);
                        if(cs['country2'].options[i].text === vfsDet['country']){
                            console.log('----equalhere-----' + cs['country2'].options[i].text + vfsDet['country']);                        
                            cs['country2'].text = cs['country2'].options[i].text;
                            cs['country2'].value = cs['country2'].options[i].value;
                            $(cs['country2']).trigger('change');
                            break; 
                        }    
                    }
                    //fill country code
                    for(i of countryCodeObj_new){
                        if(i.dial_code === vfsDet['countryCode']) {                        
                            cs['countryCode'].options[cs['countryCode'].selectedIndex].text = i.dial_code+'-'+i.name ;
                            cs['countryCode'].options[cs['countryCode'].selectedIndex].value = vfsDet['countryCode'];
                        }
                    }
                    
                    //console.log('countryVal' + $('#countryCode').val().trim()); 
                    
                    //$('#countrycode').val(vfsDet['countrycode']);
                    // document.getElementById('{!$Component.countryOfPickup}').textContent = cs['countryOfPickup'].options[cs['countryOfPickup'].selectedIndex].text;
                    
                    //cs['country'].value= vfsDet["countrycode"]; $(cs['country']).trigger('change');
                }
                else
                    $('#modal_vfsatt').modal('show');
            }
        }
    }
    function toggleVFSPopup(){
        hideGLoader();
        if($('#chkvfs').prop('checked'))
            $('#modal_vfsatt').modal('show'); 
        else
            $('#modal_vfsatt').modal('hide');
    }
    function revertVFSCheck(){
        $('#chkvfs').prop('checked',true);
    }
    function updateADHOC(itmCd,confirmBtnFlag){
        console.log('---------------within update ADHOC method---------------');
        if(getC('chk'+itmCd).checked){ 
            showTempLoader_input();
            cs['xadh__c'].value+='vfs;'
            toggleVFS();
            //if this method is used on click of the confirm button --> add to the adhoc field "vfs;" else resetmodalInputs
            if(confirmBtnFlag == 'true'){
                console.log('if confirmbtnflag'); 
                if(cs['xadh__c'] != null) {
                    var adh = cs['xadh__c'].value;
                    if(!adh.includes(itmCd + ';')) {
                        cs['xadh__c'].value += itmCd + ';';
                        console.log('adhocvalue' + cs['xadh__c'].value);
                    }
                }
                console.log('after ifadhoc diff null'); 
            }
            if(itmCd=='vfs'){
                console.log('ahocitem33' + xadtx3__c);
                cs['xadtx3__c'].value = xadtx3__c;
                //'{"country":"Afganisthan","countrycode":"xaf","certificate":"Education certificate","university":"Issuing University Name","colladdress":"Address for Collection","contactnum":"Contact Number","contactperson":"qweqweq"}'
                if(cs['xadtx3__c'].value==""){console.log('------------------ within condition xadtx3 is null----------');resetModalInputs('#modal_vfsatt');setPlaceholder();}
                console.log('before update popup details'); 
                //updatePopupDetails();
                console.log('AFTER update popup details'); 
                //$('#modal_vfsatt').modal('show'); 
                
            }
        }
        else{
            if(!$('#chkvfs').prop('checked')){
                axsConfirmation('Please Confirm','VFS item will be removed.',true,'toggleVFS','','revertVFSCheck','');
            }
            console.log('if input not checked'); 
            if(cs['xadh__c'] != null) { 
                var adh = cs['xadh__c'].value;
                if(adh.includes(itmCd+';')){
                    cs['xadh__c'].value = adh.replace(itmCd+';', '');
                    console.log('clearing adhoc');}}
            if(itmCd=='vfs'){
                cs['xadtx3__c'].value="";
                console.log('-----------after updating xadtx3 to null--------------');
            }
        }
    }
    
    
    function saveReq() {
        var validated = true;
        if(isAdnic){
            var selectedpol = cs['xintp__c'].value; var insSelected = getC("adnicIns").checked;
            if((selectedpol==null || selectedpol=='') && (insSelected)){ 
                getC("adnicIns").checked = true;
                axsAlert('Opted for ADNIC Insurance','Please select an insurance policy or unselect the insurance to proceed with application.');
                toggleGLoader(); hideTempLoader_input(); validated=false; return;
            }   
            if(selectedpol==null || selectedpol==''){cs['ins'].checked=false;}else{cs['ins'].checked=true;}
        }   
        
        var xadh = cs['xadh__c'].value;
        if(xadh.includes('vfs;') && cs['xadtx3__c'].value==""){
            axsAlert('Opted for VFS Attestation','Please enter attestation details or unselect VFS attestation services to proceed with application.')
            toggleGLoader(); hideTempLoader_input(); validated=false; return;
        }
        
        if(!xadh.includes('vfs;') && cs['xadtx3__c'].value!=""){console.log('------------------- if not vfs  and value diff null--------' +cs['xadtx3__c'].value);
                                                                cs['xadtx3__c'].value="";}
        
        if(validated){updateRequest();}
    }
    
    function selectAdhocItems(){
        
    }
    
    function bckBtn(){window.history.back();}
    
    //cs["vfsFlag"] = document.getElementById("{!$Component.vfsFlag}");
    //cs["vfsFlag"] = document.getElementById('vfsFlag');
    
    //to show vfs Popup If vfs flag is selected on page load without clicking on green tick
    function showPopup_on_VfsOption(){
        //check if green tick or vfs flag 
        console.log('vfs flag 2'+ vfsflg);
        var returnedVfsFlag = vfsflg;
        console.log('returned vfs' + returnedVfsFlag);
        if (returnedVfsFlag == 'true' && cs['xadtx3__c'].value==""){
            console.log('vfs flag checked'); 
            //show modal popup 
            $('#modal_vfsatt').modal('show');
        }
    }
    </script>
    
    <apex:form >         
