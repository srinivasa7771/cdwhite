        <apex:actionFunction name="save_Vfs_Popup_Details" action="{!saveVfsPopupDetails}" reRender="none" status="theStatus" onbeforedomupdate="javascript: window.location.reload();" oncomplete="javascript: $('#modal_vfsatt').modal('hide');"/>
        <apex:actionFunction name="toggleVFS" action="{!saveVfsPopupDetails}" reRender="none" status="theStatus" oncomplete="toggleVFSPopup();hideTempLoader_input();"/>
