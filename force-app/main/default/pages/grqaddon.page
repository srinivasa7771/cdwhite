            });*/
            }
            
            //for VFS attestation service
            if(serviceItemList.includes('vfs;')){
                xadtx3__c = '{!JSENCODE(rqDraft.xadtx3__c)}'; 
                console.log('-----------------after updating xadtx3__c to rqDraft value-----------'+xadtx3__c);
                setTimeout(updatePopupDetails(),1000);
                console.log('-----------------after executing updatePopupDetails------------------');
                
            }
            //Close the page loader
            setTimeout(function(){
                hideGLoader();
            },400);
        });
        </script>
        
