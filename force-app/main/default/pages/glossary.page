<apex:page cache="false" standardStylesheets="false" readOnly="true" showHeader="true" sidebar="false" title="Help" controller="helpCenterController">
    <html>
        <head>
            <title>HELP</title>
        </head>
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/>
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <link class="user" href="/resource/1603193409000/axs2StyleV2" rel="stylesheet" type="text/css" />
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <apex:includeScript value="{!$Resource.ScriptV2}"/>
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        
        <apex:form id="form">
            <style>	
                .help-box {	
                display: block;	
                height: calc(100% - 1.5rem);	
                margin-bottom: 1.5rem;	
                padding: 2.125rem 1.5rem 1.5rem;	
                border-radius: 1rem;	
                background-color: #ffffff;	
                text-align: center;	
                color: inherit;	
                font-size: 1.125rem;	
                -webkit-transition: 0.3s all;	
                -o-transition: 0.3s all;	
                transition: 0.3s all;	
                }	
                .help-box > i {	
                display: inline-block;	
                margin-bottom: 1.5rem;	
                font-size: 2.75rem;	
                }	
                .help-box > h2 {	
                margin-bottom: 0.5rem;	
                }	
                .help-box p {	
                color: #4A4A4A;	
                }	
                .help-box:hover {	
                -webkit-box-shadow: 0 0 10px 5px rgba(0, 0, 0, 0.1);	
                box-shadow: 0 0 10px 5px rgba(0, 0, 0, 0.1);	
                }	
                .help-center-layout {	
                -webkit-box-align: start;	
                -ms-flex-align: start;	
                align-items: flex-start;	
                }	
                .help-center-layout .base-side {	
                border-radius: 1rem;	
                background-color: #ffffff;	
                }	
                @media (min-width: 768px) {	
                .help-center-layout .base-side {	
                margin-right: 25px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-center-layout .base-side {	
                -ms-flex-preferred-size: 380px;	
                flex-basis: 380px;	
                }	
                }	
                .help-center-layout.base-layout .base-side + .base-main {	
                border-radius: 1rem;	
                }	
                .help-center-layout .base-main {	
                padding: 0;	
                }	
                .help-center-layout .base-main .base-main-footer {	
                padding-top: 1.5rem;	
                border-radius: 0 0 1rem 1rem;	
                }	
                .help-side-menu {	
                list-style: none;	
                margin: 0 0 1.5rem;	
                padding: 0;	
                border-top: 1px solid rgba(103, 109, 120, 0.2);	
                }	
                .help-side-menu ul {	
                margin: 0;	
                list-style: none;	
                padding: 0;	
                }	
                .help-side-menu li {	
                position: relative;	
                }	
                .help-side-menu li a {	
                display: block;	
                }	
                .help-side-menu > li {	
                position: relative;	
                border-bottom: 1px solid rgba(103, 109, 120, 0.2);	
                }	
                .help-side-menu > li > a {	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                color: #333333;	
                font-weight: 500;	
                font-size: 1.25rem;	
                line-height: 1;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu > li > a {	
                padding: 16px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu > li > a {	
                padding: 16px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu > li > a {	
                padding: 16px 40px;	
                }	
                }	
                .help-side-menu li.has-children > a {	
                position: relative;	
                }	
                .help-side-menu li.has-children > a::after {	
                display: inline-block;	
                font: normal normal normal 14px/1 FontAwesome;	
                font-size: inherit;	
                text-rendering: auto;	
                -webkit-font-smoothing: antialiased;	
                -moz-osx-font-smoothing: grayscale;	
                content: "\f107";	
                position: absolute;	
                right: 1rem;	
                top: 0.75rem;	
                line-height: 1;	
                font-size: 1.5rem;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                z-index: 1;	
                }	
                .help-side-menu li.has-children.open > a::after {	
                -webkit-transform: rotate(180deg);	
                -ms-transform: rotate(180deg);	
                transform: rotate(180deg);	
                }	
                .help-side-menu li > ul {	
                display: none;	
                }	
                .help-side-menu li.open > ul {	
                display: block;	
                }	
                .help-side-menu > li.open {	
                background-color: #F5F5F5;	
                }	
                .help-side-menu > li ul {	
                padding-left: 1.25rem;	
                }	
                .help-side-menu ul.help-submenu {	
                padding-left: 0;	
                }	
                .help-side-menu ul.help-submenu > li {	
                border-bottom: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .help-side-menu ul.help-submenu > li:last-child {	
                border-bottom: none;	
                }	
                .help-side-menu ul.help-submenu > li > a {	
                display: block;	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                font-weight: 500;	
                font-size: 1.125rem;	
                line-height: 1;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 40px;	
                }	
                }	
                .help-side-menu ul.help-submenu > li > a::after {	
                top: 0.625rem;	
                color: #999999;	
                }	
                .help-side-menu ul:not(.help-submenu) {	
                padding-bottom: 10px;	
                }	
                .help-side-menu ul:not(.help-submenu) a {	
                padding-bottom: 0.625rem;	
                color: #777777;	
                }	
                .help-side-menu ul:not(.help-submenu) a:hover, .help-side-menu ul:not(.help-submenu) a:focus {	
                color: #333333;	
                }	
                .help-side-menu ul:not(.help-submenu) li.active > a {	
                color: #333333;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 30px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 40px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 50px;	
                }	
                }	
                .content-icon {	
                position: relative;	
                margin-bottom: 2rem;	
                padding-left: 2.25rem;	
                }	
                .content-icon > i {	
                position: absolute;	
                -webkit-box-flex: 1;	
                -ms-flex: 1 1 auto;	
                flex: 1 1 auto;	
                top: 2px;	
                left: 0;	
                padding-right: 0.75rem;	
                font-size: 1.5rem;	
                }	
                @media (min-width: 1200px) {	
                .service-catalogue-footer > div {	
                border-right: 1px solid rgba(103, 109, 120, 0.2);	
                }	
                }	
                .service-catalogue-footer > div:last-child {	
                border-right: none;	
                }	
                .glossary-collapse {	
                border-radius: 0.75rem;	
                background: #ffffff;	
                border: none;	
                -webkit-animation-duration: 0.5s;	
                animation-duration: 0.5s;	
                }	
                .glossary-collapse .collapse-header {	
                padding: 1rem 2.5rem 1rem 1.5rem;	
                font-weight: bold;	
                color: #4A4A4A;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .glossary-collapse .collapse-header::after {	
                top: 0.875rem;	
                right: 1rem;	
                }	
                .glossary-collapse .collapse-header:hover {	
                color: #646464;	
                }	
                .glossary-collapse .collapse-content {	
                padding: 0 1.5rem 1rem;	
                }	
                .glossary-filter a {	
                display: inline-block;	
                width: 35px;	
                line-height: 35px;	
                margin-right: 5px;	
                margin-bottom: 5px;	
                color: #333333;	
                font-size: 20px;	
                font-weight: bold;	
                text-align: center;	
                border-radius: 50%;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .glossary-filter a:hover {	
                background-color: rgba(0, 0, 0, 0.1);	
                }	
                .glossary-filter a.active {	
                background-color: #67486C;	
                color: #ffffff;	
                }	
                .glossary-filter a.inactive {	
                cursor: default;	
                color: #9B9B9B;	
                }	
                .glossary-filter a.inactive:hover {	
                background-color: transparent;	
                }	
                .card-video {	
                display: block;	
                margin-bottom: 30px;	
                background-color: #ffffff;	
                border-radius: 10px;	
                color: inherit;	
                overflow: hidden;	
                -webkit-box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
                box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-img {	
                padding-top: 55%;	
                position: relative;	
                background-repeat: no-repeat;	
                background-size: cover;	
                background-position: center center;	
                border-radius: 10px;	
                overflow: hidden;	
                }	
                .card-video-img::before {	
                content: ' ';	
                position: absolute;	
                left: 0;	
                top: 0;	
                width: 100%;	
                height: 100%;	
                background-color: rgba(30, 30, 30, 0.3);	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-img::after {	
                display: inline-block;	
                font: normal normal normal 14px/1 FontAwesome;	
                font-size: inherit;	
                text-rendering: auto;	
                -webkit-font-smoothing: antialiased;	
                -moz-osx-font-smoothing: grayscale;	
                content: "\f144";	
                position: absolute;	
                left: 50%;	
                top: 50%;	
                -webkit-transform: translate(-50%, -50%);	
                -ms-transform: translate(-50%, -50%);	
                transform: translate(-50%, -50%);	
                color: #ffffff;	
                font-size: 50px;	
                line-height: 1;	
                opacity: 0.9;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-content {	
                min-height: 105px;	
                padding: 1.25rem;	
                }	
                .card-video-title {	
                color: inherit;	
                }	
                .card-video:hover {	
                -webkit-box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
                box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
                }	
                .card-video:hover .card-video-img::before {	
                background-color: rgba(30, 30, 30, 0.5);	
                }	
                .card-video:hover .card-video-img::after {	
                opacity: 1;	
                }	
                #modal_video .modal-header {	
                padding: 1rem 1.5rem;	
                }	
                #modal_video .modal-header h4 {	
                margin-bottom: 0;	
                }	
                #modal_video .modal-content {	
                border-radius: 10px 10px 0 0;	
                }	
                .input-filter-faqs > input[type=text] {	
                border: none;	
                }	
                .faq-category-list {	
                list-style: none;	
                margin: 0 0 1.5rem;	
                padding: 0;	
                border-top: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .faq-category-list > li {	
                border-bottom: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .faq-category-list > li > a {	
                display: block;	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                color: #333333;	
                font-weight: 500;	
                font-size: 1.25rem;	
                line-height: 1;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                @media (min-width: 576px) {	
                .faq-category-list > li > a {	
                padding: 14px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .faq-category-list > li > a {	
                padding: 14px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .faq-category-list > li > a {	
                padding: 14px 40px;	
                }	
                }	
                .faq-category-list > li > a:hover {	
                background-color: #f5f6fb;	
                }	
                .faq-category-list > li.active > a {	
                background-color: #f5f6fb;	
                }	
                .faq-category-list > li ul {	
                list-style: none;	
                padding-left: 40px;	
                }	
                .faq-category-list > li ul > li > a {	
                display: block;	
                padding: 10px 12px;	
                }	
                .faq-collapse {	
                border-radius: 0.75rem;	
                background: #ffffff;	
                border: none;	
                -webkit-animation-duration: 0.5s;	
                animation-duration: 0.5s;	
                }	
                .faq-collapse .collapse-header {	
                padding: 1rem 2.5rem 1rem 1.5rem;	
                font-size: 1rem;	
                font-weight: 500;	
                color: #4A4A4A;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .faq-collapse .collapse-header::after {	
                top: 1rem;	
                right: 1rem;	
                }	
                .faq-collapse .collapse-header:hover {	
                color: #646464;	
                }	
                .faq-collapse .collapse-title {	
                font-size: 1.125rem;	
                }	
                .faq-collapse .collapse-content {	
                padding: 0 1.5rem 1rem;	
                }
                .disabled {
                pointer-events: none;
                cursor: default;
                }
            </style>
            <script>
            function rerenderblock(){
                console.log('inside rerenderblock');
                renderInfoDiv();
            }
            function rerenderglossaryBlock(val){
                var idval = val;
                console.log('inside rerenderglossaryBlock '+idval);
                document.getElementById(idval).classList.add('active');
                getInfoDiv(idval);
            }
            function reArrangeTitles(){
                $('a.collapse-header').each(function(){
                    var next = $(this).next('.collapse-title');
                    $(this).append(next);
                    $(this).next('.collapse-title').remove();
                });
            }
            </script>
            <apex:actionFunction name="getInfoDiv" action="{!onGlossClick}" oncomplete="rerenderblock()" id="getInfoDiv">
                <apex:param id="contentId1" name="contentId1" value=""/>
            </apex:actionFunction>
            <apex:actionFunction name="renderInfoDiv" reRender="glossary_list" id="renderInfoDiv" oncomplete="reArrangeTitles()"/>
            <body>
                <div id="main">
                    <div id="page_content">
                        <div class="container">
                            <div class="page-header">
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/gpm">Dashboard</a></li>
                                    <li class="breadcrumb-item"><a href="/helpCenter">Help Center</a></li>
                                    <li class="breadcrumb-item">Glossary</li>
                                </ul>
                                <!-- .breadcrumb -->
                                <h1 class="page-title">GLOSSARY</h1>
                            </div>
                            <!-- .page-header -->
                            <div class="base-layout help-center-layout">
                                <div class="base-side">
                                    <div class="base-side-content mb-0">
                                        <p class="text-light-2 fs-18">
                                            Browse our glossary of terms to understand all abbreviations used.
                                        </p>
                                        <div class="glossary-filter mt-5" id="glossary_filter">
                                            <apex:repeat value="{!alpha}" var="key">
                                                <a href="#" onclick="rerenderglossaryBlock(this.id)" id="{!key}" class="{!alpha[key]}">{!key}</a>
                                            </apex:repeat>
                                        </div>
                                    </div>
                                    <!-- .base-side-content -->
                                </div>
                                <!-- .base-side -->
                                
                                <div class="base-main bg-transparent">
                                    <apex:outputPanel id="glossary_list">
                                        <div class="base-main bg-transparent">
                                            <apex:variable value="{!0}" var="ind1"/>
                                            <apex:repeat value="{!glossDetailList}" var="glossDet" id="glossRepeat">
                                                <apex:variable var="ind1" value="{!ind1+1}"/>
                                                <div class="base-collapse glossary-collapse animated fade-in-up-sm" style="display: block;">
                                                    <a href="#" class="collapse-header collapsed" data-toggle="collapse"
                                                       data-target="#glossary_item_{!ind1}">
                                                        <div class="collapse-title">{!glossDet.Label__c}</div>
                                                    </a>
                                                    <div id="glossary_item_{!ind1}" class="collapse">
                                                        <div class="collapse-content">
                                                            <p>
                                                                {!glossDet.Definition__c}
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </apex:repeat>
                                        </div>
                                        <!-- .base-collapse -->
                                        
                                    </apex:outputPanel>
                                </div>
                                
                                <!-- .base-main -->
                            </div>
                            <!-- .base-layout -->
                        </div>
                    </div>
                </div>
            </body>
        </apex:form>
        <!-- main js -->
        <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js')}"  />
    </html>
</apex:page>