    <script>
    var selectedJSON = [];
    var reqId = '', cNum='', reason='';
    $(document).ready(function(){
        cNum = getUrlParameter('c');
        reason = getUrlParameter('r');  
        callWS();
        reqId = '{!req.id}';
        if(cNum == '')
            cNum = '{!req.rtacn__c}';
        //Axs2CustomJS
        
    });
    function createDD(){
        let str = cs['parkingString'].value;
        allJSONStr = str.replaceAll('\t', ' ');        
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        var allJSONObj = JSON.parse(allJSONStr);
        for(i of allJSONObj){
            var d ={};
            d.text = i.cardNum;
            d.cardNum = i.cardNum;
            d.cHolderNm = (i.cHolderNm==null)?'NA':i.cHolderNm;
            d.expDate = i.expDate;
            d.id = i.cardNum;
            d.cardId = i.cardId;
            //console.log(i.cardNum+' -- '+i.actStat);
            if(i.actStat=='Inactive'||i.actStat=='Active')
                data.push(d);
        }
        $('.input-select-member').change(function () {
            if ($(this).val() === '') {
                $(this).next('.select2').removeClass('selected');
            } else {
                $(this).next('.select2').addClass('selected');
            }
        });
        $('.input-select-member').select2({
            data: data,
            allowClear: true,
            escapeMarkup: function (markup) {
                return markup;
            },
            templateResult: function (data) {
                if (!data.id && data.id!=undefined) {
                    return data.cardNum;
                }
                
                var html = '<div class="user-title-media user-title-media-sm">' +
                    '<div>' +
                    '<div class="user-name mb-2">' + data.cardNum + '</div>' +
                    '<div class="user-title font-weight-normal">Vehicle owned by ' + data.cHolderNm +
                    ' - Expires on '+data.expDate+'</div>' +
                    '</div>' +
                    '</div>';
                return html;
            },
            templateSelection: function (data) {
                if (!data.id && data.id!=undefined) {
                    return data.cardNum;
                }
                
                var html = '<div class="user-title-media user-title-media-sm">' +
                    '<div>' +
                    '<div class="user-name mb-2">' + data.cardNum + '</div>' +
                    '<div class="user-title font-weight-normal">Vehicle owned by ' + data.cHolderNm +
                    ' - Expires on '+data.expDate+'</div>' +
                    '</div>' +
                    '</div>';
                return html;
            }
        });
        if(cs['rtacn__c'].value!=''&&cs['rtacn__c'].value!=undefined)
            $('.input-select-member').val(cs['rtacn__c'].value).trigger('change');
        setTimeout(function () {
            $('.input-select-member').trigger('change');
        }, 100);
        
    }
    function loadVehicles1(){
        if(cNum!='' ){
            $('.input-select-member').val(cNum).trigger('change');
            /*console.log('cNum -- '+cNum+' && reason -- '+reason);
            toggleGLoader();
            loadVehicles();*/
        }
    }
    function loadSelected(){
        let l = cs['parkingString'].value;
        $('[r="'+reason+'"]').prop('checked',true).trigger('change');
        $('[num="'+cNum+'"]').prop('checked',true).trigger('change');
        var s=l.replace("\"Items\"",'\'Items\'')
        selectedJSON = JSON.parse(s);
    }
    function loadPrevData(){
        // $('[num="'+cs['rtacn__c'].value+'"]').prop('checked',true).trigger('change');
        $('.input-select-member').val(cs['rtacn__c'].value).trigger('change');
    }
    function aftrLoad(){
        cs['Reason__c'].value = "Lost";
        $('.prkOpt').select2({enableSearch:true});
        $('[name="reason"]').on('change',function(){
            var v = $('[name="reason"]:checked').val();
            cs['Reason__c'].value = v;
        });
        if(reqId!='')
            loadPrevData();
    }
    function settoFld(e){
        var cardNum = $(e).val();
        removeValError($('#cardDet'));
        //var cardNum = $(e).attr('num');
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        if(allJSONStr.length>0){
            allJSON = JSON.parse(allJSONStr);
            for(i=0;i<allJSON.length;i++){
                if(cardNum == allJSON[i].cardNum){
                    selectedJSON[0] = allJSON[i];
                }
            }
        }
        console.log('selectedJSON[0]====',selectedJSON[0]);
        cs['rtacn__c'].value = cardNum;
        var refMob = (selectedJSON[0]?.refMobile)?selectedJSON[0].refMobile:cs["rmob__c"].value;
        if( refMob.startsWith('+971'))
        {
            refMob = refMob.substring(4);
        }  
        cs["rmob__c"].value=refMob;
        
        //cs["rmob__c"].value=refMob;https://axs2--axsstg.sandbox.my.salesforce.com/_ui/common/apex/debug/ApexCSIPage#//(selectedJSON[0]?.refMobile)?selectedJSON[0].refMobile:cs["rmob__c"].value;
        //cs["xceml__c"].value = selectedJSON[0].email;
        $('.table-parking').parent().parent().find('.frmErrMsg').remove();
    }
    
    
    function getUrlParameter(key){
        var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
        return (res==undefined)?'':res[1];
    }
    
    
    </script>
