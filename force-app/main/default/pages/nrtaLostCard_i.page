    <script type="text/javascript">
    var cs = {};
    var ad4 = {"ActionName":"insertparkingrequest","OracleID":"","AgNo":"","AXSId":"","reason":"","CardNumber":"","Eligibility":"","RequestType":"Parking Card","BusinessPark":"","SectorLocationId":"","Sector":"","CardRequestType":"Lost","ParkingType":"Paid","EndDate":"","CardsDetail":[{"cardHolderName":"","Email":"","Mobile":"","Phone":"","Vehicles":[]}]};
    
    function saveDetails(){
        
        //cs['ias__c'].value='0np';
        if(!$('#cardDet').val()){
            addValError($('#cardDet'),'Please select a card');
            return;
        }
        cs['xadh__c'].value='0np';
        cs['xpveh__c'].value=selectedJSON[0].vehicleNumber;
        cs['xchn__c'].value=selectedJSON[0].cHolderNm;
        cs['xppor__c'].value=selectedJSON[0].pPlaceOfReg;
        cs['xps__c'].value=selectedJSON[0].sector;        
        createAD4();
        if($('.frmErrMsg').is(':visible')){
            scrollToDiv($('.frmErrMsg').eq(0));
            return;
        }
        var brk = vflds('.requiredFld,.applMob', true);
        var mob = isUAEMobNum($(".applMob"));
        if(mob==false){
            brk = true;
        }
        if(!brk){toggleGLoader(); afso(); }
    }
    
    function createAD4(){
        ad4.CardNumber = $('#cardDet').val();
        ad4.Sector= selectedJSON[0].sector;
        ad4.SectorLocationId = selectedJSON[0].sectorId;
        var dt = selectedJSON[0].expDate.split('/')[2]+'-'+selectedJSON[0].expDate.split('/')[1]+'-'+selectedJSON[0].expDate.split('/')[0];
        ad4.EndDate = dt;
        ad4['reason']=cs['Reason__c'].value;
        ad4['CardRequestType']=cs['Reason__c'].value;
        ad4['Eligibility'] = selectedJSON[0].EligibilityName;
        ad4['ParkingType'] = selectedJSON[0].cardType;
        cs['xadtx4__c'].value = JSON.stringify(ad4);
    }
    
    function vflds(clsName){
        var brk = false;var elem = '';
        
        $(clsName).each(function(){ 
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=true; addValError(this,'This field is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        return brk;
    }
    
    
    </script> 
    
