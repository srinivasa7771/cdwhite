<apex:page action="{!gCC}" contentType="text/csv#CCStatement.csv" applyHtmlTag="false" cache="false" expires="0" readOnly="true" sidebar="false" showHeader="false"  title="Credit/Debit Card Statement" standardController="Account" extensions="gctlAdPDF" >
        Credit/Debit Card Statement {!newLN}
        - from <apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dF}"/></apex:outputText> to <apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dT}"/></apex:outputText>{!newLN}
        Print Date: <apex:outputText value="{0, Time, dd-MMM-yyyy: h:mm a}"><apex:param value="{!NOW()}"/></apex:outputText>

        {!newLN}

        Company Name, , {!A.Name}, , , License #, , {!A.lc__c}
        <!-- Available Balance, , {!A.adb__c}  {!newLN} -->
        
        Transactions History
        
        
        {!$ObjectType.g_Tran__c.fields.Name.label}, {!$ObjectType.g_Req__c.label}, {!$ObjectType.g_Tran__c.fields.STA__c.label}, {!$ObjectType.g_Tran__c.fields.dt__c.label}, Amount  {!newLN}
        <apex:repeat value="{!Ts}" var="T">                                               
            <apex:outputText value="{!SUBSTITUTE(JSENCODE(T.T.Name), ',', ' ')}" />  , 
            <apex:outputText value="{!SUBSTITUTE(JSENCODE(T.T.RQ__r.Name), ',', ' ')}" /> ,  
            <apex:outputText value="{!SUBSTITUTE(JSENCODE(T.T.STA__c), ',', ' ')}" /> ,
            
            <apex:outputText value="{0, Date, dd-MM-yyyy}"><apex:param value="{!T.T.dt__c}"/></apex:outputText> ,
            
            
            <apex:outputText value="{!T.T.A__c}" /> 
            {!newLN}
        </apex:repeat>                               
</apex:page>