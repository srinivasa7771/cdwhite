    function epckPID(lcl,sdt){
        var tdy=new Date();
        id = dtParse(sdt,lcl); 
        var flg=true;
        if(id>tdy){fldErr('psIssue','Passport issue date cannot be future date.',cs);return false;}
        else{fldErr('psIssue',null,cs);return true;}
        return flg;
    }
    function ckDOB(lcl,sdt){
        var tdy=new Date();
        id = dtParse(sdt,lcl); 
