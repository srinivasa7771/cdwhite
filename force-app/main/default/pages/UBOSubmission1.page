        if(id>tdy){fldErr('dob','Date of birth cannot be future date.',cs);return false;}
        else{fldErr('dob',null,cs);return true;}
        return flg;
    }
    function epckPED(lcl,sdt){
        var tdy=new Date();
        id = dtParse(sdt,lcl); 
