                                                                cs['cCountry']=getC('{!$Component.cCountry}');
                                                                </script>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-sm-6"> 
                                                            <div class="form-group">
                                                                <label>Residence Phone</label>
                                                                <apex:input id="cPhone" type="text" value="{!indvInformation.cPhone}" styleclass="crequiredFld form-control"/>
                                                                <script type="text/javascript">
                                                                cs['cPhone']=getC('{!$Component.cPhone}');
                                                                </script>
                                                            </div>
                                                        </div>  
                                                        <div class="col-sm-6"> 
                                                            <div class="form-group"> 
                                                                <label>Mobile No</label>
                                                                <apex:input id="cMobile" type="text" value="{!indvInformation.cMobile}" styleclass="crequiredFld form-control"/>
                                                                <script type="text/javascript">
                                                                cs['cMobile']=getC('{!$Component.cMobile}');
                                                                </script>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    
                                                    <!-- Start Additional Details of UBO-->
                                                    <h2>Additional Details of Ultimate Beneficial Owner(s) (UBO)</h2>
                                                    
                                                    <div class="col-sm-6"> 
                                                        <div class="form-group"> 
                                                            <label> The number of other legal persons which the Beneficial Owner owns, manages or controls accordingly</label>
                                                            <apex:selectList value="{!indvInformation.noOfUBO}" size="1" id="legals" styleclass="requiredFld form-control input-select2-flat">
                                                                <apex:selectOption itemValue="" itemLabel=""/>
                                                                <apex:selectOption itemValue="0-1" itemLabel="0-1"/>
                                                                <apex:selectOption itemValue="2-3" itemLabel="2-3"/>
                                                                <apex:selectOption itemValue="4-5" itemLabel="4-5"/>
                                                                <apex:selectOption itemValue="6-7" itemLabel="6-7"/>
                                                                <apex:selectOption itemValue="8-9" itemLabel="8-9"/>
                                                                <apex:selectOption itemValue="More than 10" itemLabel="More than 10"/>
                                                            </apex:selectList>
                                                            <script type="text/javascript">
                                                            cs['legals']=getC('{!$Component.legals}');
                                                            </script>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="requiredInput" id="fileRI">
                                                        <br/><b>Upload passport/emirates ID card</b><br/>
                                                        <apex:inputFile value="{!attachment.body}" filename="{!attachment.name}" id="file"/>
                                                        <script type="text/javascript">
                                                        cs['file']=getC('{!$Component.file}');
                                                        </script>
                                                        <apex:outputPanel id="file1">
                                                            <script type="text/javascript">
                                                            cs['file1']=getC('{!$Component.file1}');
                                                            </script>
                                                            <apex:repeat value="{!indvInformation.eId}" var="v">
                                                                <a href="{!v.url}" target="_blank">{!v.Name}</a> |&nbsp;&nbsp;
                                                            </apex:repeat>
                                                        </apex:outputPanel>
                                                    </div>
                                                </apex:outputPanel>
                                                <!-- End Additional Details of UBO -->
                                            </div>
                                            
                                            <apex:actionFunction name="saveInfoUBO" action="{!saveInfo}" />
                                            
                                            <div class="mt-4 base-main-footer">
                                                <apex:commandButton styleClass="btn btn btn-primary base-nav-next" action="{!cancelNewUBO}" value="Cancel"/>
                                                <a href="" onClick="sv();" class="btn btn btn-primary base-nav-next" style="color:#fff">Save</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                        <!--########################################################################################## -->
                        
                    </div>
                </div>
            </div>
        </div>
