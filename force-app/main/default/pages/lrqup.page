        var ad3MemData = {}, isEditingMem = false , exMemPPChanged= false;
        function memEdit(dId){
            
            editingMemDocId = dId;
            ad3MemData = {};
            if(cs["xadtx3__c"] && cs["xadtx3__c"].value){
                let ad3 = JSON.parse(cs["xadtx3__c"].value);
                console.log('ad3 data :'+JSON.stringify(ad3));
                if(ad3 && ad3.serviceRequests != undefined &&ad3.serviceRequests[0]&&ad3.serviceRequests[0].members.length>0){ //PJ 1.1
                    if(ad3.serviceRequests[0].members.length>1 && dId){
                        for(i of ad3.serviceRequests[0].members){
                            if(dId == i.attachmentId){
                                ad3MemData = i;
                            }
                        }
                    }
                    else
                        ad3MemData = ad3.serviceRequests[0].members[0];
                }
            }
            if(Object.keys(ad3MemData).length>0){
                for(i of Object.keys(ad3MemData)){
                    if(i!='addresses'){
                        if(typeof(ad3MemData[i])=='object' && ad3MemData[i] && Object.keys(ad3MemData[i]).length>0){
                            let recObj = (i=='passports' || i=='addresses')?ad3MemData[i][0]:ad3MemData[i];
                            for(j of Object.keys(recObj)){
                                let e = $('#modal_confirm_information_LA').find('[ddaKeyparent='+i+'][ddaKey='+j+']');
                                let f = e.attr('for');
                                let v = (e.hasClass('input-datepicker'))?formatDate_LA(recObj[j]):recObj[j];
                                if(f=='allowSingleQuote'){
                                    v = v.replaceAll('\\','');
                                    v = v.replaceAll('\\','');  
                                }
                                e.val(v);
                            }
                        }
                        else if(i=='perMobile'){
                            $('#modal_confirm_information_LA').find('[ddakey="phoneCode"]').val(ad3MemData[i].split('-')[0]);
                            $('#modal_confirm_information_LA').find('[ddaKey='+i+']').val(ad3MemData[i].split('-')[1]);
                        }
                            else if(i== 'isEmailVerified' && ad3MemData.isEmailVerified == true){  //PJ 1.1- Show correct green sign when email is verified
                                $('[ddakey="isEmailVerified"]').show();
                                cs['isEmailVerified'] = true;
                                //$('#otpValidateEmailBtn').hide();
                            }
                                else if(i== 'isMobilePhoneVerified' && ad3MemData.isMobilePhoneVerified== true){ //PJ 1.1 - Show correct green sign when mobile number is verified
                                    $('[ddakey="isMobilePhoneVerified"]').show();
                                    cs['isMobilePhoneVerified'] = true;
                                    //$('#otpValidateMobileBtn').hide();
                                }
                                    else{
                                        let e = $('#modal_confirm_information_LA').find('[ddaKey='+i+']');
                                        let f = e.attr('for');
                                        let v = (e.hasClass('input-datepicker'))?formatDate_LA(ad3MemData[i]):ad3MemData[i];
                                        v = (i=='proposedNumberOfShares'&&!v)?0:v;
                                        if(i=='nationality'){
                                            $('[ddakey="nationality"]').find('option[for="'+ad3MemData.nationality+'"]').prop('selected',true)
                                            $('[ddakey="nationality"]').trigger('change');
                                        }
                                        if(f=='allowSingleQuote'){
                                            v = v.replaceAll('\\','');
                                            v = v.replaceAll('\\','');  
                                        }
                                        e.val(v);
                                    }
                    }
                    $('[fldName="shareNum"]').parents('col-md-6').hide();
                }
            }
            $('#modal_confirm_information_LA select').trigger('change');
            $('#otpButtonBlock').hide();  //PJ 1.1 - Hiding validate button on edit as mobile number and email should be validated at this stage.
            if(ad3MemData.emiratesId ){
                if(ad3MemData.emiratesId.docNo)
                    $('#modal_confirm_information_LA [name="eid"][for="yes"]').prop('checked',true).trigger('change');
                else
                    $('#modal_confirm_information_LA [name="eid"][for="no"]').prop('checked',true).trigger('change');
            }
            $('#modal_confirm_information_LA').find('[name="sal"][for="'+ad3MemData.salutation+'"]').prop('checked',true);
            /* For Address and nationality fields starts.-- need to be removed  */
            $('[ddakey="nationality"]').find('option[for="'+ad3MemData.nationality+'"]').prop('selected',true);
            $('[ddakey="nationality"]').trigger('change');
            $('[ddakey="birthCountry"]').find('option[for="'+ad3MemData.birthCountry+'"]').prop('selected',true);//U_S 1.2
            $('[ddakey="birthCountry"]').trigger('change');//U_S 1.2
            if(ad3MemData.addresses &&  ad3MemData.addresses.length > 0){ // PJ 1.1
                $('[ddakey="Area"]').val(ad3MemData.addresses[1].area);
                $('[ddakey="Street"]').val(ad3MemData.addresses[1].street);
                $('[ddakey="emirate"]').val(ad3MemData.addresses[1].city);
                $('[ddakey="emirate"]').select2();
                            /*U_S* -- Start 1.2*/
                if(ad3MemData.addresses[1].postalCode){
                  $('#modal_confirm_information_LA [name="eid"][for="yes"]').prop('checked',true).trigger('change');  
                }
                else{
                $('#modal_confirm_information_LA [name="eid"][for="no"]').prop('checked',true).trigger('change');
                }
                if(ad3MemData.visitedUAE){
                    if(ad3MemData.visitedUAE==true){
                        $('#modal_confirm_information_LA [name="vid"][for="yes"]').prop('checked',true).trigger('change');
                    }
                    if(ad3MemData.visitedUAE==false){
                        $('#modal_confirm_information_LA [name="vid"][for="no"]').prop('checked',true).trigger('change');
                    }
                }
                /*U_S -- End*/
                $('[ddakey="buildingNo"]').val(ad3MemData.addresses[1].buildingNo);
                $('[ddakey="postalCode"]').val(ad3MemData.addresses[1].postalCode);
                $('[fldname="pstreet"]').val(ad3MemData.addresses[0].street);
                $('[fldname="pcity"]').val(ad3MemData.addresses[0].city);
                $('[ddakey="pcountry"]').find('option[for="'+ad3MemData.addresses[0].country+'"]').prop('selected',true);
            }
            $('[ddakey="pcountry"]').trigger('change');
            /* For Address and nationality fields ends.*/
            cs['docname'].value = 'Passport Copy';
            isEditingMem = true;
            $('#modal_confirm_information_LA').modal('show');
        }
        
        function titleCase(elem) {
            let str = $(elem).val();
            if(!str)
                return;
            console.log('--str--'+str);
            var splitStr = str.toLowerCase().split(' ');
            for (var i = 0; i < splitStr.length; i++) {
                splitStr[i] = splitStr[i].charAt(0).toUpperCase() + splitStr[i].substring(1);     
            }
            $(elem).val(splitStr.join(' ')); 
        }
        //Add  warning message
        function addWarningMsg(thiselem,message){
            console.log('addWarningMsg:::');
            var elem = $(thiselem);
            var warElem = '<div class="warningMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(warElem);
            }else{
                elem.parent().append(warElem);
            }
        }
        //Remove warning error
        function removeWarningMsg(thiselem){
            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
        }
        
