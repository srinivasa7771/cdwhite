                <script type="text/javascript">
                cs['docBase64']=getC('{!$Component.docBase64}');
                var docTypes = {"BMP":0,"JPG":1,"PNG":3,"PDF":4};
                function setDDADoc(){
                    var respData;
                    removeTempLoader();
                    if(cs['docBase64'].value){
                        if(typeof(JSON.parse(cs['docBase64'].value))=='string'){
                            respData = JSON.parse(JSON.parse(cs['docBase64'].value));
                        }
                        else
                            respData = JSON.parse(cs['docBase64'].value);
                    }
                    else if(respData.Message =='Failed' || respData.ResponseCode == '404' || cs['docId'].value=='' || cs['docBase64'].value==''){
                        axsConfirmation('Information','We couldn\'t fetch the document. Do you want to try again?',false,'callGetDDADoc',uploadElem,'openFileuploadPopUp');
                        return;
                    }
                    var imgData, imgType ;
                    let DWObject = Dynamsoft.WebTwainEnv.GetWebTwain('dwtcontrolContainer');
                    if(!respData.Data && respData.Message){
                        imgData = respData.Message;
                        imgType = cs['docId'].value.split('/')[cs['docId'].value.split('/').length-1].split('.')[1];//defaulting to JPG as we are not receiving from DMS
                    }
                    else{
                        imgData = respData.Data.body;
                        imgType =respData.Data.documentName.split('.')[1].trim();// choosing by DDA response
                    }
                    DWObject.LoadImageFromBase64Binary(imgData,docTypes[imgType.toUpperCase()]);
                    $('#exDocMessage').show().addClass('blinkAny');
                    $('#modal_fileuploadPopUp').modal('show');
                    //axsConfirmation('Information','We have fetched the existing document from our recoreds.<br /> Do you want to proceed with the same?',false,'updateReqDoc','','btnRemoveCurrentImage_onclick');
                    //axsAlert('Information','We have retrieved your passport from our records. Please review it, or alternatively, you can use the upload button.');
                }
                function openFileuploadPopUp(){
                    cs['docId'].value='';
                    exMemPPChanged = true;
                    $('#modal_fileuploadPopUp').modal('show');
                }
                </script>
