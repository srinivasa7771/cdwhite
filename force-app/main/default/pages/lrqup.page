                                    v = v.replace(/'/g, "\\'");  
                                }
                                recObj[j] = v.trim();
                            }
                        }
                    }
                    else if(i=='perMobile'){
                        ddaData[i] = $('[ddakey="phoneCode"]').val()+'-'+$('[ddakey="perMobile"]').val();
                    }
                        else if(i== 'isEmailVerified'){  //PJ 1.1
                            if(cs['isEmailVerified'] && (cs['isEmailVerified'] == true || cs['isEmailVerified'] == 'true')){
                                ddaData[i] = true;
                                if(cs['isEmailChanged'] === true){
                                    ddaData['emailVerificationDatetime'] = new Date().toISOString();
                                }
                                else{
                                    ddaData['emailVerificationDatetime'] = cs['emailVerificationDatetime'];
                                }
                            }
                        }
                            else if(i== 'isMobilePhoneVerified'){ //PJ 1.1
                                if(cs['isMobilePhoneVerified'] && (cs['isMobilePhoneVerified'] == true || cs['isMobilePhoneVerified'] == 'true')){
                                    ddaData[i] =  true;
                                    if(cs['isMobileChanged'] === true){
                                        ddaData['mobilePhoneVerificationDatetime'] = new Date().toISOString();
                                    }
                                    else{
                                        ddaData['mobilePhoneVerificationDatetime'] = cs['mobilePhoneVerificationDatetime'];
                                    }
                                }
                            }
                                else{
                                    let e = $(modal).find('[ddaKey='+i+']');
                                    let v = (e.hasClass('input-datepicker'))?revertDateFormat(e.val()):e.val();
                                    let f = e.attr('for');
                                    v = (i=='proposedNumberOfShares'&&!v)?0:v;
                                    v = (i=='nationality' || i=='countryOfIncorporation')?$('[ddakey="'+i+'"]').find('option:selected').text():v;
                                    if(v){
                                        if(f=='allowSingleQuote'){
                                            v = v.replace(/\\/g, '\\\\'); 
                                            v = v.replace(/'/g, "\\'");  
                                        }
                                        ddaData[i] = v.trim();
                                    }
                                }
                }
            }
            for(d of Object.keys(ddaActions[0])){
                if(cs["xadh__c"].value.includes(d+';'))
                    ddaData.positions= ddaActions[0][d][0];
            }
            if(selectedJSON && selectedJSON.length>0 || cs['xadtx1__c'].value){
                if(cs["xadh__c"].value.includes('mn;') || cs["xadh__c"].value.includes('cs;')){
                    if(selectedJSON.length==1){
                        ddaData.ddaId = selectedJSON[0].ddaId;
                    }
                }
                if(cs["xadh__c"].value.includes('da;')||cs["xadh__c"].value.includes('ar;') || cs['docname'].value.includes('Exmem') || cs['docname'].value.includes('Existing Member')){
                    if(cs['xadtx1__c'] && cs['xadtx1__c'].value){
                        if(cs['docname'].value.includes('-')){
                            let memName = cs['docname'].value.split('-')[1].trim();
                            for(let [i,v] of JSON.parse(cs['xadtx1__c'].value).entries()){//U_S
                                if(v.type=='Person' && capitalizeName(v.firstName)+' '+capitalizeName(v.lastName) == memName)
                                    ddaData.ddaId = v.ddaId;
                            }
                        }
                    }
                }
            }
            if(adhoc2Data.length>0){
                let memName = cs['docname'].value.includes('-')?cs['docname'].value.split('-')[1].trim():'';
                for(let [i,v] of adhoc2Data.entries()){
                    if(v.firstName+' '+v.lastName == memName){
                        ddaData.UID = v.firstName+''+v.lastName+'_11';
                    }
                }
            }
            var ad2=[];
            if(cs['xadtx2__c'].value){
                var x = cs['docname'].value.replace("Passport Copy - ","").replaceAll(' ','')+'_11';
                ad2=JSON.parse(cs['xadtx2__c'].value);
                for(let v of ad2){
                    if(v.UID == x){
                        v.ppNum = $('#modal_confirm_information_LA #passportid').val();
                    }
                }
            }
            ddaData.salutation = $('#modal_confirm_information_LA [name="sal"]:checked').attr('for');
            ddaData.actionType = (cs['docname'].value.includes('Existing Member'))?'DataUpdate':(!cs['docname'].value.includes('Existing Member') && ddaData.ddaId)? 'UPDATEINFO': 'ADD';//U_S
            let visitedUAEVal;
            if($('.isvisitedUAE.reqRadio:visible')){
                visitedUAEVal=$('#modal_confirm_information_LA [name="vid"]:checked').attr('for');//U_S 1.2
                if(visitedUAEVal=='yes'){
                 ddaData.visitedUAE=true;  
                }
                else if(visitedUAEVal=='no'){
                 ddaData.visitedUAE=false;  
                }
            }
            ddaData.birthCountry=$('#modal_confirm_information_LA #bnat option:selected').text();//U_S 1.2
            if(ddaData.addresses &&  ddaData.addresses.length > 0){ // PJ 1.1
                ddaData.addresses[1].street = $('[ddakey="Street"]').val();
                ddaData.addresses[1].city = $('[ddakey="emirate"]').val();
                ddaData.addresses[1].area = $('[ddakey="Area"]').val();
                ddaData.addresses[1].buildingNo = $('[ddakey="buildingNo"]').val();
                ddaData.addresses[1].postalCode = $('[ddakey="postalCode"]').val();
                ddaData.addresses[0].street = $('[ddakey="pstreet"]').val();
                ddaData.addresses[0].city = $('[ddakey="pcity"]').val();
                ddaData.addresses[0].country = $('[ddakey="pcountry"]').find('option:selected').text();
            }
            
            let ad4 = (cs["xadtx4__c"] && cs["xadtx4__c"].value)?JSON.parse(cs["xadtx4__c"].value):[];
            crmDataMem = JSON.parse(adhoc4Proto)[0];
            for(i of Object.keys(crmDataMem)){
                let e = $('#modal_confirm_information_LA').find('[fldName='+i+']');
                let v = (i=='country')?e.find('option:selected').text():e.val();
                crmDataMem[i] = v;
            }
            let mFnName = $('[ddakey="firstName"]').val()+' '+$('[ddakey="lastName"]').val();
            if($('[name="eid"]:checked').attr('for')=='yes'){
                crmDataMem.InOrOut = 'In';
                if(cs["inUAE__c"]){
                    cs["inUAE__c"].value = true;
                }
                 if(!cs["docname"].value.includes('Existing Member'))
                {
                    cs["xcddocs__c"].value += 'Emirates ID - front - '+mFnName+';Emirates ID - back - '+mFnName+';Visa Page - '+mFnName+';';//U_S
                }
                if(cs["docname"].value.includes('Existing Member'))
                {
                    cs["xcddocs__c"].value += 'Exmem Emirates ID - front - '+capitalizeName(mFnName)+';Exmem Emirates ID - back - '+capitalizeName(mFnName)+';Exmem Visa Page - '+capitalizeName(mFnName)+';';//U_S
                }
                
            }
            else{
                crmDataMem.InOrOut = 'Out';
                if(cs["inUAE__c"])
                    cs["inUAE__c"].value = false;
                cs["xcddocs__c"].value.replaceAll('Emirates ID - front - '+mFnName+';');
                cs["xcddocs__c"].value.replaceAll('Emirates ID - back - '+mFnName+';');
                cs["xcddocs__c"].value.replaceAll('Visa Page - '+mFnName+';');
                if(ddaData.emiratesId){
                    for(k of Object.keys(ddaData.emiratesId)){ // PJ 1.1
                        ddaData.emiratesId[k] = '';
                    }
                }
            }
            for(let [i,v] of ad4.entries()){
                if(v.Passport_No == crmDataMem.Passport_No)
                    ad4.splice(i,1);
            }
            if(isEditingMem){
                for([i,v] of adhoc3Data.serviceRequests[0].members.entries()){
                    if(v.passports&& v.passports.length>0 &&v.passports[0].docNo==ddaData.passports[0].docNo)
                        adhoc3Data.serviceRequests[0].members.splice(i,1);
                }
            }
            ad4.push(crmDataMem);
            adhoc3Data.serviceRequests[0].members.push(ddaData);
            
            cs["xadtx3__c"].value = JSON.stringify(adhoc3Data);
            cs["xadtx2__c"].value = JSON.stringify(ad2);
            cs["xadtx4__c"].value = JSON.stringify(ad4);
            cs["xcfn__c"].value = ddaData.firstName+' '+ddaData.lastName;
            
            if(isEditingMem){
                showTempLoader();
                callWSOnEdit();
                isEditingMem = false;
                editingMemDocId = '';
                resetPopup('LA');
                return;
            }
            resetPopup('LA');
            
            saveRequest();
            exMemPPChanged = false;
        }
        function aftercallWS(){
            removeTempLoader();
        }
        function salOnChange(){
            let brk = false;  $('#modal_confirm_information_LA .salErr').hide();
            if($('#modal_confirm_information_LA [name="sal"]:checked').length==0){
                $('#modal_confirm_information_LA .salErr').show();
                $('#modal_confirm_information_LA').animate({
                    scrollTop: ($('.salErr').offset().top-60)
                }, 100);
                brk = true;
            }
            return brk;
        }
        function checkValidData(modal){
            var elem = '';
            var validated  = true;
            var m = modal?modal:'#modal_confirm_information_LA'
            $(m).find('.forEdit,.requiredFld,.applMob').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null || v==undefined ){//||$(this).parent().find('.frmErrMsg').length>0
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            /*U_S -- Start */
            if($('.isvisitedUAE.reqRadio').is(':visible')){
                if($('#modal_confirm_information_LA [name="vid"]').is(':checked')==false){
                    addValError($(m).find('[name="vid"]'),'**This field is required!');
                    validated=false;
                }
                else{
                removeValError($(m).find('[name="vid"]'));
                  validated=true;  
                }
            }
            if(!(cs['xadh__c'].value.includes('aau'))&&$('#modal_confirm_information_LA [name="eid"]').is(':checked')==false){
                    addValError($(m).find('[name="eid"]'),'**This field is required!');
                    validated=false;
                }
             else if($('#modal_confirm_information_LA [name="eid"]').is(':checked')==true){
                removeValError($(m).find('[name="eid"]'));
                  validated=true;  
                }
            /*U_S -- End */
            if(!(cs['xadh__c'].value.includes('aau'))){
                if(!cs['docname'].value.includes('Existing Member') && !$(m).find('.isEmailVerified').is(':visible')){ //PJ 1.1 U_S
                    validated=false;
                    addValError($(m).find('.isEmailVerified'),'Please validate email address');
                }
                if(!cs['docname'].value.includes('Existing Member') && !$(m).find('.isMobilePhoneVerified').is(':visible')){ //PJ 1.1 U_S
                    validated=false;
                    addValError($(m).find('.isMobilePhoneVerified'),'Please validate mobile number');
                }
                
                var passportValue = $(m).find('.passportNumber').val();
                const psNoPattern = /^[a-zA-Z0-9]{6,12}$/;
                if(psNoPattern.test(passportValue) == false || passportValue.length < 6 || passportValue.length > 12){
                    validated=false;
                    addValError($(m).find('.passportNumber'),'Passport Number must be 6-12 characters long and contain only letters and numbers !'); 
                }
            }
            checkAllDates('input-datepicker');
            if(!(cs['xadh__c'].value.includes('aau')) && salOnChange())
                return;
            if($(m+' .frmErrMsg:visible').length>0 ){
                validated = false;
            }
            return validated;
        }
        function validateForm() {
            const input = $('#modal_confirm_information_LA #perMobileNumber').val();
            const specialCharPattern =  /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]+/;
            
            if (specialCharPattern.test(input)) {
               addValError('#modal_confirm_information_LA #perMobileNumber','Invalid MobileNumber');
                return false; 
            }
            return true;
        }
        function submitReq(){
            
            let ppDoc=$('#udDocType').val();
            let personName=ppDoc.replace("Passport Copy - ","");
            let docPPnum=$('#modal_confirm_information_LA #passportid').val();
            docPPnum=docPPnum.toUpperCase();
            if(personName && cs['xadtx2__c'].value){//ppDoc.includes("Passport Copy - ")
                for (i of JSON.parse(cs['xadtx2__c'].value)) {
                    var exMemData;
                    if(cs['xuvdet__c'].value)
                    {
                        exMemData = JSON.parse(cs['xuvdet__c'].value);
                    } 
                    let name=i.firstName+' '+i.lastName;
                    name=name.trim();
                    var exclude=false;
                    if(exMemData){ 
                        for(let m of exMemData){
                            //var exclude=false;
                            if((m.axsDocName && m.axsDocName.includes(ppDoc)) || (cs['xcamc__c'].value.includes('Manager') || cs['xcamc__c'].value.includes('Secretary'))){
                                exclude=true;
                            }
                        }
                    }
                    let passportNumber=i.ppNum.toUpperCase();
                    if(name==personName && docPPnum!=passportNumber && exclude==false){
                        addValError('#modal_confirm_information_LA #passportid','<elem class="text-primary">'+docPPnum+ '</elem> does not match with provided passport number <elem class="text-primary">'+i.ppNum+ '</elem> in the application page');
                        return;
                    }
                    
                }
            }
            $('#sendOtpBlock').hide();
            if(!checkEmailFormate(('#modal_confirm_information_LA #perEmailId'))){
                addValError('#modal_confirm_information_LA #perEmailId','Please enter valid email Address'); 
                return;
            }
            if(checkValidData() && validateForm()){
                $('#cnfmBtn').show();
                attachmentSave_LA();
            }
        }
        function updateMob(){
            $('#sendOtpBlock').show();
            $('#cnfmBtn').hide();
            
        }
        function sendOTP(){
            $('#cnfmBtn').hide();
            if(checkValidData()){
                $('#sendOtpBlock').hide();
                $('.otpBlock').show();
            }
        }
        function validateOTP(){
            
            removeValError('#otpVal')
            let definedOtp = '{!$Label.Onboarding_OTP}';
            let userOtp = $('#otpVal').val();
            if(!userOtp){
                addValError('#otpVal','Please enter OTP!');
                return;
            }
            if(definedOtp && definedOtp!='NA'){
                if( userOtp==definedOtp){
                    if(checkValidData()){
                        attachmentSave_LA();
                        $('.otpBlock').hide();
                    }
                }
                else{
                    $('#otpVal').val('');
                    addValError('#otpVal','Invalid OTP, Please re enter');
                }
            }
        }
        
        $(window).on('load', function() {
        });
        </script>
    </apex:outputText>
</apex:page>