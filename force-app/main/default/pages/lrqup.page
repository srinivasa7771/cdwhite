        function axsConfirmation(ch,cb,loader,onYes,onYesArgs,onNo,onNoArgs){
            $('#modal_confirm_global').remove();
            if(cb==undefined) cb='';
            var cBlock = '<div class="modal fade modal-base" data-backdrop="static" id="modal_confirm_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <div class="modal-body"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <h2 class="mb-4">'+ch+'</h2> <p>'+cb+'<p class="col-xl-12 col-lg-12" style="text-align: right;"> <button class="col-xl-4 col-lg-12 btn btn-primary mr-2 btn-block-sm cBtns" id="cYes" val1="yes"> YES </button> <button class="col-xl-4 col-lg-12 btn btn-outline-primary btn-block-sm cBtns" val1="no"> NO </button><br class=""> </div> </div> </div> </div> </div> </div> </div> </div></div>'
            $('body').append(cBlock);
            $('#modal_confirm_global').modal('show');
            $('.cBtns').on('click',function(){
                $('#modal_confirm_global').modal('hide');
                if($(this).attr('val1').includes('yes')){
                    if(loader)
                        showGLoader();
                    if(onYes!=undefined&&onYes!=null&&onYes!=''){
                        if(onYesArgs!=undefined&&onYesArgs!=null&&onYesArgs!=''){
                            $('#modal_confirm_global').modal('hide').on('hidden.bs.modal',function(){
                                window[''+onYes](onYesArgs);
                            });
                        }
                        
                        else{
                            $('#modal_confirm_global').modal('hide').on('hidden.bs.modal',function(){
                                window[''+onYes]();
                            });
                        }
                    }
                }
                else if($(this).attr('val1').includes('no')){
                    if(onNo!=undefined&&onNo!=null&&onNo!=''){
                        if(onNoArgs!=undefined&&onNoArgs!=null&&onNoArgs!='')
                            $('#modal_confirm_global').modal('hide').on('hidden.bs.modal',function(){
                                window[''+onNo](onNoArgs);
                            });
                        else
                            $('#modal_confirm_global').modal('hide').on('hidden.bs.modal',function(){
                                window[''+onNo]();
                            });
                    }
                }
            });
        }
