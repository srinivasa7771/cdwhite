<apex:page cache="false" controller="grp_NonVisaServiceReportController" docType="html-5.0" standardStylesheets="false" readOnly="true" showHeader="true" sidebar="false" title="AXS" >
    <html>
        <head>
            <title>AXS</title>
            <style>
                [hidden="0"],[hidden=false] {
                display: block !important;
                }
            </style>
        </head>
        <script type="text/javascript">
        function reloadDIV () {
            alert('inside reloadDiv');
        }
        function loadTabData(){
            renderTab2PassData();
            renderTab2PermitData();
        }
        function getNxtOneYrData(filterVal){
            if(filterVal=='nxtOneYear')
                Nxt1YrData();
            if(filterVal=='lastMonth')
                lstMonthData();
            if(filterVal=='last3Month')
                lst3MonthData();
            if(filterVal=='last6Month')
                lst6MonthData();
            if(filterVal=='last12Month')
                lst12MonthData();
        }
        </script>
        <apex:form id="frm">
            <apex:messages id="errorMsg"/>
            <apex:actionfunction name="onChangeDate1Method" action="{!valueupdateDate1}" rerender="datepicker1">
                <apex:param name="dat1FromVf" value=""/>
            </apex:actionfunction>
            <apex:actionfunction name="onChangeDate2Method" action="{!valueupdateDate2}" rerender="datepicker2">
                <apex:param name="dat2FromVf" value=""/>
            </apex:actionfunction>
            <apex:actionfunction name="onChangeDate3Method" action="{!valueupdateDate3}" rerender="datepicker3">
                <apex:param name="dat3FromVf" value=""/>
            </apex:actionfunction>
            <apex:actionfunction name="onChangeDate4Method" action="{!valueupdateDate4}" rerender="datepicker4">
                <apex:param name="dat4FromVf" value=""/>
            </apex:actionfunction>
            <apex:actionfunction name="onChangePay1Method" action="{!valuepay1}" rerender="dummyDiv">
                <apex:param name="pay1Val" value=""/>
            </apex:actionfunction>
            <apex:actionfunction name="renderTab2PassData" action="{!passportChangeMethod}" rerender="passportSection"></apex:actionfunction>
            <apex:actionfunction name="renderTab2PermitData" action="{!rpChangeMethod}" rerender="rpSection"></apex:actionfunction>
            <apex:actionfunction name="Nxt1YrData" action="{!nxtOneYrData}" rerender="transTable,dateVal34"></apex:actionfunction>
            <apex:actionfunction name="lstMonthData" action="{!lastMonthData}" rerender="transTable,dateVal34"></apex:actionfunction>
            <apex:actionfunction name="lst3MonthData" action="{!last3MonthData}" rerender="transTable,dateVal34"></apex:actionfunction>
            <apex:actionfunction name="lst6MonthData" action="{!last6MonthData}" rerender="transTable,dateVal34"></apex:actionfunction>
            <apex:actionfunction name="lst12MonthData" action="{!last12MonthData}" rerender="transTable,dateVal34"></apex:actionfunction>
            <body onload="removeUnwantedCSS()">
                <div id="main">
                    <div id="page_content">
                        <div class="container">
                            <div class="page-header">
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/gpm">Dashboard</a></li>
                                    <li class="breadcrumb-item">Reports</li>
                                </ul>
                                <!-- .breadcrumb -->
                                <h1 class="page-title">REPORTS</h1>
                            </div>
                            <!-- .page-header -->
                            <div class="row">
                                <div class="col-xl-3 col-lg-4 col-md-6">
                                    <div class="report-counter">
                                        <i class="icon-total-employees text-primary"></i>
                                        <div>
                                            <div class="counter-number">{!TotalEmployeeCount}</div>
                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">TOTAL EMPLOYEES</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-lg-4 col-md-6" style="{!IF(showStudentThings,'display:block','display:none')}">
                                    <div class="report-counter">
                                        <i class="icon-sponsored-employee text-primary"></i>
                                        <div>
                                            <div class="counter-number">{!TotalStudentCount}</div>
                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">TOTAL STUDENTS</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-lg-4 col-md-6">
                                    <div class="report-counter">
                                        <i class="icon-globe text-primary"></i>
                                        <div>
                                            <div class="counter-number">{!nationCount}</div>
                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">TOTAL NATIONALITIES</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-4"></div>
                            <div class="row">
                                <div class="col-xl-12 mb-xl-0 mb-4">
                                    <div class="tabs accordion-tabs tabs-3">
                                        <ul class="nav nav-tabs" role="tablist">
                                            <li class="nav-item">
                                                <a class="nav-link active" data-toggle="tab" href="#tab_1">
                                                    {!IF(showStudentThings,'EMPLOYEES/STUDENTS','EMPLOYEES')}
                                                    <i class="tab-icon icon-account"></i>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" data-toggle="tab" href="#tab_2" onclick="loadTabData();">
                                                    EXPIRY DATES 
                                                    <i class="tab-icon icon-expiry-date"></i>
                                                </a>
                                            </li>
                                            <li class="nav-item" style="{!IF(hidTab,'display:none','display:block')}">
                                                <a class="nav-link" data-toggle="tab" href="#tab_3">
                                                    PAYMENTS / STATMENTS
                                                    <i class="tab-icon icon-payment-statement"></i>
                                                </a>
                                            </li>
                                        </ul>
                                        <!-- .nav-tabs -->
                                        <div class="accordion" id="app_accordion">
                                            <div class="tab-content">
                                                <!-- #tab_1 -->
                                                <div class="accordion-item open tab-pane fade show active" id="tab_1">
                                                    <div class="accordion-toggle">
                                                        <a href="#" data-toggle="collapse" data-target="#collapse_1">
                                                            <i class="tab-icon icon-account"></i>&nbsp;
                                                            {!IF(showStudentThings,'EMPLOYEES / STUDENT','EMPLOYEES')}
                                                            <i class="fa fa-angle-down"></i>
                                                        </a>
                                                    </div>
                                                    <div id="collapse_1" class="accordion-content collapse show" data-parent="#app_accordion">
                                                        <div class="accordion-content-inner">
                                                            <div class="d-md-flex pt-4">
                                                                <h2 class="mb-2">EXPORT ALL DATA</h2>
                                                                <div class="ml-auto">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!exportAllSelVal}" id="exportAllFilter" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!Allvalues}"/>
                                                                                <apex:actionSupport event="onchange" reRender="allDataSec"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <apex:pageBlock id="allDataSec" >
                                                                        <div class="ml-4 mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="{!exportAllSelVal}"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="AllData"/>
                                                                                <apex:param assignTo="{!ptEmp}" name="myparm3" value="ptData"/>
                                                                            </apex:commandLink>
                                                                            </div>
                                                                        </apex:pageBlock>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <hr class="mb-5"/>
                                                            <h2 class="mb-3">AGE RANGE</h2>
                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!ageSelectedValue}" id="ageFilterVal" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!Allvalues}"/>
                                                                                <apex:actionSupport event="onchange" action="{!ageChangeMethod}" reRender="AgeSection"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <div class="ml-auto mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="Employee-Non Sponsored-Student-Spouse-Child"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="Age__c"/>
                                                                            </apex:commandLink>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <!-- .col -->
                                                            </div>
                                                            <div class="mb-3"></div>
                                                            <apex:pageBlock id="AgeSection" >
                                                                <div class="row" style="width:100%;">
                                                                    <div class="col-xl-6">
                                                                        <apex:chart data="{!ChartData.ageRangeData.grData}" height="334px" width="100%" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af" animate="true">
                                                                            <apex:axis position="left" fields="peopleCount" grid="true" gridFill="true" type="Numeric"/>
                                                                            <apex:axis position="bottom" fields="Range" grid="true" type="Category">
                                                                            </apex:axis>
                                                                            <apex:barSeries orientation="vertical" axis="left" xField="Range" yField="peopleCount" colorsProgressWithinSeries="true" tips="true" title="peopleCount" >
                                                                                <apex:chartTips height="28" width="120" />
                                                                            </apex:barSeries>
                                                                        </apex:chart>
                                                                        <div class="mb-3"></div>
                                                                    </div>
                                                                    <!-- .col -->
                                                                    <div class="col-xl-3">
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">{!ChartData.ageRangeData.totalAvg} <small class="fs-16">YEARS</small></div>
                                                                            <div class="counter-label fs-16 text-light initialism" style="color: #9B9B9B !important;">AVG. AGE OF {!ageSelectedValue}s</div>
                                                                        </div>
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">{!ChartData.ageRangeData.largestNumber} <small class="fs-16">YEARS</small></div>
                                                                            <div class="counter-label fs-16 text-light initialism" style="color: #9B9B9B !important;">OLDEST {!ageSelectedValue}</div>
                                                                        </div>
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">{!ChartData.ageRangeData.smallestNumber} <small class="fs-16">YEARS</small></div>
                                                                            <div class="counter-label fs-16 text-light initialism" style="color: #9B9B9B !important;">YOUNGEST {!ageSelectedValue}</div>
                                                                        </div>
                                                                    </div>
                                                                    <!-- .col -->
                                                                    <div class="col-xl-3">
                                                                        <table class="table table-report-sm">
                                                                            <thead style="background-color: white; !important">
                                                                                <tr>
                                                                                    <th>Age Range</th>
                                                                                    <th>#</th>
                                                                                    <th style="text-align: center; !important">%</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <apex:repeat value="{!ChartData.ageRangeData.grData}" var="string">
                                                                                    <tr>
                                                                                        <td>
                                                                                            <apex:outputText value="{!string.Range}" />
                                                                                            <br/>
                                                                                        </td>
                                                                                        <td>
                                                                                            <apex:outputText value="{!string.peopleCount}" />
                                                                                            <br/>
                                                                                        </td>
                                                                                        <td style="text-align: center; !important">
                                                                                            <apex:outputText value="{!string.peoplePercent}%" />
                                                                                            <br/>
                                                                                        </td>
                                                                                    </tr>
                                                                                </apex:repeat>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <!-- .col -->
                                                                </div>
                                                            </apex:pageBlock>
                                                        </div>
                                                        <!-- .accordion-content-inner -->
                                                        <!-- .accordion-content-inner -->
                                                        <div class="accordion-content-inner">
                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <h2 class="mb-3">GENDER</h2>
                                                                </div>
                                                                <!-- .col -->
                                                                <div class="col-xl-6">
                                                                    <h2 class="mb-3">ROLE</h2>
                                                                </div>
                                                                <!-- .col -->
                                                            </div>
                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!genderSelectedValue}" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!Allvalues}"/>
                                                                                <apex:actionSupport event="onchange" action="{!genderChangeMethod}" reRender="genderSection"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <div class="ml-auto mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="Employee-Non Sponsored-Student-Spouse-Child"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="Gender__c"/>
                                                                            </apex:commandLink>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-xl-6">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!TypeSelectedValue}" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!EmpTypeDropValues}"/>
                                                                                <apex:actionSupport event="onchange" action="{!typeChangeMethod}" reRender="empTypeSection"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <div class="ml-auto mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="Employee-Non Sponsored-Student-Spouse-Child"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="rol__c"/>
                                                                            </apex:commandLink>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <!-- .col -->
                                                            </div>
                                                            <div class="mb-3"></div>
                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <apex:pageBlock id="genderSection">
                                                                        <apex:chart data="{!ChartData.genderData.BarGrData}" height="330px" width="100%" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af" background="#FFFFFF">
                                                                            <apex:legend position="right"/>
                                                                            <apex:pieSeries dataField="peopleCountParam" labelField="RangeParam" donut="40" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af" highlight="true">
                                                                                <apex:chartTips height="28" width="120" />
                                                                                <apex:chartLabel display="none" />
                                                                            </apex:pieSeries>
                                                                        </apex:chart>
                                                                    </apex:pageBlock>
                                                                    <div class="mb-3"></div>
                                                                </div>
                                                                <div class="col-xl-6">
                                                                    <apex:pageBlock id="empTypeSection">
                                                                        <apex:chart data="{!ChartData.employeeTypeData.BarGrData}" height="350px" width="100%" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af">
                                                                            <apex:legend position="right"/>
                                                                            <apex:pieSeries dataField="peopleCountParam" donut="40" labelField="RangeParam" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af" highlight="true" >
                                                                            <apex:chartTips height="28" width="120" />
                                                                                <apex:chartLabel display="none" />
                                                                                </apex:pieSeries>
                                                                        </apex:chart>
                                                                    </apex:pageBlock>
                                                                    <div class="mb-3"></div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- .accordion-content-inner -->
                                                        <!-- .accordion-content-inner -->
                                                        <div class="accordion-content-inner" style="{!IF(hidTab,'display:none','display:block')}">
