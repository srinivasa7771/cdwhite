                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!salarySelectedValue}" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!SalDropValues}"/>
                                                                                <apex:actionSupport event="onchange" action="{!salaryChangeMethod}" reRender="salarySection"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <div class="ml-auto mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="Employee-Non Sponsored"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="mgs__c"/>
                                                                            </apex:commandLink>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <!-- .col -->
                                                            </div>
                                                            <div class="mb-3"></div>
                                                            <apex:pageBlock id="salarySection">
                                                                <div class="row">
                                                                    <div class="col-xl-6">
                                                                        <apex:chart data="{!ChartData.salaryRangeData.grData}" height="334px" width="100%" colorSet="#7b9a95,#807a86,#b7a2a0,#8e7392,#979b83,#8896af" animate="true" theme="Salesforce">
                                                                            <apex:axis position="left" fields="peopleCount" grid="true" gridFill="true" type="Numeric"/>
                                                                            <apex:axis position="bottom" fields="Range" grid="true" type="Category">
                                                                            </apex:axis>
                                                                            <apex:barSeries orientation="vertical" axis="left" xField="Range" yField="peopleCount" colorsProgressWithinSeries="true">
                                                                                <apex:chartTips height="28" width="120" />
                                                                            </apex:barSeries>
                                                                        </apex:chart>
                                                                        <div class="mb-3"></div>
                                                                    </div>
                                                                    <!-- .col -->
                                                                    <div class="col-xl-3">
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">
                                                                                <apex:outputText value="{0, number, ###,###,##0}">
                                                                                    <apex:param value="{!ChartData.salaryRangeData.totalAvg}"/>
                                                                                </apex:outputText>
                                                                                <!--{!ChartData.salaryRangeData.totalAvg} -->
                                                                                <small class="fs-16">AED</small>
                                                                            </div>
                                                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">AVG SALARY</div>
                                                                        </div>
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">
                                                                                <apex:outputText value="{0, number, ###,###,##0}">
                                                                                    <apex:param value="{!ChartData.salaryRangeData.largestNumber}"/>
                                                                                </apex:outputText>
                                                                                
                                                                                <small class="fs-16">AED</small>
                                                                            </div>
                                                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">HIGHEST SALARY</div>
                                                                        </div>
                                                                        <div class="report-counter report-counter-sm">
                                                                            <div class="counter-number">
                                                                                <apex:outputText value="{0, number, ###,###,##0}">
                                                                                    <apex:param value="{!ChartData.salaryRangeData.smallestNumber}"/>
                                                                                </apex:outputText>
                                                                                 
                                                                                <small class="fs-16">AED</small>
                                                                            </div>
                                                                            <div class="counter-label fs-16 text-light" style="color: #9B9B9B !important;">LOWEST SALARY</div>
                                                                        </div>
                                                                    </div>
                                                                    <!-- .col -->
                                                                    <div class="col-xl-3">
                                                                        <table class="table table-report-sm">
                                                                            <thead style="background-color: white; !important">
                                                                                <tr>
                                                                                    <th>Salary Range</th>
                                                                                    <th>#</th>
                                                                                    <th style="text-align: center; !important">%</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <apex:repeat value="{!ChartData.salaryRangeData.grData}" var="string">
                                                                                    <tr>
                                                                                        <td>
                                                                                            <apex:outputText value="{!string.Range}" />
                                                                                            <br/>
                                                                                        </td>
                                                                                        <td>
                                                                                            <apex:outputText value="{!string.peopleCount}" />
                                                                                            <br/>
                                                                                        </td>
                                                                                        <td style="text-align: center; !important">
                                                                                            <apex:outputText value="{!string.peoplePercent}%" />
                                                                                            <br/>
                                                                                        </td>
                                                                                    </tr>
                                                                                </apex:repeat>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <!-- .col -->
                                                                </div>
                                                            </apex:pageBlock>
                                                        </div>
                                                        <!-- .accordion-content-inner -->
                                                        <!-- .accordion-content-inner starts-->
                                                        <div class="accordion-content-inner">
                                                            <h2 class="mb-3">COUNTRIES</h2>
                                                            <div class="row">
                                                                <div class="col-xl-6">
                                                                    <div class="d-flex form-style">
                                                                        <div class="form-group" style="width: 300px;">
                                                                            <apex:selectList value="{!countrySelectedValue}" size="1" styleClass="form-control input-select2-flat">
                                                                                <apex:selectOptions value="{!Allvalues}"/>
                                                                                <apex:actionSupport event="onchange" action="{!countryChangeMethod}" reRender="countrySection"/>
                                                                            </apex:selectList>
                                                                        </div>
                                                                        <div class="ml-auto mt-1">
                                                                            <apex:commandLink value="DOWNLOAD DATA" action="{!exportData}" target="_blank" styleClass="btn btn-outline-primary btn-outline-primary-3">
                                                                                <apex:param assignTo="{!filterVal}" name="myparm1" value="Employee-Non Sponsored-Student-Spouse-Child"/>
                                                                                <apex:param assignTo="{!fieldVal}" name="myparm2" value="nc__c"/>
                                                                            </apex:commandLink>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <!-- .col -->
                                                            </div>
                                                            <div class="mb-3"></div>
                                                            <apex:pageBlock id="countrySection">
                                                                <div class="row">
                                                                    <div class="col-xl-8 col-lg-7">
                                                                        <img src="{!URLFOR($Resource.assets_NUI, '/images/map.png')}" alt=""/>
                                                                        <div class="mb-3"></div>
                                                                    </div>
                                                                    <!-- .col -->
                                                                    
                                                                        <div class="col-xl-4 col-lg-5">
                                                                            <table class="table table-report-sm mb-0">
                                                                                <thead style="background-color: white; !important"> 
                                                                                    <tr>
                                                                                        
                                                                                        <th style="width: 60%;">Country</th>
                                                                                        <th style="width: 20%;">#</th>
