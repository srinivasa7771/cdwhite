<apex:page Controller="grqCtrlAddSanction">
    <apex:pagemessages />
    
    <apex:form >
        <apex:pageBlock >
            <apex:pageBlockSection title="Existing Sanctions" columns="1"  >
                <apex:outputField title="Account Sanctions" value="{!acc.snc__c}"/>
            </apex:pageBlockSection>
            
        </apex:pageBlock>
        <apex:pageBlock title="Sanction Details">
            <apex:pageBlockButtons >
                <apex:commandButton action="{!saveSanction}" value="Save"/>
                <apex:commandButton action="{!cancel}" value="Cancel"/>
            </apex:pageBlockButtons>
            <apex:pageBlockSection title="GSO Sanctions" columns="1" rendered="{!usr.profile.name=='B2'}" >
                <apex:inputField label="Add / Remove" value="{!acc.GSO__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Finance Sanctions" columns="1" rendered="{!OR(usr.profile.name=='FN3',usr.profile.name=='FN4')}">
                <apex:inputField label="Add / Remove" value="{!acc.FIN__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Leasing Sanctions" columns="1" rendered="{!usr.profile.name=='Leasing'}">
                <apex:inputField label="Add / Remove1" value="{!acc.Lease__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Complaince Sanctions" columns="1" rendered="{!usr.profile.name=='DDA BO'}">
                <apex:inputField label="Add / Remove" value="{!acc.CA_San__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Sanction Notes" columns="1">
                <apex:inputField value="{!acc.sn__c}"/>
                <apex:inputField value="{!acc.snadrmd__c}"/>
            </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
</apex:page>