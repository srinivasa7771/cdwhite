<script>
    //Validation for Non-Sponsor criteria
    function GccCountry(cont){
        var GCC = ['United Arab Emirates','Saudi Arabia','Qatar','Oman','Kuwait','Bahrain'];
        return GCC.includes(cont); 
    }
    //Validation for Non-Sponsor criteria
    function validateNonSponsorCriteria(){
        var sponsorRequire  = true;
        var salutation = $("input[name='salutation']:checked").val();
        var martialStatus = $("input[name='martialStatus']:checked").val();
        var nationality = cs['xcnc__c'].value;
        console.log('salutation>>'+ salutation);
        console.log('martialStatus>>'+ martialStatus);
        console.log('nationality>>'+ nationality);
        console.log('in GCC>>'+ GccCountry(nationality));
        
        if(salutation!='' && salutation!='undefined' && nationality!='' ){
            if(GccCountry(nationality)){
                console.log('No Sponsor Div');
                document.getElementById("sponsorDiv").style.display = "none";
                console.log('No Sponsor Div');
                document.getElementById("sponsorDiv").style.display = "none";
                sponsorRequire = false;
            }else{
                if(salutation=='Mr.'){
                    console.log('add Error');
                    document.getElementById("sponsorDiv").style.display = "none";
                    
                    var ab = "This is for Female on husband/Father sponsorship withNon GCC nationality."
                    axsAlert('Alert!',ab);
                    //alert('This is for Female on husband/Father sponsorship withNon GCC nationality');
                    sponsorRequire = false;
                }else if(salutation=='Ms.'){
                    console.log('show Sponsor Div');
                    document.getElementById("sponsorDiv").style.display = "block";
                    sponsorRequire = true;
                }
            }
        }
        return sponsorRequire;
    }

