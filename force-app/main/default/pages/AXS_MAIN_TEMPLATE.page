<apex:page id="main" showheader="false">
<head>
<link rel="shortcut icon" href="{!URLFOR($Resource.axs_favicon)}" type="image/x-icon" />
</head>
  <header>
  
    <style>
    body
    {
        margin: 0px;
        word-break: break-word;
    }
    p
    {
        margin: 0px;
    }
    .darkText
    {
        color: #3d4f8b;
    }
    
    .greyText
    {
        color: #828282;
    }
    
    @font-face {
        font-family: canaroMedium;
        src: url({!URLFOR($Resource.fonts, 'canaro_medium.eot?#iefix')}) format('embedded-opentype'), 
         url({!URLFOR($Resource.fonts, 'canaro_medium.woff')}) format('woff'), 
         url({!URLFOR($Resource.fonts, 'canaro_medium.otf')})  format('truetype'),
         url({!URLFOR($Resource.fonts, 'canaro_medium.svg#svgFontName')}) format('svg');
    }
    
    @font-face {
        font-family: canaroLight;
        src: url({!URLFOR($Resource.fonts, 'canaro_light.eot?#iefix')}) format('embedded-opentype'), 
         url({!URLFOR($Resource.fonts, 'canaro_light.woff')}) format('woff'), 
         url({!URLFOR($Resource.fonts, 'canaro_light.otf')})  format('truetype'),
         url({!URLFOR($Resource.fonts, 'canaro_light.svg#svgFontName')}) format('svg');
    }
    
    .body
    {
        max-width: 2840px;
        margin: 0px auto 100px;
    }
    
    .center
    {
        //max-width:800px;
        margin: 10px 16%;
    }
    
    .header
    {
        display: table;
        width: 100%;
    }
    
    .logoContainer
    {
        max-width: 154px;
    }
    
    .logo
    {
        width: 100%
    }
    
    .menu 
    {
        display: table-cell;
        vertical-align: middle
    }
    input, textarea
    {
        -webkit-appearance: none;
        appearance: none;
        border-radius: 0px;
        -webkit-border-radius: 0px;
    }
    .menuItems
    {
        display: table-cell;
        float:right;
    }
    
    .menuItem
    {
        color: #3d4f8b;
        font-family: canaroMedium;
        font-size: 16px;
        list-style: none;
        float: left;
        margin: 0px 27px;
        padding: 4px 0px 0px;
    }
    
    @media screen and (max-width: 1088px)
    {
        .menuItem {
             margin: 0px 13px;
        }
    }
    .loginItem
    {
        border-radius: 5px;
        padding: 4px 6px 4px;
        margin-right: 0px;
    }
    
    .current
    {
        color: #45c5ef;
        border-color: #45c5ef;
    }
    
    .loginItem.current
    {
        background: #45c5ef;
        color: white;
    }
    
    .banner
    {
        width: 100%;
        position: relative;
        z-index: 0;
    }
    
    .loginIcon
    {
        width: 10px;
        margin-left: 5px;
        position: relative;
        top: 2px;
    }
    .mainContent
    {
        position: relative;
        z-index: 100;
    }
    </style>
  </header>
  <apex:includeScript value="https://code.jquery.com/jquery-latest.min.js"/>
  <apex:includeScript value="{!URLFOR($Resource.youtubePopupJS)}"/>
  <apex:outputPanel id="body" layout="block" styleClass="body">
      <apex:outputPanel layout="block" id="headerContainer" styleClass="headerContainer center">
          <apex:outputPanel layout="block" id="header" styleClass="header">
          
            <apex:outputPanel layout="block" id="logo" styleClass="logoContainer">
                 <apex:image styleClass="logo" url="{!$Resource.AXSLogo}"/>
            </apex:outputPanel>
            
            <apex:outputPanel layout="block" id="menu" styleClass="menu">
            
                 <ul id="menuItems" class="menuItems">
                     <a href="/home"><li id="item-1" class="menuItem homeMenuItem">
                         Home
                     </li></a>
                     <a href="/videos"><li id="item-2" class="menuItem videosMenuItem">
                         Videos
                     </li></a>
                     <a href="/faq"><li id="item-3" class="menuItem FAQMenuItem">
                         FAQs
                     </li></a>
                     <a href="/contact-us"><li id="item-4" class="menuItem contactMenuItem">
                         Contact Us
                     </li></a>
                     <a href="/axslogin"><li id="item-5" class="menuItem loginItem">
                         Login
                         <apex:image id="loginIcon" styleClass="loginIcon" url="{!$Resource.loginIcon}"/>
                     </li></a>
                 </ul>
              
            </apex:outputPanel>    <!--End of menu-->
            
          </apex:outputPanel>     <!--End of Header-->
      
      </apex:outputPanel>     <!--End of HeaderContainer-->
 
      <apex:outputPanel layout="block" id="banner" styleClass="banner">
          <c:contentblock name="banner"></c:contentblock>
      </apex:outputPanel>    <!--End of banner-->
      
      <apex:outputPanel layout="block" id="mainContent" styleClass="mainContent center">
          <c:contentblock name="mainContent"></c:contentblock>
      </apex:outputPanel>    <!--End of mainContent-->
  
  </apex:outputPanel>    <!--End id=body-->

</apex:page>