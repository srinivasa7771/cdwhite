            function addItm(itmCd){
                if(itmCd == null || itmCd == ''){
                    itmCd = cs["itmCdId"].value;
                }
                if($('#xcbd1__c').val() != null)
                {
                    cs["xcbd2__c"].value=$('#xcbd1__c').val();
                }
                
                $('#modal_item_information').modal('hide');
                $('#modal_Cancel').modal('hide');
                
                if(itmCd == 'ai'){
                    var invalData = false;
                    if($('#datepicker1').val() == null || $('#datepicker1').val() == ''){
                        axsAlert('Validation Error.','Please update Arrival Date.');
                        return;
                    } 
                    if($('.frmErrMsg').length >1  || $('.frmErrMsg').is(':visible')){
                        invalData = true; 
                    }
                    if(invalData){
                        axsAlert('Validation Error.','Arrival Date should not be today/future date.');
                        return;
                    }
                    
                    cs["xad__c"].value=$('#datepicker1').val();
                    
                }
                if(itmCd == 'exu'){
                    cs["xad__c"].value=$('#datepicker2').val();
                }
                $('#preloader').fadeIn();
                console.log('xad__c::'+cs["xad__c"].value);
                createItm(itmCd);
            }
