                if(itmCd == 'eci' || itmCd == 'eca' || itmCd == 'cor'){
                    cs["itmCdId"].value=itmCd;
                    
                    $('#modal_item_information').modal('show');
                }
                else{
                    $('#preloader').fadeIn();
                    createItm(itmCd); 
                }
                /*else if(itmCd == 'exu') {
