    <script>
    $(document).ready(function(){
        if($('.nav-tabs .nav-item').length>3){
            $('.nav-tabs').addClass('nav-tabs-5');
        }
        if('{!rq.crflg__c}'=='true'){
            $('#modal_Correction_submission').modal('show')
        }
        $('.requiredFld').on('keyup change',function(){
            if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                return;
            if(!$(this).is(':visible'))
                return;
            showErrMsg($(this),'rqrd',true);
            var v = $(this).val();
            if(v==''||v==null||v==undefined||v.lenght<1){
                if(elem=='')
                    elem = $(this);
                addValError($(this),'This field is required');
                validated =  false;
            }
            else
                removeValError($(this));
        });
        var tbname = '{tb}';
        if(tbname == 'p'){
            $('[href="#payments_tab"]').trigger('click');
        }
        /* var msg='{!successMsg}';
                                if(msg=='true'){
                                    axsAlert('Thank you for submmiting the request.','Your request has been forwared to back office for futher process.');
                                }else if(msg=='false'){
                                    axsAlert('Request Saved.','Your changes have been saved.');
                                }*/
        $('select').on('change',function(){
            removeValError($(this));
        });
        setTimeout(function(){
            $('.input-datepicker').datetimepicker({
                format: 'DD/MM/YYYY'
            });
        },500);
        var str; /*box status-box bg-white*/
        var ids= document.getElementsByClassName('box status-box aos-init aos-animate');
        for(var i=0;i<ids.length;i++){
            str=ids[i].innerHTML;
            if(str.includes('#rpdownload') ){
                str = str.replace('#rpdownload','<br/><a onclick="downloadDoc(\'rp:rt:trp\');" href="#" class="btn btn-primary" >DOWNLOAD eRESIDENCE COPY</a><br/>');
                str = str.replace('#iadownload','<br/><a onclick="downloadDoc(\'rp:rt:trp\');" href="#" class="btn btn-primary" >DOWNLOAD EMIRATES ID APPLICATION FORM</a><br/>');
            }
            if(str.includes('#undownload') ){
                str = str.replace('#undownload','<br/><a onclick="downloadDoc(\'utn\');" href="#" class="btn btn-primary" >DOWNLOAD Utility NOC</a><br/>');
            }if(str.includes('#fodownload') ){
                str = str.replace('#fodownload','<br/><a onclick="downloadDoc(\'ftNoc\');" href="#" class="btn btn-primary" >DOWNLOAD Fit Out NOC</a><br/>');
            }
            if(str.includes('#appdrawings')){
                str = str.replace('#appdrawings','<br/><a onclick="downloadDoc(\'appdrawing\');" href="#" class="btn btn-primary" >DOWNLOAD Approved Drawings</a><br/>');
            }  
            else{
                str = str.replace('#download','<br/><a onclick="downloadDoc();" href="#" class="btn btn-primary" >DOWNLOAD</a><br/>');
            }
            str = str.replace('#sla1','{!rq.slaN__c}');
            str = str.replace('#sla','{!rq.slaN__c}');
            str = str.replace('#upload','');
            var adhVal = '{!rq.xadh__c}';
            var expflg = '{!rq.expflg__c}';
            if(expflg == 'true')
                str = str.replace('#ptype','Express').replace('#pdays','3');
            else if(adhVal != '' && adhVal.includes('pf;'))
                str = str.replace('#ptype','Platinum').replace('#pdays','1');
                else
                    str = str.replace('#ptype','Normal').replace('#pdays','5');
            var md = '{!rq.Acc__r.mtc__c}';
            if(md != 'MOH')
                str = str.replace('#medcet',' Dubai Knowledge Park').replace('#mcet','{!$Label.msgDHALoc}');
            else if(md == 'MOH')
                str = str.replace('#medcet','Dubai International Academic City').replace('#mcet','{!$Label.msgMOHLoc}');
            
            ids[i].innerHTML=str;         
        }
        
        var srv_uid2 = '{!rq.srvc__r.uid__c}';
        if(srv_uid2=='162' || srv_uid2=='198' || srv_uid2=='199' || srv_uid2=='212'){
            $(".staddontab").hide();
        }
        /*$('.data-value a').css('cursor','default').unbind().on('click',function(e){
            e.preventDefault();
        });*/
    });
    </script>
