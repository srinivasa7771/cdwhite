                            }   
                        }
                        var td1= '<td class="table-people-mobile-start"><div class="action-dropdown dropdown">'+
                        '<button type="button" class="btn btn-secondary button-dropdown" data-toggle="dropdown">'+
                        '<i class="fa fa-ellipsis-v"></i></button>'+
                        '<div class="dropdown-menu dropdown-menu-right"><h4 class="dropdown-header bg-primary">ACTIONS</h4>'+subActions+'</div></div></td>';
                        //tr += td1;
                        $(tableId).find('th').each(function() {
                            var j = $(this).attr('field');
                            var n = $(this).text();
                            n = (n=='NAME / JOB TITLE'?'':n);
                            var v = val[j] ? val[j] : 'NA';
                            var subText = '';
                            if (j == 'actions' || j == 'dummy' ||!j) return;
                            else if (j == 'STA__c') {
                                v = (v == 'Draft') ? 'Under Activation' : v;
                            } else if (j == 'name') {// <img src="/servlet/servlet.FileDownload?file=' + val.Photo_ID__c + '" onerror="imgError(this,val.Gender__c);" alt="" /> 
                                //v = '<div class="people-name-wrapper" gend="'+val.Gender__c+'" index="'+ind+'">  <div class="people-name"> <a href="./gConInfo?id=' + val.Id + '" target="_blank" class="row-link"></a> ' + val.FirstName + ' </div>';
                                 v = '<div class="people-name-wrapper" ptsta='+val.ptsta__c+' gend="'+val.Gender__c+'" index="'+ind+'"> <div class="avatar"><img loading="lazy" src="/servlet/servlet.FileDownload?file=' + val.Photo_ID__c + '" onerror="imgError(this,\''+val.Gender__c+'\');" alt="" /> </div> <div class="people-name"> <a href="./gConInfo?id=' + val.Id + '" target="_blank" class="row-link"></a> ' + val.FirstName + ' </div>';
                                if (val.Job_Title_Formula__c) {
                                    v += '<div class="people-job">' + val.Job_Title_Formula__c + '</div>';
                                }
                                v += '</div>';
                            } else if (j == 'p__c') {
                                subText = (((val.Passport_Status__c).includes('Expires') || (val.Passport_Status__c).includes('EXPIRED')) ? '<span class="text-danger">' + val.Passport_Status__c + '</span>' : (val.Passport_Status__c).includes('Valid') ? '<span class="text-grey">' + val.Passport_Status__c + '</span>' : '');
                                v = '<div class="people-property-flex"> <div class="mr-2">' + val.p__c + '</div> ' + subText + ' </div>';
                            }else if (j == 'pte') {
                                subText = ((val.pte__c&&val.ptsta__c=="Employed") ? '<span class="text-grey">' + val.pte__r.Name + '</span>' :'');
                                v = '<div class="people-property-flex"> <div class="mr-2">' + (val.ptsta__c?val.ptsta__c:'N/A') + '</div> ' + subText + ' </div>';
                            } else if (j == 'rp__c') {
                                subText = (val.RP_Sts__c) ? ((val.RP_Sts__c).includes('EXPIRED') ? '<span class="badge-status badge-status-urgent">EXPIRED</span>' : (val.RP_Sts__c).includes('MISSING') ? 'N/A' : (val.RP_Sts__c).includes('EXP: IN') ? '<span class="badge-status badge-status-process">' + val.RP_Sts__c + '</span>' : (val.RP_Sts__c).includes('Valid Till') ? '<span class="text-grey">' + val.RP_Sts__c + '</span>' : '') : 'N/A';
                                v = '<div class="people-property-flex"> <div class="mr-2">' + (val[j] ? val[j] : '') + '</div> ' + subText + ' </div>';
                            } else {
                                //v = '<div class="people-property"> <span class="people-property-label">' + j + '</span> ' + (val[j] ? val[j] : 'NA') + ' </div>';
                                v = (val[j] ? val[j] : 'N/A');
                            }
                            if(j == 'forAlpha'){
                                tr += '<td style="display:none" class="people-name1">' + val.FirstName + '</td>';
                            }
                            else if(j == 'custRol')
                                tr += '<td >' + roles[val['rol__c']] + '</td>';/*style="display:none !important"*/
                            else{
                                if(n)
                                    tr += '<td><div class="people-property"><span class="people-property-label">'+n.toLowerCase()+'</span>' + v + '</div></td>';
                                else
                                    tr += '<td>' + v + '</td>';
                                }
                            });
                        var actions = '<td class="actions">';
                        if (Object.keys(actionLinks).includes(val.rol__c)) {
                            if (val.STA__c != 'Inactive') {
                                subActions = ((val.STA__c != 'Draft') ? '<a style="'+(actionLinks[val.rol__c]['let']?'':'display:none;')+'" class="dropdown-item" href="/grqsdr?sid='+actionLinks[val.rol__c]["let"]+'">REQUEST FOR '+cRole+' LETTER</a>' : '');
                                //subActions += (val.RP_Sts__c) ? ((val.RP_Sts__c.includes('EXPIRED') || val.RP_Sts__c.includes('EXP: IN')) ? '<a class="dropdown-item" href="/grqsdr?sid='+actionLinks[val.rol__c]["ren"]+'">RENEW '+cRole+' VISA</a>' : '') : '';
                                subActions += '<a class="dropdown-item" href="/grqsdr?sid='+actionLinks[val.rol__c]["ame"]+'">AMEND '+cRole+' VISA</a> ';
                                subActions += ((val.STA__c != 'Draft') ? '<a class="dropdown-item" href="/grqsdr?sid='+actionLinks[val.rol__c]["can"]+'">CANCEL '+cRole+' VISA</a>' : '');
                                //subActions += ((val.rol__c == 'Student' && val.STA__c == 'Active' &&val.Age__c >17 && val.RP_Sts__c!='EXPIRED') ? '<a class="dropdown-item" href="/grqsdr?sid='+actionLinks["Student"]["prmt"]+'">STUDENT PART TIME PERMIT</a>' : '');
                                subActions += ((val.rol__c == 'Student' && val.STA__c == 'Active' && (!val.ptsta__c) &&val.Age__c >17 && val.RP_Sts__c!='EXPIRED') ? '<a class="dropdown-item" href="#" onclick="createPrtTime(\''+val.FirstName+'\',\''+val.Id+'\')">APPLY FOR PART TIME PERMIT</a>' : '');
                                actions += '<div class="action-dropdown dropdown"> <div type="button" class="btn btn-secondary button-dropdown" data-toggle="dropdown"> <val class="fa fa-ellipsis-v"></val> </div> <div class="dropdown-menu"> <h4 class="dropdown-header dropdown-header bg-primary text-light">ACTIONS</h4> ' + subActions + ' </div> </div>';
                                
                            }
                        }
                        var dumTD = '<td style="display:none !important">dummy</td>';
                        actions += '</td>';
                        tr += actions + dumTD+'<td class="table-people-mobile-end"></td></tr>';
                        tableData += tr;
                    }
                    $(tableId).find('tbody').html(tableData);
                    var table = $(tableId).DataTable({
                        dom: 'Alfrtip',
                        language: {
                            'paginate': {
                                'previous': '<i class="fa fa-long-arrow-left"></i><span> PREV</span>',
                                'next': '<span>NEXT </span><i class="fa fa-long-arrow-right"></i>'
                            }
                        }
                    });
                    if(userInfo.lFrm=='Freelancer'){
                        $('.dropdown-item').each(function(){
                            let t= $(this).text();
                            if(t.toLowerCase().includes('renew')){
                                $(this).remove();
                            }
                        });
                    }
                }
                
                function createPrtTime(conName,conId){
                    axsConfirmation('Please confirm','Are you sure you want to apply part time permit for <b>'+conName+'</b>.<br>This action will create a request.',true,'createPrtTime1',conId);
                }
                function createPrtTime1(conId){
                    document.getElementById('{!$Component.selectedCon}').value = conId;
                    createPartTime();
                }
                
                function alert() {
                    console.log(Object.values(arguments).join())
                    console.log('From --- '+new Error().stack);
                };
