    <script>
    var selectedJSON = [];
    var reqId = '', cNum='', reason='';
    $(document).ready(function(){
        cNum = getUrlParameter('c');
        reason = getUrlParameter('r');  
        callWS();
        reqId = '{!JSENCODE(req.id)}';
        cs['xadh__c'].value='1np';
        //Axs2CustomJS
        if(cs["xcmob__c"] && cs["rmob__c"]){
            $(cs["xcmob__c"]).on('change',function(){
                cs["rmob__c"].value = cs["xcmob__c"].value;
            });
        }
    });
    function createDD(){
        let e = cs['parkingString'].value;
        allJSONStr = e.replaceAll('\t', ' '); 
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        (function ($) {
            $(function () {
                var allJSONObj = JSON.parse(allJSONStr);
                for(i of allJSONObj){
                    var d ={};
                    d.text = i.cardNum;//cardType;
                    d.cardNum = i.cardNum;
                    d.cardType = i.cardType;
                    d.cHolderNm = (i.cHolderNm==null)?'NA':i.cHolderNm;
                    d.expDate = i.expDate;
                    d.id = i.cardNum;
                    d.cardId = i.cardId;
                    d.actStat = i.actStat;
                    if(i.actStat=='Active'||i.actStat=='Inactive')
                        data.push(d);
                }
                $('.input-select-member').change(function () {
                    if ($(this).val() === '') {
                        $(this).next('.select2').removeClass('selected');
                    } else {
                        $(this).next('.select2').addClass('selected');
                    }
                });
                
                setTimeout(function () {
                    $('.input-select-member').trigger('change');
                }, 100);
                
                $('.input-select-member').select2({
                    data: data,
                    allowClear: true,
                    escapeMarkup: function (markup) {
                        return markup;
                    },
                    templateResult: function (data) {
                        if (!data.id && data.id!=undefined) {
                            return data.cardNum;
                        }
                        
                        var tex = (data.cardType=="Paid"?"Additional parking permit":"Standard parking permit");
                        var html = '<div class="user-title-media user-title-media-sm">' +
                            '<div>' +
                            '<div class="user-name mb-2">' + data.cardNum + '</div>' +
                            '<div class="user-title font-weight-normal"> ' + tex +' in  <b>'+data.actStat+'</b> status'+
                            /*'<div class="user-title font-weight-normal">Expires on '+data.expDate+'</div>' +*/
                            '</div>' +
                            '</div>';
                        return html;
                    },
                    templateSelection: function (data) {
                        if (!data.id && data.id!=undefined) {
                            return data.cardNum;
                        }
                        
                        var tex = (data.cardType=="Paid"?"Additional parking permit":"Standard parking permit");
                        var html = '<div class="user-title-media user-title-media-sm">' +
                            '<div>' +
                            '<div class="user-name mb-2">' + data.cardNum + '</div>' +
                            '<div class="user-title font-weight-normal"> ' + tex +' in  <b>'+data.actStat+'</b> status'+
                            '</div>' +
                            '</div>';
                        return html;
                    }
                });
                
            });
            // .ready
        }(jQuery));
        setTimeout(function(){
            if(reqId!='')
                loadPrevData();
        },400);
    }
    function LorD(elem){
        cs['Reason__c'].value = $(elem).val();
        $('#sbmtBtn').text('PROCEED TO PAY');
        $('#cdCmp').hide();
        $('#Paid .eConInfo').show();
    }
    function selSer(elem){
        $('#sbmtBtn').text('SUBMIT');
        selectedSer = $(elem).val();
        $('.services').find('.frmErrMsg').remove();
        $('[name="reason"]').prop('checked',false);
        if(selectedSer == 'Cancel'){
            $('#rsns,#cdCmp').show();
            $('#Paid .eConInfo').hide();
            cs['Reason__c'].value='Cancellation';
            if(cs['Reason__c'].value!='' && cs['Reason__c'].value!=undefined)
                cs['xadh__c'].value='xnp';
            else
              cs['xadh__c'].value='0np';
        }
        else{
            $('#rsns,#cdCmp').hide();
            $('#Paid .eConInfo').show();
            cs['xadh__c'].value='1np';
            cs['Reason__c'].value='Deactivation';
        }
    }
    function loadSelected(){
        let l = cs['parkingString'].value;
        $('[r="'+reason+'"]').prop('checked',true).trigger('change');
        $('[num="'+cNum+'"]').prop('checked',true).trigger('change');
        var s=l.replace("\"Items\"",'\'Items\'')
        selectedJSON = JSON.parse(s);
    }
    function loadPrevData(){
        $('.input-select-member').val(cs['rtacn__c'].value).trigger('change');
        $('#'+selectedJSON[0].cardType).show();
        if(cs["Reason__c"].value.includes('Cancel')){
            $('#'+selectedJSON[0].cardType).find('[value="Cancel"]').prop('checked',true).trigger('change');
            $('#rsns').find('[value="'+cs["Reason__c"].value+'"]').prop('checked',true).trigger('click');
        }
        else if(cs["Reason__c"].value.includes('Deact'))
            $('#'+selectedJSON[0].cardType).find('[value="Deactivate"]').prop('checked',true).trigger('change');
        // $('[num="'+cs['rtacn__c'].value+'"]').prop('checked',true).trigger('change');
        //$('.input-select-member').val(cs['rtacn__c'].value).trigger('change');
    }
    function aftrLoad(){
        //cs['Reason__c'].value = "Lost";
        if(reqId!='')
            loadPrevData();
    }
    function settoFld(e){
        removeValError('#cardDet');
        $('[name="ser"]:checked').prop('checked',false);
        var cardNum = $(e).val();
        if(cardNum==''||cardNum==undefined)
            return; 
        //var cardNum = $(e).attr('num');
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        if(allJSONStr.length>0){
            allJSON = JSON.parse(allJSONStr);
            for(i=0;i<allJSON.length;i++){
                if(cardNum == allJSON[i].cardNum){
                    selectedJSON[0] = allJSON[i];
                }
            }
        }
        $('.srvcs').hide();
        $('#Paid ').show()
        $('#Paid .eConInfo').hide();
        if(selectedJSON[0].cardType=='Free'){
            $('#Free').find('[value="Deactivate"]').prop('checked',true).trigger('change');
            $('#Paid .eConInfo').show();
            $('#Paid #srvcs').hide();
        }
        else{
            $('#'+selectedJSON[0].cardType).show();
            $('#Paid #srvcs').show();
        }
        /*cs["xcmob__c"].value = selectedJSON[0].refMobile;
        cs["rmob__c"].value = selectedJSON[0].refMobile;
        cs["xceml__c"].value = selectedJSON[0].email;*/
        
        //cs['rtacn__c'].value = cardNum;
        $('.table-parking').parent().parent().find('.frmErrMsg').remove();
        $('.chk').show();
    }
    
    
    function getUrlParameter(key){
        var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
        return (res==undefined)?'':res[1];
    }
    
    
    </script>
</apex:page>