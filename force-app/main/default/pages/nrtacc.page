    <script type="text/javascript">
    var cs = {};
    var selectedSer = '';
    var ad4 = {"ActionName":"insertparkingrequest","SectorLocationId":"","OracleID":"","AgNo":"","AXSId":"","CardNumber":"","Eligibility":"","RequestType":"Parking Card","BusinessPark":"","Sector":"","CardRequestType":"","ParkingType":"Paid","EndDate":"","CardsDetail":[{"cardHolderName":"","Email":"","Mobile":"","Phone":"","Vehicles":[]}]};
    
    function createAD4(){
        ad4.CardNumber = $('#cardDet').val();
        ad4.Sector= selectedJSON[0].sector;
        var dt = selectedJSON[0].expDate.split('/')[2]+'-'+selectedJSON[0].expDate.split('/')[1]+'-'+selectedJSON[0].expDate.split('/')[0];
        ad4.EndDate = dt;
        ad4['SectorLocationId'] = selectedJSON[0].sectorId;
        ad4['Eligibility'] = selectedJSON[0].EligibilityName;
        ad4['ParkingType'] = selectedJSON[0].cardType;
        ad4['CardRequestType'] = cs['Reason__c'].value;
        ad4['reason'] = cs['Reason__c'].value;
        cs['xadtx4__c'].value = JSON.stringify(ad4);
    }
    function saveDetails(){
        //cs['ias__c'].value='0np';
        if($('#cardDet').val()==undefined||$('#cardDet').val()==''){
            addValError('#cardDet','Please select a card.');
            return;
        }
        if($('[name="ser"]:checked').val()==undefined||$('[name="ser"]:checked').val()==''){
            // $('#Paid .services .form-group .frmErrMsg').remove();
            //$('#Paid .services .form-group').append('<div class="frmErrMsg">Please choose an option.</div>');
            scrollToDiv($('#Paid .services .form-group'));
           addValError('[value="Cancel"]','Please choose an option.');
            return;
        }
        var cardNum = $('.input-select-member').val();
        cs['rtacn__c'].value = selectedJSON[0].cardNum;
        cs['xpveh__c'].value=selectedJSON[0].vehicleNumber;
        cs['xchn__c'].value=selectedJSON[0].cHolderNm;
        cs['xppor__c'].value=selectedJSON[0].pPlaceOfReg;
        cs['xps__c'].value=selectedJSON[0].sector;
        var brk = vflds('.requiredFld,.applMob', true);
        /*if(cs["rtacn__c"].value=='' || cs["rtacn__c"].value==undefined){
            $('.table-parking').parent().parent().append('<div class="frmErrMsg">Please select vehicle number to proceed</div>');
            scrollToDiv($('.table-parking'));
            brk = true;
        }*/
        if($('[name="ser"]:checked').val() == 'Cancel'){
            // $('#rsns,#cdCmp').show();
            if(cs['Reason__c'].value!='' && cs['Reason__c'].value!=undefined){
                cs['xadh__c'].value='xnp';
                if(!brk){createAD4();toggleGLoader(); saverq();return; }
            }
            else
              cs['xadh__c'].value='0np';
        }
        else{
            //$('#rsns,#cdCmp').hide();
            cs['xadh__c'].value='1np';
        }
        if(!brk){createAD4();toggleGLoader();saverq(); /*(pushPD();*/ }
    }
    
    
    function vflds(clsName){
        var brk = false;var elem = '';
        
        $(clsName).each(function(){ 
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=true; addValError(this,'This field is required!'); 
                    if(elem==''){ elem = $(this);}
                }//else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        return brk;
    }
    
    
    </script> 
    
