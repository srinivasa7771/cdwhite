<apex:page id="page" standardStylesheets="true" sidebar="false" showHeader="true" deferLastCommandUntilReady="true" extensions="gctlRQ"   standardController="g_Req__c" >
    <apex:includeScript value="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js"/>
    <apex:stylesheet value="{!$Resource.gCss}"/><apex:includeScript value="{!$Resource.jsH}"/>  
    <apex:includeScript value="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js"/>
        
    <script>
    var cn = '';
    $(document).ready(function() {
        cn = getUrlVars()["cn"];
         if(cn=='206' || cn=='220'){cs["stkr"].style.display="none";cs["stkr2"].style.display="none";cs['cd'].style.display='block'; cs['cd2'].style.display='none'}
        if(cn=='196'){cs["stkr"].style.display="block";cs["stkr2"].style.display="block";cs['cd'].style.display='block'; cs['cd2'].style.display='none'}
        if(cn===void 0 || cn=='' || cn=='apt'){cs['cd2'].style.display='block';
                                 cs["stkr"].style.display="none";cs["stkr2"].style.display="none";cs['cd'].style.display='none';
                                 }
        
    });
    
    var cs={};
    function openForm(type) {
        var cn = getUrlVars()["cn"];
        window.open("/apex/grqn?c="+cn, "_self");
        return false;
    }

    function openReq() {
        var id = getUrlVars()["id"];
        window.open("/"+id, "_self");
        return false;
    }    
    function getUrlVars() {
        var vars = {};
        var parts = window.location.href.replace(/[?&]+([^=&]+)=([^&]*)/gi,function(m,key,value) {vars[key] = value;});
        return vars;
    }
    
    function prntStk(type) {
        //var cn = getUrlVars()["cn"];
        var rqid = getUrlVars()["id"];
        if(type=='1'){window.open("/apex/grbrcd3?id="+rqid, "_new");
        }else{window.open("/apex/grbrcd2?id="+rqid, "_new");}
        
        return false;
    }
    </script>
 
     
<b><apex:pageMessages id="msg" /></b>
    
    <apex:form id="form" >
        <apex:pageBlock >
            <apex:pageBlockSection columns="1">
                <apex:pageBlockSectionItem >
                  <br/><br/>
                    <div id="cd" style="display:none">
                        
                    
                        <h3>Your request <a href="" onclick="openReq();" title=""> <b style="color:#3fc6f1;cursor:pointer;">{!rqNo}</b></a> has been submitted successfully to back office for review. </h3>
                        
                        <br/><h4>Please <a href="" onclick="openForm();" title="Apply for another transaction" ><b style="color:#3fc6f1;cursor:pointer;">click here</b></a> to apply for another transaction.</h4>
                    
                    <script type="text/javascript">
                        cs['cd']=getC('cd');
                        cs['cd'].style.display='none';
                        </script>
                        </div>
                </apex:pageBlockSectionItem>
                  <apex:pageBlockSectionItem >
                 <div id="cd2" style="display:none">
                        <h3>Your request <a href="" onclick="openReq();" title=""> <b style="color:#3fc6f1;cursor:pointer;">{!rqNo}</b></a> has been submitted successfully and forwared to back office for verification. </h3>
                       
                <script type="text/javascript">
                        cs['cd2']=getC('cd2');
                        cs['cd2'].style.display='none';
                        </script>
                      </div>
                       </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
            
            <apex:pageBlockSection columns="1">  
                <apex:pageBlockSectionItem >
                   <div id="stkr" style="display:none">
                        <h4><a href="" onclick="prntStk('1');" title="Print Sticker" ><b style="color:#3fc6f1">Empost Sticker</b></a></h4><br/>
                        <script type="text/javascript">
                        cs['stkr']=getC('stkr');
                        cs['stkr'].style.display='none';
                        </script>
                    </div>
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                     <div id="stkr2" style="display:none">
                        <h4><a href="" onclick="prntStk('2');" title="Print Sticker" ><b style="color:#3fc6f1">Envelope Sticker</b></a></h4><br/>
                        <script type="text/javascript">
                        cs['stkr2']=getC('stkr2');
                        cs['stkr2'].style.display='none';
                        </script>
                    </div>
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
            
            <apex:pageBlockSection columns="1">  
                    
            </apex:pageBlockSection>
        </apex:pageBlock> 
        
    </apex:form>
</apex:page>