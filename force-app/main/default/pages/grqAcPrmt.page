    <script type="text/javascript">
    var ispu={!ispu},lcl='{!lcl}',sta='{!req.STA__c}',cs={}; var isgu={!isgu}; 
    var lf='',af='',adf='',aif,adif,cif,fnxPg; var mcol = new String(); var mx=1;var my; 
    var lstActiveReq = new Array(); var jsonAllVals ={}; var isEditBO = false; 
    
    function assignFldValue(element){
        $(element).each(function(){ 
            var val = $(this).val();
            var eid = $(this).attr('id');
            var a = eid.split(':'); eid = a[a.length-1]; eid = eid.replace('__c','');
             
            //update format for date fields
            if($(this).hasClass('input-datepicker')){
                var dt2 = val.split('/') ;
                if(dt2.length==3){val = dt2[2].trim() +'-'+ dt2[1].trim() +'-'+  dt2[0].trim();}
            }else if($(this).hasClass('jsnfldMultipic') && val!=null){
                val=$(this).val().join(';');
            }
            jsonAllVals[eid+'__c'] = val;
        });
        //### cs["dummyadh"].value = JSON.stringify(jsonAllVals);
    }
    
    $(document).ready(function(){
        $(".inputTimeMaxLength").attr('maxlength', '5');    
        $(".jsnfld,  .jsnfldMultipic, .input-datepicker" ).change(function() { assignFldValue($(this));});
        $('.alphaNum').bind('keyup', function(e) {
            $(this).val($(this).val().replace(/[^a-zA-Z0-9 ]/g, ''));
            if (e.which >= 97 && e.which <= 122) {
                var newKey = e.which - 32;
                e.keyCode = newKey;
                e.charCode = newKey;
            }
            $(this).val(($(this).val()));
        });

        if(!ispu && !isgu){
            var urlParam = getAxsURLParam('m');
            if(urlParam=='edit'){
                $(".disableBoEdit").attr("disabled","true");
            }
        }
        
        loadData();assignLoc();
        if(lstActiveReq.length==0){$("#mapActiveReq").hide();}
        
        
        setTimeout(function(){
            var strLocList = '{!strLocList}';
            if(strLocList==null || strLocList==''|| strLocList=='[]'){
                $("#xaloc").select2({
                    language: {
                        inputTooShort: function (args) {
                            return "Please enter your office address";
                        }
                    },minimumInputLength: 5,tags:true}); }
        },500);
    })
    
    function loadData(){shwOther(false);removeVal();assignFldValue(".jsnfld, .jsnfldMultipic"); setTimeOnLoad('xst');setTimeOnLoad('xet'); } 
    function vfrm(nSTA){return hsSnc(nSTA)?!1:hRq(nSTA)?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):hErr(nSTA)?(alrt("{!$Label.msgCRR}","{!$Label.msgCRRD}"),!1):!0}
    function hsSnc(nSTA){return false;} 
    function hErr(nSTA){return false;}
    
    function hRq(nSTA) {
        var brq = false; 
        fldErr('xst__c',null,!0);fldErr('xet__c',null,!0);fldErr('xcpid__c',null,!0);fldErr('xcped__c',null,!0);fldErr('xchn__c',null,!0);fldErr('xcmob__c',null,!0);fldErr('csp__c',null,!0);fldErr('prf__c',null,!0);fldErr('xrap__c',null,!0);fldErr('xaloc__c',null,!0);fldErr('xceml__c',null,!0);
        brq = fldReq('csp__c',cs)||brq;  brq = fldReq('prf__c',cs)||brq;  brq = fldReq('xrap__c',cs)||brq; brq = fldReq('xaloc__c',cs)||brq;  brq = fldReq('xcpid__c',cs)||brq;  brq = fldReq('xcped__c',cs)||brq; brq = fldReq('xchn__c',cs)||brq; brq = fldReq('xcmob__c',cs)||brq;brq = fldReq('xceml__c',cs)||brq;
        var brk = valDates() || valTime('xst__c') || valTime('xet__c'); 
        
        brq= brk||brq;
        brq = fldReq('xst__c',cs)||brq;brq = fldReq('xet__c',cs)||brq;
        if(cs['xrap__c'].value != null && (cs['xrap__c'].value == 0 || cs['xrap__c'].value > 98)){
            addValError(cs['xrap__c'], "Please Enter a valid Numeric Value");brq = true;    
        }
        
        return brq;
    }
    
    function isAlphabet(evt) {
        evt = (evt) ? evt : window.event;var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (!(charCode == 32 || (charCode > 64 && charCode < 91) || (charCode > 96 && charCode < 123))) {
            //addValError(cs['xchn__c'], "Please Enter only Alphabetical characters");  
            return false; 
        }
        return true;
    }
    
    function isNumber(evt) {
        var r = true;
        evt = (evt) ? evt : window.event;var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            //addValError(cs['xrap__c'], "Please Enter a Numeric Value"); 
            r = false;
        }
        return r;
    }
    
    
    function shwOther(clearVals){
        var prf = cs['prf__c'].value;
        if(prf=='Others' || prf=='Events/Promotions (AVMS Requests)'){ 
            cs['Reason__c'].style.display='block'; cs['Reason__cl'].style.display='block';
            getC('hpr__cRI').style.display='none';
        }else{
            cs['Reason__c'].style.display='none';cs['Reason__cl'].style.display='none';
            getC('hpr__cRI').style.display='block';
        }
        
        /* clear picklist only onchange*/
        if(clearVals){cs['hpr__c'].value = ''; $('#hpr').val(null).trigger('change');};
    }
    
    
    function removeVal(){
        var prf = cs['prf__c'].value; getC('hpr__cRI').style.display='block';var selectobject= getC('hpr'); 
        selectobject.length = 0;
        var list = ['Grease traps more than 2M deep','Confined space entry ( shaft, manhole)','Fire alarm system isolation for more than 8 hours','Handling of chemicals / dangerous goods','Hot-work (activity which generate sparks/Naked flames)','Mechanical lifting, usage of crane, boom lift, cherry picket etc.','Spray painting','Sprinkler system isolation for more than 8 hours','Work at height using scaffolding more than 2 meters high'];
        for(var i=0; i<list.length;i++){var newOption = new Option(list[i], list[i], true, cs['hpr__c'].value.includes(list[i]));$('#hpr').append(newOption);}
        
        if(prf=='Grease Trap Cleaning'){
            for(var i=0; i<selectobject.length; i++){ var val=selectobject.options[i].value;if(val != 'Grease traps more than 2M deep'){ selectobject.remove(i);i--;}}
        }else if(prf=='Access Control, CCTV and Other Devices Fixing'){
            for(var i=0; i<selectobject.length; i++){ var val=selectobject.options[i].value; if(val!= 'Hot-work (activity which generate sparks/Naked flames)' && val != 'Work at height using scaffolding more than 2 meters high'){ selectobject.remove(i); i--; }}
        }else if(prf=='Furniture / Office Asset Removal' || prf=='Move In (Furniture and Office Equipment Delivery) After Completion Of Fit-Out' || prf=='Office Accessories Fixing (TV, Projector, Screen etc.)'){
            for(var i=0; i<selectobject.length; i++){ var val=selectobject.options[i].value; if(val != 'Work at height using scaffolding more than 2 meters high'){selectobject.remove(i); i--;}}
        }else if(prf=='IT Related Works (Network Cabling, Computer, Printer)'){
            for(var i=0; i<selectobject.length; i++){ var val=selectobject.options[i].value; if(val != 'Fire alarm system isolation for more than 8 hours' && val != 'Sprinkler system isolation for more than 8 hours'){selectobject.remove(i);i--;}}
        }else if(prf=='Telecommunication Services'){
            for(var i=0; i<selectobject.length; i++){ var val=selectobject.options[i].value; if(val != 'Confined space entry ( shaft, manhole)' && val != 'Mechanical lifting, usage of crane, boom lift, cherry picket etc.' && val != 'Work at height using scaffolding more than 2 meters high'){selectobject.remove(i);i--;}}
        }else if(prf=='Antenna Installation' || prf=='External signage fixing' || prf=='Film Shooting' || prf=='Fixing Signage In Internal Common Area, Building Directory Update' || prf=='Major Fit-Out Work' || prf=='Minor Fit-Out Work' || prf=='Fit-Out Mobilazation' || prf=='Technical Maintenance Of BP Owned Assets' || prf=='Film shooting'){
            for(var i=0; i<selectobject.length; i++){  var val=selectobject.options[i].value; if(val== 'Grease traps more than 2M deep'){selectobject.remove(i);break;}}
        }else if(prf=='' || prf=='Events/Promotions (AVMS Requests)' || prf=='Pest Control'  || prf=='Others'){getC('hpr__cRI').style.display='none'; }
        
        var newOption = new Option('Not applicable','', true, false ); $('#hpr').append(newOption);
    }
    
    function NumberLimit(n) {
        var num = parseInt(n.value); var brk = false; removeValError(cs['xrap__c']);
        if(num <=  0 ){addValError(cs['xrap__c'],'Value should be greater than 0'); brk=true;} 
        if(num > 98 ){addValError(cs['xrap__c'],'Value should be less than 99'); brk=true;}
        return brk;
    }
  
    function cpyDates(d) { cs[d+'__c'].value = cs[d].value;  assignFldValue($('#'+d));}
    
    function valDates() { 
        var brk=false, stDtErr=false, endDtErr=false;
        if(cs['xcpid__c'].value==""){stDtErr=true;}
        if(cs['xcped__c'].value==""){endDtErr=true;}
        var stDate = cs['xcpid__c'].value; var splitDt = stDate.split("/");
        if (splitDt != "" && splitDt.length == 3) {stDate = splitDt[2] + '-' + splitDt[1] + '-' + splitDt[0];}
        
        var date = new Date(); var today1 = date.getTime();
        stDate = new Date(stDate).getTime();
        if(stDate < today1) { addValError(cs['xcpid'], "Start Date should be future date"); brk=true; stDtErr=true;}
        
        var expDate = cs['xcped__c'].value; var splitDt2 = expDate.split("/");
        if (splitDt2 != "" && splitDt2.length == 3) {expDate = splitDt2[2] + '-' + splitDt2[1] + '-' + splitDt2[0];}
        
        expDate = new Date(expDate).getTime();
        if(expDate < today1) { addValError(cs['xcped'], "End Date should be future date"); brk=true;endDtErr=true; }
        if (expDate < stDate) { addValError(cs['xcped'], "End Date must be greater than start date"); brk=true;endDtErr=true;}
        
        if(!endDtErr){removeValError(cs['xcped']);}
        if(!stDtErr){removeValError(cs['xcpid']);}
        valTime(); 
        return brk; 
    }
    
    function formatTimeHHMM(xtime,keycd){
        var st = cs[xtime].value;
        if(keycd!=8 && keycd!=46 && st!='' && st.length>=2 && !st.includes(":")){ st = [st.slice(0, 2), ':', st.slice(2)].join('');cs[xtime].value = st;}        
    }
    
    // set the time values
    function setTime(eId) {
        cs[eId+'__c'].value = $('#'+eId).val() + ' ' + $('#'+eId+'s').val(); 
        $(cs[eId+'__c']).trigger('change'); valTime();
    }
    
    // set the UI fields 
    function setTimeOnLoad(eId) {
        var t =  cs[eId+'__c'].value; 
        if(t!=undefined && t!=""){
            var t2 = t.split(" "); $('#'+eId).val(t2[0]); $('#'+eId+'s').val(t2[1]);
            $('#'+eId).trigger('change');  $('#'+eId+'s').trigger('change'); 
        }else{
            setTime(eId);
        }
    }
    
    function valTime_Bk(xtime){
        formatTime(); 
        var st = cs[xtime].value; var brk = false;
        if(st!='' ){
            if(!st.includes(":") && st.length==3){st='0'+st;}
            if(!st.includes(":") && st.length==4){st = ''+st[0]+st[1]+':'+st[2]+st[3];cs[xtime].value = st;}
            
            var isValid = /^([0-1]?[0-9]|2[0-3]):([0-5][0-9])(:[0-5][0-9])?$/.test(st);
            if (!isValid){
                addValError(cs[xtime], "Invalid time (time range - 00:00 to 23:59)");  brk = true;
            }else if(cs['xcpid__c'].value==cs['xcped__c'].value && cs['xst__c'].value !="" && cs['xet__c'].value!="" && (cs['xst__c'].value >= cs['xet__c'].value)){
                addValError(cs['xet__c'], "End time must be later than start time");  brk = true;
            }
            
        }else{brk=true;}
        
        if(!brk){removeValError(cs[xtime]);}
        return brk;
    }
    
    function valTime(xtime){
        var brk = false;
        
        if(cs['xcpid__c'].value!="" && cs['xcped__c'].value!="" && cs['xcpid__c'].value==cs['xcped__c'].value && ($('#xst').val() >= $('#xet').val() && ($('#xsts').val()==$('#xets').val() )|| ($('#xsts').val()=='PM' && $('#xets').val()=='AM') )){
            addValError($('#xet'), "End time must be later than start time");  brk = true;
        }
        
        if(!brk){removeValError($('#xet'));}
        return brk;
    }
    
    function formatTime() {
        var st = cs['xst__c'].value;var et =cs['xet__c'].value;
        if(st!=null && st!=''){st = st.split(":"); if(st[1]!=undefined){cs['xst__c'].value= st[0]+":"+st[1];}}
        if(et!=null && et!=''){et = et.split(":"); if(et[1]!=undefined){cs['xet__c'].value= et[0]+":"+et[1];}} 
    }
    
    
    function setRenewalDetails(e,reqId,num){
        if(e.checked){
            cs["renewalRqId"].value = reqId; cs["xrap__c"].value = num;
            getC('newpermit').style.display="none"; getC('permitdets').style.display="none";  //getC('newdocs').style.display="none"; 
            $(".newpermit").hide();
            for(var i=0; i<lstActiveReq.length; i++){if(lstActiveReq[i]!=reqId){ getC(lstActiveReq[i]).checked = false;}}
        }else{
            getC('newpermit').style.display=""; getC('permitdets').style.display="";  $(".newpermit").show();//getC('newdocs').style.display="";
            cs["renewalRqId"].value = ''; cs["xrap__c"].value = "";}
    }
    
    function saveDetails(){
        var brk = vflds('.requiredFld');
        
        if(cs["renewalRqId"].value==''){brk = /***chkDocs() ||***/ valDates() || valTime() || NumberLimit(cs['xrap__c']) || brk;}
        
        if(!brk){
            // if(cs["xbrnd__c"].value==''){cs["xbrnd__c"].value = '{!xbrand}';}
            toggleGLoader(); 
            if(cs["renewalRqId"].value!=''){afup();}else{afso1();}
            
        }
    }
    
    
    function chkDocs(){
        var brk = false;
        if('{!req.id}'==''){
            $('#requiredDoc').show();
            brk=true;
        }
        return brk;
    }
    
    
    function vflds(clsName){
        var brk = false;var elem = '';
        
        $(clsName).each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=true; addValError(this,'Value is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        return brk;
    }
    
    /*function addValError(thiselem,message){
