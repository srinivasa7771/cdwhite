                                <script type="text/javascript">
                                cs['CatOpt']=getC('{!$Component.CatOpt}');
                                cs['category']=getC('{!$Component.category}');
                                ctg = '{!JSENCODE(selCatg)}';
                                </script>
                            </div>
                        </div>
                        <div class="slds-col slds-grid">
                            <div class="slds-form-element__label">Item:</div>
                            <div class="slds-col slds-form-element__control">
                                <apex:selectList id="items2" value="{!selItm}" multiselect="false"  size="1" onchange="resetSTA();" >
                                    <apex:selectOptions value="{!itemOptions}"/>
                                </apex:selectList>
                                <script type="text/javascript">cs['itm']=getC('{!$Component.itm}');
                                cs['items']=getC('{!$Component.items}');
                                itmLst = '{!JSENCODE(ItmOpt)}';
                                </script>
                            </div>
                        </div>
                        <div class="slds-col slds-grid">
                            <div class="slds-form-element__label">Status:</div>
                            <div class="slds-col slds-form-element__control">
                                <apex:selectList value="{!selStat}" multiselect="false" size="1" id="status" >
                                    <apex:selectOption itemLabel="-None-"  itemvalue=""  />
                                    <apex:selectOption itemLabel="Under Review"  itemvalue="rv,pd,dr,v,n,svc,sip,sac,pp,sd"  />
                                    <apex:selectOption itemLabel="Corrected By Customer"  itemvalue="cc,ccc,v,vcc"  />
                                    <apex:selectOption itemLabel="Awating Customer Correction"  itemvalue="rc,rcc"  />
                                    <apex:selectOption itemLabel="Requires DNRD Correction"  itemvalue="ic"  />
                                    <apex:selectOption itemLabel="Sent to DNRD/EMPOST"  itemvalue="if,cif"  />
                                    <apex:actionSupport event="onchange" action="{!queryReq}" rerender="listForm" status="sts" />
                                    
