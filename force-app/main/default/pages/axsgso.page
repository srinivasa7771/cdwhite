                        </div>
                    </div>
                    <script type="text/javascript" charset="utf8">
                    var oTable;var currentNumberDisplayed = 500;
                    $(document).ready(function() {
                        $('#load').click( function () {
                            var oSettings = oTable.fnSettings();currentNumberDisplayed += 2;oSettings._iDisplayLength = currentNumberDisplayed;oTable.fnDraw();});
                        oTable = $('[id$=testTable]').DataTable({"iDisplayLength": 20,"autoWidth": false}); 
                        
                        $("#testTable_info").detach().prependTo('#testTable_wrapper');
                        $("#testTable_paginate").detach().prependTo('#testTable_wrapper');
                        //$('#testTable').parent().prepend($('#testTable_info'));
                        //$('#testTable').parent().prepend($('#testTable_paginate'));
                    });
                    </script>
                    
                    <apex:actionstatus id="sts">
                        <apex:facet name="start">
                            <div class="slds-spinner_container">
                                <div id="mySpinner" role="status" class="slds-spinner slds-spinner_medium">
                                    <span class="slds-assistive-text">Loading</span>
                                    <div class="slds-spinner__dot-a"></div>
                                    <div class="slds-spinner__dot-b"></div>
                                </div>
                            </div>
                        </apex:facet>
                    </apex:actionstatus> 
                    <apex:outputPanel rendered="{! IF(ISBLANK(finalListRqItm), false, true) }">
                        <table id="testTable" class="slds-table slds-table_fixed-layout slds-table_bordered slds-table--header-fixed" aria-label="">
                            <thead>
                                <tr class="slds-line-height_reset">
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Request">Request</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Manage Request">Manage Request</div>
                                    </th>
                                    <apex:outputText rendered="{! IF(srvcName ==  'DFV', true, false) }">
                                        <th class="" scope="col">
                                            <div class="slds-truncate" title="Sponser Name">Sponser Name</div>
                                        </th>
                                    </apex:outputText>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Service Name">Service Name</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Priority">Priority</div>
                                    </th>
                                    <apex:outputText rendered="{! IF(srvcName ==  'EID', true, false) }">
                                        <th class="" scope="col">
                                            <div class="slds-truncate" title="Medical Fit Date">Medical Fit Date</div>
                                        </th>
                                    </apex:outputText>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Priority">Account Name</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Applicant Name">Applicant Name</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Passport#">Passport#</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Nationality">Nationality</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Payment Date">Payment Date</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Date of Action">Date of Action</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="SLA Status">SLA Status</div>
                                    </th>
                                    <th class="" scope="col">
                                        <div class="slds-truncate" title="Remarks">Remarks</div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <apex:repeat value="{!finalListRqItm}" var="record">
                                    <tr class="slds-hint-parent">
                                        <td data-label="Request" scope="row">
                                            <div class="slds-truncate" title="{!record.ri.RQ__r.name}">
                                                <a href="/{!record.ri.RQ__c}" target="_blank">{!record.ri.RQ__r.name}=={!record.ri.STA__r.Name}</a>
                                            </div>
                                        </td>
                                        <td data-label="">
                                            <div class="slds-truncate" title="Manage Request">
                                                <apex:outputField value="{!record.ri.RQ__r.xmgr__c}"/>
                                            </div>
                                        </td>
                                        <apex:outputText rendered="{! IF(srvcName ==  'DFV', true, false) }">
                                            <td data-label="">
                                                <div class="slds-truncate" title="Sponser Name">{!record.ri.RQ__r.Sponser_Name_Auto__c}</div>
                                            </td>
                                        </apex:outputText>
                                        <td data-label="">
                                            <div class="slds-truncate" title="Service Name">{!record.ri.itm__r.srvc__r.Name}</div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Priority">{!record.ri.RQ__r.prio__c}</div>
                                        </td>
                                        <apex:outputText rendered="{! IF(srvcName ==  'EID', true, false) }">
                                            <td class="" scope="col">
                                                <div class="slds-truncate" title="Medical Fit Date">
                                                    <apex:outputText value="{0,date,dd-MM-yyyy}">
                                                        <apex:param value="{!record.ri.Medical_Fit_Date__c}" />
                                                    </apex:outputText>
                                                </div>
                                            </td>
                                        </apex:outputText>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Account Name">
                                                {!IF(record.ri.RQ__r.Account_Name__c=='test identity 1', 'DED Account',record.ri.RQ__r.Account_Name__c)}
                                            </div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Applicant Name">{!record.ri.RQ__r.Full_Name__c}</div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Passport#">{!record.ri.RQ__r.xcp__c}</div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Nationality">{!record.ri.RQ__r.xcnc__c}</div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Payment Date">{!record.ri.First_Payment__c}</div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Date of Action">
                                                <apex:outputText value="{0,date,dd-MM-yyyy}">
                                                    <apex:param value="{!record.dateofAction}" />
                                                </apex:outputText>
                                            </div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="SLA Status">
                                                <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration > 9),AND(record.ri.RQ__r.expflg__c,record.duration > 4))}">
                                                    <apex:outputText value="Outside SLA"/>
                                                </apex:outputText>
                                                <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration > 6,record.duration < 9))}">
                                                    <apex:outputText value="About to Expire"/>
                                                </apex:outputText>
                                                <apex:outputText rendered="{!OR(AND(NOT(record.ri.RQ__r.expflg__c), record.duration <= 6),AND(record.ri.RQ__r.expflg__c,record.duration <= 5))}">
                                                    <apex:outputText value="Within SLA"/>
                                                </apex:outputText>
                                            </div>
                                        </td>
                                        <td class="" scope="col">
                                            <div class="slds-truncate" title="Remarks">{!record.ri.nt__c}</div>
                                        </td>
                                        
                                    </tr>
                                </apex:repeat>
                            </tbody>
                        </table>
                    </apex:outputPanel>
                    
                </apex:form>
            </div>
        </body>
    </html>
    
</apex:page>