            padding: 0;	
            }	
            .help-side-menu li {	
            position: relative;	
            }	
            .help-side-menu li a {	
            display: block;	
            }	
            .help-side-menu > li {	
            position: relative;	
            border-bottom: 1px solid rgba(103, 109, 120, 0.2);	
            }	
            .help-side-menu > li > a {	
