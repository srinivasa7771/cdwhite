                                        <div class="card-video-img"
                                             style="background-image: url('http://img.youtube.com/vi/uHC5207wdrQ/0.jpg')"></div>
                                        <div class="card-video-content">
                                            <h4 class="card-video-title">Apply for new employee</h4>
                                        </div>
                                    </a>
                                </div>
                                <!-- .col -->
                                <div class="col-xl-3 col-lg-4 col-sm-6">
                                    <a href="#modal_video" class="card-video" data-video="uHC5207wdrQ" data-toggle="modal">
                                        <div class="card-video-img"
                                             style="background-image: url('http://img.youtube.com/vi/uHC5207wdrQ/0.jpg')"></div>
                                        <div class="card-video-content">
                                            <h4 class="card-video-title">On-boarding for the new business</h4>
                                        </div>
                                    </a>
                                </div>
                                <!-- .col -->
                                <div class="col-xl-3 col-lg-4 col-sm-6">
                                    <a href="#modal_video" class="card-video" data-video="uHC5207wdrQ" data-toggle="modal">
                                        <div class="card-video-img"
                                             style="background-image: url('http://img.youtube.com/vi/uHC5207wdrQ/0.jpg')"></div>
                                        <div class="card-video-content">
                                            <h4 class="card-video-title">How to renew my lease and license</h4>
                                        </div>
                                    </a>
                                </div>
                                <!-- .col -->
                                <div class="col-xl-3 col-lg-4 col-sm-6">
                                    <a href="#modal_video" class="card-video" data-video="uHC5207wdrQ" data-toggle="modal">
                                        <div class="card-video-img"
                                             style="background-image: url('http://img.youtube.com/vi/uHC5207wdrQ/0.jpg')"></div>
                                        <div class="card-video-content">
                                            <h4 class="card-video-title">Introduction to axs</h4>
                                        </div>
                                    </a>
                                </div>
                                <!-- .col -->
                                <div class="col-xl-3 col-lg-4 col-sm-6">
                                    <a href="#modal_video" class="card-video" data-video="uHC5207wdrQ" data-toggle="modal">
                                        <div class="card-video-img"
                                             style="background-image: url('http://img.youtube.com/vi/uHC5207wdrQ/0.jpg')"></div>
                                        <div class="card-video-content">
                                            <h4 class="card-video-title">Apply for new employee</h4>
                                        </div>
                                    </a>
                                </div>
                                <!-- .col -->
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Modal -->
                <div class="modal fade modal-base" id="modal_video" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true"
                     data-backdrop="static" data-keyboard="false">
                    <div class="modal-dialog" role="document" style="width: 990px;">
                        <div class="modal-content">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <i class="icon-close"></i>
