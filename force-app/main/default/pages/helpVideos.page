            -webkit-animation-duration: 0.5s;	
            animation-duration: 0.5s;	
            }	
            .glossary-collapse .collapse-header {	
            padding: 1rem 2.5rem 1rem 1.5rem;	
            font-weight: bold;	
            color: #4A4A4A;	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .glossary-collapse .collapse-header::after {	
            top: 0.875rem;	
            right: 1rem;	
            }	
            .glossary-collapse .collapse-header:hover {	
            color: #646464;	
            }	
            .glossary-collapse .collapse-content {	
            padding: 0 1.5rem 1rem;	
            }	
            .glossary-filter a {	
            display: inline-block;	
            width: 35px;	
            line-height: 35px;	
            margin-right: 5px;	
            margin-bottom: 5px;	
            color: #333333;	
            font-size: 20px;	
            font-weight: bold;	
            text-align: center;	
            border-radius: 50%;	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .glossary-filter a:hover {	
            background-color: rgba(0, 0, 0, 0.1);	
            }	
            .glossary-filter a.active {	
            background-color: #67486C;	
            color: #ffffff;	
            }	
            .glossary-filter a.inactive {	
            cursor: default;	
            color: #9B9B9B;	
            }	
            .glossary-filter a.inactive:hover {	
            background-color: transparent;	
            }	
            .card-video {	
            display: block;	
            margin-bottom: 30px;	
            background-color: #ffffff;	
            border-radius: 10px;	
            color: inherit;	
            overflow: hidden;	
            -webkit-box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
            box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .card-video-img {	
            padding-top: 55%;	
            position: relative;	
            background-repeat: no-repeat;	
            background-size: cover;	
            background-position: center center;	
            border-radius: 10px;	
            overflow: hidden;	
            }	
            .card-video-img::before {	
            content: ' ';	
            position: absolute;	
            left: 0;	
            top: 0;	
            width: 100%;	
            height: 100%;	
            background-color: rgba(30, 30, 30, 0.3);	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .card-video-img::after {	
            display: inline-block;	
            font: normal normal normal 14px/1 FontAwesome;	
            font-size: inherit;	
            text-rendering: auto;	
            -webkit-font-smoothing: antialiased;	
            -moz-osx-font-smoothing: grayscale;	
            content: "\f144";	
            position: absolute;	
            left: 50%;	
            top: 50%;	
            -webkit-transform: translate(-50%, -50%);	
            -ms-transform: translate(-50%, -50%);	
            transform: translate(-50%, -50%);	
            color: #ffffff;	
            font-size: 50px;	
            line-height: 1;	
            opacity: 0.9;	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .card-video-content {	
            min-height: 105px;	
            padding: 1.25rem;	
            }	
            .card-video-title {	
            color: inherit;	
            }	
            .card-video:hover {	
            -webkit-box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
            box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
            }	
            .card-video:hover .card-video-img::before {	
            background-color: rgba(30, 30, 30, 0.5);	
            }	
            .card-video:hover .card-video-img::after {	
            opacity: 1;	
            }	
            #modal_video .modal-header {	
            padding: 1rem 1.5rem;	
            }	
            #modal_video .modal-header h4 {	
            margin-bottom: 0;	
            }	
            #modal_video .modal-content {	
            border-radius: 10px 10px 0 0;	
            }	
            .input-filter-faqs > input[type=text] {	
            border: none;	
            }	
            .faq-category-list {	
            list-style: none;	
            margin: 0 0 1.5rem;	
            padding: 0;	
            border-top: 1px dashed rgba(103, 109, 120, 0.2);	
            }	
            .faq-category-list > li {	
            border-bottom: 1px dashed rgba(103, 109, 120, 0.2);	
            }	
            .faq-category-list > li > a {	
            display: block;	
            font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
            letter-spacing: 0.75px;	
            color: #333333;	
            font-weight: 500;	
            font-size: 1.25rem;	
            line-height: 1;	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            @media (min-width: 576px) {	
            .faq-category-list > li > a {	
            padding: 14px 20px;	
            }	
            }	
            @media (min-width: 1200px) {	
            .faq-category-list > li > a {	
            padding: 14px 30px;	
            }	
            }	
            @media (min-width: 1500px) {	
            .faq-category-list > li > a {	
            padding: 14px 40px;	
            }	
            }	
            .faq-category-list > li > a:hover {	
            background-color: #f5f6fb;	
            }	
            .faq-category-list > li.active > a {	
            background-color: #f5f6fb;	
            }	
            .faq-category-list > li ul {	
            list-style: none;	
            padding-left: 40px;	
            }	
            .faq-category-list > li ul > li > a {	
            display: block;	
            padding: 10px 12px;	
            }	
            .faq-collapse {	
            border-radius: 0.75rem;	
            background: #ffffff;	
            border: none;	
            -webkit-animation-duration: 0.5s;	
            animation-duration: 0.5s;	
            }	
            .faq-collapse .collapse-header {	
            padding: 1rem 2.5rem 1rem 1.5rem;	
            font-size: 1rem;	
            font-weight: 500;	
            color: #4A4A4A;	
            -webkit-transition: all 0.3s;	
            -o-transition: all 0.3s;	
            transition: all 0.3s;	
            }	
            .faq-collapse .collapse-header::after {	
            top: 1rem;	
            right: 1rem;	
            }	
            .faq-collapse .collapse-header:hover {	
            color: #646464;	
            }	
            .faq-collapse .collapse-title {	
            font-size: 1.125rem;	
            }	
            .faq-collapse .collapse-content {	
            padding: 0 1.5rem 1rem;	
            }
        </style>
        <apex:form id="form">
            <script>
            $(document).ready(function(){
                /* Get iframe src attribute value i.e. YouTube video url and store it in a variable */
                var url = $("#videoFrame").attr('src');
                
                /* Assign empty url value to the iframe src attribute when modal hide, which stop the video playing */
                $("#modal_video").on('hide.bs.modal', function(){
                    $("#videoFrame").attr('src', '');
                });
                
                /* Assign the initially stored url back to the iframe src attribute when modal is displayed again */
                $("#modal_video").on('show.bs.modal', function(){
                    $("#videoFrame").attr('src', url);
                });
            });
            </script>
            <body>
