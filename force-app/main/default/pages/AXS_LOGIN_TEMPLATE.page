<apex:page id="main" showheader="false" controller="SiteLoginController" >
    <html>
        
        <head>
            <title>axs</title>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <link rel="icon" href="./favicon.ico"/>
            
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/font-awesome/css/font-awesome.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/aos/dist/aos.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/swiper/css/swiper.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/daterangepicker/daterangepicker.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/select2/dist/css/select2.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/easy-autocomplete/dist/easy-autocomplete.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/easy-autocomplete/dist/easy-autocomplete.themes.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/chart.js/dist/Chart.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/tempusdominus-bootstrap-4/build/css/tempusdominus-bootstrap-4.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/enjoyhint.css')}" /> 
            <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/fonts/icomoon/style.css')}" />
            <!-- main css -->
            <apex:stylesheet value="{!URLFOR($Resource.assets_NUI, '/css/style.css')}" />
            
            <link id="brandCss" href="{!URLFOR($Resource.assets_NUI, '/css/brand-dmc.css')}" rel="stylesheet" type="text/css" />
            
            
        </head>
        <style>
            
            
            @media (max-width: 767.98px){
            #main_login{background-image:linear-gradient(#434b7f, #77c1ea)!important;
            }
            }
            @media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
            #main_login .site-main-content {
            /*min-height: 85vh;*/
            min-height: calc(100vh - 136px);
            }
            #main_login .site-main-content1 {
            min-height: calc(100vh - 56px);
            }
            .site-footer-wrapper{
            position:relative;
            bottom:0px;
            height:90% !important;
            }
            }

            /* VMKR - 24th Dec */
            .footer-images img {
            margin: 0px 1.6em;
            width: 6em;
            }
            .footer-images {
            text-align: left;
            padding: 0 1em;
            }
            @media (min-width: 576px){
                
                /* VMKR - 12th Jan */
                .panel.panel-login1 {
                border-radius: 3rem;
                margin-left: 40%;
                width: 56% !important;
                }
                .site-footer {
                padding:1rem !important;
                }
                .panel-login {
                width: 50% !important;
                }
            .login-brand{width:70% !important;}
            }
        </style>
        <script type="text/javascript">
        var tempValue ='';
        tempValue = '{!$CurrentPage.parameters.c}';
        var brands = ['diac','dic','dic2','dkp','dmc','doc','dpc','dsp','dsc','ddd','dia'];
        var brandLogoSrc="{!URLFOR($Resource.assets_NUI, '/images/brands/diac.jpg')}";
        var images = [];
        var websites = {'dmc':'https://dmc.ae/','dsc':'https://www.dsc.gov.ae/','dia':'https://www.diadubai.com/','dic':'https://dic.ae/','dic2':'https://dubaiindustrialcity.ae/','doc':'https://dubaioutsourcecity.ae/','dpc':'https://dpc.ae/','dkp':'https://dkp.ae/','ddd':'https://www.dubaidesigndistrict.com/','dsp':'https://dsp.ae/','in5':'https://infive.ae/'};
        function loginClick(e){
            var bg = $(e).css('background-image');
            if(tempValue=='')
                return;// not clicking for common page
            window.open(websites[tempValue],'_blank');
        }
        function preload() {
            for (i =0; i<preload.arguments.length; i++) {
                images[i] = new Image();
                images[i].src = preload.arguments[i];
            }
        }
        $("link.user").each(function(){
            var h = $(this).attr('href');
            if(h.indexOf('style')<0)
                $(this).attr('disabled','disabled');
        });
        var cssLink = $('#brandCss').attr('href').replace('brand-dmc','brand-'+tempValue);
        $('#brandCss').attr('href',cssLink);
        $(document).ready(function(){
            if (!String.prototype.includes) {
                String.prototype.includes = function() {
                    return String.prototype.indexOf.apply(this, arguments) !== -1;
                };
            }
            tempValue = '{!$CurrentPage.parameters.c}';
            var url;
            var logUrl;
            if(tempValue!=''){
                //brandLogoSrc = ['ddd','dsc','dia'].includes(tempValue)?"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".png')}":"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".jpg')}";
                if(tempValue!='dmc')
                    url= "url('"+"{!URLFOR($Resource.assets_NUI, '/images/brands/header/"+tempValue+"headerbg.jpg')}"+"')";
                //else
                //  url= "url('"+"{!URLFOR($Resource.assets_NUI, '/images/full-bg.jpg')}"+"')";
                logUrl = "url('"+"{!URLFOR($Resource.assets_NUI, '/images/brands/"+tempValue+".png')}"+"')";
                //$('#main_login').css('background-image',url);
                $('.login-brand').css('background-image',logUrl);
            }
        });
        function getUrlParameter(key){
            var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
            return (res==undefined)?'':res[1];
        }
        </script>
        <apex:form >
            <!--<apex:inputHidden value="{!CurrentPage.parameters.brand}" id="brandVal"/>-->
            <body>
                
                <div id="main_login" style="background-image:url({!URLFOR($Resource.assets_NUI, '/images/brands/header/'+$CurrentPage.parameters.c+'headerbg.jpg')})">
                    <div class="site-main-content {!IF($CurrentPage.parameters.c!='','site-main-content1','')}">
                        <div class="container">
                            
                            <div class="panel panel-login {!IF($CurrentPage.parameters.c='','panel-login1','')}">
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="login-left">
                                                <div class="login-brand" style="{!IF($CurrentPage.parameters.c!='','cursor:pointer;','display:none;')} background-image:url({!URLFOR($Resource.axs2_login_logo)})" onclick="loginClick(this)"></div>
                                                <div class="login-brand" style="{!IF($CurrentPage.parameters.c!='','display:none;','')} background-image:url({!URLFOR($Resource.axs2_login_logo)});" ></div>
                                                <div class="login-brand-shadow"></div>
                                                <div class="login-brand-2" style="{!IF($CurrentPage.parameters.c!='','','display: none;')}">
                                                    <div>POWERED BY</div>
                                                    <!--<img src="../assets/images/logo-axs.png" alt=""/>-->
                                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/logo-axs.png')}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- .col -->
                                        
                                        <div class="col-md-8">
                                            <h3 class="d-none d-lg-block d-sm-block d-xl-block">LOGIN</h3>
                                            <div class="form-group">
                                                <label>Username (Email)</label>
                                                <div class="input-group">
                                                    <div class="input-group-append"><i class="input-group-text icon-username text-primary"></i></div>
                                                    <apex:inputText styleClass="form-control input-login input-login-username text-primary" style="color: #000 !important;" value="{!username}" id="username"/>
                                                </div>
                                            </div>
                                            <!-- .form-group -->
                                            <div class="form-group">
                                                <label>Password</label>
                                                <div class="input-group">
                                                    <div class="input-group-append"><i class="input-group-text icon-password text-primary"></i></div>
                                                    <apex:inputSecret id="password" style="color: #000 !important;" value="{!password}" styleClass="form-control input-login input-login-passwword"/>
                                                </div>
                                            </div>
                                            <!-- .form-group -->
                                            
                                            <div class="d-flex mb-3">
                                                <div class="mr-3">
                                                    <label class="custom-checkbox">
                                                        <input type="checkbox"/>
                                                        <span>Remember me</span>
                                                    </label>
                                                </div>
                                                <div class="ml-auto">
                                                    <a target="_blank" href="https://axsstg-axs.cs113.force.com/secur/forgotpassword.jsp?locale=us&amp;startURL=%2Fapex%2Fgpm">Forgot Password?</a>
                                                </div>
                                            </div>
                                            <apex:commandButton action="{!login}" value="SUBMIT" style="{!IF($CurrentPage.parameters.c=='','background-color: #434b7f;border-color:#434b7f;','')}" styleClass="btn btn-primary" />
                                            <!-- .form-group -->
                                        </div>
                                        <!-- .col -->
                                    </div>
                                    <!-- .row -->
                                </div>
                                <!-- .panel-body -->
                            </div>
                            <!-- .panel-login -->
                        </div>
                        <!-- .container -->
                    </div>
                    
                    <div class="site-footer-wrapper">
                        <div class="container">
                            <div class="site-footer {!IF($CurrentPage.parameters.c='','site-footer1','')}"> 
                                <div class="footerImg d-none d-lg-block d-xl-block" style="{!IF($CurrentPage.parameters.c!='','display:none !important;','')}">
                                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                                    <img src="{!URLFOR($Resource.axs2_loginFooter)}" />
                                </div>
                                <!--<div class="footer-images d-none d-lg-block d-xl-block" style="{!IF($CurrentPage.parameters.c!='','display:none !important;','')}">
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dic.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/doc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dmc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dsc.png')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dpc.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dkp.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/diac.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/dsp.jpg')}" />
                                    <img src="{!URLFOR($Resource.assets_NUI, '/images/brands/ddd.png')}" />
                                </div>-->
                                <div class="footer-links">
                                    <a href="/grqerAboutUS" target="_blank">ABOUT axs</a> |
                                    <a href="/grqerContactUs" target="_blank">CONTACT US</a> |
                                    <a href="/grqerTerms" target="_blank">TERMS OF USAGE </a> |
                                    <a href="/grqerPolicy" target="_blank">PRIVACY POLICY</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- .site-footer-wrapper -->
                </div>
                
                <!-- Vendor js -->
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/>
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/bootstrap/dist/js/bootstrap.bundle.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/aos/dist/aos.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/swiper/js/swiper.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/moment/min/moment.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/daterangepicker/daterangepicker.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/select2/dist/js/select2.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/easy-autocomplete/dist/jquery.easy-autocomplete.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/chart.js/dist/Chart.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/tempusdominus-bootstrap-4/build/js/tempusdominus-bootstrap-4.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/tablesorter/dist/js/jquery.tablesorter.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery.scrollto/jquery.scrollTo.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/kinetic.min.js')}"  />
                <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/enjoyhint/enjoyhint.min.js')}"  />
                
                <!-- main js -->
                <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js?v=2.0.13')}"  />
                
            </body>
        </apex:form>
    </html>
</apex:page>