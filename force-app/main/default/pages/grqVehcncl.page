function shwEng(blAll){
    blAllEng=blAll;
    getC(sEng).style.display='';
    var tbl = getC(sEng).getElementsByTagName('table')[0];
    var rows = tbl.getElementsByTagName('tr');
    if(!blAll){
        if(rows.length>1){rows[1].style.display='none';}        
        var cs = rows[0].getElementsByTagName('td');
        for (var c=1; c<cs.length;c++) {
            for(var i=0; i<cs[c].childNodes.length; i++) {
                cs[c].childNodes[i].style.display='none';
            }
        }
        cs = rows[0].getElementsByTagName('th');
        for (var c=1; c<cs.length;c++) {
            for(var i=0; i<cs[c].childNodes.length; i++) {
                cs[c].childNodes[i].style.display='none';
            }
        }
    } else {
        if(rows.length>1){rows[1].style.display='';}
        var cs = rows[0].getElementsByTagName('td');
        for (var c=1; c<cs.length;c++) {
            for(var i=0; i<cs[c].childNodes.length; i++) {
                cs[c].childNodes[i].style.display='';
            }
        }
        cs = rows[0].getElementsByTagName('th');
        for (var c=1; c<cs.length;c++) {
            for(var i=0; i<cs[c].childNodes.length; i++) {
                cs[c].childNodes[i].style.display='';
            }
        }
    }
}
function displayFields(){ 
    if(!{!pgHide}&&!{!md.isView}){
        fldErr('xvn__c',null,!0);fldErr('xvtyp__c',null,!0);fldErr('xvbr__c',null,!0);fldErr('xvch__c',null,!0);
        fldErr('xbtnm__c',null,!0);fldErr('xbdt__c',null,!0);fldErr('xcst__c',null,!0);fldErr('xln__c',null,!0);fldErr('xwdt__c',null,!0);
        fldErr('xeng__c',null,!0);fldErr('xengt__c',null,!0);fldErr('xneng__c',null,!0);fldErr('xengp__c',null,!0);
        fldErr('xvown__c',null,!0);fldErr('xtr2__c',null,!0);
    }
    blAllEng=false;getC(sBoat).style.display='none';getC(sV).style.display='none';getC(sEng).style.display='none';getC(sTrnsfr).style.display='none';
    if(lf=='Boat Registration'||lf=='Boat Registration Personal' || lf=='Selling or Purchasing Boat'){
        getC(sBoat).style.display='';
        shwEng(true);       
    }
    else if(lf=='RTA Vehicle Sale Boat'){
        getC(sBoat).style.display='';
        shwEng(true);
        getC(sTrnsfr).style.display='';
    }
    else if(lf=='RTA Commercial Vehicle New'||lf=='RTA Commercial Vehicle Renewal'||lf=='RTA Heavy Vehicle New / Renewal'|| lf=='RTA Heavy Vehicle New'||lf=='RTA Heavy Vehicle Renewal'||lf=='RTA Light Vehicle New'||lf=='RTA Light Vehicle Renewal' || lf=='RTA Light Vehicle New / Renewal' ||lf=='RTA Vehicle Export'|| lf=='RTA Bike Registration New / Renewal' ||lf=='RTA Bike Registration New'||lf=='RTA Bike Registration Renewal'){
        getC(sV).style.display='';
        shwEng(false);
    }
    else if(lf=='RTA Vehicle Sale'||lf=='RTA Vehicle Sale Bus'||lf=='RTA Vehicle Sale Bike'||lf=='RTA Vehicle Sale Truck'||lf=='RTA Vehicle Transfer'||lf=='RTA Vehicle Transfer Bus'||lf=='RTA Vehicle Transfer Bike'||lf=='RTA Vehicle Transfer Truck'){
        getC(sV).style.display='';
        shwEng(false);
        getC(sTrnsfr).style.display='';
        
    }   
    
    shlvp(lf);
   
    ltrToHide(la2);
}
