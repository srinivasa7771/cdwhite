    if(""==lf||"__"==lf)fldErr("xltr__c","Value is required",!0),brq=!0;
    if(af=="Others" && (aO=="" || (aO.lenght<=0)) )fldErr("xltr_Others__c","Value is required",!0),brq=!0;
    1<cs['xla2__c'].options.length&&(""==af||"__"==af)&&(fldErr("xla2__c","Value is required",!0),brq=!0);
    1<cs['xla2d__c'].options.length&&(""==adf||"__"==adf)&&(fldErr("xla2__c","Value is required",!0),brq=!0);
