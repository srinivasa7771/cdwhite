    if(lf=="RTA Driving License New / Renewal" || lf=="RTA Driving License New" || lf=="RTA Driving License New Bike" ||lf=="RTA Driving License Renewal" ||lf=="RTA Driving License Renewal Bike" ){
brq=fldReq('xltp__c',cs)||brq;
