                function uploadDoc(docname,parseFlg,rqFlg){
                    currentDoc = docname;
                    if(rqFlg == 'true' && ('{!sd.cv__c}' == 'NewVisa' || '{!sd.cv__c}' == 'Visa' || '{!sd.cv__c}' == 'StuNewVisa' || '{!sd.cv__c}' == 'VisaCorrection' || '{!sd.cv__c}' == 'DepNewCmp' || '{!sd.cv__c}' == 'VisitVisa' || '{!sd.cv__c}' == 'VisitVisaM' || '{!sd.cv__c}' == 'DepTransferCmp' || '{!sd.cv__c}' == 'DepRenewal' || '{!sd.cv__c}' == 'LostPassport' || '{!sd.cv__c}' == 'DepInsCmp')){
                        
                        var msg = ''; 
                        var srvId = $('[name="service_id"]:checked').val(); 
                        
                        if ( typeof srvId === "undefined" || srvId == "") {
                            msg = msg + 'Please select Service Type'
                        }
                        
                        if(msg != ''){
                            axsAlert('Alert',msg);
                            return false;
                        }
                        cs['xadh__c'].value  += 'md;';
                        cs["srvc__c"].value = srvId;
                        
                    }
                    '{!sd.cv__c}' == 'NewVisa'
                    var healthinsurance = $('input[name="healthinsurance"]:checked').length > 0;
                    if(healthinsurance)
                        cs['InsChk__c'].value = true;
                    // alert( cs['xadh__c'].value );
                    cs["docname"].value = docname;cs["parseId"].value = parseFlg; 
                    $(".docname").text(docname);
                    if(cs["visaTransferId"].value == 'int')
                        cs["parseId"].value = 'false';
                    if(rqFlg == 'true' && ('{!sd.cv__c}' == 'DepRenewal' || '{!sd.cv__c}' == 'CancelVisaDep') && (cs['Con__c'].value == 'undefined' ||  cs['Con__c'].value == ''))
                        cs["parseId"].value = 'true';
                    
                    $('#modal_fileuploadPopUp').modal('show');
                }
                
                function formatDate(date){
                    var d = date.split('/');
                    var dd = new Date();
                    dd.setFullYear(d[2], (parseInt(d[0]))-1, d[1]);
                    console.log(dd);
                    return dd;
                }
                
                function formatDate2(date){
                    let d = date.split('/');
                    let dd = d[1]+'/'+d[0]+'/'+d[2];
                    return dd;
                }
                
                function chkVisaValidity(dt){
                    var days = (new Date(formatDate2(dt))-new Date())/1000/60/60/24;
                    if(days>=90)
                        return true;
                    return false;
                }  
                
                function visaValidityChange(){
                    var isvisaBtn = $('#verify_visa_details_button').is(':visible');
                    if(!isvisaBtn) 
                        $('#verify_visa_details_button').trigger('click');
                }
                
                function removeAttch1(attchid,docName){
                    $('[forLoad="'+docName+'"]').find('.loader_img').show();
                    $('*').addClass('loadingProgress');
                    removeAttch(attchid);
                }
                
                function filePreview(fName,src){
                    console.log('In filePreview>>'+fName);
                    fileSrc=document.getElementById("{!$Component.fileSrc}");
                    fileSrc.value=src;
                    document.getElementById("mdHeader").innerHTML = fName;
                    document.getElementById("previewDiv").src = src;
                    //$('#modal_vfs').modal('show');
                    window.open(src, '_blank');
                }
                
                function backpg(){
                    $('#srv_id_page').show();
                    $('#doc_details').hide(); 
                    //$('#srvdecid').show();
                    //$('#srvdecdocid').hide(); 
                    $('.noOnDocs').show();
                    $('.docDef').hide();
                    $('.srvTitle').text('ABOUT THIS SERVICE'); 
                    $('.messageTable').remove();
                    $('#btn_id').hide();
                    
                    $('.flCheck').each(function(){
                        var sfFld = $(this).attr('sfField');
                        var isfldChk = false;
                        if(cs[sfFld].value=='true' || cs[sfFld].value==true){
                            isfldChk = true;
                        }
                        $(this).prop('checked',isfldChk);
                    });
                }
                
                function depTypeSelect(e){
                    if($('#depTypeId').val()!='Select'){
                        $('#depTypeId').parents('.form-group').find('.frmErrMsg').remove();
                    }
                    // to skip age validation on DOB for dependent cancellation
                    cs["uid"].value = 'onlyPast';
                    //
                    cs["xcsrs__c"].value=$(e).val() ;
                }
                
                function depSelect(e){
                    if($('#depSelId').val()!='Select'){
                        $('#depSelId').parents('.form-group').find('.frmErrMsg').remove();
                    }
                    
                    cs["xard__c"].value=false;
                    if('{!sd.cv__c}' == 'CancelVisaDep'){
                        $('.depType').hide();
                        
                        if($(e).val() != null && $(e).val() != '' && $(e).val() != 'Add')
                            cs['Con__c'].value =$(e).val();
                        else{
                            cs['Con__c'].value = ''; cs["xard__c"].value=true;
                            $('.depType').show();
                        }
                    }
                    else if( '{!sd.cv__c}' == 'DepInsCmp'){
                        $('.depType').hide();
                        
                        if($(e).val() != null && $(e).val() != '' && $(e).val() != 'Add'){
                            cs['Con__c'].value =$(e).val();
                            // saveRequest('true','lp',); 
                            cs['xadh__c'].value='inr';
                            toggleGLoader();saveRequest2();
                        }
                        else{
                            cs['Con__c'].value = ''; cs["xard__c"].value=true;
                            $('.depType').show();
                        }
                    }
                        else{
                            $('.depSrv').show(); 
                            var lst = $(e).val().split("_");
                            if(lst[0] == 'Spouse'){
                                cs['Con__c'].value = lst[1];
                                $('.vSpouse').show();$('.vChild').hide();$('.srvNew').show();$('.srvTransfers').hide();
                            }
                            else if(lst[0] == 'Child'){
                                cs['Con__c'].value = lst[1];
                                $('.vChild').show();$('.vSpouse').hide();$('.srvNew').hide();$('.srvTransfers').show();
                            }
                                else{
                                    cs['Con__c'].value = ''; cs["xard__c"].value=true;
                                    $('.vChild').show();$('.vSpouse').show();$('.srvNew').show();
                                }
                        }
                }
                
                function copyDepInfo(){
                    if('{!sd.cv__c}' == 'LostPassport'){
                        console.log('Spr1:'+cs["Spr__c"].value);
                        cs["Spr1__c"].value = cs["Spr__c"].value;
                    }
                    copyDepDtls();
                }
                
