                <apex:outputPanel id="validateVisaId">
                    <script>
                    function updateDepList(){
                        cs['xadh__c'].value  += 'inr;'
                        console.log('inside updateDepList');
                        $('.deplist').show();
                        var depListStr = {};
                        depSel = document.getElementById('depSelId');
                        $('#depSelId option').remove();
                        $('#depSelId').append(new Option('Select', 'Select'));
                        if('{!depListStr}' != ''){
                            depListStr = JSON.parse('{!depListStr}');
                            for(var x=0;x<depListStr.length;x++){
                                var dep = depListStr[x];    
                                myOption = document.createElement("option");
                                myOption.text = dep.Name;
                                if('{!sd.cv__c}' == 'DepRenewal')
                                    myOption.value = dep.rol__c+'_'+dep.Id;
                                else
                                    myOption.value = dep.Id;  
                                depSel.appendChild(myOption);
                            }
                        }
                        myOption = document.createElement("option");
                        myOption.text = 'Add new dependent';
                        myOption.value = 'Add';
                        depSel.appendChild(myOption);
                    }
                    
                    function displayService(){
                        var isValidVisa = '{!isVisaTransfer}';
                        $('#verify_visa_details').show(); 
                        $('#priority_id').show();
                        var isIncountryChecked = $('input[name="incountry"]:checked').length > 0;
                        var visa=$('.radio-visa:checked').val(); 
                        console.log('visa#######'+visa);
                        $('#ofl').hide(); $('#inc').show();
                        
                        var v1= $('#visa1').val();  var v2= $('#visa2').val(); var v3= $('#visa3').val();
                        if(isValidVisa == 'n'){
                            $('#vmsg').show();
                        } else{
                            $('#vmsg').hide();
                        }
                        if(isValidVisa == 'int' && visa=='yes'){
                            
                            $('.srvNew').hide();$('.vNew').hide();
                            $('.srvTransfers').show(); $('.vTransfers').hide(); 
                            $('.vIntTransfers').show(); 
                            cs["visaTransferId"].value = 'int';
                            cs["xeidav__c"].value = 'Yes';
                            $('#inc').show();
                        } else if(v1 == '201' && v3.substring(0, 1) == '7' && validVisa && visa=='yes' && isValidVisa != 'n'){
                            
                            $('.srvNew').hide();$('.vNew').hide();
                            $('.srvTransfers').show(); $('.vTransfers').show(); 
                            $('.vIntTransfers').hide(); 
                            cs["xeidav__c"].value = 'Yes';
                            cs["visaTransferId"].value = 'y'; $('#inc').show();
                        } else{
                            cs["xeidav__c"].value = 'No';
                            $('.srvNew').show();$('.vNew').show();
                            $('.srvTransfers').hide(); $('.vTransfers').hide(); 
                            $('.vIntTransfers').hide(); 
                            if(v1 != '204')
                                $('#ofl').show();
                        }    
                        
                        
                    }  
                    </script>
