                var MEorOA=''; // for multi entry and on arrival
                function checkArrivalDate(){
                    var date1 = $('#datepicker1').val();
                    var date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
                    var days = new Date(new Date()-new Date(date))/1000/60/60/24;
                    $('#datepicker1').parents('.form-group').find('.frmErrMsg,.serErr').remove();
                    if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                        $('#datepicker1').parents('.form-group').append('<div class="frmErrMsg">Invalid Date type!</div>');
                        return false;
                    }
                    if(MEorOA == 'convert to multi-'){
                        if(days<0||days>7){
                            $('#datepicker1').parents('.form-group').append('<div class="frmErrMsg">Service has to be applied within 7 days from Arrival!</div>');
                            return false;
                        }
                    }
                    else if(MEorOA=='extend visa'){
                        if(days<23||days>30){
                            $('#datepicker1').parents('.form-group').append('<div class="frmErrMsg">Service has to be applied within 7 days of Expiry!</div>');
                            return false;
                        }
                    }
                    return true;
                }
                $('.serRadio').on('change',function(){
                    $(this).parent().parent().parent().parent().find('.serErr').hide();
                    if(cs['Con__c'] != undefined && cs['Con__c'].value == ''){
                        $('#contactLookup').parent().find('.serErr').show()
                        return;
                    }
                });
