                <script>
                var checked1=false;
                (function ($) {
                    $(function () {
                        $('.radio-visa').change(function () {
                            $('#doc_details').hide();
                            $('#btn_id').hide();
                            if('{!sd.cv__c}' == 'NewVisa')
                                $('#priority_id').hide();
                            
                            if ($('.radio-visa:checked').val() === 'yes') {
                                $('#verify_visa_details_button').show();
                                $('#verify_visa_details').hide();
                                
                                $('#visa_file_number').show();
                                $('[name="incountry"]').prop('checked',true);
                                
                            } else if ($('.radio-visa:checked').val() === 'no') {
                                $('#verify_visa_details').show();
                                
                                $('#priority_id').show();
                                $('#visa_file_number').hide(); 
                                $('.srvNew').show();
                                $('.vNew').show();
                                $('.srvTransfers').hide();
                                $('.vTransfers').hide();
                                $('.vIntTransfers').hide();
                                $('[name="incountry"]').prop('checked',false);
                            }
                        });
                        if('{!sd.cv__c}' == 'NewVisa')
                            $('.radio-visa').trigger('change');
                        if('{!sd.cv__c}' == 'LostPassport')
                            $('#priority_id').hide();
                        $('.sponsoredby').change(function () {
                            if ($('.sponsoredby:checked').val() === 'Husband or Father') {
                                $('.srvNew').show(); $('.srvTransfers').hide();
                            }
                            else if($('.sponsoredby:checked').val() === 'Parent Company'){
                                $('.srvTransfers').show(); $('.srvNew').hide();
                            }
                        });   
                        $('.service_id').change(function () { 
                            if('{!sd.cv__c}' == 'DepRenewal'){
                                var depType = $('[name="service_id"]:checked').attr('att1');
                                if(depType != null && depType == 'Child'){
                                    cs["visaTransferId"].value = 'y';  cs["uid"].value = '017';
                                    $('.srvNew').hide();$('.srvTransfers').show();
                                }
                                else{
                                    cs["visaTransferId"].value = '';
                                    $('.srvNew').show();$('.srvTransfers').hide();
                                }
                                if(cs['Con__c'].value != 'undefined'  && cs['Con__c'].value != '')
                                {
                                    copyApplicantInfo();
                                }
                            }
                            if('{!sd.cv__c}' == 'VisaRenewal' || '{!sd.cv__c}' == 'VisaCorrection' || '{!sd.cv__c}' == 'DocAttestation' || '{!sd.cv__c}'=='updateAttr'){
                                if(cs['Con__c'] != undefined && cs['Con__c'].value != '')
                                {
                                    var docAttType = $('[name="service_id"]:checked').attr('att1');
                                    if(docAttType != null && docAttType == 'Employee Contract')
                                        cs["visaTransferId"].value = 'y';
                                    copyApplicantInfo();
                                }else{
                                    $('.service_id').prop('checked',false);
                                }
                            }
                        });
                        
                        
                        
                        $('input[name=insideUAE]').change(function () {
                            if($('.conLkp').is(':visible') &&'{!sd.vtyp__c}' != 'DepRen' && '{!sd.cv__c}' != 'CancelVisaDep' && cs['Con__c'] && cs['Con__c'].value==''){
                                $('.conLkp').find('.frmErrMsg1').html('Please select an applicant.').show();
                                $('[name="insideUAE"]').prop('checked',false);
                                return;
                            }
                            if ($(this).val() === 'NO') {
                                $('#insideUAE').show();
                            } else {
                                $('#insideUAE').hide();
                                //copyCancelApplicantInfo();
                            }
                            if (cs['xadh__c'] != null) {
                                var adh = cs['xadh__c'].value;
                                if ($(this).val() === 'YES') {
                                    cs['xadh__c'].value = adh.replace('rpc;', '').replace('ip;', '');
                                    if('{!sd.cv__c}' == 'CancelVisaDep'){cs['xadh__c'].value = adh.replace('oua;', '').replace('oup;', '');}
                                    if (!adh.includes('ins;')){ 
                                        cs['xadh__c'].value += 'ins;';
                                    }
                                    
                                }
                                else{
                                    cs['xadh__c'].value = adh.replace('ins;', ''); 
                                    if (!adh.includes('rpc;'))                                     
                                        cs['xadh__c'].value += 'rpc;';
                                    if (!adh.includes('ip;'))                                     
                                        cs['xadh__c'].value += 'ip;';
                                    
                                    if('{!sd.cv__c}' == 'CancelVisaDep'){cs['xadh__c'].value ='oup;';}
                                }
                            }
                            if(cs['Con__c'] && cs['Con__c'].value !='')
                                copyCancelApplicantInfo();
                        });
                        $('#insideUAE').change(function () { 
                            if (cs['xadh__c'] != null) {
                                var adh = cs['xadh__c'].value;
                                var isPassportAvailable = $('input[name="passport_available"]:checked').length > 0;
                                if (isPassportAvailable) {
                                    cs['xadh__c'].value = adh.replace('rpc;', '').replace('ip;', ''); 
                                    if('{!sd.cv__c}' == 'CancelVisaDep'){cs['xadh__c'].value = adh.replace('oup;', '')}
                                    if (!adh.includes('oua;'))                                     
                                        cs['xadh__c'].value += 'oua;';
                                    
                                }
                                else{
                                    cs['xadh__c'].value = adh.replace('oua;', ''); 
                                    if (!adh.includes('rpc;'))                                     
                                        cs['xadh__c'].value += 'rpc;';
                                    if (!adh.includes('ip;'))                                     
                                        cs['xadh__c'].value += 'ip;';
                                    
                                    if('{!sd.cv__c}' == 'CancelVisaDep'){cs['xadh__c'].value ='oup';}
                                }
                                
                            }
                            
                        });  
                        
                        
                        
                        $('#imgdeposit').change(function () { 
                            
                            var isimgdp = $('input[name="imgdeposit"]:checked').length > 0;
                            if(isimgdp)
                                $('#dpnoid').show(); 
                            else
                                $('#dpnoid').hide();
                        }); 
                        $('#rcid').change(function () { 
                            var rpcardFlg = $('input[name="rpcard"]:checked').length > 0;
                            var adh = cs['xadh__c'].value;
                            if(rpcardFlg){
                                adh = adh + 'xpc;';
                            }
                            else{
                                adh.replace('xpc;', '');
                            }
                            cs['xadh__c'].value =adh; 
                        });
                        $('#inc').change(function () { 
                            var isIncountryChecked = $('input[name="incountry"]:checked').length > 0;
                            var visaNum = cs["e__c"].value;
                            if('{!sd.cv__c}' == 'NewVisa'){
                                if(isIncountryChecked){
                                    $('#visa_file_number').show();
                                    $('#priority_id').hide();
                                    $('#verify_visa_details').hide();
                                    
                                }
                                else{
                                    $('#visa_file_number').hide(); 
                                    $('#priority_id').show(); $('#verify_visa_details').show();
                                }
                            }  
                            if(isIncountryChecked && ('{!srv.uid__c}' == '001' || '{!srv.uid__c}' == '002' || '{!srv.uid__c}' == '020' || '{!srv.uid__c}' == '021' || '{!srv.uid__c}' == '040' ||  '{!srv.uid__c}' == '078'))
                                $('#ofl').show(); 
                            else
                                $('#ofl').hide();
                            var isvisaBtn = $('#verify_visa_details_button').is(':visible');
                            if(!isvisaBtn && visaNum != '') 
                                $('#verify_visa_details_button').trigger('click');
                        });
                        $('.service_id').on('change',function(){
                            $(this).parent().parent().parent().parent().find('.serErr').hide();
                        })
                        
                        $('#upload_button').click(function (ev) {//
                            console.log('upload button::::');
                            
                            if($('.conLkp').is(':visible') &&'{!sd.vtyp__c}' != 'DepRen' && cs['Con__c'] && cs['Con__c'].value==''){
                                $('.conLkp').find('.frmErrMsg1').html('Please select an applicant.').show();
                                return;
                            }
                            if($('.spnLkp').is(':visible') && cs['xcsp__c'] && cs['xcsp__c'].value == ''&& '{!sd.vtyp__c}' != 'DepRen' && '{!sd.cv__c}' != 'CancelVisaDep'){
                                $('.spnLkp').find('.frmErrMsg').html('Please select an employee.').show();
                                return;
                            }/*else  if(!$("input[name='relationship']").is(':checked')){
                                console.log('please select the option::::');
                                axsAlert('Alert','Please select an option'); return false;
                            }*/else{
                                $('.spnLkp').find('.frmErrMsg').hide();
                            }
                            if($('#depSelId').val()=='Select'){
                                addValError('#depSelId','Please choose an option.');
                            }
                            $('.serRadio').each(function(){
                                if($(this).prop('checked'))
                                    checked1= true;
                            });
                            if($('.serRadio').length>0 && !checked1 && '{!sd.vtyp__c}' != 'EmpIns'){
                                $('.serRadio').parent().parent().parent().parent().find('.serErr').show();
                                return;
                            }
                            if('{!sd.cv__c}'  == 'NewVisa' && $('[name="service_id"]:checked').val()==undefined){
                                $('[name="service_id"]').parent().parent().parent().parent().find('.serErr').show();
                                return;
                            }
                            if($('.messageCell').is(':visible')){
                                errMsgScroll();
                                return;
                            }
                            if('{!sd.cv__c}' == 'LostPassport' ){
                                if($('#conSerachVal').val()=='' && $('#spnSerachVal').val()==''){
                                    axsAlert('Alert','Please select applicant'); return false;
                                }
                                /*if($('#spnSerachVal').val()!='' && $('#depSelId').val()=='Select'){
                                    
                                    axsAlert('Alert','Please select dependent'); return false;
                                }*/ // Changed on 19 Dec -- VMKR
                                if( $('#depSelId').val()=='Add'){
                                    $('.srvTransfers').hide();
                                }
                                
                                
                                if(!$( ".lostpassport" ).prop( "value", 'no').is(":checked") && !$( ".lostpassport" ).prop( "value", 'yes').is(":checked")){
                                    axsAlert('Alert','Please select where your passport has been lost.'); return false;
                                }
                                
                            }
                            if('{!sd.cv__c}' == 'DepTransferCmp' && checkVisaValidity() == false){
                                errMsgScroll();
                                return ;
                            }
                            if('{!sd.cv__c}' == 'VisitVisaM' && checkArrivalDate()==false){
                                errMsgScroll();
                                return ;
                            }
                            
                            if('{!sd.cv__c}' == 'VisaCorrection' && '{!sd.Sub_Category__c}' != 'Renewals' && $('input[name="amendvisa"]:checked').length == 0){
                                console.log('No change selected:::::');
                                $('[name="amendvisa"]').parent().parent().parent().parent().find('.frmErrMsg1').show();
                                
                                return;
                            }
                            else{
                                if(serviceId=='050' || serviceId=='051' || serviceId=='052' || serviceId=='053'){
                                    toggleGLoader();nextPgValidate(true); saveRequest2();
                                }
                                
                                if(serviceId=='uae'){ //for update attributes
                                    var selectedAtr = cs["xadh__c"].value;
                                    if(!selectedAtr.includes('sd;') && !selectedAtr.includes('ci;')){
                                        addValError('.frmErrMsg1','Please choose an option.');
                                        return;
                                    }
                                    toggleGLoader(); saveRequest2();
                                }
                                
                            }
                            
