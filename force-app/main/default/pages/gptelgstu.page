        hideTempLoader_input();
        $('[val1="'+selectedFlag+'"]').attr('selected',true);
        /* code to fix Search icon rerender issue starts */
        $('.srchDiv button').next().find('button').remove();
        var x = $('.srchDiv button').next();
        $('.srchDiv button').next().remove();
        $('.srchDiv button').append(x);
        $('select').select2();
        /* code to fix Search icon rerender issue ends */
        hideGLoader();
        $(tableId).find('tbody').html('');
        //$(tableId).DataTable().destroy()
        var tData = JSON.parse(dataStr);
        data_m = tData;
        var tableData = '';
        //for ([ind, val]  of data.entries()) {
        for (var ind=0;ind<tData.length;ind++) {
            var val = tData[ind];
