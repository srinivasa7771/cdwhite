    function changeDate(elem) {
        var e = $(elem);
        var vn = $(elem).attr('validationname');        
        var date2;
        if(vn=='pid') {
            date1 = e.val();// start date
            date =  date1.split('/')[2]+'/'+date1.split('/')[1]+'/'+date1.split('/')[0];
        }
        if(vn=='ped') {
            edate = e.val();//end date
            edate1 =  edate.split('/')[2]+'/'+edate.split('/')[1]+'/'+edate.split('/')[0];
        }
        date2 = visaExpiryDate.split('-')[0]+'/'+visaExpiryDate.split('-')[1]+'/'+visaExpiryDate.split('-')[2];// visa expiry date      
        console.log('End date--'+edate1);
        console.log('Start date--'+date);
        console.log('End date1--'+edate);
        console.log('Start date1--'+date1);
        var days = new Date(new Date(edate1)-new Date(date))/1000/60/60/24;
        console.log('--days----'+days);
        console.log('----sd'+new Date(date2) < new Date(date));
        console.log('----ed'+new Date(date) > new Date(edate1));
        if(days<30){
        addValError('#xrped__c','Duration should be a minimum of 30 days');
        }else{
            removeValError('#xrped__c');
        }
        
        if(new Date(date) > new Date(edate1)){
            console.log('ERROR');
            addValError('#xrpid__c','Start Date should be a less than end date');
        } else {
            removeValError('#xrpid__c');
         }
        if(vn=='pid'){
            if(new Date(date2) < new Date(date)) {
                addValError('#xrpid__c','Start Date should not be more than visa expiry date');  
            } 
            else if(new Date(date) <= new Date()){
                addValError('#xrpid__c','Start Date should be a future date');  
            } 
                else {
                    removeValError('#xrpid__c');
                }
        }
        else if(vn=='ped'){
            if(new Date(date2) < new Date(edate1)) {
                addValError('#xrped__c','End Date should not be more than visa expiry date');  
            }
            else if(new Date(edate1) <= new Date()){
                addValError('#xrped__c','End Date should be a future date');  
            } 
                else {
                    removeValError('#xrped__c');
                }
        }
    }
    
