    function callOffer1(){
        var validated = true;
        // addValError(cs['ofr_StuHrs'],'Maximum allowed working haours are 40!');
        //addValError(cs['xrpid__c'],'Error!');   
        $('.requiredFld').each(function(){
            let v = $(this).val();
            if(!v){
                addValError($(this),'This field required!');
                validated = false;
            }
            //else
            //  removeValError($(this));
        });
        if(cs['ofr_StuHrs'].value>40 || cs['ofr_StuHrs'].value<=0 ){
            addValError(cs['ofr_StuHrs'],'Allowed hours should be greater than 0 and less than or equal to 40');
            return;
        }
       
        else if(cs['ofr_StuHrs'].value){
            removeValError(cs['ofr_StuHrs']);
            }
        /*  if(cs['ofr_StuHrs'].value>40){
            addValError(cs['ofr_StuHrs'],'Value cannot be more than 40!');
            return;
        }
        else
            removeValError(cs['ofr_StuHrs']);*/
        if($('.frmErrMsg').is(':visible')){
        return;
        }
        if(!$('#tANDc').prop('checked')){
            $('.chk').find('.frmErrMsg').remove();
            var errElem = '<div class="frmErrMsg">Please select Terms and Conditions.</div>';
            $('.chk').append(errElem);
            scrollToDiv($('.chk'));
            return;
        }
        cs['ofrDuration'].value=$('#xrpid__c').val();
        cs['endDate'].value=$('#xrped__c').val();
        showGLoader();$('#modal_StuOffer').modal('hide');
        callOffer();
    }
    function canOfr(conId,conName){
        var d = JSON.parse($('#'+conId).attr('str'));
        $('#modal_StuCanOffer .modalFlds').each(function(){
            let f = $(this).attr('field');
            console.log(f);
            if(f!='Account.Name')
                $(this).val(d[f]);
            else
                $(this).val(d.Account.Name);
        });
        cs['can_Sturmrks'].value = '';
        cs['can_StuRat'].value = '';
        cs['can_StuID'].value = d.Id;
        $('#modal_StuCanOffer').modal('show');
        //axsConfirmation('Please confirm','Are you sure to cancell permit for '+conName,false,'canOfr1',conId);
    }
    function canOfr1(){
        if(!cs['can_Sturmrks'].value){
            addValError(cs['can_Sturmrks'],'Please enter a value!');
            return;
        }
        else
            removeValError(cs['can_Sturmrks']);
        if(!cs['can_StuRat'].value){
            addValError(cs['can_StuRat'],'Please enter a value!');
            return;
        }
        else if(cs['can_StuRat'].value>10){
            addValError(cs['can_StuRat'],'Rating should not be greater than 10!');
            return;
        }else
            removeValError(cs['can_StuRat']);
        showGLoader();$('#modal_StuCanOffer').modal('hide');
        cancelOfr();
    }
