    function imgError(elem,g){
        elem.onerror = "";
        var gen = (g=="Female")?g:"Male";
        elem.src = "./resource/assets_NUI/images/"+gen+"-Default.png";
        return true;
    }    
    function showTempLoader_select(e){
        $(e).parent().find('.select2-selection--single').addClass('tempLoader_input');
        setTimeout(function(){
            $('*').addClass('loadingProgress');
        },400);
    }
    var dTableSearch;
    var newSearch;
    function tableSearch(){
        dTableSearch  = $('#reqTable').DataTable();
        newSearch ='';
        $('.filters').each(function(){
            let dTableSearchStr_temp = '';
            let type=$(this).attr('type');
            let searchStr = $(this).val();
            let colIndex = $(this).attr('colIndex');
            if(searchStr){
                if($(this).is('input')){
                    if(searchStr && searchStr.length<3)
                        return;
                    newSearch += '.column('+colIndex+').search(\''+searchStr+'\',false,false,true)';
                    dTableSearch.column(colIndex).search(searchStr,false,false,true);
                }
                else{
                    searchStr = (searchStr.toLowerCase().includes('all'))?'':searchStr;
                    newSearch += '.column('+colIndex+').search(\''+searchStr+'\',false,true,false)';
                    dTableSearch.column(colIndex).search(''+searchStr,false,true,false);
                }
            }
        });
        dTableSearch.draw();
        console.log(newSearch);
    }
    
    
    /******* Datatable code starts -- VMKR *******/
    
    
