    function valDates(fldId,type) { 
        // fldErr('xcpid__c', null, !0);fldErr('xcped__c', null, !0);
        
        var stDate = cs[fldId].value; var splitDt = stDate.split("/");
        if (splitDt != "" && splitDt.length == 3) {stDate = splitDt[2] + '-' + splitDt[1] + '-' + splitDt[0];}
        
        var date = new Date(); var today1 = date.getTime();
        stDate = new Date(stDate).getTime();
        
        if(type=='future'){
            if(stDate > today1){ return false; } // should not be future date
        }else if(type=='past'){
            if(stDate < today1){ return false; } // should not be past date
        }
        
        
        return true;  
    }
    
    
    
