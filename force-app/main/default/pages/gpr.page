<script type="text/javascript">    
   var previousOnload = window.onload;        
   window.onload = function() { 
       if (previousOnload) { 
           previousOnload();
       }
       init();
   }
   
   function init() {
       $("[id$=fdateAD]").parent().hide();$("[id$=fdateADlbl]").hide();       
       $("[id$=tdateAD]").parent().hide();$("[id$=tdateADlbl]").hide();      
       $("[id$=fdateCD]").parent().hide();$("[id$=fdateCDlbl]").hide();       
       $("[id$=tdateCD]").parent().hide();$("[id$=tdateCDlbl]").hide();
       $("[id$=fdateBG]").parent().hide();$("[id$=fdateBGlbl]").hide();       
       $("[id$=tdateBG]").parent().hide();$("[id$=tdateBGlbl]").hide(); 
   }    
   function gSt(slct, lnk, pg, fd, td) {        
    if(fd=='fdateAD'){fd=document.getElementById('{!$Component.f1.pb1.fdateAD}').value}
    if(td=='tdateAD'){td=document.getElementById('{!$Component.f1.pb1.tdateAD}').value}    
    if(fd=='fdateCD'){fd=document.getElementById('{!$Component.f1.pb1.fdateCD}').value}
    if(td=='tdateCD'){td=document.getElementById('{!$Component.f1.pb1.tdateCD}').value}    
    if(fd=='fdateBG'){fd=document.getElementById('{!$Component.f1.pb1.fdateBG}').value}
    if(td=='tdateBG'){td=document.getElementById('{!$Component.f1.pb1.tdateBG}').value}    
    if(fd === "" || td === ""){
    }
    else
    {           
        var sfd = fd.split("/");
        var tfd = td.split("/");                 
        date1 = new Date(sfd[2],sfd[1],sfd[0]);
        date2 = new Date(tfd[2],tfd[1],tfd[0]);            
        if (date2 <= date1) {
            alert("To date Should be greater than From date");
            if(pg=='gtrAD' || pg=='gtrADcsv'){            
                document.getElementById('{!$Component.f1.pb1.fdateAD}').value="";
                document.getElementById('{!$Component.f1.pb1.tdateAD}').value="";          
            }
            if(pg=='gtrCC' || pg=='gtrCCcsv'){            
                document.getElementById('{!$Component.f1.pb1.fdateCD}').value="";
                document.getElementById('{!$Component.f1.pb1.tdateCD}').value="";          
            }
            if(pg=='gtrBG' || pg=='gtrBGcsv'){            
                document.getElementById('{!$Component.f1.pb1.fdateBG}').value="";
                document.getElementById('{!$Component.f1.pb1.tdateBG}').value="";          
            }
            
            return false;
         }      
    }
    if( document.getElementById(slct).value == 'CUSTOM' && (pg=='gtrAD' || pg=='gtrADcsv')){           
        $("[id$=fdateAD]").parent().show();$("[id$=fdateADlbl]").show();
        $("[id$=tdateAD]").parent().show();$("[id$=tdateADlbl]").show();                
    }
    else if( document.getElementById(slct).value == 'CUSTOM' && (pg=='gtrCC' || pg=='gtrCCcsv')){           
        $("[id$=fdateCD]").parent().show();$("[id$=fdateCDlbl]").show();
        $("[id$=tdateCD]").parent().show();$("[id$=tdateCDlbl]").show();                      
    }
    else if( document.getElementById(slct).value == 'CUSTOM' && (pg=='gtrBG' || pg=='gtrBGcsv')){                           
        $("[id$=fdateBG]").parent().show();$("[id$=fdateBGlbl]").show();
        $("[id$=tdateBG]").parent().show();$("[id$=tdateBGlbl]").show();        
    }
    else
    {
       $("[id$=fdateAD]").parent().hide();$("[id$=fdateADlbl]").hide();       
