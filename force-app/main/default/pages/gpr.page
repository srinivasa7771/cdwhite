       $("[id$=tdateBG]").parent().hide();$("[id$=tdateBGlbl]").hide();          
    }
    var sN = 1,
        stP = "THIS_MONTH";        
        
    switch (document.getElementById(slct).value) {
        case "THIS_MONTH":
            stP = "THIS_MONTH";
            sN = 1;
            break;
        case "LAST_MONTH":
            stP = "LAST_MONTH";
            sN = 1;
            break;
        case "LAST_N_QUARTERS1":
            stP = "LAST_N_QUARTERS";
            sN = 1;
            break;
        case "LAST_N_QUARTERS2":
            stP = "LAST_N_QUARTERS";
            sN = 2;
            break;
        case "LAST_N_QUARTERS3":
            stP = "LAST_N_QUARTERS";
            sN = 3;
            break;
        case "THIS_YEAR":
            stP = "THIS_YEAR";
            sN = 1;
            break;
        case "LAST_N_YEARS1":
            stP = "LAST_N_YEARS";
            sN = 1;
            break;
        case "LAST_N_YEARS2":
            stP = "LAST_N_YEARS", sN = 2
        case "CUSTOM":
            stP = "CUSTOM", sN = 0
    }       
        document.getElementById(lnk).setAttribute("href", "/apex/" + pg + "?id={!A.Id}&p=" + stP + "&n=" + sN + "&fd=" + fd + "&td=" + td);
                
    }
    function gPpl(slct, lnk, pg) {
        switch (document.getElementById(slct).value) {
            case "All_Employees":
                stP = "All_Employees"; 
                dR = 0;               
                break;
            case "All_Dependents":
                stP = "All_Dependents";    
                dR = 0;            
                break;
            case "All_Outsourced":
                stP = "All_Outsourced";    
                dR = 0;            
                break;    
            case "All_Students":
                stP = "All_Students"; 
                dR = 0;               
                break;
            case "Sponsored_Employees":
                stP = "Sponsored_Employees";
                dR = 0;
                break;
            case "Non_Sponsored_Employees":
                stP = "Non_Sponsored_Employees";
                dR = 0;
                break;
            case "Everyone":
                stP = "Everyone";
                dR = 0;
                break;
            case "Expired_Passports":
                stP = "Expired_Passports";
                dR = 0;
                break;
            case "Expired_Residence_Permits":
                stP = "Expired_Residence_Permits";
                dR = 0;
                break;
            case "Passports_Expiring_in_next_30_days":
                stP = "Passports_Expiring";
                dR = 30;
                break;
            case "Passports_Expiring_in_next_60_days":
                stP = "Passports_Expiring";
                dR = 60;
                break;
            case "Passports_Expiring_in_next_90_days":
                stP = "Passports_Expiring";
                dR = 90;
                break;
            case "Residence_Expiring_in_next_30_days":
                stP = "Residence_Expiring";
                dR = 30;
                break;
            case "Residence_Expiring_in_next_60_days":
                stP = "Residence_Expiring";
                dR = 60;
                break;
            case "Residence_Expiring_in_next_90_days":
                stP = "Residence_Expiring";
                dR = 90;
                break;
        }       
        document.getElementById(lnk).setAttribute("href", "/apex/" + pg + "?id={!A.Id}&p=" + stP + "&d=" + dR);
    }
    
