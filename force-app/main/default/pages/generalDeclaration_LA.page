<apex:page sidebar="false" showHeader="false" controller="ObTmplCtl" applyBodyTag="false" renderAs="pdf">
    <head>
        <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"/>
        <style>
            @page {
            margin: 1.8cm 1cm;
            size: A4;
            padding: 10px;
            @top-left {content: element(header);}
            @bottom-left {content: element(footer);}
            }
            div.header{
            position: running(header);
            padding:5px 10px;
            }
            body { font-family: 'Arial Unicode MS'; }
            .imgContainer img {
            width: 100%;
            }
           
            .empVals div {
            margin: 2px 0 0 0;
            position: relative;
            padding-top: 11px;
            min-height:13px;
            /*margin: 4px 0 0 0;*/
            }
            
            .container{
                position:absolute;
                margin-top: 20px;
            }
            .sign{
            height:38px;
            width:100%;
            }
            .pgHead{
            color:blue;
            font-weight:bold;
            border-bottom: 1px solid black;
            }
            p,li{
            font-size:12px;
            }
            ol { counter-reset: item }
            li { display: block;padding:6px 0 6px 0; }
            li:before { content: counters(item, ".") ") "; counter-increment: item; }
        </style> 
    </head>
    <body>
        <apex:outputText rendered="false">
           
        </apex:outputText>
        <apex:outputText rendered="true">
            <!--<div class="header" >
                <div style="float:left">
                    <img width='120' src="{!URLFOR($Resource.DubaiGovLogo)}" />
                </div>
                <div style="float:right">
                    <img width='200' src="{!URLFOR($Resource.DDA_Logo)}" />
                </div>
            </div>-->
            
              
               
            <div class="container">
                    <p style="text-align:left;font-size:12px;">
                            <b>Registrar of Companies</b> <br/>
                             Dubai Development Authority<br/>
                             Second Floor Building 2 Dubai Studio City<br/>
                             P O Box 478844, Dubai, UAE<br/><br/>
                        <!--apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!Today()}" /></apex:outputText--><br/>
                        </p>
                  
                <div class="firstPage">
               
                                   
                    <div class="terms">
                        
                        <p style="text-align: center;">
                            <u> Declaration of Appointment as General Manager</u>
                        </p>

                                <p> The undersigned, confirm and declare the following</p>
                        <ol><li>I have been appointed as the General Manager of the Company with effect from the date of <span style="font-family: sans-serif; font-weight:bold;"><apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!rq.createddate}" /></apex:outputText></span> till _______________ and shall be subject to the extant provisions of the DDA Private Companies Regulations of 2016, as amended, from time to time.</li>
                                    <li>As a General Manager, I shall act in good faith in order to promote the objects of the Company for the benefit of its Members as a whole, and in the best interests of the Company, its employees, the Members.</li>
                                    <li>I shall not involve myself in a situation in which I may have a direct or indirect interest that conflicts, or possibly may conflict, with the interests of the Company or bring discredit to the Company.</li>
                                    <li>I hereby accepted and acknowledge that as a condition to my appointment commencing, if I may have business interests, memberships, appointment or employment with other companies other than those of the Company, I shall declare such prior appointment or interest in writing to the Members and or Directors.</li>
                                    <li>It is expected that any interest I may have in any transaction or arrangement that the Company has entered into should be disclosed no later than when the transaction or arrangement comes up at a Board Meeting so that my interest appropriately get recorded in Minutes and the company records are updated.</li>
                                    <li>That I will comply with all the laws, regulations and decisions implemented by the Authority having jurisdiction over the Company.</li>
                                </ol>
                           
                           
                        
                    </div>
                    <div class="signBlocks">
                       <p style="text-align:left;font-size:12px;">
                            Yours Sincerely
                        </p>
                        <div class="signBlock" style="margin-top:10px">
                            <table style=" border-collapse: collapse;" width="694">
                                <tbody>
                                    <!--<apex:repeat value="{!memberLst}" var="mem">-->
                                        <tr style="height: 21.55pt;">
                                        <td style="width: 56.65pt; border: solid #BEBEBE 0.5pt; background: #E7E6E6; padding: 0in 0in 0in 0in; height: 21.55pt;" width="76">
                                            <p style="punctuation-wrap: simple; margin: 6.65pt 0in .0001pt 7.4pt;"><strong><span style="font-size: 9.0pt;">Name:</span></strong></p>
                                        </td>
                                        <td style="width: 247.6pt; border: solid #BEBEBE 0.5pt; border-left: none; background: #E7E6E6; padding: 0in 0in 0in 0in; height: 21.55pt;" width="330">
                                            <p style="punctuation-wrap: simple; margin: 6.65pt 0in .0001pt 7.4pt;"><strong><span style="font-size: 9.0pt;"><elem id="memName">{!rq.xcfn__c}</elem></span></strong></p>
                                        </td>
                                        <td style="width: 1.25in; border: solid #BEBEBE 0.5pt; border-left: none; background: #E7E6E6; padding: 0in 0in 0in 0in; height: 21.55pt;" width="120">
                                            <p style="punctuation-wrap: simple; margin: 4.95pt 0in .0001pt 6.8pt;"><strong><span style="font-size: 9.0pt; color: black;">Position:</span></strong></p>
                                        </td>
                                        <td style="width: 1.75in; border: solid #BEBEBE 0.5pt; border-left: none; background: #E7E6E6; padding: 0in 0in 0in 0in; height: 21.55pt;" width="168">
                                            <p style="punctuation-wrap: simple; margin: 6.65pt 0in .0001pt 7.4pt;"><strong><span style="font-size: 9.0pt;"><elem id="memPos">Manager</elem></span></strong></p>
                                        </td>
                                    </tr>
                                    <tr style="height: 86.35pt;">
                                        <td style="width: 520.25pt; border: solid #BEBEBE 0.5pt; border-top: none; padding: 0in 0in 0in 0in; height: 86.35pt;" colspan="4" width="694">
                                            <p style="margin-top: .6pt; punctuation-wrap: simple;"><strong><span style="font-size: 8.5pt;">&nbsp;</span></strong></p>
                                            <p style="margin-left: 6.8pt; punctuation-wrap: simple;"><strong><span style="font-size: 9.0pt;">Signature:</span></strong></p>
                                        </td>
                                    </tr>
                                    <!--</apex:repeat>-->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="secondPage">
                </div>
            </div>
        </apex:outputText>
    </body>
</apex:page>