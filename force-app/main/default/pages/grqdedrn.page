        function  nonRenewlaYears(lsdt,lcno) { 
        //alert(lcno);
        if(lcno!=null && lcno!=''){
        cs['xdedln__c'].value = lcno;
        }
        if(lsdt!=null){ 
            var renewaldate= new Date(lsdt);
            var renDifMs = Date.now() - renewaldate.getTime();
            var renDate = new Date(renDifMs); // miliseconds from epoch
            
            var yrs=Math.abs(renDate.getUTCFullYear() - 1970);
            if(yrs!=null){
                cs['xnry__c'].value=yrs;
            }
            if(yrs>1){
                alert('Please make sure lience need to be renewed for'+yrs+' years');
            }
            
        }
        else{
            cs['xnry__c'].value=1;
        }
    }
        
    
        function isAlphaNumeric(e) {
            var keyCode = e.keyCode == 0 ? e.charCode : e.keyCode;
            var ret = ((keyCode >= 48 && keyCode <= 57) || (keyCode >= 65 && keyCode <= 90) || (keyCode >= 97 && keyCode <= 122));
            return ret;
        }
        
        
    
