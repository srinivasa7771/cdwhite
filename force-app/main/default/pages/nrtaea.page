                                                    cs['xrap__c']=document.getElementById('{!$Component.xrap__c}');
                                                    </script>
                                                </div>
                                            </div>
                                            <div class="col-lg-6 onPrkType 0np">
                                                <div class="form-group">
                                                    <label>Expiry date</label>
                                                    <!--<input id="xaed" disabled="true" class="form-control" style="height:50px;" />-->
                                                    <div class="input-datepicker-group input-group">
                                                        <input type="text" onchange="checkDate_custom(this,'fid');" class="requiredFld vRegDate dateCheck requiredFldPop form-control input-datepicker forEdit" id="cExpDate"
                                                               data-toggle="datetimepicker" validationname="fid" data-target="#cExpDate" />
                                                        <div class="input-group-append">
                                                            <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#cExpDate">
                                                                <i class="icon-date"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <label class="mt-2 text-primary cExpErr">
                                                        <i class="icon icon-info-circle"></i>
                                                        Expiry date should fall within a minimum of 2 month and a maximum of 12 months from the current date, or it can be set to the next lease anniversary date comes before the 12-month limit
                                                    </label>
                                                    <!--<apex:inputHidden id="xaed__c1" value=""/>-->
                                                    <script type="text/javascript">
                                                    cs['xaed__c1']=document.getElementById('{!$Component.xaed__c1}');
                                                    </script>
                                                </div>
                                            </div>
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Total amount (AED)</label>
                                                    <apex:inputHidden value="{!req.xtpa__c}" id="xtpa__c"/>
                                                    <input class="form-control disabledApex" value="{!req.xtpa__c}" id="xtpa"/>
                                                    <script type="text/javascript">
                                                    cs['xtpa__c']=document.getElementById('{!$Component.xtpa__c}');
                                                    cs['xtpa__c'].disabled = true;
                                                    </script>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-style">
                                            <c:eContactInfo req="{!req}" noNotes="true"  id="conTactcmp" cmpTitle="Contact Details"/>
                                        </div>
                                    </div>
                                    <div class="pb-5"></div>
                                </div>
                                <!--<button class="btn btn-primary" style="width: 150px;" onclick="submitPage(this,event)">SUBMIT</button>-->
                                <div class="base-main-footer">
                                    <div class="base-nav">
                                        <a class="btn btn-primary base-nav-next d-none" onclick="submitPage(this,event)" style="color: #fff;">
                                            PROCEED 
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </apex:outputText>
                    </div>
                </div>
            </div>
        </apex:outputPanel>
    </apex:form>
    <script type="text/javascript">
    var axs2CusomJS = "{!$Resource.AXS2CustomJs}";
    var allJSON = {};
    var allJSONStr = '';
    var data = [];
    var selectedJSON = [];
    var uPrc = 0;
    var currentVehicle = 1;
    var serviceId = '{!srv.uid__c}';
    var uid,locationExceptions;
    var fldToEIDAFlds = {'Name':'xchn__c','ID_Number':'xceidid__c','country2':'','emailid':'xceml__c','mobileid':'rmob__c'};
    var vehicleObj ={};
    var totEmp = '{!Acc.vetemp__c }';
    var park = 'DOC';
    var optionSeleted = false;
    $(document).ready(function(){
        locationExceptions = "{!$Label.AdditionalParkingExceptionLoc}";
        cs["uid"].value = "{!srv.uid__c}";
        callWS();
        if('{!req.id}'=='')
            cs["xadh__c"].value='';
        if('{!req.id}'!='' &&cs["xadh__c"].value){
            $('[itemCode="'+cs["xadh__c"].value.split(';')[0]+'"]').prop('checked',true);
            setTimeout(function(){$('[name="parkType"] ').trigger('change');},500);
        }
        
        $('.btn').on('click',function(event){
            //  event.preventDefault();
        });
        
    });
    var backOrFront, currentItemCd;
    var currVehicle = {"status":"","sequence":"","pltNum_RC": "", "RegDate_RC": "", "por_RC": "", "VehType_RC": "", "VehModel_RC": ""};
    var vehicleObj1 = {};
    
    function updateItem(e){
        if('{!req.id}'!='')
            return;
        if($('[name="parkType"]:checked').val()){
            removeValError('[name="parkType"]');
            var iCode = $(e).attr('itemCode');
            console.log('---iCode---'+iCode);
            $('.locSection').show();
            cs['xadh__c'].value= iCode+';';
            $(cs['xrap__c']).removeClass('disabledApex');
            $('.onPrkType').hide();
            if(iCode=='0np'){
                
                $('.onPrkType.0np').show();
            }
            formatTitle(iCode);
        }
        else{
            $(cs['xrap__c']).addClass('disabledApex');
        }
    }
    
    function formatTitle(selType)
    {
        console.log('selType===',selType);
        if(selType == 'snp')
        {
            $('#stdTile').show();
            $('#addTile').hide();
        }
        else if(selType == '1np' || selType == '0np')
        {
            $('#stdTile').hide();
            $('#addTile').show();
        }
    }
    
    function checkDate_custom(elem){  
        var e = $(elem);
        var date,date2
        $('.cExpErr').removeClass('errDate');
        removeValError(elem);
        var date1 = e.val();
        //var date3 = cs['xaed__c'].value;
        //cs['xaed__c'].value = e.val();
        var date3 = selectedJSON[0].locExp;
        date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
        date2 =  date3.split('/')[1]+'/'+date3.split('/')[0]+'/'+date3.split('/')[2];
        var days = new Date(new Date(date) - new Date())/1000/60/60/24;
        var days1 = new Date(new Date(date2) - new Date(date))/1000/60/60/24;
        var r = true;
        if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
            r = 'invalid'
        }
        
        var exp= date1.split('/'); 
        var expDate = new Date(exp[2]+'-'+exp[1]+'-'+exp[0]);
        exp= selectedJSON[0].locExp.split('/');
        var expDate2 = new Date(exp[2]+'-'+exp[1]+'-'+exp[0]);
        
        if(days<60 || days1<0 || expDate > expDate2 || days>365){ 
            $('.cExpErr').addClass('errDate').fadeOut().fadeIn().fadeOut().fadeIn();
            e.focus();
            return false;
        }
        return true;
        /*
        if(days<(30) || days>365 || days1<0){
            $('.cExpErr').addClass('errDate').fadeOut().fadeIn().fadeOut().fadeIn();
            e.focus();
        }*/
    }
    
    function callWS(){
        setTimeout(function(){
            callWS1();
        },200);
    }
    var crAgNo;
    var hideAddOptions = false;
    var execParkings = [];
    var paidStdParkings = [];
    function createDD(str){
        allJSONStr = str;
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        createDD1();
    }
    function removeDOCoptions(jsonStr){
        if(!allJSONStr)
            return;
        var jsonoObj = JSON.parse(allJSONStr);
        for(let i of jsonoObj){
            if(i.PaidStandardEligibility>0)
                hideAddOptions = true;
        }
    }
    function createDD1(itmCode){
        $('#cardDet').find('option[value^="AG"]').remove();
        $('#cardDet').select2(); 
        if($('#cardDet').hasClass("select2-hidden-accessible"))
            $('#cardDet').select2('destroy'); 
        console.log('---allJSONStr---'+allJSONStr);
        var allJSONObj = JSON.parse(allJSONStr);
        var allJSONObj1 = [];
        var agObj = {};
        var z=0;
        var optionData = [];
        try{
            for(let i of allJSONObj){
                var d ={};
                z++;
                d.Sequence = i.Sequence;
                d.LocationName = i.LocationName;
                d.id=(locationExceptions.includes(i.LocationName) && i.AgNumber=='')?'AG-'+z:i.SectorID;//+'_'+i.SectorID;
                d.LocaionId = i.LocaionId;
                d.SectorID = i.SectorID;
                d.Sector = i.Sector;
                d.EligibilityID = i.EligibilityID;
                d.NewEligibility = i.NewEligibility;
                d.isDefault = i.isDefault;
                d.AgNumber=(locationExceptions.includes(i.LocationName) && i.AgNumber=='')?'AG-'+z:i.AgNumber;
                d.LeaseExp = i.LeaseExp;
                d.PaidEligibility = i.PaidEligibility;
                d.RemainingPaidEligible = i.RemainingPaidEligible;
                if(i.PaidStandardEligibility>=0){
                    d.PaidStandardPrice = i.PaidStandardPrice;
                    d.PaidStandardEligibility = d.noOfAO = i.PaidStandardEligibility;
                    /*if(itmCode=='enp'){
                        if(!i.LocationName.toLowerCase().includes('executive')){
                            d.disabled = true;
                        }
                        else
                            d.disabled = false;
                    }
                    else if(itmCode=='snp'){
                         if(i.LocationName.toLowerCase().includes('executive')){
                            d.disabled = true;
                        }
                        else
                            d.disabled = false;
                    }*/
                }
                optionData.push(d);
            }
        }catch(e){
            console.log(e);
        }
        $('.input-select-member').change(function () {
            if ($(this).val() === '') {
                $(this).next('.select2').removeClass('selected');
            } else {
                $(this).next('.select2').addClass('selected');
            }
        });
        
        setTimeout(function () {
            $('.input-select-member').trigger('change');
        }, 100);
        
        $('.input-select-member').select2({
            data: optionData,
            allowClear: true,
            escapeMarkup: function (markup) {
                return markup;
            },
            templateResult: function (data) {
                if (!data.id && data.id!=undefined) {
                    return data.id;
                }
                
                //var html = '<div class="user-title-media user-title-media-sm" num="'+data.id+'">' +
                var html ='';
                if(data.disabled)
                    return;
                /*html = '<div class="user-title-media user-title-media-sm" disabled="disabled" num="'+data.LocaionId+'">';
                else*/
                html = '<div class="user-title-media user-title-media-sm" num="'+data.LocaionId+'">';
                html+='<div>' +
                    '<div class="user-name mb-2">' + data.LocationName + '</div>' +
                    '<div class="user-title font-weight-normal"> Agreement Number:' + data.AgNumber +
                    ' • Expires on '+data.LeaseExp+'</div>' +
                    '</div>' +
                    '</div>';
                var pp = {"locSeq":data.Sequence,"PaidStandardEligibility":data.PaidStandardEligibility,"RemainingPaidEligible":data.RemainingPaidEligible,"NewEligibility":data.NewEligibility,"pel":data.PaidEligibility,"PaidStandardPrice":data.PaidStandardPrice,"locId":data.LocaionId,"locName":data.LocationName,"locExp":data.LeaseExp,"locAgNum":data.AgNumber,"secId":data.SectorID,"sec":data.Sector,"elgID":data.EligibilityID, "default": data.isDefault}
                $('[num="'+data.SectorID+'"]').attr('pp',JSON.stringify(pp));
                $('[value="'+data.id+'"]').attr('pp',JSON.stringify(pp));
                $('[value="'+data.SectorID+'"]').attr('secId',data.SectorID);
                return html;
            },
            templateSelection: function (data) {
                if (!data.id && data.id!=undefined) {
                    return data.id;
                }
                
                var html = '<div class="user-title-media user-title-media-sm" num="'+data.LocaionId+'">' +  
                    '<div>' +
                    '<div class="user-name mb-2">' + data.LocationName + '</div>' +
                    '<div class="user-title font-weight-normal"> Agreement Number:' + data.AgNumber +
                    ' • Expires on '+data.LeaseExp+'</div>' +
                    '</div>' +
                    '</div>';
                //var pp = {"cardId":data.id,"elg":data.elg,"sector":data.sector,"add":data.add,"cntrExp":data.cntrExp,"noOfAO":data.noOfAO,"noOfDays":data.noOfDays};
                var pp = {"locSeq":data.Sequence,"PaidStandardEligibility":data.PaidStandardEligibility,"RemainingPaidEligible":data.RemainingPaidEligible,"NewEligibility":data.NewEligibility,"pel":data.PaidEligibility,"PaidStandardPrice":data.PaidStandardPrice,"locId":data.LocaionId,"locName":data.LocationName,"locExp":data.LeaseExp,"locAgNum":data.AgNumber,"secId":data.SectorID,"sec":data.Sector,"elgID":data.EligibilityID, "default": data.isDefault}
                $('[num="'+data.SectorID+'"]').attr('pp',JSON.stringify(pp));
                $('[value="'+data.SectorID+'"]').attr('pp',JSON.stringify(pp));
                $('[value="'+data.id+'"]').attr('pp',JSON.stringify(pp));
                $('[value="'+data.SectorID+'"]').attr('secId',data.SectorID);
                return html;
            }
        });
        optionSeleted = true;
    }
    let prevData = '', selectedItem='';
    function loadPrevData(){
        if(!(cs['xadtx4__c'] || cs['xadtx4__c'].value))
            return;
        prevData = JSON.parse(cs['xadtx4__c'].value);
        selectedItem = cs['xadh__c'].value.replace(';','');
        $('#cardDet').val( prevData.SectorID).attr('disabled',true);//a0E0p00000E1kvNEAR
        $('[itemcode='+selectedItem+']').prop('checked',true);
        $('[name="parkType"]').attr('disabled',true);
        $('.onPrkType').hide();
        $(cs['xrap__c']).val(prevData['ReqSlots']).attr('disabled', true);
        if(selectedItem=='0np'){
            $('#xtpa').parent().hide();
            $('.onPrkType.0np').show();
            selecteEndDate = prevData['EndDate'].split('-');
            $('#cExpDate').val(selecteEndDate[2]+'/'+selecteEndDate[1]+'/'+selecteEndDate[0]);//.attr('disabled',true);removed to avoid undefined cases
        }
    }
    var avlblPermits = 0; 
    var orgnlPermits = 0;
    var usedPermits = 0;
    function settoFld(e){
        selectedJSON[0] = {};
        var cardNum = $(e).val();
        
        if(!cardNum){
            $('#selectedSector').hide();
            $('.frmErrMsg').remove();
            $('.base-nav-next').addClass('d-none');
            return;
        }
        $('#selectedSector').show();
        var ppData = JSON.parse($('[value="'+cardNum+'"]').attr('pp'));
        
        if('{!req.id}'==''){
            $('#totPermits').parent().hide();
            $('#xtpa').parent().hide();
            $('.parkingOptions').hide();
            // $(cs['xrap__c'],cs['xtpa__c']).val('');
            $('#xtpa').val('');
            cs["xrap__c"].value='';
            $('[name="parkType"]').prop('checked',false).trigger('change');
        }
        selectedJSON[0] = ppData;
        $('.parkingOptions').show();
        $('.parkingOptions label').hide();
        
        //avlblPermits = 0;
        
        orgnlPermits = selectedJSON[0].PaidStandardEligibility - selectedJSON[0].NewEligibility;
        usedPermits = selectedJSON[0].pel;
        let rm = selectedJSON[0].PaidStandardEligibility-selectedJSON[0].pel;
        let ng=selectedJSON[0].RemainingPaidEligible;
        let rmng = rm>ng?rm:ng;
