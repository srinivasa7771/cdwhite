        <apex:outputPanel id="mainDiv">
            <div id="main">
                <b><apex:pageMessages id="msg"  /></b>
                <div class="container pt-2 pb-2">
                    <div class="text-right">
                        <apex:outputPanel rendered="{!NOT(req.id=='')}">
                            <span class="d-inline-block mr-2 align-middle" style="font-size: 1.875rem;line-height: 1;">
                                SR # <span class="text-000">{!req.Name} </span>
                            </span>
                        </apex:outputPanel>
                    </div>
                </div>
                <div class="container">
                    <div class="base-layout">
                        <div class="base-side">
                            <div class="base-side-content">
                                <div>
                                    <h3 class="text-primary d-md-block d-none">ABOUT THIS SERVICE</h3>
                                    <div class="collapse collapse-content-wrapper" id="onboarding_side_content_1">
                                        <div class="collapse-content">
                                            <p class="text-000">
                                                Using this service, you can request for additional parking permits or users. <br /><br />
                                                The additional parking permits purchased will be added to your total parking eligibility.<br /><br />
                                                The additional users will be allowed access to parking  based on current parking eligibility and  availability. This will not increase the total eligibility.
                                                <!--{!srv.sdg__r.sd__c}-->
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <apex:outputText ><!-- rendered="{!Acc.park__c!='doc'}"-->
                            
                            <div class="base-main">
                                <div class="base-main-content">
                                    <h3 class="base-main-title">Request for Parking Permits</h3>
                                    <div class="fs-18 my-2 locSection">Select parking location to proceed</div><!--request for additional parking permits / enroll a user-->
                                    <apex:outputPanel id="cardList" styleClass="locSection">
                                        <div class="form-group">
                                            <select id="cardDet" class="form-control input-select-member" 
                                                    data-placeholder="Select a sector" onchange="settoFld(this)">
                                                <option></option>
                                            </select>
                                        </div>
                                    </apex:outputPanel>
                                    
                                    <label class="fs-18 parkingOptions">Select a service to apply for</label><br />
                                    <div class="form-group parkingOptions" id="0np">
                                        
                                        <label class="custom-radio custom-radio-sm mb-4 nonDoc">
                                            <input value="addPar" id="addPar" itemCode='0np' onchange="updateItem(this);" name="parkType" type="radio" />
                                            <span data-original-title="" data-placement="top" data-toggle="tooltip">Additional parking</span>
                                        </label>&nbsp;
                                        <label class="custom-radio custom-radio-sm mb-4 nonDoc">
                                            <input value="enUsr" id="enUsr" itemCode='1np' onchange="updateItem(this);" name="parkType" type="radio" />
                                            <span data-original-title="" data-placement="top" data-toggle="tooltip">Additional user</span>
                                        </label>
                                        <label class="custom-radio custom-radio-sm mb-4 docExtra">
                                            <input value="stdPaid" id="stdPar" itemCode='snp' onchange="updateItem(this);" name="parkType" type="radio" />
                                            <span data-original-title="" data-placement="top" data-toggle="tooltip">Standard parking</span><!--Surface-->
                                        </label>&nbsp;
                                        <label class="custom-radio custom-radio-sm mb-4 docExtra">
                                            <input value="execPaid" id="excPar" itemCode='enp' onchange="updateItem(this);" name="parkType" type="radio" />
                                            <span data-original-title="" data-placement="top" data-toggle="tooltip">Executive parking</span>
                                        </label>
                                    </div>
                                    <label style="display:none;" class="text-primary fs-15">
                                        Your company has been pre-approved for <span id="totPermits"></span> <span id='paidType'></span> parking permits based on the size of your leased area.
                                        Currently, <span id="avlblPermits"></span> pre-approved parking permits available
                                    </label>
                                    <div id="selectedSector" class="" style="display:none"> 
                                        
                                        <span  id="addTile" style="{!if(req.xadh__c ==  'snp;', 'display:none', 'display:block')}">
                                            <h4  class="mt-2">Additional parking permits information</h4>
                                        </span>
                                        <span id="stdTile" style="{!if(req.xadh__c ==  'snp;', 'display:block', 'display:none')}">
                                            <h4  class="mt-2">Standard parking permits information</h4>
                                        </span>
                                        
                                        <div class="row row-lg">
                                            <div class="col-lg-6">
                                                <div class="form-group">
                                                    <label>Choose number of parking permits</label>
                                                    <apex:inputField type="text" onkeyup="validDigits(this)" onchange="updateReqPrkSlots(this.value,this)" styleClass="disabledApex requiredFld form-control numOnly jsnfld" value="{!req.xrap__c}" id="xrap__c"
                                                                     />
