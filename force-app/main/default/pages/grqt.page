            <apex:pageBlockSection collapsible="false" columns="1" rendered="{!AND(NOT(ISNULL(T)),NOT(pgHide),T.Items__r.size>0)}">
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Items" />
                    <apex:outputPanel >
                        <table class="list" border="0" cellpadding="0" cellspacing="0" style="font-size:11px;">
                             <tbody>
                                <tr class="headerRow">
                                    <th scope="col">{!$ObjectType.g_reqitem__c.label}</th>
                                    <th scope="col" >{!$ObjectType.g_TranItem__c.fields.exp__c.label}</th>
                                                                   
                                    <th scope="col" class="{!IF(AND(cnSv,cnSvSTA,T.TP__c='Refund'),'','CurrencyElement')}">
                                    {!if(NOT(ispu),$ObjectType.g_TranItem__c.fields.A__c.label,'')}                                    
                                    </th>
                                    <th scope="col"  class="CurrencyElement">
                                       <apex:outputPanel layout="none" rendered="{!AND(NOT(ispu),T.TP__c!='Claim')}">
                                        VAT
                                       </apex:outputPanel>
                                    </th>
                                    <th scope="col"></th>
                                </tr>
                                  <apex:variable var="dupChk" value="" />   
                                <apex:repeat value="{!T.Items__r}" var="I">
                                     <apex:outputPanel layout="none" rendered="{!OR(NOT(ispu),AND(ispu,dupChk !=I.itm__r.itm__r.Name))}">
                                     <apex:variable var="dupChk" value="{!I.itm__r.itm__r.Name}" /> 
                                     <apex:variable var="amt" value="{!0}" />    
                                     <apex:repeat value="{!T.Items__r}" var="tItm">
                                       <apex:variable var="amt" value="{!amt+IF(dupChk == tItm.itm__r.itm__r.Name,tItm.A__c,0)}" />  
                                     </apex:repeat>    
                                    <tr class="dataRow">
                                        <td class="dataCell" style="width:1%;white-space:nowrap;">
                                            <apex:outputField value="{!I.itm__r.itm__r.Name}" rendered="{!NOT(ispu)}" />
                                            <apex:outputField value="{!I.itm__r.itm__r.lbl__c}" rendered="{!ispu}" />                                   
                                        </td>
                                        <td class="dataCell" style="width:1%;white-space:nowrap;">
                                            <apex:outputField value="{!I.exp__c}"  />
                                        </td>  
                                       
                                        <td class="dataCell {!IF(AND(cnSv,cnSvSTA,T.TP__c='Refund'),'','CurrencyElement')}" style="width:1%;white-space:nowrap;">                                           
                                           
                                            <apex:outputPanel layout="none" rendered="{!AND(cnSv,cnSvSTA,T.TP__c='Refund',NOT(T.fwc__c))}">
                                            <div id="{!I.Id}A__cRI" class="requiredInput">
                                                <div class="requiredBlock"></div>
                                               
                                                <apex:inputText id="A__c" value="{!I.A__c}" style="font-size:11px;" >
                                                   <apex:actionSupport event="onchange" rerender="vatid" /> 
                                                </apex:inputText> 
                                                   
                                                <script type="text/javascript">  cs['{!I.Id}A__c']=getC('{!$Component.A__c}'); if('{!I.VAT__c}' != null && '{!I.VAT__c}' != '' && parseFloat('{!I.A__c}') > parseFloat('{!I.VAT__c}')) cs['{!I.Id}A__c'].value="{!I.A__c - I.VAT__c}"; </script>
                                                 </div>
                                            </apex:outputPanel>                                     
                                            <apex:outputText value="{!I.A__c-I.VAT__c}" rendered="{!AND(NOT(AND(AND(cnSv,NOT(T.fwc__c),cnSvSTA),T.TP__c='Refund')),NOT(ispu))}"/>
                                            
                                              
                                        </td> 
                                        <td class="dataCell CurrencyElement" style="width:10%;white-space:nowrap;"> 
                                            <apex:outputPanel id="vatid">
                                            <apex:outputPanel layout="none" rendered="{!AND(NOT(ispu),T.TP__c!='Claim',OR(I.A__c > 0,AND(I.A__c <= 0,NOT(ISNULL(I.VAT__c)),I.VAT__c <=0)))}">
                                                <apex:outputText value="{!I.VAT__c}" style="font-size:11px;"/>  
                                            </apex:outputPanel>  
                                            <apex:outputPanel layout="none" rendered="{!AND(NOT(ispu),T.TP__c!='Claim',I.A__c <= 0,NOT(ISNULL(I.VAT__c)),I.VAT__c >0)}">
                                              <apex:outputText id="VAT__c" value="0.0" style="font-size:11px;width:20px;" />
                                            </apex:outputPanel> 
                                            </apex:outputPanel>
                                         </td>
                                        <td class="dataCell"></td>                                      
                                    </tr>
                                   </apex:outputPanel>
                                </apex:repeat>
                             </tbody>
                        </table>
                    </apex:outputPanel>
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
        </apex:outputpanel>
    </apex:pageBlock>
    
    
