    <script type="text/javascript">
      var loc=false;
          <apex:repeat value="{!T.Items__r}" var="I">loc=showloc('{!JSENCODE(I.itm__r.sta__r.Courier_Stage__c)}')||loc;
    </apex:repeat>
    function showloc(stage){
        if(stage=='Collection' || stage=='Delivery'){    
           
        return true;
        }
        return false;
        }
    
    </script>    
       
       
       
      <script type="text/javascript">
function vfrm(nSTA){
   
    if("{!oldSTA}"!="Cancelled"&&cs["STA__c"].value=="Cancelled"){return confirm("Do you want to continue with payment cancellation?");}
          //return hRq(nSTA)?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):!0;
          return hRq(nSTA)?!1:!0
}

function hRq(nSTA){   
    
    var brq = false;    
    if({!cnSv}){        
        fldErr('STA__c',null,!0);fldErr('cq__c',null,!0);fldErr('ci__c',null,!0);fldErr('cdt__c',null,!0);fldErr('Bnk__c',null,!0);fldErr('md__c',null,!0);
        if({!AND(cnSv,cnSvSTA,T.TP__c='Refund',NOT(T.fwc__c))}){<apex:repeat value="{!T.Items__r}" var="I">fldErr('{!I.Id}A__c',null,!0);</apex:repeat>}  
        if({!AND(T.TP__c='Payment',T.md__c='Cash')}){<apex:repeat value="{!T.Items__r}" var="I">brq=ChkLoc('{!I.exp__c}','{!JSENCODE(I.itm__r.sta__r.Courier_Stage__c)}')||brq;</apex:repeat>}
      
        if({!cnSvSTA}){             
            brq=fldReq('STA__c',cs)||brq;
            if(cs['md__c']!=null){brq=fldReq('md__c',cs)||brq;}
                    
            if({!AND(cnSv,cnSvSTA,T.TP__c='Refund',NOT(T.fwc__c))}){
                <apex:repeat value="{!T.Items__r}" var="I">
                    brq=fldReq('{!I.Id}A__c',cs)||brq;
                  
                  if(cs['{!I.Id}A__c'] != null && '{!I.VAT__c}' != null && '{!I.VAT__c}' != '' )
                  {
                      var uamt = Number(cs['{!I.Id}A__c'].value) + Number('{!I.VAT__c}');
                      var amt = Number('{!I.A__c}');
                      if(uamt > amt){
                        brq = true; fldErr('{!I.Id}A__c','Amount should not greater then refund Amount',!0);
                        }
                  }
                
                </apex:repeat>
                
              }
            }  
             
       /* if('{!JSENCODE(T.md__c)}'=='Cheque'||'{!JSENCODE(T.md__c)}'=='Wire Transfer'||'{!JSENCODE(T.md__c)}'=='Bank Letter'){brq = fldReq('cq__c',cs)||brq;brq = fldReq('ci__c',cs)||brq;brq = fldReq('cdt__c',cs)||brq;brq = fldReq('Bnk__c',cs)||brq;} */
        if({!AND(cnSv,cnSvSTA,T.TP__c='Refund',NOT(T.fwc__c))} && !brq){
                <apex:repeat value="{!T.Items__r}" var="I">
                    if(cs['{!I.Id}A__c'] != null && '{!I.VAT__c}' != null && '{!I.VAT__c}' != '')
                  {
                      var uamt = Number(cs['{!I.Id}A__c'].value) + Number('{!I.VAT__c}');
                      if(Number(cs['{!I.Id}A__c'].value) != 0)
                        cs['{!I.Id}A__c'].value = uamt;    
                  }
                
                </apex:repeat>
                
              }
       } 
    
                                                    
    return brq;
}
function ChkLoc(priority,stage){
 
   if(stage=='Collection' && priority=='false' &&  cs['coucl__c'].value!='At Office'){ 
       alert('Courier Collection at counter is avalibale for express services,others will be at company office premises.');
       return true;
       }
    return  false;
    }
</script>
