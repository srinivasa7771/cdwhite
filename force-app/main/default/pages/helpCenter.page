<apex:page cache="false" standardStylesheets="false" readOnly="true" showHeader="true" sidebar="false" title="Help">
    <html>
        <head>
            <title>HELP</title>
            <!--<apex:stylesheet value="{!$Resource.axs2StyleV2}" />-->
        </head>
        <style>
            .help-box{
            display: block;
            height: calc(100% - 1.5rem);
            margin-bottom: 1.5rem;
            padding: 2.125rem 1.5rem 1.5rem;
            border-radius: 1rem;
            background-color: #ffffff;
            text-align: center;
            color: inherit;
            font-size: 1.125rem;
            -webkit-transition: 0.3s all;
            -o-transition: 0.3s all;
            transition: 0.3s all;
            }
            .help-box i{
            display: inline-block;
            margin-bottom: 1.5rem;
            font-size: 2.75rem;
            }

        </style>
        <apex:form id="form">
            <body>
                <div id="main">
                    <div id="page_content">
                        <div class="container">
                            <div class="page-header">
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/gpm">Dashboard</a></li>
                                    <li class="breadcrumb-item">Help Center</li>
                                </ul>
                                <!-- .breadcrumb -->
                                <h1 class="page-title">HELP CENTER</h1>
                            </div>
                            <!-- .page-header -->
                            <div class="row">
                                <div class="col-xl-4 col-md-6">
                                    <a href="/serviceCatalogue" class="help-box">
                                        <i class="icon-service-catalogue text-primary"></i>
                                        <h2>SERVICE CATALOGUE</h2>
                                        <p>
                                            Browse through all our services and get information on timelines and documents required.
                                        </p>
                                    </a>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <a href="/glossary" class="help-box">
                                        <i class="icon-glossary text-primary"></i>
                                        <h2>GLOSSARY</h2>
                                        <p>
                                            Browse our glossary of terms to understand all abbreviations used.
                                        </p>
                                    </a>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <a href="/helpFAQ" class="help-box">
                                        <i class="icon-faq text-primary"></i>
                                        <h2>FAQs</h2>
                                        <p>
                                            Get answers to all your questions regarding various processes and services available.
                                        </p>
                                    </a>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <a href="/userManual" class="help-box">
                                        <i class="icon-video-tutorials text-primary"></i>
                                        <h2>USER GUIDES</h2>
                                        <p>
                                           Access our services easily by checking our step-by-step guides.
                                        </p>
                                    </a>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <a href="/serviceFees" class="help-box">
                                        <i class="icon-money-2 text-primary"></i>
                                        <h2>SERVICE FEES</h2>
                                        <p>
                                            Get a breakdown of the various fees applicable per service.
                                        </p>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js')}"  />
            </body>
        </apex:form>
    </html>
</apex:page>