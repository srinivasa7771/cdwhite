<apex:page showheader="false" showChat="false">
<apex:includeScript value="{!$Resource.jsH}"/>  
<script>
var id = getQryVar("id");
function getQryVar(variable) {
var query = window.location.search.substring(id);
var vars = query.split("?");
for (var i=0;i<vars.length;i++) {
var pair = vars[i].split("=");
if(pair[0] == variable) {return pair[1];}
} }
function ev(id){setNav();window.location.href='/apex/grqei?id='+id;}
window.onload = function() { 
     ev(id);
    }
</script>
</apex:page>