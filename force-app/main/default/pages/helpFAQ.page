                position: relative;	
                }	
                .help-side-menu li a {	
                display: block;	
                }	
                .help-side-menu > li {	
                position: relative;	
                border-bottom: 1px solid rgba(103, 109, 120, 0.2);	
                }	
                .help-side-menu > li > a {	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                color: #333333;	
                font-weight: 500;	
                font-size: 1.25rem;	
                line-height: 1;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu > li > a {	
                padding: 16px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu > li > a {	
                padding: 16px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu > li > a {	
                padding: 16px 40px;	
                }	
                }	
                .help-side-menu li.has-children > a {	
                position: relative;	
                }	
                .help-side-menu li.has-children > a::after {	
                display: inline-block;	
                font: normal normal normal 14px/1 FontAwesome;	
                font-size: inherit;	
                text-rendering: auto;	
                -webkit-font-smoothing: antialiased;	
                -moz-osx-font-smoothing: grayscale;	
                content: "\f107";	
                position: absolute;	
                right: 1rem;	
                top: 0.75rem;	
                line-height: 1;	
                font-size: 1.5rem;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                z-index: 1;	
                }	
                .help-side-menu li.has-children.open > a::after {	
                -webkit-transform: rotate(180deg);	
                -ms-transform: rotate(180deg);	
                transform: rotate(180deg);	
                }	
                .help-side-menu li > ul {	
                display: none;	
                }	
                .help-side-menu li.open > ul {	
                display: block;	
                }	
                .help-side-menu > li.open {	
                background-color: #F5F5F5;	
                }	
                .help-side-menu > li ul {	
                padding-left: 1.25rem;	
                }	
                .help-side-menu ul.help-submenu {	
                padding-left: 0;	
                }	
                .help-side-menu ul.help-submenu > li {	
                border-bottom: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .help-side-menu ul.help-submenu > li:last-child {	
                border-bottom: none;	
                }	
                .help-side-menu ul.help-submenu > li > a {	
                display: block;	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                font-weight: 500;	
                font-size: 1.125rem;	
                line-height: 1;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu ul.help-submenu > li > a {	
                padding: 14px 40px;	
                }	
                }	
                .help-side-menu ul.help-submenu > li > a::after {	
                top: 0.625rem;	
                color: #999999;	
                }	
                .help-side-menu ul:not(.help-submenu) {	
                padding-bottom: 10px;	
                }	
                .help-side-menu ul:not(.help-submenu) a {	
                padding-bottom: 0.625rem;	
                color: #777777;	
                }	
                .help-side-menu ul:not(.help-submenu) a:hover, .help-side-menu ul:not(.help-submenu) a:focus {	
                color: #333333;	
                }	
                .help-side-menu ul:not(.help-submenu) li.active > a {	
                color: #333333;	
                }	
                @media (min-width: 576px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 30px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 40px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .help-side-menu ul.help-submenu ul {	
                padding-left: 50px;	
                }	
                }	
                .content-icon {	
                position: relative;	
                margin-bottom: 2rem;	
                padding-left: 2.25rem;	
                }	
                .content-icon > i {	
                position: absolute;	
                -webkit-box-flex: 1;	
                -ms-flex: 1 1 auto;	
                flex: 1 1 auto;	
                top: 2px;	
                left: 0;	
                padding-right: 0.75rem;	
                font-size: 1.5rem;	
                }	
                @media (min-width: 1200px) {	
                .service-catalogue-footer > div {	
                border-right: 1px solid rgba(103, 109, 120, 0.2);	
                }	
                }	
                .service-catalogue-footer > div:last-child {	
                border-right: none;	
                }	
                .glossary-collapse {	
                border-radius: 0.75rem;	
                background: #ffffff;	
                border: none;	
                -webkit-animation-duration: 0.5s;	
                animation-duration: 0.5s;	
                }	
                .glossary-collapse .collapse-header {	
                padding: 1rem 2.5rem 1rem 1.5rem;	
                font-weight: bold;	
                color: #4A4A4A;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .glossary-collapse .collapse-header::after {	
                top: 0.875rem;	
                right: 1rem;	
                }	
                .glossary-collapse .collapse-header:hover {	
                color: #646464;	
                }	
                .glossary-collapse .collapse-content {	
                padding: 0 1.5rem 1rem;	
                }	
                .glossary-filter a {	
                display: inline-block;	
                width: 35px;	
                line-height: 35px;	
                margin-right: 5px;	
                margin-bottom: 5px;	
                color: #333333;	
                font-size: 20px;	
                font-weight: bold;	
                text-align: center;	
                border-radius: 50%;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .glossary-filter a:hover {	
                background-color: rgba(0, 0, 0, 0.1);	
                }	
                .glossary-filter a.active {	
                background-color: #67486C;	
                color: #ffffff;	
                }	
                .glossary-filter a.inactive {	
                cursor: default;	
                color: #9B9B9B;	
                }	
                .glossary-filter a.inactive:hover {	
                background-color: transparent;	
                }	
                .card-video {	
                display: block;	
                margin-bottom: 30px;	
                background-color: #ffffff;	
                border-radius: 10px;	
                color: inherit;	
                overflow: hidden;	
                -webkit-box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
                box-shadow: 0 5px 10px 0 rgba(0, 0, 0, 0.1);	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-img {	
                padding-top: 55%;	
                position: relative;	
                background-repeat: no-repeat;	
                background-size: cover;	
                background-position: center center;	
                border-radius: 10px;	
                overflow: hidden;	
                }	
                .card-video-img::before {	
                content: ' ';	
                position: absolute;	
                left: 0;	
                top: 0;	
                width: 100%;	
                height: 100%;	
                background-color: rgba(30, 30, 30, 0.3);	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-img::after {	
                display: inline-block;	
                font: normal normal normal 14px/1 FontAwesome;	
                font-size: inherit;	
                text-rendering: auto;	
                -webkit-font-smoothing: antialiased;	
                -moz-osx-font-smoothing: grayscale;	
                content: "\f144";	
                position: absolute;	
                left: 50%;	
                top: 50%;	
                -webkit-transform: translate(-50%, -50%);	
                -ms-transform: translate(-50%, -50%);	
                transform: translate(-50%, -50%);	
                color: #ffffff;	
                font-size: 50px;	
                line-height: 1;	
                opacity: 0.9;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .card-video-content {	
                min-height: 105px;	
                padding: 1.25rem;	
                }	
                .card-video-title {	
                color: inherit;	
                }	
                .card-video:hover {	
                -webkit-box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
                box-shadow: 0 5px 10px 5px rgba(0, 0, 0, 0.1);	
                }	
                .card-video:hover .card-video-img::before {	
                background-color: rgba(30, 30, 30, 0.5);	
                }	
                .card-video:hover .card-video-img::after {	
                opacity: 1;	
                }	
                #modal_video .modal-header {	
                padding: 1rem 1.5rem;	
                }	
                #modal_video .modal-header h4 {	
                margin-bottom: 0;	
                }	
                #modal_video .modal-content {	
                border-radius: 10px 10px 0 0;	
                }	
                .input-filter-faqs > input[type=text] {	
                border: none;	
                }	
                .faq-category-list {	
                list-style: none;	
                margin: 0 0 1.5rem;	
                padding: 0;	
                border-top: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .faq-category-list > li {	
                border-bottom: 1px dashed rgba(103, 109, 120, 0.2);	
                }	
                .faq-category-list > li > a {	
                display: block;	
                font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;	
                letter-spacing: 0.75px;	
                color: #333333;	
                font-weight: 500;	
                font-size: 1.25rem;	
                line-height: 1;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                @media (min-width: 576px) {	
                .faq-category-list > li > a {	
                padding: 14px 20px;	
                }	
                }	
                @media (min-width: 1200px) {	
                .faq-category-list > li > a {	
                padding: 14px 30px;	
                }	
                }	
                @media (min-width: 1500px) {	
                .faq-category-list > li > a {	
                padding: 14px 40px;	
                }	
                }	
                .faq-category-list > li > a:hover {	
                background-color: #f5f6fb;	
                }	
                .faq-category-list > li.active > a {	
                background-color: #f5f6fb;	
                }	
                .faq-category-list > li ul {	
                list-style: none;	
                padding-left: 40px;	
                }	
                .faq-category-list > li ul > li > a {	
                display: block;	
                padding: 10px 12px;	
                }	
                .faq-collapse {	
                border-radius: 0.75rem;	
                background: #ffffff;	
                border: none;	
                -webkit-animation-duration: 0.5s;	
                animation-duration: 0.5s;	
                }	
                .faq-collapse .collapse-header {	
                padding: 1rem 2.5rem 1rem 1.5rem;	
                font-size: 1rem;	
                font-weight: 500;	
                color: #4A4A4A;	
                -webkit-transition: all 0.3s;	
                -o-transition: all 0.3s;	
                transition: all 0.3s;	
                }	
                .faq-collapse .collapse-header::after {	
                top: 1rem;	
                right: 1rem;	
                }	
                .faq-collapse .collapse-header:hover {	
                color: #646464;	
                }	
                .faq-collapse .collapse-title {	
                font-size: 1.125rem;	
                }	
                .faq-collapse .collapse-content {	
                padding: 0 1.5rem 1rem;	
                }
            </style>
            <script>
            function rerenderDetailBlock(val){
                console.log('inside rerenderblock'+val);
                var val1 = document.getElementById('searchkw').value;
                console.log('searchKey==='+val1);
                var len = val1.length;
                console.log('len==='+len);
                if(len >= 3){
                    searchKeywork(val1);
                }	
            }
            function renderagain(){
                renderInfoDiv();
            }
            function reArrangeTitles(){
                $('a.collapse-header').each(function(){
                    var next = $(this).next('.collapse-title');
                    $(this).append(next);
                    $(this).next('.collapse-title').remove();
                });
            }
            function showServices(val1,val2){
                getInfoDiv(val1,val2);
            }
            function loadAllFAQs(){
                renderAllFAQs();
            }
            function renderHeader(val){
                //renderInfoDiv();
                console.log('inside renderHeader====='+val);
            }
            </script>
            <apex:actionFunction name="getInfoDiv" action="{!onFAQCatChange}" status="theStatus" oncomplete="renderagain();" id="getInfoDiv">
                <apex:param id="contentId1" name="contentId1" value=""/>
                <apex:param id="contentId2" name="contentId2" value=""/>
            </apex:actionFunction>
            <apex:actionFunction name="searchKeywork" action="{!searchFAQ}" status="theStatus" oncomplete="renderagain();" id="searchKeywork">
                <apex:param id="dataVal1" name="dataVal1" value=""/>
            </apex:actionFunction>
            <apex:actionFunction name="renderAllFAQs" action="{!loadDefaultFAQs}" status="theStatus" oncomplete="renderagain();" id="renderAllFAQs"/>
            <apex:actionFunction name="renderInfoDiv" reRender="faq_list" immediate="true" id="renderInfoDiv" oncomplete="reArrangeTitles()"/>
            <body>
                <div id="main">
                    <div id="page_content">
                        <div class="container">
                            <div class="page-header">
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/gpm">Dashboard</a></li>
                                    <li class="breadcrumb-item"><a href="/helpCenter">Help Center</a></li>
                                    <li class="breadcrumb-item">FAQs</li>
                                </ul>
                                <!-- .breadcrumb -->
                                <h1 class="page-title">FAQs</h1>
                            </div>
                            <!-- .page-header -->
                            <div class="base-layout help-center-layout">
                                <div class="base-side">
                                    <div class="base-side-content mb-0">
                                        <p class="text-light-2 fs-18">
                                            Get answers to all your questions regarding various processes and services available.
                                        </p>
                                    </div>
                                    <!-- .base-side-content -->
                                    <ul class="faq-category-list help-side-menu" id="faqs_filter">
                                        <li class="active"><a href="#" id="init" onclick="loadAllFAQs();">ALL</a></li>
                                        <apex:variable value="{!0}" var="ind1"/>
                                        <apex:repeat value="{!mainfaqOptions}" var="ser1" id="servRepeat1">
                                            <apex:variable var="ind1" value="{!ind1+1}"/>
                                            <li class="has-children">
                                                <a href="#">{!ser1.header}</a>
                                                <ul class="help-submenu">
                                                    <apex:variable value="{!0}" var="ind2"/>
                                                    <apex:repeat value="{!ser1.subHeaderWrapper}" var="subCat" id="servRepeat">
                                                        <apex:variable var="ind2" value="{!ind2+1}"/>
                                                        <li>
                                                            <a href="#" onclick="event.preventDefault();showServices({!ind1},{!ind2});">{!subCat.subHeadName}</a>
                                                        </li>
                                                    </apex:repeat>
                                                </ul>
                                            </li>
                                        </apex:repeat>
                                    </ul>
                                </div>
                                <!-- .base-side -->
                                <div class="base-main bg-transparent">
                                    
                                    <div class="row">
                                        <div class="col-xl-4 col-lg-5">
                                            <div class="d-flex align-items-center mb-4">
                                                <label class="mr-3 fs-18 font-weight-bold">Search:</label>
                                                <div class="form-group mb-0 w-100">
                                                    <apex:selectList value="{!filterVal}" id="exportAllFilter" size="1" styleClass="form-control input-select2-flat">
                                                        <apex:selectOptions value="{!Allvalues}"/>
                                                    </apex:selectList>
                                                </div>
                                            </div>
                                            <!-- .d-flex -->
                                        </div>
                                        <!-- /.col-lg-6 -->
                                        <div class="col-xl-8 col-lg-7">
                                            <div class="input-group input-filter-faqs mb-4">
                                                <input id="searchkw" type="text" class="form-control" placeholder="Search by keyword or a question you might have" style="border: none;" value="{!keyWord}" 
                                                       onkeyup="rerenderDetailBlock('searchVal');"/>
                                                <div class="input-group-append">
                                                    <button class="btn bg-white" type="button" style="border-radius: 0 0.5rem 0.5rem 0;">
                                                        <div class="icon-search" onclick="rerenderDetailBlock('searchVal');"></div>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- /.col-lg-6 -->
                                    </div>
                                    <!-- /.row -->
                                    
                                    <div id="faq_list">
                                        <apex:outputPanel id="faq_list">
                                            <div id="displayFAQOptions" style="{!IF(displayFAQOptions.size > 0 , 'display:block' , 'display:none')}">
                                                <apex:variable value="{!0}" var="ind1"/>
                                                <apex:repeat value="{!displayFAQOptions}" var="faqDeatils" id="faqRepeat">
                                                    <apex:variable var="ind1" value="{!ind1+1}"/>
                                                    <div class="base-collapse faq-collapse animated fade-in-up-sm">
                                                        <a href="#" class="collapse-header collapsed" data-toggle="collapse" data-target="#faq_item_{!ind1}">
                                                            <div class="collapse-title">{!faqDeatils.Summary}</div>
                                                        </a>
                                                        <div id="faq_item_{!ind1}" class="collapse">
                                                            <div class="collapse-content">
                                                                <p>
                                                                    <apex:outputText value="{!faqDeatils.Details__c}" escape="true"/>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </apex:repeat>
                                                <!-- .faq-collapse -->
                                            </div>
                                            <div style="{!IF(displayFAQOptions.size = 0 , 'display:block' , 'display:none')}">
                                                <p class="text-light-2 fs-18" style="text-align: center;">
                                                    No Records to display!!!
                                                </p>  
                                            </div>
                                        </apex:outputPanel>
                                    </div>
                                    
                                    <!-- #faq-list -->
                                    
                                    
                                    
                                </div>
                                <!-- .base-main -->
                            </div>
                            <!-- .base-layout -->
                        </div>
                    </div>
                </div>
            </body>
        </apex:form>
        <!-- main js -->
        <apex:includeScript value="{!URLFOR($Resource.assets_NUI, '/js/script.js')}"  />
    </html>
</apex:page>