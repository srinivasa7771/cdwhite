<apex:page id="page" standardStylesheets="true" sidebar="false" showHeader="true" deferLastCommandUntilReady="true" standardController="g_Req__c" extensions="gctlConMgmt" label="Key Contacts" title="Contact Management">
    <apex:includeScript value="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js"/>
    <apex:stylesheet value="{!$Resource.gCss}"/><apex:includeScript value="{!$Resource.jsH}"/>   
    
    <apex:stylesheet value="{!URLFOR($Resource.JQ, '/css/redmond/jquery-ui-1.10.4.custom.min.css')}"/>
    <apex:includeScript value="{!URLFOR($Resource.JQ, '/js/jquery-ui-1.10.4.custom.min.js')}"/>
    <div id="abx" style="width:450px;"><div id="adt" ></div></div>
    
    <script> 
        var cs={};var cif,cnt=0; var isCh = false; var roleMngr = '';
        $(document).ready(function(){loadData();});
       
        function loadData(){
            getC("mainban").style.display="none";if(typeof(cs['mRole__c'])!='undefined'){roleMngr=cs['mRole__c'].value;} disableFields();cRenderCon(false,'{!JSENCODE(lstCI.size)}');
            $("#pw").dialog({title:"Important Notice!",autoOpen: true, show: {effect: "drop",duration: 200},hide: {effect: "explode",duration: 400},width:600,maxHeight:500,overflow:true,modal: true,padding:0});     
        } 
   
    
    function chkBillingContact(count){
        var bCount = 0;
        for(var j=0;j<count;j++){
            var sta = cs['sta__c'+ j].value;
            if(sta=='Active'){
				var opt;
                var select = document.getElementById(cs['rol__c'+j].id);
                var options = select && select.options;
                for (var i=0, iLen=options.length; i<iLen; i++) {
                    opt = options[i];
                    if (opt.selected) { 
                        if(opt.value =='Billing Contact' || opt.text =='Billing Contact'){bCount++;}
                    }
                }
            }
        }
        
        if(bCount>1){  alrt("Data Error","A single billing contact should be active at any point in time. Please check all contact roles."); return true;}
        return false;
    }
    
      
    
    /*validate UAE Landline format*/
    function vLandline(f,cs,isReq){
        fldErr(f,null,isReq);
        var lndRgx = /^(?:\+971|00971|0)(?:2|3|4|6|7|9)[0-9]{7}$/; 
        if(cs[f].value.trim()!=''){
            var ldno = cs[f].value.trim();
            if(!lndRgx.test(ldno)){
                fldErr(f,'Expecting UAE Landline number',isReq);
                return false;
            }
        }
        return true;
    }

    
    function vfrm(count){
        
        var sRoles = 0;var selected = [];cnt=count; var brq = false;var roleChk=' ';
        
        //check # of billing contacts
        var multipleBillingContacts =  chkBillingContact(count);
        if(multipleBillingContacts){return false;}
        
        
        for(var i=0;i<count;i++){
            var sta = cs['sta__c'+ i].value;
            if(sta=='Active'){
                var iRole=cs['rol__c'+i].value; var iName=cs['name__c'+i].value; var iCon=cs['Con__c'+i].value; 
                var iEml=cs['email__c'+i].value; var iPhn=cs['phone__c'+i].value; var iLdno=cs['ldno__c'+i].value;
                
                fldErr('rol__c'+i,null,!0); brq = fldReq('rol__c'+i, cs) || brq;fldErr('email__c'+i,null,!0); brq = fldReq('email__c'+i, cs) || brq;
                fldErr('phone__c'+i,null,!0); brq = fldReq('phone__c'+i, cs) || brq;fldErr('ldno__c'+i,null,!0); brq = fldReq('ldno__c'+i, cs) || brq;
                fldErr('ad__c',null,!0);  brq = fldReq('ad__c', cs) || brq;
                
                fldErr('MEmailM',null,!0);  brq = fldReq('MEmailM', cs) || brq;
                fldErr('MPhone',null,!0);  brq = fldReq('MPhone', cs) || brq;
                
                brq =!(vMob('phone__c'+i,cs,true))||brq;
                brq =!(vLandline('ldno__c'+i,cs,true))||brq;
                
                var chk = cs['extcon__c'+i].checked;
                if(!chk){fldErr('Con__c'+i,null,!0); brq = fldReq('Con__c'+i, cs) || brq;}else{fldErr('name__c'+i,null,!0); brq = fldReq('name__c'+i, cs) || brq;}
            }
        }  
        brq = vVAN() || brq;
        if(brq==false){saveAccInfo();}else{alrt("Information Missing","Please check all the required fields and validate the data.");}
        
        return !brq;
    }
    
        function clsp(s,r){if(s=='true'){ window.top.location.reload(); /*if(r=='true'){window.top.location.reload();}else{setTimeout(function(){ window.open('', '_self', '');window.close();},2000);}*/}}  
        
        $("#abx").dialog({autoOpen: false,show: {effect: "drop",duration: 200},hide: {effect: "explode",duration: 400}});
        function alrt(a,b){document.getElementById("adt").innerHTML="<br/>"+b;$("#abx").dialog({width:300,modal:!0});$("#abx").dialog("option","title",a);$("#abx").dialog("open")}
        
        function fldsEdt(i){
            cs['Con__c'+i].disabled=false; /*cs['Con__lk'+i].style.display='block';*/ cs['sphn__c'+i].disabled=false; cs['seml__c'+i].disabled=false;cs['name__c'+i].disabled=false; 
            cs['email__c'+i].disabled=false;  cs['phone__c'+i].disabled=false;  cs['ldno__c'+i].disabled=false;
            cs['rol'+i].style.display='none';getC('rol_c'+i).style.display='block';cs['extcon__c'+i].disabled=false;
            
            var chk = cs['extcon__c'+i].checked; cs['extcon__c'+i].onclick();
            if(!chk){cs['Con__c'+i].style.display='block';cs['name__c'+i].style.display='none';}else{cs['Con__c'+i].style.display='none';cs['name__c'+i].style.display='block';}
        }
        function disableFields(s){
            var c = '{!JSENCODE(lstCI.size)}';
            for(var i=0;i<c;i++){
                var rol = cs['email__c'+i].value; 
                if(rol!='' && rol!=null) { 
                    cs['Con__c'+i].disabled=true;cs['Con__lk'+i].style.display='none'; cs['sphn__c'+i].disabled=true; cs['seml__c'+i].disabled=true; 
                    cs['name__c'+i].disabled=true; cs['email__c'+i].disabled=true; cs['phone__c'+i].disabled=true; cs['ldno__c'+i].disabled=true;
                    cs['Con__c'+i].style.display='none'; cs['extcon__c'+i].disabled=true;
                    
                    if(s=='save'){cs['rol'+i].style.display='none'; if(getC('rol_c'+i)!=null){getC('rol_c'+i).style.display='block';}
                                  if(getC('btnEdt'+i)!=null){getC('btnEdt'+i).style.display='block';}
                    }else{cs['rol'+i].style.display='block'; getC('rol_c'+i).style.display='none';  }
                    
                    var sta = cs['sta__c'+ i].value;
                    if(getC('btnDact'+i)!=null &&(sta=="Active" || sta==null)) {
                        cs['sta__c'+ i].value="Active";
                        getC('page:form:pbMain:rBlc:'+i+':pbs').style.background="white";getC("btnEdt"+i).style.display="block";
                        }else if(getC('btnDact'+i)!=null && sta=="Inactive"){
                        getC('page:form:pbMain:rBlc:'+i+':pbs').style.background="antiquewhite"; getC("btnEdt"+i).style.display="none";
                    }
                }
            } 
            getC('page:form').style.display = 'block';
        }
         
        function closef() { window.open('', '_self', '');window.close();}
        function cpyName(i){cs['name__c'+i].value=cs['Con__c'+i].value;}
        
        function cRenderCon(a,num,isNew) {
            for(var i=0; i<=num; i++){
                if(typeof(cs['extcon__c'+i])!='undefined'){
                    if(isNew!='true'){cs['extcon__c'+i].checked=true; }
                    var chk = cs['extcon__c'+i].checked;
                    if(chk){cs['name__c'+i].style.display = 'block';cs['Con__c'+i].style.display = 'none';cs['Con__lk'+i].style.display = 'none';
                    }else if(!chk){ cs['Con__c'+i].style.display = 'block';cs['Con__lk'+i].style.display = 'block';cs['name__c'+i].style.display = 'none';}
                }
            }
        }    
        //function hRq(){var brq = false;if(cs['name'].value!="" || cs['Con__c'].value!="") {fldErr('rol__c',null,!0); brq = fldReq('rol__c',cs) || brq;}return brq;}
        
        function removeCon(i){
            var sta = cs['sta__c'+ i].value;
            
            var selectedRoles='\n';
            var select1 = document.getElementById("page:form:pbMain:rBlc:"+i+":pbs:iRol:rol__c");
            for (var n1=0;n1<select1.length;n1++) {
                if(select1.options[n1].selected){
                    selectedRoles+=select1.options[n1].text+", ";
                }
            }
            selectedRoles = selectedRoles.substring(0, selectedRoles.length - 2) + " \n";
            var msg = "This contact will be removed from the list of Key-Contacts.\n\nPlease make sure you assign below role(s) to existing Contact or add a new key-contact: "+selectedRoles+" \n Are you sure to remove ?";
            if((sta=="Active" || sta==null || sta=='') && confirm(msg)==true) {
                cs['sta__c'+ i].value="Inactive"; getC('btnDact'+i).style.display="none";
                getC('page:form:pbMain:rBlc:'+i+':pbs').style.background="antiquewhite"; getC("btnEdt"+i).style.display="none";
                
                cs['Con__c'+i].disabled=true;cs['Con__lk'+i].style.display='none'; cs['sphn__c'+i].disabled=true; cs['seml__c'+i].disabled=true; 
                cs['name__c'+i].disabled=true; cs['email__c'+i].disabled=true; cs['phone__c'+i].disabled=true; cs['ldno__c'+i].disabled=true;
                cs['Con__c'+i].style.display='none'; cs['extcon__c'+i].disabled=true; cs['rol__c'+i].style.display="none";cs['rol'+i].style.display="none";
                cs['iRol'+i].style.display="none";getC('rol_c'+i).style.display='none';
    
            }
        }
        
        function asgnR(){
            var chk = cs['asgnR'].checked;
            if(chk) {
                cs['mRole__c'].value = 'Manager Incharge;VAT Contact;Office Admin/Manager'; //Billing Contact;
                cs['mRoleh1'].value = 'Manager Incharge;Office Admin/Manager'; //Billing Contact;VAT Contact;
            }else{cs['mRole__c'].value=roleMngr; cs['mRoleh1'].value= roleMngr;}
        }
    
    function vVAN(updtCon){
        fldErr('van__c',null,true); var x = cs['van__c'].value; var updt = false;
        if(x=='' || x==null){return false;}
        
        if(x=='100072771700003'){
        	fldErr('van__c','Invalid TRN!',true);
            return true;
        }
        if (! /^[0-9]{15}$/.test(x)) {
            fldErr('van__c','Please input exactly 15 Digits. e.g.123456789012345',true);
            return true;
        }
        
        return false;
    }
    
    
    function isNumberKey(evt){
        var isNum = true;
        var e = evt || window.event; 
        var charCode = e.which || e.keyCode;                        
        if (charCode > 31 && (charCode < 47 || charCode > 57)){isNum= false;}
        if (e.shiftKey){ isNum= false;}
        
        if(!isNum){fldErr('pb__c','Please input only digits.',true);}else{fldErr('pb__c',null,!0);}
        
        return isNum;
    }
    
    
    function toLowerCase(fid){
        if(cs[fid].value != null && cs[fid].value!=''){
            cs[fid].value = cs[fid].value.toLowerCase();
        }
    }
    
    </script> 
    
