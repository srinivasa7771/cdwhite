<apex:page controller="ExportTransactionsAsXMLCtrl" contentType="text/xml#Tecom-{!str}.xml" standardStylesheets="false" applyHtmlTag="false" cache="false" expires="0" sidebar="false" showHeader="false" readOnly="true">
   
    <Reconciliation>{!nwln}
        <ServiceProviderDetails>{!nwln}
            <SPCODE>DH</SPCODE>{!nwln}
            <SERVCODE>TECOM</SERVCODE>{!nwln}</ServiceProviderDetails>{!nwln}
        <TransactionDetails>{!nwln}
   <apex:repeat value="{!transList}" var="transaction"> {!nwln}
                <Transaction>{!nwln}
                    <SPTRN>{!transaction.tid}</SPTRN>{!nwln}
                    <TransDate><apex:outputText value="{0,date,dd'/'MM'/'yyyy HH:mm:ss}"><apex:param value="{!transaction.gwdt}" /></apex:outputText></TransDate> {!nwln}
                    <Amount>{!transaction.amt}</Amount> {!nwln}
                    <DEGTRN>{!transaction.gwrf}</DEGTRN> {!nwln}
                    <Status>0</Status> {!nwln}
                    <PaymentMethod>{!transaction.md}</PaymentMethod>{!nwln} </Transaction>
</apex:repeat>{!nwln}</TransactionDetails>{!nwln}</Reconciliation>
</apex:page>