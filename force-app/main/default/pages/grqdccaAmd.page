        function updateComponentJSCaller(val){
            if('{!req.id}' == '') {
                cs['xcddocs__c'].value = '';
            }
            $('.dynaComps,.existDirSec,#exMemLst,.existDirSec,#exMemOpt').hide();
            $('#exMemOpt input').prop('checked',false);
            cs['xcamc__c'].value=val;
            if (val && val =='Deregistration- Freelancer') {/* service - 923 */
                $('.base-nav-next').hide();
                 axsAlert('Information','Please click here to proceed with <a class="fs-18 text-danger" href="/grqsdr?sid=a29fu000000G633">Freelancer Deregistration</a>');
            }
            else if(val && !val.toLowerCase().includes('deregistration') && val!='Change of Company Address'&& !val.toLowerCase().includes('shares')){
                console.log('--Started the if condition---');
                var compName = '';
                for([i,v] of Object.keys(componentMap).entries()){
                    if(componentMap[v].indexOf(val)>-1)
                        compName = v;
                    console.log('---compName---'+compName);
                }
                showTempLoader();
                updateComponentJS(compName);
                console.log('--Ended the method---');
            }
            else{amdCat(val);}
        }
        
        

