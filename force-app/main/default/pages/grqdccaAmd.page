                    }
                }
                //ad3Data.serviceRequests[0].members = members;
            }
            if(adhArr.includes('dc') || adhArr.includes('ar')|| adhArr.includes('da')){
                let ad2Mems = [];
                if(!cs['xadtx2__c'])
                    return;
                $('.addedMem').each(function(){
                    let fn = $(this).find('.frstName').text();
                    let ln = $(this).find('.lstName').text();
                    let ppnb=$('#ppnb').val();
                    let action = $(this).attr('action');
                    let p = $(this).attr('ppnum');
                    let m = {};
                    m.firstName = fn;
                    m.lastName = ln;
                    m.action = action.toUpperCase();
                    m.UID = fn+''+ln+'_11';
                    m.UID =m.UID.replace(/\s/g, '')
                    m.ppNumber=ppnb;
                    if(p)
                        m.ppNum = p.toUpperCase();
                    //if(action == 'remove')
                    ad2Mems.push(m);
                })
                cs['xadtx2__c'].value = JSON.stringify(ad2Mems);
            }
        }
        function validateData_old(){
            if('{!req.id}'){
                toggleGLoader();
                next();
                return;
            }
            console.log('validateData:::');
            console.log('Notes:::::'+cs['nt__c'].value);
            var colNote = document.getElementById('page:mainForm:pbMain:collDelcmp:collDelInfo:nt__c').value;
            console.log('colNote:::::'+colNote);
            var conNote = document.getElementById('page:mainForm:pbMain:conTactcmp:conInfo:nt').value;
            console.log('conNote'+conNote);
            if(colNote != null && colNote != ''){
                cs['nt__c'].value = colNote;
                cs['nt'].value=colNote;
                document.getElementById('page:mainForm:pbMain:conTactcmp:conInfo:nt').value = colNote;
                console.log('NotesCol:::::'+cs['nt__c'].value);
            }   
            if(conNote != null && conNote != ''){
                cs['nt__c'].value = conNote;
                cs['nt'].value=conNote;
                document.getElementById('page:mainForm:pbMain:collDelcmp:collDelInfo:nt__c').value = conNote;
                console.log('NotesCon:::::'+cs['nt__c'].value);
            }
            
            var elem = '';
            var validated  = true;
            $('.requiredFld').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                var v = $(this).val();
                console.log('id:::::'+$(this).attr("id"));
                console.log('v:::::'+v);
                if(!v){
                    console.log('$$$$$$$$$$$$$$$$$$');
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            console.log('validated1::::'+validated);
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            console.log('validated1::::'+validated);
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated2::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            console.log('validated3::::'+validated);
            if(!cs['xcamdt__c'].value){
                //addValError($(cs['xcamc__c']),'**This field is required!');
                axsAlert('Alert','Please select <b>Amendment Type</b>');
                validated = false;
            }
            if((cs['nt'].value == null || cs['nt'].value == "") && (cs['xcamc__c'].value == 'Remove Activity')){
                //add required class to this component 
                var notes_input = cs['nt'];
                notes_input.classList.add("requiredFld");
                //axsAlert('Alert','Please enter notes');
                validated = false;
            }
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        }
