        /*U_S*/
         /*U_S Document List Preparation Start*/
        var missedData=false;
        var skipMissedMem=false;
        const missedFields = ['birthCountry','placeborn','gender','birthDate','nationality','passportShare'];
        function docListGen() {
            // --- Preparing Missed Members: if any member is missing in the above fields,
            // we prepare Existing Member documents for them.
            // Parse selectedJson safely
            let selectedDocNos = selectedJSON.flatMap(m =>
                                                      (m.passports || []).map(p => p.docNo).filter(Boolean)
                                                     );

            // Loop members
            for (let i of JSON.parse(cs['existingMemDetail'].value).licenseInfos[0].members) {
                const anyFieldIsNull = missedFields.some(field => i[field] === null);

                if (i.type === 'Person' && i.positions !== 'Ultimate Beneficiary' && anyFieldIsNull) {
                    if (cs['xcamc__c'].value === 'Change of General Manager' && i.positions === 'Manager') {
                        managerMem.push(i);
                    }
                    if (cs['xcamc__c'].value === 'Appoint/Change of Secretary' && i.positions === 'Secretary') {
                        secMem.push(i);
                    }

                    // only add to missedMem if not already in selectedJson (by docNo)
                    let memberDocNos = (i.passports || []).map(p => p.docNo).filter(Boolean);

                    // check if none of this member's passports exist in selectedJson
                    let hasDocInSelected = memberDocNos.some(doc => selectedDocNos.includes(doc));

                    if (!hasDocInSelected) {
                        missedMem.push(i);
                        missedData = true;
                    }

                    // Remove Manager/Sec if they were marked
                    if (managerMem.length) {
                        missedMem = missedMem.filter(item => item.ddaId !== managerMem[0].ddaId);
                    } else if (secMem.length) {
                        missedMem = missedMem.filter(item => item.ddaId !== secMem[0].ddaId);
                    }
                }
            }

            console.log('--missedMem--', missedMem);

            let docs = [], docStr = '';
            let addedMembersSet = new Set();

            // ---- Added Members Loop ----
            if(cs['xcamc__c'].value=='Change of Director - Add and Remove'){
                $('#addedMems .row').not('.newMemHead').each(function () {
                    let fn = $(this).find('.col-2').eq(0).text().trim();
                    let ln = $(this).find('.col-2').eq(1).text().trim();
                    let selectedFor = $(this).find('.col-2').eq(3).text().trim();
                    let fullName = fn + ' ' + ln;
                    addedMembersSet.add(fullName.toLowerCase()); // store in lowercase for comparison
                    if (fn && ln &&  selectedFor.toLowerCase() !== 'remove as director') {
                        docs.push('Passport Copy - ' + fullName);
                        docs.push('RIC Form - ' + fullName);
                    }
                });
            }
            else if(cs['xcamc__c'].value=='Change of Director - Add New'){
                $('#addedMems .row').not('.newMemHead').each(function () {
                    let fn = $(this).find('.col-3').eq(0).text().trim();
                    let ln = $(this).find('.col-3').eq(1).text().trim();
                    let fullName = fn + ' ' + ln;
                    addedMembersSet.add(fullName.toLowerCase()); // store in lowercase for comparison
                    if (fn && ln) {
                        docs.push('Passport Copy - ' + fullName);
                        docs.push('RIC Form - ' + fullName);
                    }
                });
            }
            docStr += docs.join(';') + ';';

            // ---- Missed Members Loop ----
            if (Array.isArray(missedMem) && missedMem.length > 0) {
                for (let exSh of missedMem) {
                    let firstName = capitalizeName(exSh.firstName.replaceAll("'", ""));
                    let lastName = capitalizeName(exSh.lastName.replaceAll("'", ""));
                    let fullName = firstName + ' ' + lastName;

                    // Only add Exmem Passport Copy if not in addedMembersSet
                    if (!addedMembersSet.has(fullName.toLowerCase())) {
                        if (docStr && !docStr.endsWith(';')) {
                            docStr += ';';
                        }
                        docStr += 'Exmem Passport Copy - ' + fullName + ';';
                    }
                }
            }

            // ---- Remove Duplicates & Ensure Ending Semicolon ----
            let docsArray = docStr.split(';').filter(item => item.trim() !== '');
            let uniqueDocsArray = [...new Set(docsArray)];
            let uniqueDocs = uniqueDocsArray.join(';') + ';';

            cs['xcddocs__c'].value = uniqueDocs;
        }
