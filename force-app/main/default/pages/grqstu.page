        //Validation for current Nationality if it is syria
        function validateCurrenNationality(thisElement){
            var curNat = $(thisElement).val();
            if(curNat == 'Syria'){
                addValError(thisElement,'Visa issuance subject to Immigration discretion');
                return false;
            }else{
                removeValError(thisElement);     
            }
        }
        //Validation  for UAE Mobile Number
        //in AXS2Customjs
        //validate mobile number
        function checkMob(thisElem){
            var mobNo = $(thisElem).val();
            if(mobNo.length < 10){
                addValError(thisElem,'Please enter valid mobile Number!!');
            }else{
                removeValError(thisElem);    
            }
        }
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                return false;    
            }else{
                removeValError(thisElement);   
                return r;
            }
        }
        //Calulate Age 
        function getAge(dob){
            console.log('getAge::::');
            var parts = dob.split("/");
            var dob = new Date(parts[2], parts[1] - 1, parts[0]);
            console.log('dob:::'+dob);
            var today = new Date(); var nowyear = today.getFullYear(); var nowmonth = today.getMonth();var nowday = today.getDate();
            var birthyear = dob.getFullYear(); var birthmonth = dob.getMonth();var birthday = dob.getDate();
            var age = nowyear - birthyear;
            console.log('age:::'+age);
            return age;
        }
        //Validation for Date of birth is 10 year old
        function validateDOB(thisElement){
            
            console.log('validateDOB::::');
            console.log('r::::'+checkValidDate(thisElement));
            if(checkValidDate(thisElement) == true){
                
                var date = $(thisElement).val();
                var age = getAge(date);
                
                if (age<=0) { 
                    removeWarningMsg(thisElement);
                    removeValError(thisElement);   
                    addValError(thisElement,'Date of birth should not be future date');
                    return false;   
                }else if(age<10 && age>0){
                    removeWarningMsg(thisElement);
                    removeValError(thisElement);   
                    addValError(thisElement,'Minimum Age should be 10 years');
                    return false;    
                }else if(age>25){
                    removeWarningMsg(thisElement);
                    removeValError(thisElement);   
                    addWarningMsg(thisElement,'Student aged above 25 years is subject to immigration discretion');
                    return false;
                }
                    else{
                        console.log('correct::::');
                        removeWarningMsg(thisElement);
                        removeValError(thisElement);     
                    }
            }
            
        }
        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //Validate Data on click of next button
        function validateData(){
            console.log('validateData:::');
            var elem = '';
            var validated  = true;
            
            
            $('.requiredFld, .applMob').each(function(){
                
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            var salutation = $("input[name='salutation']:checked").val();
            var martialStatus = $("input[name='martialStatus']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            //alert('salutation v:'+validated);
            if(martialStatus == undefined){
                $("input[name='martialStatus']").parent().parent().parent().find('.option-error').show();
                //alert('Please select martial status');
                validated =false;
            }//alert('martialStatus v:'+validated);
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }//alert('GCC_Nations v'+validated);
            
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            //console.log('Martial status:::'+cs['xcms__c'].value);
            //console.log('Student Graduate:::'+cs['xcstg__c'].value);
            console.log('Date of Birth:::'+cs['xcbd__c'].value);
            if(validated == true){
                if($("#optionallnm").is(':checked')){
                    cs["xcln__c"].value = cs["xcfn__c"].value; 
                    cs["xcfn__c"].value = '';
                }
                
                if(typicalCountries.includes(cs["xcnc__c"].value) ){/*&& cs["xcfn__c"].value.includes(cs["xcln__c"].value)*/
                    var tempName = cs["xcfn__c"].value.split(' ')[0];
                    cs["xcln__c"].value = cs["xcfn__c"].value.replace(tempName,'').trim();
                    cs["xcfn__c"].value = tempName;
                }
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        
        function svRDrft(){
            if($("#optionallnm").is(':checked')){
                cs["xcln__c"].value = cs["xcfan__c"].value; 
            }
            svRDrft2();
        }
        
        </script>
