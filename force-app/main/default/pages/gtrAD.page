<apex:page action="{!gAD}" renderAs="pdf" applyHtmlTag="false" cache="false" expires="0" readOnly="true" sidebar="false" showHeader="false"  title="Customer Deposit Statement" standardController="Account" extensions="gctlAdPDF" >
<head>
<style type="text/css" >
@page {
size: A4 portrait;
margin-right:1cm;
margin-left:1cm;
orphans:1; widows:1;
@bottom-left {
    content: "Print Date:<apex:outputText value="{0, Time, dd-MMM-yyyy: h:mm a}"><apex:param value="{!NOW()}"/></apex:outputText>";
    font-size:10px;
    font-family: Arial, Helvetica, sans-serif;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    border-top-style: solid;
    border-top-width: 1px;
    border-color:#c7c7c7;
}
@bottom-right {
    content: "Page " counter(page) " of " counter(pages);
    font-size:10px;
    font-family: Arial, Helvetica, sans-serif;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    border-top-style: solid;
    border-top-width: 1px;
    border-color:#c7c7c7;
}
@bottom-center {
    content: "Customer Deposit Activity Statement [<apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dF}"/></apex:outputText>-<apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dT}"/></apex:outputText>]";
    font-size:10px;
    font-family: Arial, Helvetica, sans-serif;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    border-top-style: solid;
    border-top-width: 1px;
    border-color:#c7c7c7;
}
}
thead{display: table-header-group;}
</style>
<apex:stylesheet value="/sCSS/66.0/sprites/1401037870000/Theme3/default/gc/elements.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401037870000/Theme3/default/gc/common.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401037870000/Theme3/default/gc/printableView.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1400172052000/Theme3/gc/dStandard.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401037870000/Theme3/default/gc/extended.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401037870000/Theme3/default/gc/zen-componentsCompatible.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401879760000/Theme3/00D20000000mHry/00520000003A38T/gc/dCustom0.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401879760000/Theme3/00D20000000mHry/00520000003A38T/gc/dCustom1.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401879760000/Theme3/00D20000000mHry/00520000003A38T/gc/dCustom2.css"/>
<apex:stylesheet value="/sCSS/66.0/sprites/1401879760000/Theme3/00D20000000mHry/00520000003A38T/gc/dCustom3.css"/>
</head>
<body>

<table border="0" cellpadding="0" cellspacing="0" style="width:100%">
    <tr>            
        <td nowrap="nowrap" style="width:1%;vertical-align:middle;"><apex:Image value="{!URLFOR($Resource.axsRS, '/images/Finance_Report.png')}" /></td>
        <td nowrap="nowrap" style="vertical-align:middle;">
            <h1>&nbsp;&nbsp;Customer Deposit Activity Statement</h1> - from <apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dF}"/></apex:outputText> to <apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!dT}"/></apex:outputText><br/>
            &nbsp;&nbsp;Print Date: <apex:outputText value="{0, Time, dd-MMM-yyyy: h:mm a}"><apex:param value="{!NOW()}"/></apex:outputText>
            <apex:pageMessages ></apex:pageMessages> 
        </td>
        <td nowrap="nowrap" align="right">
            <apex:image url="{!URLFOR($Resource.axsRS, '/images/axs_logo.png')}" width="100" height="40"/>         
        </td>
    </tr>
</table> 

<br/>
<apex:pageBlock mode="mainDetail"  tabStyle="Account" >
    <apex:pageBlockSection columns="2" collapsible="false" title="">
        <apex:outputfield value="{!A.Name}" label="Company Name" />
        <apex:outputfield value="{!A.lc__c}" />  
        <apex:outputfield value="{!A.adb__c}" label="Available Balance"/>            
    </apex:pageBlockSection>
    <apex:pageBlockSection columns="1" collapsible="false" rendered="{!OR(cd>0,db>0)}">     
        <apex:pageBlockSectionItem >
            <apex:outputLabel value="" />
            <apex:outputpanel >
                <apex:image id="theImage" url="https://chart.googleapis.com/chart?cht=p3&amp;chs=400x90&amp;chl=Total%20Credit%20AED%20{!cdT}|Total%20Debit%20AED%20{!dbT}&amp;chd=t:{!TEXT(cd/(cd+db))},{!TEXT(db/(cd+db))}&chco=f1f9ff|ff8989" width="400" height="90"/>
            </apex:outputpanel>
        </apex:pageBlockSectionItem>
    </apex:pageBlockSection>
    <apex:pageBlockSection columns="1" collapsible="false" title="Transactions History">
        <apex:pageBlockSectionItem >
            <apex:outputPanel >
                <table class="list" border="0" cellpadding="0" cellspacing="0" style="-fs-table-paginate:paginate;border:none;font-size:11px;page-break-inside:auto;">                    
                        <thead style="display:table-header-group;">
                        <tr class="headerRow">
                            <th scope="col">{!$ObjectType.g_Tran__c.fields.Name.label}</th>
                            <th scope="col">{!$ObjectType.g_Req__c.label}</th>
                            <th scope="col">{!$ObjectType.g_Tran__c.fields.TP__c.label}</th>
                            <th scope="col">{!$ObjectType.g_Tran__c.fields.dt__c.label}</th>
                            <th scope="col">Credit (AED)</th>
                            <th scope="col">Debit (AED)</th>
                        </tr> 
                        </thead>
                        <tbody>
                        <apex:repeat value="{!Ts}" var="T">                                    
                            <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;{!IF(T.isCrdt,'background-color:#f1f9ff;','')}">                               
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;"><apex:outputField value="{!T.T.Name}" />&nbsp;&nbsp;</td>
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;"><apex:outputField value="{!T.T.RQ__r.Name}"/>&nbsp;|&nbsp;<apex:outputField value="{!T.T.RQ__r.srvc__r.lbl__c}" />&nbsp;<apex:outputField value="{!T.T.RQ__r.Applicant_Name__c}"/></td>
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;"><apex:outputField value="{!T.T.TpAD__c}" /></td>
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;"><apex:outputField value="{!T.T.dt__c}" /></td>
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;text-align:right;"><apex:outputText rendered="{!T.isCrdt}" value="{!T.T.A__c}" /></td>
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;text-align:right;"><apex:outputText rendered="{!NOT(T.isCrdt)}" value="{!T.T.A__c}" /></td>                                       
                            </tr>   
                        </apex:repeat>                               
                        </tbody>
                </table>
            </apex:outputPanel>
        </apex:pageBlockSectionItem>
    </apex:pageBlockSection>
</apex:pageBlock>
</body>
</apex:page>