            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            var f = $(this).attr('fldname');
            ad4[cs['xadtx2__c'].value][f] = v;
        });*/
        cs['xadtx4__c'].value = JSON.stringify(ad4);
    }
