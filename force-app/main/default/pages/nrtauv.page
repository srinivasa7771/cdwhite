    <script>
    var selectedJSON = [];
    var allJSON = {};
    var lst_pdObj = {};
    var allJSONStr = '';
    var lst_pd = '';
    var allJSONObj1=[];
    var currentVehicle = 1;
    var uid;
    var fldToInput = {'cardNum':'rtacn__c','sector':'xps__c','cHolderNm':'xchn__c','chLand':'xoln__c','refMobile':'rmob__c','email':'xceml__c','vehicleNumber':'xpveh__c','pPlaceOfReg':'xppor__c','secVclNum':'xsvn__c','sPlaceOfReg':'xspor__c'};
    var mandateFlds = {'email':'xceml__c','refMobile':'rmob__c'};//,'chLand':'xoln__c'
    $(document).ready(function(){
        cs["uid"].value = "{!srv.uid__c}";
        //if()$('[vNum='+cs["xpveh__c"].value+']').prop('checked',true)
        callWS();
        $('.btn').on('click',function(event){
            event.preventDefault();
        });
        //setTimeout(settoFld(),1000);
        $('.requiredFldPop').on('change keyup',function(){
            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            if(v==''||v==undefined||v=='--None--'||v=='Select'){
                return;
            }
            else
                showErrMsg($(this),'rqrd',true);
        });
    });
    
    function formData(d){
        allJSONStr = d;
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        allJSONObj = JSON.parse(allJSONStr);
        //debugger;
        for(i of allJSONObj){
            var a = {};
            var b = {};
            // if(i.secVclNum==null){
            for(j of Object.keys(i)){
                if(j!='secVclNum'&&j!='sPlaceOfReg'){
                    a[j] = i[j];
                }
            }
            a['vehType'] = 'primary';
            allJSONObj1.push(a);
            //}
            if(i.secVclNum!=null){
                for(j of Object.keys(i)){
                    if(j!='vehicleNumber'&&j!='pPlaceOfReg'){
                        if(j == 'secVclNum')
                            b['vehicleNumber'] = i[j];
                        else if(j == 'sPlaceOfReg')
                            b['pPlaceOfReg'] = i[j];
                            else
                                b[j] = i[j];
                    }
                }
                b['vehType'] = 'secondary';
                allJSONObj1.push(b);
            }
        }
        var tableData='';
        for(i of allJSONObj1){
            var tr='<tr>';
            tr += '<td><label class="custom-radio"><input cNum="'+i.cardNum+'" vNum="'+i.vehicleNumber+'" type="radio" name="Vehicle number" checked='+((cs["xpveh__c"].value==i.vehicleNumber)?true:false)+' onchange="settoFld(this)" /><span></span></label></td>';
            if(i.vehicleNumber=='')
                tr +='<td><div class="vehicle-number mb-1"><span style="color:red;">No Vehicle</span></div></td>';
            else
                tr +='<td><div class="vehicle-number mb-1"><span>'+i.vehicleNumber+'</span></div></td>';
            tr +='<td>'+i.pPlaceOfReg+'</td>';
            tr += '<td>'+i.cHolderNm+'</td>';
            /*tr +='<td><b style="color: #E62D38;">NA</b></td>';*/
            tr +='<td style="text-transform: capitalize;">'+i.vehType+'</td>';
            tr +='<td>'+i.expDate+'</td>';
            tr +='<td>'+i.cardNum+'</td>';
            tr +='</tr>';
            tableData +=tr;
        }
        $('#parkingtable tbody').append(tableData);
    }
    
    
    function setToRQFld1(e){
        var id = $(e).attr('id');
        var id1 = $(e).attr('id1');
        if(cs['xadtx2__c'].value.includes('primary')){
            setToRQFld(id,e);
        }
        else if(cs['xadtx2__c'].value.includes('secondary')){
            setToRQFld(id1,e);
        }
    }
    var changed = 0;
    var changedJSON = {};
    function checkChange(e,id){
        if(selectedJSON.length>0&&selectedJSON[0][id]!=null){
