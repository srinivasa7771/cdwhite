                                            function submitPage(el,ev){
                                                var validated = true;
                                                var elem = '';
                                                if('{!JSENCODE(req.id)}'==''||'{!nD}'!='false'){//getUrlParameter('id')
                                                    axsAlert('Alert','Required vehicle documents are missing, please check');
                                                    return;
                                                }
                                                ev.preventDefault();
                                                for(i in mandateFlds){
                                                    var v = cs[mandateFlds[i]].value;
                                                    if(!v){
                                                        addValError(cs[mandateFlds[i]],'This field is required!');
                                                        validated = false;
                                                        if(elem=='') elem = cs[mandateFlds[i]];
                                                    }
                                                    else{
                                                        //removeValError(cs[mandateFlds[i]]);
                                                    }
                                                }
                                                if($('.frmErrMsg').is(':visible')){
                                                    scrollToDiv($('.frmErrMsg').eq(0).parent());
                                                    return;
                                                }
                                                if(validated){
                                                    //cs['xadtx4__c'].value = JSON.stringify(ad4);
                                                    toggleGLoader();
                                                    updItems();
                                                    pushPD();
                                                }
                                                else if(elem!='')
                                                    scrollToDiv($(elem));
                                                
                                            }
