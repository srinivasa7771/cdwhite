    // for OCR Component
    function attachmentSaveVRC(){
        isValidData = true;
        $('.requiredFldPop').each(function(){
            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            if(v==''||v==undefined||v=='--None--'||v=='Select'){
                isValidData = false;
                if($(this).is('select'))
                    showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                else
                    showErrMsg($(this),'rqrd','invalid');
                //return false;
            }
            else
                showErrMsg($(this),'rqrd',true);
            checkAllDates('vRegDate','152');
            if($('.frmErrMsg').length>1&&$('.frmErrMsg').is(':visible')){
                isValidData = false;
            }
        });
        
        if(checkVehicle() == true){
            return;
        }
        if(vaidateData()!=false){
            $('[forLoad="' + currentDoc + '"]').find('.loader_img').show();
            createAD4();
            $('#modal_RC_confirm_information,#modal_RC_confirm_information_back').modal('hide');
            saveAttachment_RC();
        }
    }
    
    function vaidateData(){
        isValidData = true;
        $('.requiredFldPop').each(function(){
            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            if(v==''||v==undefined||v=='--None--'||v=='Select'){
                isValidData = false;
                if($(this).is('select'))
                    showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                else
                    showErrMsg($(this),'rqrd','invalid');
            }
            else
                showErrMsg($(this),'rqrd',true);
        });
        checkAllDates('vRegDate','152');
        if($('.frmErrMsg').length>1&&$('.frmErrMsg').is(':visible')){
            isValidData = false;
            //return isValidData;
        }
        return isValidData;
    }
    var ad4 = {};
    function createAD4(){
        if(!ad4[cs['xadtx2__c'].value])
            ad4[cs['xadtx2__c'].value] = {};
        $('#modal_RC_confirm_information,#modal_RC_confirm_information_back').find('input,select').each(function(){
            if(!$(this).is(':visible'))
                return;
            var v = $(this).val();
            var f = $(this).attr('fldname');
            ad4[cs['xadtx2__c'].value][f] = v;
        });
