    function loadPrevData(){
        if('{!JSENCODE(req.id)}'!=''&&cs['xadtx2__c'] && cs['xadtx2__c'].value!=''){
            if(cs['xadtx2__c'].value=='primary'){
                $('#vehNum').val(cs['xpveh__c'].value);
                $('#por').val(cs['xppor__c'].value);
            }
            if(cs['xadtx2__c'].value=='secondary'){
                $('#vehNum').val(cs['xsvn__c'].value);
                $('#por').val(cs['xspor__c'].value);
            }
        }
        if(cs["xadtx4__c"].value!=''&&cs["xadtx4__c"].value){
            ad4 = JSON.parse(cs["xadtx4__c"].value);
        }
    }
    function checkVehicle(e){
        var vnu = $('#xpveh__c').val();
        for(i of lst_pdObj){
            if(vnu == i.vehicleNumber || vnu == i.secVclNum){
                addValError($('#xpveh__c'),'This vehicle already exists!');
                return true;
            }
            else
                removeValError($('#xpveh__c'));
        }
        return false;
    }
    function settoFld(p1,p2){
        lst_pd = p1;
        allJSONStr = p2;
        $('#vehicle_details').show();
        //$('#select_employee').show();
        var cardNum = getUrlParameter('c');
        var vehNum = getUrlParameter('v');
        if(vehNum.includes('%20')){
            vehNum = vehNum.replace('%20',' ');
            }
        //cs['rtacn__c'].value = cardNum;
        //$('.table-parking').parent().parent().find('.frmErrMsg').remove();
        allJSONStr = allJSONStr.split("\"Items\"").join('\'Items\'');
        lst_pd = lst_pd.split("\"Items\"").join('\'Items\'');
        lst_pdObj = JSON.parse(lst_pd);
        if('{!JSENCODE(req.id)}'==''){
            if(allJSONStr.length>0){
                allJSON = JSON.parse(allJSONStr);
                // for(i=0;i<allJSON.length;i++){
                    if(vehNum == allJSON[0].vehicleNumber||vehNum == allJSON[0].secVclNum){
                        selectedJSON[0] = allJSON[0];
                        $('#vehNum').val(vehNum);
                        if(vehNum == allJSON[0].vehicleNumber){
                            $('#por').val(allJSON[0].pPlaceOfReg);
                            cs['xadtx2__c'].value = 'primary';
                        }
                        else{
                            $('#por').val(allJSON[0].sPlaceOfReg);
                            cs['xadtx2__c'].value = 'secondary';
                        }
                    }
                //}
                for(i in fldToInput){
                    //var elem = $('.'+i);
                    var elem = $(cs[fldToInput[i]]);
                    elem.val(selectedJSON[0][i]);
                    if(elem.is('select')){
                        elem.trigger('change');
                    }
                }
            }
            else{
                $('#vehicle_details').html("<h1 style='color:#E62D38;'>No Matching records.</h1>");
                $('#vDocs,.sbmtBtn').hide();
            }
        }
        //cs["xadh__c"].value = '';
        //loadPrevData();
    }
    
