  <script>
 $(document).ready(function(){
     $('.div_ans').click(function () {
       $(this).toggleClass('selected');  
 });
 var ids = new Array();
$('#btn').click(function () {
    var selected_activities =$('.selected');
    var cm = $('#cmId').val();
    var ids = '';
    selected_activities.each(function(){
          var id_str   =  $(this).attr("id");
          var id_arr      =  id_str.split("_");
          var selval       =  id_arr[1];
        if(selval!='undefined' && selval!='' && selval!=null && selval!='Other'){
            ids = ids+selval+',';
        }
    });
    if(ids != null && ids != '')
        ids =ids.substring(0, ids.length - 1);
    var qid = 's';
    var ctg = '';
    if(cs['ans1'].value != null && (cs['ans1'].value == '1' || cs['ans1'].value == '2' || cs['ans1'].value == '3'))
     qid = 'd';
    if(cs['ans1'].value != null && cs['ans1'].value == '1')
      ctg = 'Very Dissatisfied';
    else if(cs['ans1'].value != null && cs['ans1'].value == '2')
      ctg = 'Dissatisfied';
    else if(cs['ans1'].value != null && cs['ans1'].value == '3')
      ctg = 'Passive';
    else if(cs['ans1'].value != null && cs['ans1'].value == '4')
      ctg = 'Satisfied';
    else if(cs['ans1'].value != null && cs['ans1'].value == '5')
      ctg = 'Very Satisfied';
     if(ids == '' && cm == '')
     {
         alert('Please select reason');
     }
    else if(ids == ''){
        ids = 'Others';
       ansSubmit(cs['ans1'].value,ids,cm,qid,ctg);
        }
       else
          ansSubmit(cs['ans1'].value,ids,cm,qid,ctg); 
    });
 });
     
     
</script>     
