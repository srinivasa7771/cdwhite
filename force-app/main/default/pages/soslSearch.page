                    </p>
                    <button class="btn btn-outline-primary open-request-option" data-target="request_options_3">
                        GET SERVICES
                    </button>
                </div>

                <div class="panel-request-mobile">
                    <button class="btn open-request-option" data-target="request_options_3">
                        COMPANY SERVICES
                    </button>
                </div>

            </div>
            <!-- .panel-request-main -->
        </div>
        <!-- .col -->

        <div class="col-lg-3 col-md-6">
            <div class="panel-request panel-request-main">
                <i class="icon-vfs request-icon"></i>

                <div class="panel-request-body">
                    <h4 class="request-title">OTHER SERVICES</h4>
                    <p class="request-description">
                        Parking, PO Box and other services from our partner
                    </p>
                    <button class="btn btn-outline-primary open-request-option" data-target="request_options_4">
                        GET SERVICES
                    </button>
                </div>
                
                <div class="panel-request-mobile">
                    <button class="btn open-request-option" data-target="request_options_3">
                        OTHER SERVICES
                    </button>
                </div>


            </div>
            <!-- .panel-request-main -->
        </div>
        <!-- .col -->

    </div>
    <!-- .row -->
                    </div>
                    <!-- #request_main -->

