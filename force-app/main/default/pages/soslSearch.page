                        <button class="btn btn-outline-primary btn-block">EMPLOYEE ABSCONDER WITHDRAWAL</button>
                        <button class="btn btn-outline-primary btn-block">IMMIGRATION PRINTOUT</button>
                        <button class="btn btn-outline-primary btn-block">STUDENT ABSCONDER DECLARATION</button>
                    </div>
                </div>
            </div>
            <!-- .col -->
        </div>
        <!-- .row -->
    </div>
    <!-- #request_options_1 -->
                    <div class="request-options" id="request_options_2" style="display: none;">
        <button type="button" class="btn btn-outline-primary request-options-back">
            <i class="fa fa-chevron-left"></i> BACK
        </button>
        <h3 class="modal-request-header">
            <i class="icon-immigration"></i>
            <span>VISA AND IMMIGRATION</span>
        </h3>
        <div class="row">
            <div class="col-lg-3 col-md-6">
                <div class="panel-request panel-request-options">
                    <h4 class="request-options-title">
                        NEW VISAS/REQUESTS
                    </h4>
                    <a href="#" class="request-options-title-dropdown collapsed" data-toggle="collapse"
