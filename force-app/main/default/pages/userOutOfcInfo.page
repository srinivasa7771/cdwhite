<apex:page standardController="User" Extensions="userOutOfOfficeExt" showHeader="false" sidebar="false">
    <apex:form >
        <apex:pageBlock id="useroutSec" title="Out Office">
            <apex:pageBlockSection columns="2">
            <apex:outputfield value="{!usr.Out_Of_Office__c}"  id="oo"/> <br/>
            <apex:inputfield value="{!usr.From_Date__c}"  id="fd"/> 
            
            <apex:inputfield value="{!usr.To_Date__c}"  id="td" /> <br/>        
            <apex:commandButton value="Submit" action="{!Save}" rerender="useroutSec" />
            </apex:pageBlockSection>

        </apex:pageBlock>
    </apex:Form>
</apex:page>