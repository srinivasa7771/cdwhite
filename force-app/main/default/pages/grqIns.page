    function saveDetails(){
        var brk = vflds('.requiredFld', true);
        var selectedpol = cs['xintp__c'].value; var insSelected = getC("adnicIns").checked;
        cs['xrped__c'].value=$('#xrped').val();
        if(selectedpol==null || selectedpol==''){ 
            getC("adnicIns").checked = true;
            hideTempLoader_input(); toggleGLoader(); brk=true; 
            $('#modal_insurance_sel').modal('show'); $( "#instype" ).focus(); return;
        } 
        if(!brk){
            afso(); 
        }else{
            toggleGLoader();hideTempLoader_input();
        }
    }
    
    function vflds(clsName, checkLookup){
        var brk = false;var elem = '';
        
        $(clsName).each(function(){
            var v = $(this).val();
            if($(this).is(':visible')){      
                if(v==''||v==null||v==undefined||v=="--None--"||v.length<1){
                    brk=true; addValError(this,'Value is required!'); 
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);}
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            }
        });
        
        return brk;
    }
    var exdateo;
    var exdatesp;
    function changeDate(elem) {
        var e = $(elem);
        exdateo = e.val();
        exdatesp =  exdateo.split('/')[2]+'/'+exdateo.split('/')[1]+'/'+exdateo.split('/')[0];
        console.log('--exdateo--'+exdateo);
        console.log('--exdatesp--'+exdatesp);
        
        var days=(new Date(exdatesp)-new Date())/1000/60/60/24;
        console.log('--days--'+days);
        if(new Date(exdatesp) <= new Date()){
            addValError('#xrped','RP Expiry date should be a future date');  
        }
        else if(days<1){
            addValError('#xrped','The residence permit should be valid.');
        }
            else{
                removeValError('#xrped');
            }
    }
