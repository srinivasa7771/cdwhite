        z-index: 0 !important;
        }
        
        /**** Update in styles.css ****/
        .bootstrap-datetimepicker-widget table td {
        padding: 5px !important;
        }
        .select2-container--default{
        width: 100% !important;
        }
        .page-item a{
        cursor: pointer;
        }
        .zoom{
        font-size: x-large;
        }
        span.box-check {
        display: block;
        cursor: pointer;
        }
        
        span.box-check > input {
        display: none;
        }
        
        span.box-check > input + .box::before {
        position: absolute;
        content: '';
        right: -27px;
        top: -27px;
        width: 0;
        height: 50px;
        background-color: #94CB59;
        -webkit-transform: rotate(45deg);
        -ms-transform: rotate(45deg);
        transform: rotate(45deg);
        -webkit-transition: all 0.3s;
        -o-transition: all 0.3s;
        transition: all 0.3s;
        }
        
        
        span.box-check > input + .box::after {
        display: inline-block;
        font: normal normal normal 14px/1 FontAwesome;
        font-size: inherit;
        text-rendering: auto;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        position: absolute;
        content: "\f00c";
        right: 3px;
        top: 3px;
        width: 13px;
        height: 13px;
        font-size: 13px;
        color: #fff;
        opacity: 0;
        -webkit-transition: all 0.3s;
        -o-transition: all 0.3s;
        transition: all 0.3s;
        }
        
        span.box-check > input:checked + .box {
        background-color: #DCDCDC;
        }
        
        span.box-check > input:checked + .box::before {
        width: 50px;
        }
        
        span.box-check > input:checked + .box::after {
        opacity: 1;
        }
        .loadingProgress{
        cursor: wait !important;
        pointer-events: none !important;
        }
        .loader_temp{
        padding-left: 1rem;
        }
        .tempLoader_input {    
