    <script type="text/javascript"> 
    var sta = "{!rq.STA__c}"; 
    var idleTime = 0; var idleInterval; var rmSecs = 10; var ispu = {!ispu};
    
    $(document).ready(function() { 
        /*if('{!JSENCODE(Acc.ORACLE_PARTY_ID__c)}'=='' ||!'{!JSENCODE(Acc.ORACLE_PARTY_ID__c)}'){
            $('#modal_no_opi').modal('show');
        }*/
        if(!cs['xadh__c'])
            cs['xadh__c']=getC('{!$Component.xadh__c}');
        if('{!JSENCODE(rq.STA__c)}'=='Draft' || '{!JSENCODE(rq.STA__c)}'=='Open'  ){$('#modal_welcome_back').modal('show');}
        if(cs['xfb__c']!=null && cs['xfb__c']!=undefined) getC('xfbdisp').value = cs['xfb__c'].value;
        if((sta=='Draft' || sta == 'Open') && ispu){ setPopupDuration();}
        
        $('.main-navbar-nav,.btn-new-request,#searchForm').remove();// to remove menu in header
        
        $('[name="est"]').on('change',function(){
            let v = $(this).val().toLowerCase();
            removeValError('[name="est"]');
            cs['xcst__c'].value = v;
            if(v=='yes' ){
                if(!cs["xadh__c"].value.includes('ec;') && '{!JSENCODE(rq.xvtyp__c)}' != 'DED')
                    cs["xadh__c"].value +='ec;vq;';
                
            } else{
                cs["xadh__c"].value = cs["xadh__c"].value.replace('ec;','');
                cs["xadh__c"].value = cs["xadh__c"].value.replace('vq;','');
                
            }
            var rqId1 = '{!JSENCODE(rq.id)}';
            if(cs['xcst__c'].value){
                $('[name="est"][value="'+cs['xcst__c'].value+'"]').prop('checked',true); 
            }
            
        });
    });
    
    function setPopupDuration(){
        idleInterval = setInterval(timerIncrement, 60000); 
        $(this).mousemove(function (e) {
            idleTime = 0;
        });
        $(this).keypress(function (e) {
            idleTime = 0;
        });
    }
    
    function timerIncrement() {
        idleTime = idleTime + 1;
        console.log(idleTime);
        if (idleTime == 10 ) {  
            $('#modal_saved').modal('show');
            clearInterval(idleInterval);
            //setInterval(displayAndLogout, 1000); 
        }
    }
    
    function displayAndLogout(){
        rmSecs = rmSecs - 1; 
        $('#logoutmsg').text("You will be logged out and this screen will close in #noofsecs seconds.");
        
        $('#logoutmsg').text($('#logoutmsg').text().replace('#noofsecs',rmSecs));
        if(rmSecs==0){
            nextpg1();
            window.location.href = "/secur/logout.jsp"; 
        }
    }
    
    
    
    
    function showTempLoader_input(e){
        $(e).addClass('tempLoader_input');
        $('*').addClass('loadingProgress');
    }
    function hideTempLoader_input(e){
        $('.tempLoader_input').removeClass('tempLoader_input');
        $('*').removeClass('loadingProgress');
    }
    function nextpg(t){
        //alert('tnbame:;'+t);
        showTempLoader(event.target);
        if('{!JSENCODE(rq.Acc__r.clt__c)}' != 'Land')
        {
            this.isRenderBus = 'true';
        }
        else
        {
            this.isRenderBus = 'false';
        }
        nextpg1(t);
        
    }
    
    function nextpg_brdcrmbs(t){
        var rqSta = '{!JSENCODE(rq.STA__c)}';
        if( rqSta!=null && (rqSta=='Open' || rqSta=='Draft')){return false;}  //t=='businessName' &&
        showTempLoader(event.target);
        if(t == 'businessName' && '{!JSENCODE(rq.xvtyp__c)}' == 'DED')
            t =  'confpage';
        nextpg1(t);
    }
    function nextpg2(t){
        setTimeout(function(){ nextpg1(t); }, 3000);
        
    }
    
    function shwComps(){
        $(".steps-desktop").hide();
        $("#dftStage").show();
        
    }
    
    var dateReg = new RegExp(/^\d{2}[./-]\d{2}[./-]\d{4}$/);
    function dformat2(dt,id){
        if(!dateReg.test(dt)){
            addValError(id,'Invalid date format!');
            return;
        }
        var datearray = dt.split("/");
        if(datearray[1] >12){
            dt = datearray[0] + '/' + datearray[1] + '/' + datearray[2].split(" ")[0];  
        }
        else{
            dt = datearray[1] + '/' + datearray[0] + '/' + datearray[2].split(" ")[0];    
        }
        var d = new Date(dt);//alert(d);
        var m=d.getMonth()+1;
        var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
        var mm=m>9?m:'0'+m;
        var yy=d.getFullYear();
        document.getElementById(id).value=dd+'/'+mm+'/'+yy;
    }
    
    setTimeout(function(){
        $('#modal_confirm_information,#add_corp_shareholder').modal('hide').on('hidden.bs.modal',function(){
            isCurrentlyEditing = false;
        });
    },1000);
    
    
    function convertToLower(e){//pass element, better on keydown
        $(e).val($(e).val().toLowerCase());
    }
    /* keep this in last please - VMKR */
    var makeReadOnly = (c) =>{
        $('.'+c).each(function(){
        $(this).addClass('readOnlyElem').parent().addClass('disabledCursor');
        if($(this).is('select')|| $(this).is('button')){
        $(this).attr('disabled','true');
    }
        /*else if($(this).is('input')){
                $(this).addClass('readOnlyElem');
            }
            else if($(this).is('a')){
                $(this).addClass('readOnlyElem');
            }*/
        $(this).addClass('readOnlyElem').parent().addClass('disabledCursor');
    });
    }
        
      
        
