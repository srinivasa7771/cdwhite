<apex:page sidebar="false" controller="SiteLoginController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="{!$Api.Session_ID!='NULL_SESSION_ID'}" standardStylesheets="false" title="Contact axs" >
    <apex:outputPanel rendered="{!$Api.Session_ID='NULL_SESSION_ID'}">
        <c:guheader heading="Contact Us" br="{!pk}" />
    </apex:outputPanel>
    <style>
        .iconF {
        font-size: 2em;
        color: #3e528a;
        }
        
        .iconF i {
        margin: 0.1em;
        }
        .iconF img {
        width: 1.2em;
        transition: width 1s, transform 1s;
        }
        
        .iconF .img1:hover {
        transform: rotate(360deg);
        width: 1.5em;
        }
        .form-group a {
        color: #000 !important;
        }
    </style>
    <div class="container">
        
        <div class="page-header pt-2 pl-3">
        </div>
        <!-- .page-header -->
        
        <div class="base-layout">
            
            <div class="base-main">
                <div class="base-main-content">
                    <div class="row">
                        <div class="col-lg-2"></div>
                        <div class="col-lg-3">
                            <div class="form-group">
                                <div class="iconF">
                                    <img class="img1" src="{!URLFOR($Resource.contactIcons, '/phone.png')}" />
                                    <Label>Phone</Label>
                                </div>
                                <div>
                                    <div class="contactSubtext"><a href="tel://8004297">800 4 AXS(297)</a></div>    
                                </div>                            
                            </div>
                        </div>
                        <!-- .col -->
                        <div class="col-lg-3">
                            <div class="form-group">
                                <div class="iconF">
                                    <img class="img1" src="{!URLFOR($Resource.contactIcons, '/mail.png')}" />
                                    <Label>Email </Label>
                                </div>
                                <div>
                                    <a href="mailto:support@axs.ae">support@axs.ae</a>
                                </div>                            
                            </div>
                        </div>
                        <!-- .col 
                        <div class="col-lg-3">
                            <div class="form-group">
                                <div class="iconF">
                                    <img src="{!URLFOR($Resource.contactIcons, '/YouTube_Icon.png')}" />
                                    <Label>Youtube</Label>
                                </div>
                                <div>
                                    <a href="https://www.youtube.com/channel/UCZKbzMF0z1WzOoPLObUtyaA" target="_blank">axs YouTube page</a>
                                </div>
                                
                            </div>
                        </div>
                        <!-- .col -->
                        <div class="col-lg-4">
                            <div class="form-group">
                                <div class="iconF">
                                    <img src="{!URLFOR($Resource.contactIcons, '/address.png')}" />
                                    <Label>Address</Label>
                                </div>
                                <div>
                                    Dubai Knowledge Park, Block 8<br />Ground Floor, Dubai, UAE.
                                </div>
                                
                            </div>
                        </div>
                        
                        <!-- .col -->
                    </div>
                </div>
                <!-- .base-main-content -->
            </div>
            <!-- .base-main -->
        </div>
        <!-- .base-layout -->
        
    </div>
    <apex:outputPanel rendered="{!$Api.Session_ID='NULL_SESSION_ID'}">
        <div class="site-footer-wrapper">
            <div class="container">
                <div class="site-footer">
                    <div class="footer-links">
                        <apex:outputText rendered="{!!invalidPK}">
                            <a href="/grqerAboutUS?i={!$CurrentPage.parameters.i}" target="_blank">ABOUT axs</a> |
                            <a>CONTACT US</a> |
                            <a href="/grqerTerms?i={!$CurrentPage.parameters.i}" target="_blank">TERMS OF USAGE </a> |
                            <a href="/grqerPolicy?i={!$CurrentPage.parameters.i}" target="_blank">PRIVACY POLICY</a>    
                        </apex:outputText>
                        <apex:outputText rendered="{!invalidPK}">
                            <a href="/grqerAboutUS" target="_blank">ABOUT axs</a> |
                            <a>CONTACT US</a> |
                            <a href="/grqerTerms" target="_blank">TERMS OF USAGE</a> |
                            <a href="/grqerPolicy" target="_blank">PRIVACY POLICY</a>
                        </apex:outputText>
                    </div>
                </div>
            </div>
        </div>
    </apex:outputPanel>
</apex:page>