<style>
        .bPageBlock {
            background-color: white !important;
            }
     .requiredBlock1 {
    background-color: #c00;
    position: absolute;
    left: -4px;
    width: 3px;
    top: 1px;
    bottom: 1px;
}
        .amount-collapse {
            margin-bottom: 10px;
        }
        
        .amount-collapse .amount-collapse-toggle {
            display: block;
            position: relative;
        }
        
        .amount-collapse .amount-collapse-toggle::after {
            content: "\f106";
            display: inline-block;
            font: normal normal normal 14px/1 FontAwesome;
            font-size: inherit;
            text-rendering: auto;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            position: absolute;
            top: 0;
            right: 12px;
            font-size: 32px;
            color: rgba(74, 74, 74, 0.5);
            line-height: 45px;
            transition: all 0.3s;
            transform-origin: center center;
        }
        
        .amount-collapse .amount-collapse-toggle.collapsed::after {
            top: 2px;
            transform: rotate(180deg);
        }
        
        .amount-collapse .amount-row-head {
            margin-bottom: 0;
        }
        
        .amount-collapse .amount-row {
            padding-right: 40px;
        }
        
        @media (min-width: 768px) {
            .amount-collapse .amount-row {
                padding-right: 50px;
            }
        }
        
        .amount-row {
            display: flex;
            padding: 6px 15px 0;
        }
        
        .amount-row:first-child {
            padding-top: 12px;
        }
        
        .amount-row-head {
            margin-bottom: 10px;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            background-color: #F5F5F5;
            color: #4A4A4A;
        }
        
        .amount-row-head .amount-row-title {
            font-weight: 500;
            font-family: "Helvetica Neue Cond", "Helvetica Neue", Arial, sans-serif;
            letter-spacing: 0.75px;
        }
        
        .amount-row-foot {
            font-size: 1rem;
        }
        
        .amount-row-rp {
            padding-right: 40px;
        }
        
        @media (min-width: 768px) {
            .amount-row-rp {
                padding-right: 50px;
            }
        }
        
        .amount-row-col {
            flex: 0 0 35%;
        }
        
        @media (min-width: 768px) {
            .amount-row-col {
                flex: 0 0 180px;
            }
        }
    </style>
