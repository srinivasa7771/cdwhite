    <script type="text/javascript">
   
    function cancelTran(chk){
       if(chk.checked){
         cs['nt__c'].style.display='';
         cs['ntlbl'].style.display='';
        }
        else{
           cs['nt__c'].style.display='none';
           cs['ntlbl'].style.display='none'; 
        }
        }
    function vfrm(){
        var brq = false; 
       
         brq=fldReq('tp__c',cs)||brq;
        if(cs['fwc__c'].checked)
          brq=fldReq('nt__c',cs)||brq;
       
        if(!brq && cs['tp__c'].value <1)
          fldErr('tp__c','Amount should ve valid.',!0);
         if(!brq) 
          afc();
        }
 </script>
    <c:pgHeader id="sH" entityId="{!T.Id}" ispu="false" tabName="Request" iconURL="{!URLFOR($Resource.axsRS, '/images/files.png')}" title="Customer Deposit Details" subtitle="" description="" STA="Open"  />
    <apex:actionStatus id="theStatus" startText="Loading... Please wait."><apex:facet name="start"><apex:outputPanel ><c:progress /></apex:outputPanel></apex:facet></apex:actionStatus>
    <apex:form id="f">
 <apex:pageBlock mode="edit" id="p" >
     <apex:actionFunction name="afc" action="{!crtTran}" status="theStatus" rerender="p,sH,msg" onbeforedomupdate="javascript:toggle_inputs();"/>
     <apex:pageBlockButtons >
          <a href="" onClick="vfrm();" class="btnCncl"> Submit</a>
     </apex:pageBlockButtons>
     <apex:pageBlockSection columns="1">
         <apex:pageBlockSectionItem >
         <apex:outputLabel value="Account" />
                    <apex:outputPanel >
                        <div id="acc" >
                          <apex:outputField id="accId" value="{!T.Acc__c}" style="font-size:11px;"/>
                        </div>
                    </apex:outputPanel>
         
        </apex:pageBlockSectionItem>
        <apex:pageBlockSectionItem >
         <apex:outputLabel value="Customer Deposit Topup Amount" />
                    <apex:outputPanel >
                        <div id="tp__cRI" class="requiredInput">
                            <div class="requiredBlock"></div>
                            <apex:input type="number" id="tp__c" value="{!topamt}" style="font-size:15px;"/>
                            <script type="text/javascript">
                                cs['tp__c']=getC('{!$Component.tp__c}');
                            </script>                         
                        </div>
                    </apex:outputPanel>
         
        </apex:pageBlockSectionItem>
        <apex:pageBlockSectionItem >
         <apex:outputLabel value="Do you want to cancel existing Transaction?" />
                    <apex:outputPanel >
                        <div id="fwc__cRI" >
                            <div>
                            <apex:inputCheckbox onclick="cancelTran(this)" id="fwc__c" /> 
                                <script type="text/javascript">
                                cs['fwc__c']=getC('{!$Component.fwc__c}');
                            </script>
                            </div>                            
                        </div>
                    </apex:outputPanel>
         
        </apex:pageBlockSectionItem>
       <apex:pageBlockSectionItem >
         <apex:outputLabel value="Notes" id="ntlbl" style="display:none" />
             
                  <apex:outputPanel >
                      <div id="nt__cRI" class="requiredInput">
                       <div class="requiredBlock"></div>
                       <apex:inputTextarea value="{!nt}" id="nt__c" rows="5"  cols="100" style="display:none" /> 
                      <script type="text/javascript">
                                cs['nt__c']=getC('{!$Component.nt__c}');
                                 cs['ntlbl']=getC('{!$Component.ntlbl}');
                                
                            </script>
                      </div>
                   </apex:outputPanel>
           
         
         
        </apex:pageBlockSectionItem>  
     
     </apex:pageBlockSection>
 </apex:pageBlock>
    
 </apex:form>  
</apex:page>