<apex:page sidebar="false" controller="PSADocController" action="{!AccountDetails}" showHeader="false" renderAs="pdf" applyBodyTag="false">
<head>
    <style>
        div.header{
            position: running(header);
            padding:5px 10px;
        }
        .sign{
            height:38px;
            width:100%;
        }
        .pgHead{
            color:blue;
            font-weight:bold;
            border-bottom: 1px solid black;
        }
       
    </style>
   
    <style>
        @page {
            margin: 1.8cm 1cm;
            size: A4;
            padding: 10px;
            @top-left {content: element(header);}
            @bottom-left {content: element(footer);}
        }
        body{        
            font-family:'Microsoft Sans Serif', sans-serif;
        }
        p,span,li{
            font-size:12px;
            text-align: justify;
            text-justify: inter-word;
        }
        underSignature{
            text-align: left;
            text-justify: none;
        }
        .container{
            position:absolute;
            margin-top: 20px;
        }            
        #LicenseNbre{
            font-family:Calibri;float:right;width:200px;margin-left:100px;
        }
        #DocumentTitle{
            border-bottom: 1px solid black;margin-left:200px;          
        }
        .smallTitles{
            border-bottom: 1px solid black;
        }
        .subTitles{
            margin-left:45px;
        }
        ol { counter-reset: item }
       
        li { display: block;padding:6px 0 6px 0; }
       
        li:before {
            content: counters(item, ".") "." " ";
            counter-increment: item;
        }
        .line{
            border-bottom: 1px solid black;  
            width:200px;
        }
        .acceptedBy{
            float: right;
        }
       
    </style>
    <!--  <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"/>-->    
    <apex:includeScript value="https://www.lightningdesignsystem.com/assets/styles/salesforce-lightning-design-system.min.css"/>
   
</head>
<body>
    <!--<apex:outputText rendered="false">
    <h1>
    Request is missing
    </h1>
    </apex:outputText>-->
    <apex:outputText rendered="true">
    <!-- <div class="header" >
    <div style="float:left">
    <img width='120' src="{!URLFOR($Resource.DubaiGovLogo)}" />
    </div>
    <div style="float:right">
    <img width='200' src="{!URLFOR($Resource.DDA_Logo)}" />
    </div>
    </div> -->
    <div>
        <div>
            <strong id="LicenseNbre">License No. {!LicenseNumber}</strong><br/><br/><br/>
            <strong id="DocumentTitle">
                EMPLOYEE SPONSORSHIP AGREEMENT
            </strong><br/><br/>
            <p class="subTitles">
                This Agreement is made on the <apex:outputText value=" {0,date, MMM d, yyyy}"> <apex:param value="{!AgreementDate}"/></apex:outputText>.
            </p>
            <strong class="subTitles">BETWEEN:</strong>
            <div>
                <ol>
                    <li>
                        Dubai Development Authority by virtue of Law No.15 of 2014 repealing the Law No. 1 of 2000 of the<br/>&nbsp;&nbsp;
                        Emirate of Dubai establishing the Dubai Technology and Media Free Zone (as amended) of P.O.Box<br/>&nbsp;&nbsp;&nbsp;
                        73000,Dubai, United Arab Emirates ("DDA")
                       
                        <p>
                            &nbsp; &nbsp;and
                        </p>
                    </li>                              
                    <li>
                        {!CompanyName} (the "Employer")
                    </li>
                </ol>
            </div><br/>
            <strong class="subTitles">WHEREAS:</strong>
           
            <div>
                <ol class="betweenList">
                    <li>
                        &nbsp; &nbsp; The Employer is a duly licensed business in the Zone.  
                    </li>                              
                    <li> &nbsp; &nbsp; The Employer wishes to engage Employees for its business in the Zone.</li>
                    <li> &nbsp; For the purposes of the Immigration and Labour Laws, DDA will arrange under its own name to obtain<br/>&nbsp;&nbsp;&nbsp;
                        residence and work permits for the Employees in the United Arab Emirates so as to enable the<br/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;employees to work for the Employer.
                    </li>
                </ol>
            </div><br/>
            <strong class="subTitles">IT IS AGREED AS FOLLOWS:</strong><br/>
            <div>
                <ol>
                    <li>
                        &nbsp; &nbsp; <span class="smallTitles">Terms and Conditions.</span>
                       
                        <ol>
                            <li>The General Terms and Conditions for Sponsorship of Personnel (2004 Edition) (the "General Terms and Conditions") (as may be amended from time to time by DDA) apply as the terms and conditions of this Agreement.</li>
                            <li>Capitalised Terms have the same meaning in this Agreement as set out in the General Terms and Conditions.</li>
                        </ol>
                    </li>
                    <li>
                        &nbsp; &nbsp;<span class="smallTitles">Sponsorship of Employees</span>
                        <div style="margin-left:25px;">                                
                            <p>
                                DDA shall sponsor the persons listed in a Schedule to be supplied in writing by the Employer (which
                                schedule may be amended from time to time by the Employer) (the "Employees") for the purpose of
                                employment by the Employer, and the Employer accepts the Sponsorship of the Employees by DDA,
                                subject to the General Terms and Conditions and this Agreement.
                            </p>
                        </div>
                       
                    </li>
                </ol>
            </div>
           
            <div class="acceptedBy">
                <br/>
                <p>
                    Electronically Accepted By
                </p>
                <p>
                    {!signedBy}
                </p>
                <p>
                    <apex:outputText value="{0,date,MMM d, yyyy h:mm a}">
                    <apex:param value="{!signedDate}" />
                </apex:outputText>
            </p>
        </div>
       
    </div>
    <div class="secondPage">
    </div>
</div>
</apex:outputText>
</body>
</apex:page>