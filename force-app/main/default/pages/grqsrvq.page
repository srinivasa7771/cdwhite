  <apex:actionStatus id="theStatus" startText="Loading... Please wait."><apex:facet name="start"><apex:outputPanel ><c:progress /></apex:outputPanel></apex:facet></apex:actionStatus>
</apex:outputPanel>  
 <apex:actionFunction name="ansSubmit" action="{!submit}" status="theStatus" reRender="stsId">
        <apex:param name="ans" assignTo="{!anwser2}" value=""/>
        <apex:param name="cm" assignTo="{!cm}" value=""/>
  </apex:actionFunction>  
    <apex:actionFunction name="prvsPage" action="{!previous}" status="theStatus" reRender="stsId" />   
    
