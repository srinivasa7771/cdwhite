<apex:page showHeader="false" sidebar="false" controller="gctlRQSRV">
 <head>
     <meta charset="UTF-8"/>
<title>axs | onsite survey</title>
     <link href="https://fonts.googleapis.com/css?family=Sintony:400,700" rel="stylesheet"/> 
     <script src="https://code.jquery.com/jquery-3.3.1.min.js"></script>
<script>
 $(document).ready(function(){
     $('.div_ans').click(function () {
       $(this).toggleClass('selected');  
 });
 var ids = new Array();
$('#btn').click(function () {
    var selected_activities =$('.selected');
    var cm = $('#cmId').val();
    var ids = '';
    selected_activities.each(function(){
          var id_str   =  $(this).attr("id");
          var id_arr	  =	 id_str.split("_");
          var selval       =  id_arr[1];
        if(selval!='undefined' && selval!='' && selval!=null){
            ids = ids+selval+',';
        }
    });
    if(ids != null && ids != '')
        ids =ids.substring(0, ids.length - 1);
     ansSubmit(ids,cm);
    });
 });
</script>     
<style>
	
	
	body {
		
		font-family: 'Sintony', sans-serif;
		margin: 0px;
		padding: 0px;
		
	}
	#axs_logo{
		
		margin-left: auto;
		margin-right: auto;
		width: 200px;
		margin-top: 40px;
		margin-bottom: 30px;
		
	}
	.selected
   {
     background-color:#5ac3ea !important;
     color : white; 
    }
	.survey_q{
		
		width: 100%;
		max-width: 770px; 
		margin-left:auto;
		margin-right: auto;
		text-align: center;
		font-size: 24px;
		color: #6D6D6D;
		
		font-weight: bold;
	}
	
	.survey_a{
		width: 100%;
		max-width: 820px; 
		margin-left:auto;
		margin-right: auto;
		text-align: center;
		margin-bottom: 40px;
		font-size: 20px;
		color: #6D6D6D;
		list-style: none;
	
	}
	.survey_a li{
		width: 100px;
		display: inline-block;
		margin-right: 20px;
		
	}
	 .div_ans {
       background-color: rgba(0,0,0,.01);
    width: 500px;
    border: 1px solid rgba(0, 0, 0, .1);
    font-size : 16px;
    padding: 15px;
    margin: 10px;
    margin-right: auto;
    margin-left: auto;
}
  .div_ans1 {
       
    width: 530px;
    font-size: 24px;
    color: #6D6D6D;
    font-family: 'Sintony', sans-serif;
    <!--font-size : 14pt;
    font-family : arial, helvetica, sans-serif;-->
    font-weight : bold;
    padding: 5px;
    margin: 5px;
    margin-right: auto;
    margin-left: auto;
}  
    .div_ans2 {
       
    width: 500px;
    font-family: 'Sintony', sans-serif;
    font-size: 70%;
    height : 1.5em;
    border : 1px solid #c2c2c6;
    padding: 10px;
    margin: 10px;
    margin-right: auto;
    margin-left: auto;
}  
    .Buttons {
      text-align : right;
      padding : 10px;
      margin-top : 10px;
      padding-right: 400px;
      margin-right: auto;
      margin-left: auto;
    }
    .Buttons1 {
      border : 1px solid #1048a9;
      background-color :#3E5089 !important; 
      color : #fff;
      font-size : 16px;
      padding : 8px 20px;
      margin-right: auto;
      margin-left: auto;
     }
	.survey_a li svg{
		width: 120px;
		height: 120px;
		fill: #adadad;
		display: block;
		margin-left: auto;
		margin-right: auto;
		 transition: all .2s ease-in-out;
		
	}
	.survey_a li svg:hover{
		
		fill: #5ac3ea;
	}
   
	
	</style> 
</head>

<body>
