<apex:page sidebar="false" cache="false" expires="0" title="Dependents with Non Sponsored Role" 
label="Dependents with Non Sponsored Role" controller="grNsh" showHeader="false">
<script type="text/javascript">
function pvb(val,p,n){ 
window.opener.document.getElementById('{!TBx}').value='';
window.opener.document.getElementById('{!TBx}').style.display='none'; 
window.opener.document.getElementById('{!TBx}'+'_lkwgt').style.display='none'; 
window.opener.document.getElementById('{!SId}').style.display='block';
window.opener.document.getElementById('{!SId}').value=val;
window.opener.document.getElementById('{!P}').value=p;
window.opener.document.getElementById('{!N}').value=n;
window.opener.nspEr();window.close();}
</script>
<apex:form ><apex:pageBlock >
<apex:pageBlockSection columns="1">
<font face="verdana" color="green"><h3>Non Sponsored dependents, who are working in a diffrent company.</h3></font>

<apex:pageBlockSectionItem >
<apex:outputpanel >
                        <table class="list" border="0" cellpadding="0" cellspacing="0">
                        <tbody>
                        <tr class="headerRow">
                        
                        <th class="col" scope="col">Name</th>                        
                        <th scope="col" nowrap="nowrap">Passport#</th>
                        <th scope="col" nowrap="nowrap">Nationality</th>                                 
                        <th scope="col" nowrap="nowrap">Role</th>
                        </tr>
                        </tbody>
                        <apex:repeat value="{!clst}" var="c">
                        <tr class="dataRow"><td class="dataCell">
                        <apex:outputLink value="{!c.FirstName } {!c.LastName }" onclick="pvb('{!c.FirstName } {!c.LastName }','{!c.p__c}','{!c.nc__c}')" rendered="{!NOT(ISNULL(c.Id))}">
                        {!c.FirstName } {!c.LastName }</apex:outputLink></td>
                        <td class="dataCell"><apex:outputField value="{!c.p__c}"/></td>
                        <td class="dataCell"><apex:outputField value="{!c.nc__c}"/></td>                        
                         <td class="dataCell"><apex:outputField value="{!c.pRol__c}"/></td>      
                        </tr>    
                        </apex:repeat>                        
                        </table>    
</apex:outputpanel> 
</apex:pageBlockSectionItem>
</apex:pageBlockSection></apex:pageBlock>
</apex:form>
</apex:page>