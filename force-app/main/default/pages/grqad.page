<apex:page sidebar="false" controller="ApplicantDetailController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true" standardStylesheets="false" title="{!req.srvc__r.lbl__c}">
    <html>
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        
        <meta name="viewport" content="width=device-width, initial-scale=1" /> 
        <script>
        var cs = {};
        var Ser_uid = '{!JSENCODE(req.srvc__r.uid__c)}';
        // Only page level validations
        function checkDatePageLevel(elem){
            var e = $(elem);
            removeValError(e);
            var date;
            var r = true;
            var date1 = e.val();
            date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
            var days = new Date(new Date()-new Date(date))/1000/60/60/24;
            if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
                addValError(elem,'Invalid date type!');
                r = false;
            }else if(days<1){
                addValError(elem,'Date should not be today/future date!');
                r = false;
            }else if(days>=1&&days<15){
                if(Ser_uid=='039'||Ser_uid=='083')
                    addValError(elem,'Service can only be applied after 15 days from Last attended date!');
                else
                    addValError(elem,'Service can only be applied after 15 days from Last day of work!');
                r = false;
            }
            return r;
        }
        
        function validateData(){
            var elem = '';
            var validated  = true;
            $('.requiredFld').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                var v = $(this).val();
                if(v==''||v==null || v==undefined){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            try{
                if(checkDatePageLevel)
                    validated = checkDatePageLevel($('#xaed__c'));
            }catch(e){
                console.log('No checkDatePageLevel Function in this page');
            }
            console.log('submit validated:::'+validated);
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                //console.log('Expiry Date:::'+cs['xcped__c'].value);
                //console.log('DOB:::'+cs['xcbd__c'].value);
                next();
                //alert("Req Updated::::::::::"); 
            }
        }
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        function showDraftAlert1(){
            var rqNum = '{!JSENCODE(req.Name)}';
            $('#modal_alert_global').remove(); 
            var cBlock = '<div class="modal fade modal-base" id="modal_alert_global" role="dialog" tabindex="-1" style="display: none;" aria-hidden="true"> <div class="modal-dialog" role="document" style="width: 607px;"> <div class="modal-content"> <div class="modal-body text-center pt-5 pb-5"> <div class="row"> <div class="col-12 order-md-2"> <div class="d-flex flex-column h-100"> <div class="mb-auto"> <div class="mb-3 fs-24" style="text-align:center;">Your Request has been saved!</div><div class="mb-3 fs-24">SR # <b>'+rqNum+'</b></div> <p style="text-align: center;">You can continue with this request from \'Drafts\' tab on your Dashboard<p class="col-xl-12 col-lg-12" style="font-size: 0.8em;text-align: center;"> <div class="col-xl-4"></div> <button class="col-xl-4 col-lg-12 btn btn-outline-primary mr-2 btn-block-sm" id="gDash">GO TO DASHBOARD</button> </div> </div> </div> </div> </div> </div> </div> </div></div>'
            $('body').append(cBlock);
            $('#modal_alert_global').modal('show');
            $('#gDash').on('click',function(){
                window.open('/gpm','_self');
            });
        }
        </script>
        
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <apex:form id="mainForm" styleClass="form-style">
            <apex:pageBlock id="pbMain">
                <apex:outputPanel id="saveRq"> 
                </apex:outputPanel>
                <apex:actionFunction name="next"  action="{!saveReq}" status="theStatus" reRender="pbMain,errmsg,saveRq,msg" oncomplete="$('#preloader').fadeOut();hideTempLoader_input();loadData_con();"    onbeforedomupdate="javascript: toggle_inputs();"/>
                <apex:actionFunction name="saveReqDraft1" action="{!saveDraft}" oncomplete="toggleGLoader();showDraftAlert1();" />
                <apex:actionFunction name="cancelRq" action="{!CancelR}" reRender="errmsg,msg" oncomplete="toggleGLoader();" />
                <apex:actionFunction name="svRDrft" action="{!saveDraft}" status="theStatus" rerender="msg"  oncomplete="toggleGLoader();showDraftAlert('{!JSENCODE(req.Name)}')"/>

                <apex:actionFunction name="boSave" action="{!saveBO}" oncomplete="hideGLoader();showDraftAlert2('{!JSENCODE(req.Name)}');" />
                <apex:outputPanel rendered="{!AND(NOT(ispu),NOT(isgu))}">
                    <c:guheader heading="{!srv.lbl__c}" />
                </apex:outputPanel>
                
                <body class="base">
                    
                    <div id="main">
                        <div class="container pt-2 pb-2">
                            <div class="text-right">
                                <span class="d-inline-block mr-2 align-middle" style="font-size: 1.875rem;line-height: 1;">
                                    SR # <span class="text-000">{!req.Name} </span>
                                </span>
                                <!-- <a href="#" onclick="saveReqDraft()" class="btn btn-black"> SAVE DRAFT </a>-->
                                <c:drftCnclBtns req="{!req}" shwCncl="true" shwDraft="{!IF(OR(req.id=='',req.STA__c=='Draft',req.STA__c=='Open'),true,false)}"/>

                            </div>
                        </div>
                        
                        
                        
                        <div class="container">
                            
                            <div class="base-layout">
                                <!--left-side pannel start-->   
                                <div class="base-side">
                                    <div class="base-side-content">
                                        <div>
                                            
                                            <c:grqupd Dim="V"/>
                                            
                                        </div>
                                    </div>
                                    <!-- .base-side-content -->
                                </div>
                                <!--left-side pannel- end -->  
                                <div class="base-main">
                                    
                                    <div class="base-main-content">
                                        
                                        <div class="steps steps-desktop">
                                            <div class="step-item active">
                                                <div class="step-item-inner">
                                                    <i class="step-icon icon-members"></i>
                                                    <div class="step-title">Applicant details</div>
                                                </div>
                                            </div>
                                            <div class="step-item">
                                                <div class="step-item-inner">
                                                    <i class="step-icon icon-cash-deposit"></i>
                                                    <div class="step-title">Review &amp; Payment</div>
                                                </div>
                                            </div>
                                            <!--  -->
                                        </div>
                                        <!-- end .steps -->
                                        
                                        
                                        <div class="steps steps-mobile">
                                            
                                            <div class="step-item active">
                                                <div class="step-item-inner">
                                                    <i class="step-icon icon-members"></i>
                                                    <div class="step-title">Applicant</div>
                                                </div>
                                            </div>
                                            <!--  -->
                                            <div class="step-item">
                                                <div class="step-item-inner">
                                                    <i class="step-icon icon-addon"></i>
                                                </div>
                                            </div>
                                            <!--  -->
                                            <div class="step-item">
                                                <div class="step-item-inner">
                                                    <i class="step-icon icon-cash-deposit"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- .steps-mobile -->
                                        
                                        
                                        <b><apex:pageMessages id="msg"  />
                                            
                                            
                                        </b>
                                        
                                        <!-- .base-collapse -->
                                        <div id="conlookuprow" class="row">
                                            <div class="form-group col-lg-6">
                                                <!--<c:gconlookup id="conlookup" Request="{!req}" role="Employee" accId="{!req.Acc__c}" sta="Active"/> -->
                                                <div class="form-group">
                                                    <label>Applicant name</label>
                                                    <input class="lookup form-control" disabled="true" id="conSerachVal" type="text" value="{!req.Con__r.firstName} {!req.Con__r.lastName}"/>
                                                    <!-- <apex:inputField styleClass="form-control" value="{!req.con__r.name}" id="xcfn__c" disabled="true"/>-->
                                                    <script type="text/javascript">
                                                    cs['xcfn__c']=document.getElementById('{!$Component.xcfn__c}');
                                                    </script>
                                                </div>
                                                <apex:inputHidden id="xadh__c" value="{!req.xadh__c}"/>
                                                <script>
                                                var lkpID = '{!$Component.conlookup}';
                                                cs["xadh__c"]=document.getElementById("{!$Component.xadh__c}");
                                                </script>
                                            </div>
                                            <apex:outputPanel styleClass="form-group col-lg-6" rendered="{!contains(req.srvc__r.name,'Declaration')}">
                                                <apex:outputText rendered="{!OR(req.srvc__r.uid__c=='037',req.srvc__r.uid__c=='038')}">
                                                    <label>Last day of work</label>
                                                </apex:outputText>
                                                <apex:outputText rendered="{!OR(req.srvc__r.uid__c=='039',req.srvc__r.uid__c=='083')}">
                                                    <label>Last attended date</label>
                                                </apex:outputText>
                                                <div class="input-datepicker-group input-group">
                                                    <apex:inputHidden id="xaed__c" value="{!req.xaed__c}" />
                                                    <input type="text" class="requiredFld form-control input-datepicker" id="xaed__c"
                                                           data-toggle="datetimepicker" data-target="#xaed__c" value="{!req.xaed__c}"
                                                           onchange = "cs['xaed__c'].value=this.value;checkDatePageLevel(this)"/>
                                                    <script type="text/javascript">
                                                    cs['xaed__c']=document.getElementById('xaed__c');
                                                    // dformat('{!JSENCODE(req.xaed__c)}','xaed__c');
                                                    cs['xaed__c']=getC('{!$Component.xaed__c}');
                                                    $('#xaed__c').val(getFormattedDate('{!JSENCODE(req.xaed__c)}'));
                                                    </script>
                                                    <div class="input-group-append">
                                                        <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#xcpid__c">
                                                            <i class="icon-date"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </apex:outputPanel>
                                        </div>
                                        <div class="base-collapse">
                                            <div id="application_details" class="collapse show">
                                                <div class="collapse-content">
                                                    <form class="form-style" id="app_details_form" action="">
                                                        
                                                        <c:eContactInfo req="{!req}" id="collDelcmp" />
                                                        
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- .base-main-content -->
                                        
                                        <!-- .base-main-content -->
                                        <c:saveBtn ispu="{!ispu}" isgu="{!isgu}"/>
                                        
                                    </div>
                                    <!-- .base-main -->
                                    
                                </div>
                                <!-- .base-layout -->
                                
                            </div>
                            <!-- .container -->
                            
                            
                            <!-- .site-footer-wrapper -->
                        </div>
                        
                        <!-- Modal -->
                        
                    </div>
                </body>
            </apex:pageBlock>
        </apex:form>
        <apex:form id="uploadFrm">
            
            <c:fileuploadpopupnew13 R="{!req}" /> 
            
        </apex:form>
    </html>    
</apex:page>