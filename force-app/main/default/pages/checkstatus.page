<apex:page showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5.0" Controller="reqstssearchctl">
    

<html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" lang="en">
        <head>
            <meta charset="utf-8" />
            <meta http-equiv="x-ua-compatible" content="ie=edge" />
            <title>Check Status</title>
            <meta name="viewport" content="width=device-width, initial-scale=1" />
            <!-- Import the Design System style sheet -->
            <link rel="stylesheet" href="https://rbbiapps.com/2019/tecom/assets/css/style.css?v=2.0.13"/>
        </head>
    <body>
    <apex:form >  
    
        <c:guheader heading="Check Status" br="" />
    
    <div class="container">
        
        <div class="page-header pt-2 pl-3">
            
<!--
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a href="#"><font style="vertical-align: inherit;"><font style="vertical-align: inherit;">Dashboard</font></font></a></li>
                <li class="breadcrumb-item"><font style="vertical-align: inherit;"><font style="vertical-align: inherit;">About axs</font></font></li>
            </ul>
-->
            <!-- .breadcrumb -->
            
            <!--<h1 class="page-title"><font style="vertical-align: inherit;"><font style="vertical-align: inherit;">ABOUT AXS</font></font></h1>
            -->
        </div>
        <!-- .page-header -->
        
        <div class="base-layout">
            
            <div class="base-main">
                <div class="base-main-content">
                     <apex:outputPanel rendered="{!!codeCheck}">
                    <h3 class="base-main-title">Enter service request number / Passport number to check the status of your application.</h3>
                     <div   align="center" >
                        
    <div class="col-lg-4 col-md-6">
        <div class="panel ui-panel h-100">
    <div class="panel-body p-xl-5">

        <div class="form-group">
              <apex:inputText value="{!searchstring}" label="Input"  styleClass="form-control input-search"   />
        </div>
          <div align="center">
              
                                                <apex:outputPanel rendered="{! codeCheck==false }" >
                                                    <div class="g-recaptcha" data-sitekey="{!sitekey}" style="transform:scale(0.90);"></div>
                                                    <script src='https://www.google.com/recaptcha/api.js'>
                                                    </script>
                                                </apex:outputPanel>
        </div><br/>
        <apex:commandButton value="Click hear to search " action="{!search}" styleClass="btn btn-primary btn-outline-primary-2" rendered="{! codeCheck==false }"   />
      </div></div></div>
                    </div>
                         </apex:outputPanel>
             <apex:pageBlock title="Application Status" rendered="{!codeCheck==true}" >
                  <apex:outputPanel rendered="{! actMsg!=null }" >   
                       <div   align="center" >
                 <div class="col-xl-4 col-lg-6" >
                        <div class="box status-box box-white aos-init aos-animate" data-aos="fade-up" data-aos-once="true">
                            <div class="status-box-icon">
                                
                            </div>
                            <div class="pt-2"></div>
                            <h4>Current Status</h4>
                            <div class="fs-16">
                                <p>
                                <apex:outputText value="{!actMsg}" escape="true"/></p>

                            </div>
                        </div>
                    </div>
                      </div>
                 </apex:outputPanel>
                 
                  <div class="panel">
    <div class="panel-body">

      
                 <div class="table-responsive table-responsive-lg">
                 <table class="table ui-table">
                     <thead>
                         <tr>
                     <th>MileStone</th>
                     <th>Staus</th>
                     <th>Modified Date</th>
                         </tr></thead>
                         <tbody>
                         <apex:repeat value="{!hist}" var="r">
                          <tr>
                     <td>{!r.itm__r.Name}</td>
                     <td>{!r.T__r.Name}</td>
                     <td>
                     <apex:outputText value="{0,date,dd/MM/yyyy'at' HH:mm:ss z}">
       <apex:param value="{!r.lastModifieddate}" />
   </apex:outputText>
                     </td>
                       </tr>
                         </apex:repeat>
                         </tbody>
                 </table>
                 </div>
                      </div>
                 </div>
               
                
                 <apex:commandButton value="Click hear to search another request" action="{!search}" onclick="window.history.go(-1);" styleClass="btn btn-primary btn-outline-primary-2" rendered="{! codeCheck==true }"   />            
                            </apex:pageBlock>
                    
                </div>
                <!-- .base-main-content -->
            </div>
            <!-- .base-main -->
        </div>
        <!-- .base-layout -->
        
    </div>
    <apex:outputPanel rendered="{!$Api.Session_ID='NULL_SESSION_ID'}">
        <div class="site-footer-wrapper">
            <div class="container">
                <div class="site-footer">
                    <div class="footer-links">
                        
                        <apex:outputText rendered="true">
                            <a>ABOUT axs</a> |
                            <a href="/grqerContactUs" target="_blank">CONTACT US</a> |
                            <a href="/grqerTerms" target="_blank">TERMS OF USAGE</a> |
                            <a href="/grqerPolicy" target="_blank">PRIVACY POLICY</a>
                        </apex:outputText>
                    </div>
                </div>
            </div>
        </div>
    </apex:outputPanel>
        </apex:form>
    </body>
        </html>
</apex:page>