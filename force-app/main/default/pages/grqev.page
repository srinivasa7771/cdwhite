        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //Validate Data on click of next button
        function validateData(){
            console.log('in validateData');
            var elem = '';
            var validated  = true;
            $('.requiredFld,.applMob').each(function(){
                //if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                //return;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null || v==undefined|| v=='--None--'){
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            $('.ddValidation').each(function(){
                //debugger;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                showErrMsg($(this),'rqrd',true);
                var v = $(this).val();
                if(v==''||v==null||v==undefined){
                    if($(this).is('select'))
                        showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                    else
                        showErrMsg($(this),'rqrd','invalid');
                    return false;
                }
            });
            var salutation = $("input[name='salutation']:checked").val();
            var martialStatus = $("input[name='martialStatus']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            //alert('salutation v:'+validated);
            if(martialStatus == undefined){
                $("input[name='martialStatus']").parent().parent().parent().find('.option-error').show();
                //alert('Please select martial status');
                validated =false;
            }//alert('martialStatus v:'+validated);
            if(validateBasicSalary( cs['xcmbs__c']) == false){   
                validated =false;
            }//alert('Basic salary v:'+validated);
            /*if(validateCurrenNationality(cs['xcnc__c']) == false){
                validated =false;
            }//alert('current Nationality v'+validated);*/
            if('{!req.acc__r.Legal_Framework__c}'=='Freelancer'){
                
                
                var sal = parseFloat($(cs['xcmbs__c']).val().replace(',',''));
                if($(cs['xcma__c']).val())
                    sal =  sal + parseFloat($(cs['xcma__c']).val().replace(',',''));
                if($(cs['xcmta__c']).val())
                    sal =  sal + parseFloat($(cs['xcmta__c']).val().replace(',',''));
                if($(cs['xcmoa__c']).val())
                    sal =  sal + parseFloat($(cs['xcmoa__c']).val().replace(',',''));
                if(sal > 10000){
                    validated =false;
                    axsAlert('Alert','Freelancer total Salary should NOT be more than AED 10,000');   
                    
                }
            }
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                scrollToDiv(elem);
            }
            console.log('uid===>', '{!req.srvc__r.uid__c}');
            if('{!req.srvc__r.uid__c}'=='gv') { //validate non sponsored id duration is selected
                let adh = cs['xadh__c'].value;
                console.log('adh===>', adh);
                let elem = $('#gvOption');
                if (elem.parents('.form-group').find('.frmErrMsg')) {
                    elem.parents('.form-group').find('.frmErrMsg').eq(0).remove();
                    elem.removeClass('is-invalid');
                }
                if(!adh.includes('id;') && !adh.includes('2id;') && !adh.includes('5id;')) {
                    validated = false;
                    console.log('::ERROR:::');
                    console.log('::gvOption===>',$('#gvOption'));
                    
                    var errElem = '<div class="frmErrMsg">Please select the Non Sponsored ID card duration.</div>';
                    elem.parents('.form-group').find('.frmErrMsg').remove();
                    elem.parents('.form-group').eq(0).append(errElem);
                    elem.addClass('is-invalid');  
                    scrollToDiv($('.frmErrMsg').eq(0).parent());                  
                }
                
            }
            
            console.log('submit validated:::'+validated);
            if(validated == true){
                /*** 
                showTempLoader(event.target);
                toggleGLoader();
                console.log('note:::'+cs['xcma__c'].value); console.log('Issue Date:::'+cs['xcpid__c'].value);
                //console.log('Expiry Date:::'+cs['xcped__c'].value); //console.log('DOB:::'+cs['xcbd__c'].value);
                next();
                **/ 
                
                // diverted flow to check the applicant name in immigration system 
                if(typicalCountries.includes(cs["xcnc__c"].value) ){/*&& cs["xcfn__c"].value.includes(cs["xcln__c"].value)*/
                    var tempName = cs["xcfn__c"].value.split(' ')[0];
                    cs["xcln__c"].value = cs["xcfn__c"].value.replace(tempName,'').trim();
                    cs["xcfn__c"].value = tempName;
                }
                else if($("#optionallnm").is(':checked')){
                    cs["xcln__c"].value = cs["xcfan__c"].value; 
                }
                toggleGLoader(); checkForName();
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
