<apex:page cache="false" controller="ApplicantDetailController" docType="html-5.0" standardStylesheets="false"   showHeader="{!IF(or(isgu=true,isFContU),false,true)}" sidebar="false" title="Application Submission" >
    <link rel="icon" href="./favicon.ico" />
    <style>
        i.selectPay {
        position: relative;
        padding: 5px 5px 0px 0px;
        cursor: pointer;
        }
    </style>  
    <body>
         <apex:outputPanel rendered="{!or(isgu,isFContU)}">
            <c:guheader heading="{!req.srvc__r.Name}" />
        </apex:outputPanel>
        <div class="container">
            <div class="onboarding-layout">
                <div class="onboarding-main">
                    <div class="onboarding-main-content">
                        <apex:outputText rendered="{!req.srvc__r.uid__c != 'dnc'}">
                            <h3 class="text-center pt-4">
                                Application Submission status
                            </h3>
                        </apex:outputText>
                        <apex:outputText rendered="{!AND(req.srvc__r.uid__c == 'dnc')}">
                            <!--<h2>
                                Thank you for submitting this request. Once issued, we will notify you to download the DDA NOC.
                            </h2>-->
                        </apex:outputText><br />
                        <div class="row">
                            <div class="col-xl-4 col-lg-6"></div>
                            <div class="col-xl-4 col-lg-6">
                                <div class="box status-box aos-init aos-animate" id="stsMsgId" style="background-color: #f4f4f4">
                                    <div class="status-box-icon">
                                        <i class="icon-ok circle-icon-ok"></i>
                                    </div>
                                    <h4>REQUEST SUBMISSION</h4><br />
                                    <p>
                                        Thank you for submitting <b>{!req.srvc__r.Name}</b> request <b>{!req.Name}.</b>
                                        <apex:outputtext rendered="{!AND(req.srvc__r.uid__c == '327',req.os__c=='Contractor Appointed',req.xfb__c == NULL)}">
                                            <br />We have sent an email to the contractor to provide further details. You will be notified as soon as they submit the application.
                                        </apex:outputtext>
                                        <apex:outputtext rendered="{!AND(req.srvc__r.uid__c == '327',req.xfb__c != NULL)}">
                                            <br />The application for the fit-out has been submitted to the engineering department. It usually takes 3 working days for approval.
                                        </apex:outputtext>
                                    </p>
                                    <apex:outputText rendered="{!AND(req.srvc__r.uid__c == 'dnc')}">
                                        <p>
                                            Once issued, we will notify you to download the DDA NOC.
                                        </p>
                                    </apex:outputText>
                                    <apex:outputtext rendered="{!!isgu}">
                                        <a href="/apex/grqStatus?id={!req.id}" class="btn btn-primary" style="color: #fff;">GO BACK TO REQUEST</a>
                                    </apex:outputtext>
                                    <!--<p>{!req.Name} was successfully submitted.</p><br />
                                        <div class="amount-row amount-row-head row-cols-2">
                                            <div class="amount-row-title mr-2" style="">Request#</div>
                                            <div class="amount-row-title mr-2" style="">Status</div>
                                        </div>
                                        <div class="amount-row row-cols-2">
                                            <div class="mr-2" style="">{!req.name}</div>
                                            <div class="mr-2" style="">{!req.STA__c}</div>
                                        </div>-->
                                </div>
                            </div>
                            <div class="col-xl-4 col-lg-6"></div>
                        </div>
                        <!--<div class="row mt-5 mb-3">
                            <div class="col-xl-12 col-lg-6">
                                <div class="onboarding-finish-status" style="background-color: #DCDCDC;" >
                                    <i class="icon-ok circle-icon-ok onboarding-finish-status-icon" ></i>
                                    <h4>{!req.srvc__r.Name}</h4>
                                    <div class="amount-row amount-row-head row-cols-3">
                                        <div class="amount-row-title mr-2" style="">Request#</div>
                                        <div class="amount-row-title mr-2" style="">Status</div>
                                        <div class="amount-row-title mr-2" style="">Status</div>
                                    </div>
                                    <div class="amount-row row-cols-3">
                                        <div class="mr-2" style="">{!req.name}</div>
                                        <div class="mr-2" style="">{!req.STA__c}</div>
                                        <div class="mr-2" style="">Submitted Successfully</div>
                                    </div>
                                    <apex:outputPanel rendered="{!IF((req.srvc__r.uid__c != 'dnc'),true,false)}">
                                        <div class="my-4">
                                            &nbsp; &nbsp;
                                            <a href="/apex/grqStatus?id={!req.id}" class="btn btn-primary" style="color: #fff;">REQUEST</a>
                                        </div>
                                    </apex:outputPanel>
                                </div>
                            </div>
                        </div>-->
                        <!-- .row -->
                    </div>
                    <div class="onboarding-main-footer">
                        <div class="onboarding-nav-wrapper">
                            <p class="onboarding-nav-info onboarding-footer-info">
                                <i class="icon-info-circle text-primary" style="vertical-align: middle;"></i>
                                You can access all information related to the Lease, License and Payments in ‘Company Info’
                                section from your Dashboard.
                            </p>
                            <apex:outputtext rendered="{!IF((req.srvc__r.uid__c != 'dnc'),true,false)}">
                                <div class="onboarding-nav">
                                    <p class="onboarding-nav-info onboarding-footer-info">
                                        <i class="icon-info-circle text-primary" style="vertical-align: middle;"></i>
                                        You can access all information related to the Lease, License and Payments in ‘Company Info’
                                        section from your Dashboard.
                                    </p>
                                    <apex:outputLabel rendered="{NOT(isFContU)}">
                                    <a href="/gpm" class="btn btn-primary onboarding-nav-next">
                                        GO TO THE DASHBOARD
                                    </a>
                                    </apex:outputLabel>
                                    <!--</apex:outputtext>-->
                                </div>
                            </apex:outputtext>
                            <!-- .onboarding-nav -->
                        </div>
                        <!-- .onboarding-nav-wrapper -->
                    </div>
                    <!-- .onboarding-main-footer -->
                </div>
            </div>
        </div>
    </body>
    <script>
    $(window).on('load', function() {
        if('{!JSENCODE(isFContU)}'=='true'){
            $(".open-request-modal").hide();
            $(".main-navbar-nav").hide();
            $(".connect-buttons-toggle").hide();
            $(".btn-notification").hide();
            $(".mr-auto").hide();
            $(".top-navbar-menu").hide();
            $(".badge-status").hide();
            $("#searchForm").hide();
            $("#nxtRen").text('{!JSENCODE(req.Acc__r.name)}');            
        }
    });
    </script>
</apex:page>