                window.open(websites[tempValue],'_blank');
            }
            function preload() {
                for (i =0; i<preload.arguments.length; i++) {
                    images[i] = new Image();
                    images[i].src = preload.arguments[i];
                }
            }
            $("link.user").each(function(){
                var h = $(this).attr('href').toLowerCase();
                if(h.indexOf('style')<0 && h.indexOf('axs2mandate')<0)
                    $(this).attr('disabled','disabled');
            });
            if(!tempValue)
