                if (!String.prototype.includes) {
                    String.prototype.includes = function() {
                        return String.prototype.indexOf.apply(this, arguments) !== -1;
                    };
                }
                if(navigator.appVersion.includes('MSIE 7.0') || navigator.appVersion.includes('MSIE 8.0')|| navigator.appVersion.includes('MSIE 9.0')|| navigator.appVersion.includes('MSIE 5.0')){
