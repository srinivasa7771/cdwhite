                        showTempLoader_input(cs['otp']);
                        createData();
                    }
                    else{
                        axsAlert('Error','Please enter OTP');
                    }
                }
            }
            
            function showErrorMsg(type,result,otpValMsg){
                if(type=='otp'){
                    hideTempLoader_input(cs['otp']);
                    if(result){
                        if(otpValMsg){$('.showonOTP,#mobText').hide();}
                        
                        addValError(cs['otp'],otpValMsg);//OTP validation failed, regenerate the OTP and verify.//Entered OTP is invalid, please check.<br>Alternatively you can re-generate the OTP.
                        $(cs['otp']).addClass('is-invalid');//notouch
                        //$('.showonOTP').hide();
                    }
                }
            }
            var onCaptchExpired = function(response){
                console.log('response::::'+response);
                $('#resendText').parents('.col-12').hide();
                $('#mobText,.base-nav-next').hide();
            }
            var correctCaptcha = function(response) {
                console.log('correctCaptcha::::');
                console.log('response::::'+response);
                if (response.length == 0) {
                    $('#recaptcha-error').show();
                    $('#recaptcha-error').focus();
                    //capNotChecked= true;
                }else if(response.length > 0){
                    //$('#g_recaptcha').hide();
                    //sendOtp($('#resendText'));
                    $('#resendText').parents('.col-12').show();
                    capNotChecked= true;
                }else {
                    $('#recaptcha-error').hide();
                    capNotChecked = false;
                }
                
                return capNotChecked;
            };
            function afterValidateCaptcha(res){
                axsAlert('Result',res);
            }
