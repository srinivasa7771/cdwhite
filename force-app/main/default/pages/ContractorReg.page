                    //$('#main_login').css('background-image',url);
                    $('.login-brand').css('background-image',logUrl);
                }
            });
            function getUrlParameter(key){
                var res = new RegExp('[\?&]' + key + '=([^&#]*)').exec(window.location.href);
                return (res==undefined)?'':res[1];
            }
            function search1(){
                search2();
            }
            var otpAttem = 0;
            function sendOtp(e){
                var validate = true; 
                
            if(validate){
            
                otpAttem++;
                $('#resendText').text('RE-GENERATE OTP');
                $(cs['otp']).removeAttr('disabled').removeClass('noTouch');
                $('.showonOTP,#mobText').show();
              
                generateOTP();
               
                $(cs['otp']).show();
                if(otpAttem>1){
                    $('#mobText span span').eq(0).text('A new ');
                }
            }
        }
            function validateFld1(e){
                //if($(e).val().length>=8){
                $(cs['cPassword']).val('');
                validateFld(e);
                //}
            }
            function validateFld(e){
                //var test=new RegExp("^[0-9A-Za-z_.]+$");
                var regex = new RegExp($(e).attr('regex'));
                var nextFld = $(e).attr('nextFld');
                var res = regex.test($(e).val());
                var infoElem = $(e).parents('.form-group').find('.info');
                if(!res){
                    infoElem.addClass('text-danger font-weight-bold fs-14').removeClass('text-black-50');
                    //infoElem.fadeOut().fadeIn().fadeOut().fadeIn();
                    $(e).focus();
                }
                else if($(e).val().length>=8){
                    infoElem.removeClass('text-danger font-weight-bold fs-14').addClass('text-black-50');
                    if(nextFld){
                        $(cs[nextFld]).removeAttr('disabled');
                    }
                    if($(e).attr('id').includes('username')){
                        //isUsernameAvailable(e);
                    }
                }
                // cs['pgpass'].value = $(e).val();
                
            }
            
            function assignOtp(e){
                cs["otpfrmPg"].value = $(e).val().trim();
                $('#g_recaptcha').show();
            }
            
            function checkCpwd(e){
                var pVal = cs["password"].value;
                if($(e).val().length==pVal.length && $(e).val() != pVal){
                    addValError(e,'Password doesn\'t match.!');
                }
                else if($(e).val().length==pVal.length && $(e).val() == pVal){
                    removeValError(e);
                    $('#g_recaptcha').show();
                }
            }
                        
            function createDataJS(){
                if(cs["otpfrmPg"]){
