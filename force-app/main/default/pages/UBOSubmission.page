    function checkExistingUBO(){
        var notDuplicateUbo=true;
        if($('[exc="uboexcevalue"] option:selected').val()=='true')
            return notDuplicateUbo;
        if({!editingUbo})
            return notDuplicateUbo;
        if('{!relatedTo}' == null ||'{!relatedTo}' == 'undefined'||'{!relatedTo}' == ''){
            var newUBO = cs['fName'].value+cs['lName'].value+cs['dob'].value+cs['nation'].value;
            if(JSON.parse(existingUbos).info.approvedubos.entries()){
                for([i,m] of JSON.parse(existingUbos).info.approvedubos.entries()){
                    if((m.dob)){
                        let existUBO = m.fName+m.lName+formatDate_LA(m.dob)+m.nation;
                        if(newUBO == existUBO){
                            notDuplicateUbo=false;
                            addValError($('#uboSaveBtn'),'An entry already exists with the same First Name, Last Name, Nationality and Date of Birth.');
                        }
                    }
                }
            }
            if(JSON.parse(existingUbos).info.request){
                for([i,m] of JSON.parse(existingUbos).info.request.requbos.entries()){
                    if((m.dob)){
                        let draftUBO = m.fName+m.lName+formatDate_LA(m.dob)+m.nation;
                        if(newUBO == draftUBO){
                            notDuplicateUbo=false;
                            addValError($('#uboSaveBtn'),'An entry already exists with the same First Name, Last Name, Nationality and Date of Birth.');
                        }
                    }
                }
            }
        }
        return notDuplicateUbo;
    }
