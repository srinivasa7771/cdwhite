                                    <div class="col-md-12" id="nacq1">
                                        <label>Are you acting as a nominee shareholder on behalf of a third party?</label>
                                        <div class="form-group mt-3 reqRadio">
                                            <label class="custom-radio mr-5">
                                                <input type="radio" ddaRsh="Yes" onchange="nomineeSH(this)"  for="nSHyes" html-for="nSHyes"  name="yName1" class="radioBtn nominee inActiveUbos"/>
                                                <span>Yes</span>
                                            </label>
                                            <label class="custom-radio mr-5">
                                                <input type="radio" ddaRsh="No" onchange="nomineeSH(this)"   for="nSHno"  html-for="nSHyes" name="yName1" class="radioBtn nominee inActiveUbos"/>
                                                <span>No</span>
                                            </label>
                                            <div class="option-error frmErrMsg" style="display:none">Please select an option!</div>
                                        </div>
                                    </div>
                                                    
                                    <div class="col-md-12" id="nacq2">
                                        <label>Are you acting as a nominee director on behalf of a third party?</label>
                                        <div class="form-group mt-3 reqRadio">
                                            <label class="custom-radio mr-5">
                                                <input type="radio" ddaRD="Yes" onchange="nomineeD(this)" for="nDyes"  name="yName2" class="radioBtn nominee"/>
                                                <span>Yes</span>
                                            </label>
                                            <label class="custom-radio mr-5">
                                                <input type="radio"  ddaRD="No" onchange="nomineeD(this)" for="nDno"  name="yName2" class="radioBtn nominee"/>
                                                <span>No</span>
                                            </label>
                                            <div class="option-error frmErrMsg" style="display:none">Please select an option!</div>
                                        </div>
                                    </div>
                                                    
                                                    <!-- Start Additional Details of UBO-->
                                                    <h2>Additional Details of Ultimate Beneficial Owner(s) (UBO)</h2>
                                                    
                                                    <div class="col-sm-6"> 
                                                        <div class="form-group"> 
                                                            <label> The number of other legal persons which the Beneficial Owner owns, manages or controls accordingly</label>
                                                            <apex:selectList value="{!indvInformation.noOfUBO}" size="1" id="legals" html-for="legals" styleclass="requiredFld form-control input-select2-flat">
                                                                <apex:selectOption itemValue="" itemLabel="None"/>
                                                                <apex:selectOption itemValue="0-1" itemLabel="0-1"/>
                                                                <apex:selectOption itemValue="2-3" itemLabel="2-3"/>
                                                                <apex:selectOption itemValue="4-5" itemLabel="4-5"/>
                                                                <apex:selectOption itemValue="6-7" itemLabel="6-7"/>
                                                                <apex:selectOption itemValue="8-9" itemLabel="8-9"/>
                                                                <apex:selectOption itemValue="More than 10" itemLabel="More than 10"/>
                                                            </apex:selectList>
                                                            <script type="text/javascript">
                                                            cs['legals']=getC('{!$Component.legals}');
                                                            </script>
                                                        </div>
                                                    </div>
                                                    <div class="form-group">
                                                        <div class="requiredInput" id="fileRI">
                                                            <br/><b>Upload passport/emirates ID card</b><br/>
                                                            <input type="file" id="file" name="passportEmiratesId" onchange="uploadFile()"/>
                                                            <script type="text/javascript">
                                                            cs['file']=getC('{!$Component.file}');
                                                            </script>
                                                            <apex:outputPanel id="file1">
                                                                <script type="text/javascript">
                                                                cs['file1']=getC('{!$Component.file1}');
                                                                </script>
                                                                <apex:repeat value="{!indvInformation.eId}" var="v">
                                                                    <div id="{!v.contentDocumentId}">
                                                                    <i class="fa fa-check-circle text-success"></i>
                                                                    <a href="{!v.url}" target="_blank" style="cursor:pointer" class="upload-item-title text-li">{!v.Name}</a> |&nbsp;&nbsp;
                                                                    <a  onclick="hideDoc('{!v.contentDocumentId}')" class="aBtn upload-item-remove"><i class="fa fa-close"></i></a>
                                                                    </div>
                                                                    </apex:repeat>
                                                            </apex:outputPanel>
                                                        </div>
                                                    </div>
                                                </apex:outputPanel>
                                                <!-- End Additional Details of UBO -->
                                            </div>
                                                                                        
                                            <div class="mt-4 base-main-footer form-group submitBtns" >
                                                <apex:commandButton styleClass="btn btn btn-primary base-nav-next" action="{!cancelNewUBO}" ondblclick="clearCache()" value="Cancel"/>
                                                <a href="" onClick="sv();" class="btn btn btn-primary base-nav-next" style="color:#fff" id="uboSaveBtn">Save</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                        </apex:outputPanel>
                        <div class="modal fade modal-base" id="CessationPopup" tabindex="-1" role="dialog" aria-hidden="true">
                            <div class="modal-dialog" role="document" style="width: 500px;">
                                <div class="modal-content">
                                    <div class="modal-body">
                                        <button aria-label="Close" class="close" data-dismiss="modal" type="button">
                                            <i class="icon-close"></i>
                                        </button>
                                        <br/>
                                        This action will lead to deletion of the UBO,system will automatically update the status as "Deleted" and a request will 
                                        be created which needs to be submitted for approval.
                                        <br/><br/>
                                        <div class="form-group">
                                            Enter the Cessation Date: 
                                            <div class="input-datepicker-group input-group" id="cessDateDiv">
                                                <apex:inputHidden id="cessDt1" value="{!cessDt}" />
                                                <input placeholder="DD/MM/YYYY" type="text" class="requiredFld form-control input-datepicker " id="cessDt"
                                                       onchange="checkDate(this,'arrInt');assignfldVal(this.value,'cessDt1');"
                                                       data-toggle="datetimepicker" data-target="#cessDt" value="{!cessDt}"
                                                       validationname="cessdtid"/>
                                                <script type="text/javascript">
                                                cs['cessDt']=getC('{!$Component.cessDt1}');
                                                cs['cessDt1']=getC('{!$Component.cessDt1}');
                                                </script>
                                                <div class="input-group-append">
                                                    <button class="btn text-primary" type="button" data-toggle="datetimepicker" data-target="#cessDt">
                                                        <i class="icon-date"></i>
                                                    </button>
                                                </div>
                                            </div>  
                                        </div>
                                        Do you wish to continue with this action?
                                        <div class="mt-4 base-main-footer">
                                            <a href="" onClick="sendCessDt()" class="btn btn btn-primary base-nav-next" style="color:#fff">Yes</a>
                                            <a href="" onClick="closeCessDtpopup()" class="btn btn btn-primary base-nav-next"
                                               style="color:#fff">No</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>  
                        <div class="modal fade modal-base" id="delDocPopup" tabindex="-1" role="dialog" aria-hidden="true">
                            <div class="modal-dialog" role="document" style="width: 500px;">
                                <div class="modal-content">
                                    <div class="modal-body">
                                        <button aria-label="Close" class="close" data-dismiss="modal" type="button">
                                            <i class="icon-close"></i>
                                        </button>
                                        <div class="row"> 
                                            <div class="col-12 order-md-2"> 
                                                <div class="d-flex flex-column h-100">
                                                    <div class="mb-auto"> 
                                                        <h4 class="mb-4" style="text-align:center;">Do you wish to continue deleting the Document?</h4> 
                                                        <div class="mt-4 base-main-footer">
                                                            <a href="" onClick="confirmDelDoc()" class="btn btn btn-primary base-nav-next" style="color:#fff">Yes</a>
                                                            <a href="" onClick="$('#delDocPopup').modal('hide');" class="btn btn btn-primary base-nav-next" style="color:#fff">No</a>
                                                        </div>
                                                    </div> 
                                                </div> 
                                            </div> 
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!--########################################################################################## -->
                    </div>
                </div>
            </div>
        </div>
        <c:grqupd Dim="L" PayDone="false"/>
        <c:fileuploadpopupnew13 R="{!rq}" /> 
    </apex:form>  
    
    <script>
    var countryCodeOptions1= '<option value=""></option>'; //1.1
    for(x=0;x<countryCodeObj_new.length;x++){
        var i = countryCodeObj_new[x];
        var opt = '<option value="'+i.dial_code+'">'+i.dial_code+'</option>';
        countryCodeOptions1 += opt;
    }
    $('.countrycodes').html(countryCodeOptions1);
    setTimeout(function(){
        $('.countrycodes').select2({allowSearch:true});
    },500);

    var countryNamesOptions= '<option value=""></option>'; //1.1
    for(x=0;x<countryCodeObj_new.length;x++){
        var i = countryCodeObj_new[x];
        var opt = '<option value="'+i.name+'">'+i.name+'</option>';
        countryNamesOptions += opt;
    }
    $('.countryNames').html(countryNamesOptions);
    setTimeout(function(){
        $('.countryNames').select2({allowSearch:true});
    },500);

    </script>
    
