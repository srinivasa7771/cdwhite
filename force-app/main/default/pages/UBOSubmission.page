    function checkPEDate(elem,type){
        var e = $(elem);
        var date;
        var date1 = e.val();
        date =  date1.split('/')[1]+'/'+date1.split('/')[0]+'/'+date1.split('/')[2];
        var days = new Date(new Date()-new Date(date))/1000/60/60/24;
        var r = true;
        if(date.length!=10||date.match(/\//g).length!=2|| isNaN(days)){
            r = 'invalid'
        }else if(type=='ubo'){
            if(days> 1) r='todayPast';
        }
        showErrMsg(e,type,r);
        if(r!=true){    
            e.focus();
        }
    }
    
