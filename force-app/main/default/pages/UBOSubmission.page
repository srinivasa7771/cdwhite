    function updateMobileFields(mobileNumber,countryCodeId,mobilePhoneId){
            let mobileText = mobileNumber.toString();
            let countryCodeContainerIdfinal =  'select2-'+countryCodeId+'-container';                                        
            let countryCodeSpan =  document.getElementById(countryCodeContainerIdfinal);                                             
            let refMobile = document.getElementById(countryCodeId); 

            if(mobileText.startsWith('00')){
                mobileText = mobileText.replace('00','');
            }
            else if(mobileText.startsWith('0')){
                mobileText = mobileText.replace('0','');
            }
            if(countryCodeSpan && mobileText.includes('-')){
                countryCodeSpan.innerHTML = mobileText.split('-',2)[0];
                cs[mobilePhoneId].value = mobileText.split('-',2)[1];
            } 
            else if(mobileText.includes('-')){
                document.getElementById(countryCodeId).value = mobileText.split('-',2)[0];
                cs[mobilePhoneId].value = mobileText.split('-',2)[1];
            }
            else{
                cs[mobilePhoneId].value = mobileText;
            }
        }
