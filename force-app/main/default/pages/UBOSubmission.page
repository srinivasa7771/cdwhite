                var stock=document.getElementById('{!$Component.formId.stock}');
                var isStock=false;
                if(stock!='' && stock!=undefined && stock!=null)
                    isStock=stock.checked;
                
                var gov=document.getElementById('{!$Component.formId.gov}');
                var isGov=false;
                if(gov!='' && gov!=undefined && gov!=null)
                    isGov=gov.checked;
                if(!isStock && !isGov)  {
                    brq=true;
                    fldErr('experror','Please select at leaset one exception',!0);
                }
                if(cs['fCor1'].children.length==1){
                    if(cs['fCor'].value==null || cs['fCor'].value==''){
                        fldErr('fCor','Value is required',!0);
                        brq=true;
                    }
                }
                
            }
        }
        if(isExceptionApplied=="true" || isExceptionApplied==true){
            isExceptionApplied=true;
        }else{
            if(cs['more'].checked==false && cs['director'].checked==false && cs['body'].checked==false && cs['managment'].checked==false && cs['corporate'].checked==false)
                fldErr('tou','Value is required',!0);
            if(cs['file1'].children.length==1){
                if(cs['file'].value==null || cs['file'].value==''){
                    fldErr('file','Value is required',!0);
                    brq=true;
                }
            }
            if(cs['fName']){
                brq = fldReq('fName',cs)||brq;
                brq = fldReq('lName',cs)||brq;
                brq = fldReq('nation',cs)||brq;
            }
            brq =!(epckPID('sv',cs['psIssue'].value))||brq;
            brq =!(epckPED('sv',cs['psExpiry'].value))||brq;
            brq = fldReq('psNo',cs)||brq;
            brq = fldReq('psIssuePlace',cs)||brq;
            brq = fldReq('placeofBirth',cs)||brq;
            brq = fldReq('psIssue',cs)||brq;
            brq = fldReq('psExpiry',cs)||brq;
            if(cs['dob']){                
                brq =!(ckDOB('sv',cs['dob'].value))||brq;
