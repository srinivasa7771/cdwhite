        <table width="47%" border="0" cellspacing="0" cellpadding="0">
            <tbody>
                <tr>
                    <th class="overview_title_employees">
                        <apex:outputLabel value="{!IF(srvc=='utl','Utilized Parkings ',if(srvc=='blnc','Parking Balance ','Parking Eligibility '))}" />
                    </th>
                </tr>
                <tr> 
                    <td><div class="emp_left">Free</div><div class="emp_right"> <apex:outputText id="fap" value="{!freeP}"/></div></td>
                </tr>  
                
                <tr> 
                    <td><div class="emp_left">Paid</div><div class="emp_right"> <apex:outputText id="pap" value="{!paidP}"/></div></td>
                </tr>
            </tbody>
        </table>
        
    </div>
</apex:page>