<body>
   

     
<table border="0" cellpadding="0" cellspacing="0" style="width:100%">

    <tr>            
        <td nowrap="nowrap" style="width:1%;vertical-align:middle;"><apex:Image value="{!URLFOR($Resource.axsRS, '/images/Finance_Report.png')}" /></td>
        <td nowrap="nowrap" style="vertical-align:middle;">
            <h1>&nbsp;&nbsp;Bank Guarantee Refund</h1><br/>
            &nbsp;&nbsp;(Print Date:<apex:outputText value="{0, Date, dd-MMM-yyyy}"><apex:param value="{!TODAY()}"/></apex:outputText>)
        </td>
        <td nowrap="nowrap" align="right">
            <apex:image url="{!URLFOR($Resource.axsRS, '/images/axs_logo.png')}" width="100" height="40"/>         
        </td>
    </tr>
</table> 
   
<br/>
<apex:pageBlock mode="mainDetail"  tabStyle="Account" >
    <apex:pageBlockSection columns="2" collapsible="false" title="">
        <apex:outputLabel value="Company Name"/>
        <apex:outputLabel value="Licence#"/>
       
        <br/><br/>
    </apex:pageBlockSection>
    
    <apex:pageBlockSection columns="1" collapsible="false" >
        <apex:pageBlockSectionItem >
            <apex:outputPanel >
                <b>Refund Details</b>  
               <table class="list" border="0" cellpadding="0" cellspacing="0" style="-fs-table-paginate:paginate;border:none;font-size:11px;page-break-inside:auto;">                    
                  
                   <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;">                               
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                                    <apex:outputLabel value="Receipt Number:" />&nbsp;&nbsp;</td>
                                            </tr>   
               
                   <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;"> 
                 <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                       <apex:outputLabel value="Amount (in AED):" />&nbsp;&nbsp;</td>
                                            </tr> 
                     <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;">                               
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                                    <apex:outputLabel value="PRO Mobile #:" />&nbsp;&nbsp;</td>
                                            </tr>   
                    <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;">                               
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                                    <apex:outputLabel value="Email ID:" />&nbsp;&nbsp;</td>
                                            </tr> 
                   <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;"> 
             <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                 <apex:outputLabel value="Reason For Refund Request: " />&nbsp;&nbsp;<br/>
                 <br/><br/><br/><br/><br/><br/>
                </td>
                </tr>  
                   
                   
                   <tr class="noRowsHeader" style="page-break-inside:avoid;page-break-after:auto;border-bottom:none;border-top:none;">                               
                                <td class="dataCell" style="border-bottom:none;border-top-width:1px;border-top-style:solid;border-left:none;">
                                    <apex:outputLabel value="Name of Authorized Signatory:" />&nbsp;&nbsp;<br/><br/><br/></td>
                                            </tr> 
                   
                </table>
          </apex:outputPanel> 
        </apex:pageBlockSectionItem>
         
    </apex:pageBlockSection>
</apex:pageBlock>
