<apex:page sidebar="false" title="Service Clone"  controller="xp_ct_serviceClone" >

 

<script>
function clone(){if(typeof AF_Clone == 'function'){AF_Clone();}}
function deleteService(){if(typeof AF_Delete == 'function'){AF_Delete();}}
function deleteServiceItem(){if(typeof AF_DeleteServiceItem== 'function'){AF_DeleteServiceItem();}}
function cloneServiceItem(){if(typeof AF_CloneServiceItem== 'function'){AF_CloneServiceItem();}}
function cloneItemToSameSer(){if(typeof AF_CloneItemToSameSer== 'function'){AF_CloneItemToSameSer();}}
function refreshService(){if(typeof AF_RefreshSer== 'function'){AF_RefreshSer();}}    
    
</script>
<apex:form >

<apex:actionFunction name="AF_Clone" action="{!cloneService}" status="theStatus" rerender="pbMain,msg"  />
<apex:actionFunction name="AF_Delete" action="{!deleteService}" status="theStatus" rerender="pbMain,msg"  />
<apex:actionFunction name="AF_DeleteServiceItem" action="{!deleteServiceItemById}" status="theStatus" rerender="pbMain,msg"  />
<apex:actionFunction name="AF_CloneServiceItem" action="{!cloneServiceItemByID}" status="theStatus" rerender="pbMain,msg"  />
<apex:actionFunction name="AF_CloneItemToSameSer" action="{!cloneItemByIDSameSer}" status="theStatus" rerender="pbMain,msg"  />
<apex:actionFunction name="AF_RefreshSer" action="{!refreshService}" status="theStatus" rerender="pbMain,msg"  />
<apex:pageMessages id="msg" />

<apex:actionStatus id="theStatus" startText="Updating Information. Please wait...">
        <apex:facet name="start">
            <apex:outputPanel >
                <c:progress id="progressid" />
            </apex:outputPanel>
        </apex:facet>
    </apex:actionStatus>
    
<apex:pageBlock mode="detail" id="pbMain">

<apex:pageBlockButtons >
<input type="button" value="  Clone  " class="btn" onclick="javascript: clone();" />
<input type="button" value="  Cancel  " class="btnCancel" onclick="javascript: cancel();" />
<input type="button" value="  Delete  " class="btnCancel" onclick="javascript: deleteService();" />
<input type="button" value="  Delete Item  " class="btnCancel" onclick="javascript: deleteServiceItem();" />
<input type="button" value="  Clone Item  " class="btnCancel" onclick="javascript: cloneServiceItem();" />    
<input type="button" value="  Clone Item - Same Service " class="btnCancel" onclick="javascript: cloneItemToSameSer();" />
<input type="button" value="  Refresh  " class="btnCancel" onclick="javascript: refreshService();" /> 
</apex:pageBlockButtons>

<apex:pageBlockSection columns="1" collapsible="false">



<apex:pageBlockSectionItem >
<apex:outputLabel value="Service" for="service" style="font-weight:bold"/>
<apex:selectList size="1" value="{!serviceID}" id="serviceID" >
<apex:selectOptions value="{!selectServList}"/>
</apex:selectList>
</apex:pageBlockSectionItem>


<apex:pageBlockSectionItem >
<apex:outputLabel value="New Service Name" for="servicename" style="font-weight:bold"/>
<apex:inputText value="{!newServiceName}" id="newServiceName" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
<apex:outputLabel value="Service Item Id" for="servicename" style="font-weight:bold"/>
<apex:inputText value="{!serviceItemId}" id="serviceItemId" />
</apex:pageBlockSectionItem>
<apex:pageBlockSectionItem >
<apex:outputLabel value="Old Service Unique Code" for="Old Service Unique Code" style="font-weight:bold"/>
<apex:inputText value="{!oldServCode}" id="oldServCode" />
</apex:pageBlockSectionItem>
<apex:pageBlockSectionItem >
<apex:outputLabel value="Service Unique Code" for="Service Unique Code" style="font-weight:bold"/>
<apex:inputText value="{!uniqServCode}" id="uniqServCode" />
</apex:pageBlockSectionItem>
<apex:pageBlockSectionItem >
<apex:outputLabel value="New Item Code" for="New Item Code" style="font-weight:bold"/>
<apex:inputText value="{!newItemUniqCode}" id="newItemUniqCode" />
</apex:pageBlockSectionItem>
<apex:pageBlockSectionItem >
<apex:outputLabel value="New Item Name" for="New Item Name" style="font-weight:bold"/>
<apex:inputText value="{!newItemName}" id="newItemName" />
</apex:pageBlockSectionItem>

</apex:pageBlockSection>
</apex:pageBlock>
</apex:form>
</apex:page>