<script type="text/javascript">
    var ispu={!ispu},lcl='{!lcl}',sta='{!rq.STA__c}',cs={}; 
    var isNew = '{!md.isNew}';var isView = '{!md.isView}'; var isEdit = '{!md.isEdit}';
    var lf='',af='',adf='',aif,adif,cif,fnxPg;
    var csf=new Array();
  
    var cs={}
    $(document).ready(function(){hdflds();})
    
    function vfrm(nSTA){return hsSnc(nSTA)?!1:hRq(nSTA)?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):hErr(nSTA)?(alrt("{!$Label.msgCRR}","{!$Label.msgCRRD}"),!1):valcbx()?(alrt("Agreement Missing","Agreement selection is required in order to process with your application."),!1):!0}
    function hsSnc(nSTA){return false;}
    function hErr(nSTA){return false;}
    
    function hdflds() {
        
        if(sta!="Draft"){
            var test = document.getElementsByClassName("btnNrm"); for(i=0;i<test.length;i++){if(test[i].text=="Edit"){test[i].style.display="none"}}
            getC("page:form:pbMain:pbsec").style.display='none';
        }

        if(isView=='false'){
            getC("page:form:noagr").style.display='none';
            if('{!$Profile.Name}'=='CC2'){cs['xchn__c'].style.display="none";}else{cs['Con__c'].style.display="none";cs['Con__clk'].style.display='none';}
        
            if('{!srv.uid__c}'=='197' && getC('xdcmt__cRI')!=null){
                /*getC('xdcmt__cRI').style.display='none';cs['xdcmt__cn'].style.display='none';cs['xdcmt__c'].value ="Lease Document Collection(Along with Cheque)";*/
                var selectobject=cs['xdcmt__c'];selectobject.length = 0;
                var option = document.createElement('option');option.text = 'Lease Document Collection(Along with Cheque)';option.value ='Lease Document Collection(Along with Cheque)';selectobject.add(option,0);
                cs['xdcmt__c'].style.display = 'none';cs['xdcmt__cn'].style.display = 'none';
            }
            shwAgreements();
            if('{!srv.uid__c}'=='197' ){
                if(typeof(cs['xanum__c'])!='undefined'){cs['xanum__c'].style.display='none';cs['xanum__cn'].style.display='none';}
                if('{!rq}'!=null && ((sta=="Draft" || sta=="Open") && ((isEdit=='true' || isNew=='true') && sta!="Under Review"))) {
                    if('{!ispu}'=='true'){callWS();}else{document.getElementById("page:form:pbMain").style.display='block';}
                }
            }else{document.getElementById("page:form:pbMain").style.display='block';getC('page:form:pbMain:pbsec').style.display='none';}
            
            
            if(typeof(cs['xchn__c'])!='undefined'){cs['xchn__c'].value = "{!$User.firstName}" +" "+ "{!$User.lastName}";}
        }
        /**var tInfo = getC('page:form:pbMain:pbsec:testTable_info');
        if(tInfo!=null && typeof(tInfo)!='undefined'){tInfo.style.display='none';}**/
    }
    
    function hRq(nSTA) {
        //if('{!srv.uid__c}'=='197'){return false;}
        if(!ispu){fldErr('acc__c',null,!0);}
        fldErr('xcfn__c',null,!0);fldErr('xcln__c',null,!0);fldErr('xdcmt__c',null,!0);fldErr('Con__c',null,!0);
        fldErr('rmob__c',null,!0);fldErr('xbn__c',null,!0);fldErr('xbrnd__c',null,!0);fldErr('xaloc__c',null,!0);
        fldErr('xanum__c',null,!0);fldErr('xchn__c',null,!0); 
        var brq = false; 
        if(!ispu){brq = fldReq('acc__c',cs)||brq;} 
        /***brq = fldReq('xcfn__c',cs)||brq; brq = fldReq('xcln__c',cs)||brq;***/ 
        if(!ispu){brq = fldReq('xdcmt__c',cs)||brq; }
        if('{!srv.uid__c}'!='197'){brq = fldReq('xanum__c',cs)||brq; }
        brq = fldReq('rmob__c',cs)||brq; brq = fldReq('xbrnd__c',cs)||brq; brq = fldReq('xaloc__c',cs)||brq; 
        if('{!$Profile.Name}'!='CC2'){brq = fldReq('xchn__c',cs)||brq;}else{brq = fldReq('Con__c',cs)||brq;}
        return brq;
    }
    
    function assignCon(name,mobile,zone,building,loc){
        cs['xchn__c'].value = name;cs['rmob__c'].value = mobile;
        cs['xbrnd__c'].value = zone;cs['xaloc__c'].value = loc;
        cs['xbn__c'].value = building;
    }
    
    function jumpToPage(){var table = $('[id$=testTable]').DataTable();table.page.jumpToData("true",3); table.column(4).visible(false);autoChck(); }
    function autoChck(){ 
        var checkboxs=document.getElementsByClassName("chk");        
        for(var i=0,l=checkboxs.length;i<l;i++) {if(checkboxs[i].checked){checkboxs[i].onclick();break;}}
    }

    function getSt(st){
        
        if(st=='true'){
            document.getElementById("page:form:pbMain").style.display='block';
            document.getElementById("page:form:noagr").style.display='none';
        }else{
            document.getElementById("page:form:pbMain").style.display= 'none';
            document.getElementById("page:form:noagr").style.display='block';
        } 
        
        if(isView=='false'){ 
            if('{!$Profile.Name}'=='CC2'){cs['xchn__c'].style.display="none";}else{cs['Con__c'].style.display="none";cs['Con__clk'].style.display='none';}
            if('{!srv.uid__c}'=='197' && getC('xdcmt__cRI')!=null){
                var selectobject=cs['xdcmt__c'];selectobject.length = 0;
                var option = document.createElement('option');option.text = 'Lease Document Collection(Along with Cheque)';option.value ='Lease Document Collection(Along with Cheque)';selectobject.add(option,0);
                cs['xdcmt__c'].style.display = 'none';cs['xdcmt__cn'].style.display = 'none';
            }
        }
    }
    
    function valcbx(){
        if('{!srv.uid__c}'!='197'){return false;}
        var checkboxs=document.getElementsByClassName("chk");var okay=false;           
        if(checkboxs.length <= 0) {okay=true;}else{for(var i=0,l=checkboxs.length;i<l;i++) {if(checkboxs[i].checked){okay=true;break;}}}
        return !okay;
    }
    
    function  chngNoOfDoc(a,flag,agNo){
        
        if(flag == 'valChng')  {
            var nDocId = a.id.replace("noDoc","chk");
            if( getC(nDocId).checked == false){ getC(nDocId).checked=true;}
        }
        var x=0;var y='';var z='';
        
        for(var i=0;i<csf.length;i++){
            var chkId = csf[i].id.replace("noDoc","chk");
            var argId = csf[i].id.replace("noDoc","cdnum");
            
            if(getC(chkId).checked == true){
                x =Number(x) +Number(csf[i].value);
                if(y==''){y = getC(argId).innerHTML;}else{y = y +',' + getC(argId).innerHTML;}
                if(z==''){z = getC(argId).innerHTML + ':' + csf[i].value;}else{z = z +',' + getC(argId).innerHTML + ':' + csf[i].value;}
            }
        }
        cs['prntcnt__c'].value =x;
        cs['xneng__c'].value =x;cs['xanum__c'].value =y;cs['xccn__c'].value =z;
        //  return a;
    }
    
    function urinfo(a,cardNum,sector,vehicleNumber,vDetails,cardId,noOfCheq){
        //alert('cardNum : '+ cardNum + ' sector: ' + sector+ ' vehicleNumber: ' + vehicleNumber+ ' vDetails: ' + vDetails+ ' cardId: ' + cardId);
        
        if($(a).is(":checked")){
            var exNum = cs['xanum__c'].value;
            /**    exNum = exNum+':'+ noOfCheq +',' + cardNum;
           if(exNum!==''){exNum += +':'+noOfCheq+',' + cardNum;
                }else{exNum = cardNum+':'+noOfCheq;}
            cs['xanum__c'].value = exNum;**/

        }else{
            /**  var agValue = cs['xanum__c'].value;
            if(agValue.includes(','+cardNum)){
                cs['xanum__c'].value = agValue.replace(','+cardNum,'');
            }else if(agValue.includes(cardNum+',')){
                cs['xanum__c'].value = agValue.replace(cardNum+',',''); 
            }else if(agValue.includes(cardNum)){
                cs['xanum__c'].value = agValue.replace(cardNum,''); 
            } **/
        }
    }
    
    function updateAgr(){if('{!srv.uid__c}'=='197'){if(cs['acc__c'].value!=''){fldErr('acc__c',null,!0);callWS();assignMngr();} shwAgreements();}}
    
    function shwAgreements(){
        
        if(getC('page:form:pbMain:pbsec')!=null){
            getC('page:form:pbMain:pbsec').style.display='none';getC('page:form:pbMain:pbBkof').style.display='none';
            
            if('{!srv.uid__c}'=='197' && (isNew || isEdit)){ 
                if(typeof(cs['acc__c'])!='undefined' && cs['acc__c'].value==''){getC('page:form:pbMain:pbsec').style.display='none';getC('page:form:pbMain:pbBkof').style.display='block';
                }else{if(sta=="Draft"){getC('page:form:pbMain:pbsec').style.display='block';}getC('page:form:pbMain:pbBkof').style.display='none';}
            }
       }
    }
    
    function updateConName(){cs['xchn__c'].value = cs['Con__c'].value;}
    function ifrm(){}
  
    function pvc(){var a=document.getElementById(cif);void 0!=a&&""!=a.value&&"000000000000000"!=a.value&&window.open("/apex/gcp?id="+a.value,"gcp","menubar=0,toolbar=0,titlebar=0,status=0,location=0,scrollbars=0,resizable=1,top=28,left=0,width=580,height=580",!1)}
    function pvc2(){window.open("/apex/gcp?id={!rq.Con__c}","gcp","menubar=0,toolbar=0,titlebar=0,status=0,location=0,scrollbars=0,resizable=1,top=28,left=0,width=580,height=580",false);}
    /*changes for DI starts*/
    function setToRQFld(id,el){
        if(cs[id]!=undefined)
            cs[id].value=$(el).val();
    }
    /*changes for DI ends*/
    
    </script>
