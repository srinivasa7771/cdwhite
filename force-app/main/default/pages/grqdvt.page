<apex:page sidebar="false" controller="ApplicantDetailController" docType="html-5.0" id="page" cache="false" readOnly="false"
           showHeader="true" standardStylesheets="false" lightningStylesheets="true" title="{!req.srvc__r.lbl__c}">
    <apex:slds />
    <html>        
        <apex:includeScript value="{!URLFOR($Resource.vendors_NUI, '/jquery/dist/jquery.min.js')}"/> 
        <apex:includeScript value="{!$Resource.jsH}"/>
        <apex:includeScript value="{!$Resource.AXS2CustomJs}"/>
        <apex:stylesheet value="{!$Resource.axs2MandateCss}"/>
        <apex:includeScript value="{!$Resource.AXS2_formValidations}"/>
        <apex:includeScript value="{!$Resource.AXS2Validations}"/>
        <script type="text/javascript">
        var GCC_Nations = ['Bahrain', 'Kuwait', 'Oman', 'Qatar', 'Saudi Arabia', 'United Arab Emirates'];
        var cs = {};
        function changeLabel(elem,val){
            $(elem).parent().find('label').html(val);
        }
        $(document).ready(function() {
            console.log('document ready::::');
            //hide ID Available field
            $(cs['xeidav__c']).parent().parent().hide();
            mr();
            changeLabel(cs['xceml__c'],"Applicant's email");
            $('#appMobile').html('Applicant&#180;s mobile');
            $('.alphaChar').bind('keyup', function(e) {
                $(this).val($(this).val().replace(/[^a-zA-Z ]/g, ''));
                if (e.which >= 97 && e.which <= 122) {
                    var newKey = e.which - 32;
                    e.keyCode = newKey;
                    e.charCode = newKey;
                }
                $(this).val(($(this).val()));
            });
            $('.numOnly').keypress(function (event) {
                var charCode = (event.which) ? event.which : event.keyCode;
                if (charCode != 46 && charCode > 31 
                    && (charCode < 48 || charCode > 57))
                    return false;
                return true;
            });
            //remove current Nationality onchange method
            cs['xcnc__c'].removeAttribute('onchange');
            //disable Martial status,Salutation
            cs['xcslt__c'].value = 'Mrs.';
            cs['xcms__c'].value = 'Married';
            $('[value="Mrs."]').prop('checked',true);
            $('[value="Married"]').prop('checked',true);
            $("input[name='martialStatus']").attr('disabled',true);
            $("input[name='salutation']").attr('disabled',true);
        });
        function dformat(dt,id){
            var d = new Date(dt);//alert(d);
            var m=d.getMonth()+1;
            var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
            var mm=m>9?m:'0'+m;
            var yy=d.getFullYear();
            document.getElementById(id).value=dd+'/'+mm+'/'+yy;
        }
        //Add  warning message
        function addWarningMsg(thiselem,message){
            console.log('addWarningMsg:::');
            var elem = $(thiselem);
            var warElem = '<div class="warningMsg">'+message+'</div>';
            if($(thiselem).attr('data-toggle') == 'datetimepicker'){
                elem.parent().parent().append(warElem);
            }else{
                elem.parent().append(warElem);
            }
        }
        //Remove warning error
        function removeWarningMsg(thiselem){
            console.log('removeWarningMsg:::');
            var elem = $(thiselem);
            elem.parent().parent().find('.warningMsg').remove();
            //elem.parent().find('.warningMsg').remove();
        }
             
        //Remove validation error
        function removeValError(thiselem){
            var elem = $(thiselem);
            elem.parent().find('.frmErrMsg').remove();
            elem.parent().parent().find('.frmErrMsg').remove();
        }
        //Validation  for UAE Mobile Number
        //validate mobile number
        function checkMob(thisElem){
            var mobNo = $(thisElem).val();
            if(mobNo.length < 10){
                addValError(thisElem,'Please enter valid mobile Number!!');
            }else{
                removeValError(thisElem);    
            }
        }
        //check whether date is valid or not
        function checkValidDate(thisElement){
            console.log('validDate:::');
            var date = $(thisElement).val();
            console.log('date:::'+date);
            var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
            var r = (date_regex.test(date))?true:'invalid';
            console.log('r::::'+r);
            if(r == 'invalid'){
                removeWarningMsg(thisElement);
                removeValError(thisElement);   
                addValError(thisElement,'Invalid date format');
                $(thisElement).addClass("is-invalid");
                return false;    
            }else{
                removeValError(thisElement);  
                $(thisElement).removeClass("is-invalid");
                return r;
            }
        }
        //Validate DOB
        function validateDOB(thisElement){
            console.log('validateDOB::::');
            checkValidDate(thisElement);
        }
        //Scroll to Div
        function scrollToDiv(e){
            $('html,body').animate({
                scrollTop: (e.offset().top-60)
            }, 100);
            e.focus();
        }
        //Validate Data on click of next button
        function validateData(){
            console.log('validateData:::');
            var elem = '';
            var validated  = true;
            console.log('validateData :::::::::::'+validated);
            $('.requiredFld').each(function(){
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    console.log('id::::::'+$(this).attr("id"));
                    addValError(this,'**This field is required!');
                    validated=false;
                    if(elem=='') elem = $(this);
                }else{
                    removeValError(this);  
                }
            });
            console.log('required :::::::::::'+validated);
            $('.ddValidation').each(function(){
                //debugger;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                showErrMsg($(this),'rqrd',true);
                var v = $(this).val();
                if(v==''||v==null||v==undefined){
                    if($(this).is('select'))
                        showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                    else
                        showErrMsg($(this),'rqrd','invalid');
                    return false;
                }
            });
            var salutation = $("input[name='salutation']:checked").val();
            var martialStatus = $("input[name='martialStatus']:checked").val();
            if(salutation == undefined){
                //alert('Please select salutation');
                $("input[name='salutation']").parent().parent().parent().find('.option-error').show();
                validated =false;
            }
            console.log('salutation v:'+validated);
            if(martialStatus == undefined){
                $("input[name='martialStatus']").parent().parent().parent().find('.option-error').show();
                //alert('Please select martial status');
                validated =false;
            }console.log('martialStatus v:'+validated);
            if(GCC_Nations.includes(cs["xcnc__c"].value)){
                validated =false;
                addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                scrollToDiv($(cs["xcnc__c"]));
            }console.log('GCC_Nations v'+validated);
            console.log('visible::::'+$('.frmErrMsg').is(':visible'));
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                validated = false;
            }console.log('frmErrMsg :::::::::::'+validated);
            if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                validated = false;
            }console.log('frmErrMsg11111111 :::::::::::'+validated);
            //alert('requiredFld v:'+validated);
            console.log('validated::::'+validated);
            if(elem!=''){
                console.log('null elem:::::');
                scrollToDiv(elem);
            }
            if(validated == true){
                showTempLoader(event.target);
                toggleGLoader();
                next();
            }
        }
        function showTempLoader(e){
            var loader = '<span class="loader_temp">';
            loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
            loader += '</span>';
            $(e).find('.loader_temp').remove();
            $(e).append(loader);
            $('*').addClass('loadingProgress');
        }
        function removeTempLoader(){
            $('*').removeClass('loadingProgress');
            $('.loader_temp').remove();
        }
        function saveReqDraft(){
            if($('.frmErrMsg').is(':visible')){
                scrollToDiv($('.frmErrMsg').eq(0).parent());
                return;
            }
            else if($('.frmErrMsg1').is(':visible')){
                scrollToDiv($('.frmErrMsg1').eq(0).parent());
                return;
            }
            saveReqDraft1();
            toggleGLoader();
        }
        function ecCheck(elem,event){
            $(elem).attr('maxlength',16);
            let v = $(elem).val();
            let l = $(elem).val().length;
            //alert(l);
            if(l==3 || l==8  ){
                $(elem).val(v+'/');
            }
        }
        </script>
        <style>
            .errField{
            border: 0.5px solid #ff00006e !important;
            }
            .frmErrMsg,.frmErrMsg1 {
            color: #ff0000;
            font-style: italic;
            padding-left: 0.8rem;
            position: absolute;
            }
            .warningMsg{
            color:#004eff;
            font-style: italic;
            padding-left: 0.8rem;
            position: absolute;
            background-color: #d5ded9;
            }
        </style>
        <apex:form id="mainForm" styleClass="form-style">
            <div class="slds-align_absolute-center">
                <apex:pageBlock id="pbMain">
                    <apex:actionFunction name="saveReqDraft3" action="{!saveDraft}"  reRender="comp" oncomplete="$('.loader_rerender').hide();hideTempLoader_input();" />
                    
                    <apex:outputPanel id="saveRq">
                    </apex:outputPanel>
                    <apex:actionFunction name="next"  action="{!saveReq}" status="theStatus"  reRender="btnid,errmsg,saveRq,msg" oncomplete="$('#preloader').fadeOut();hideTempLoader_input();"    onbeforedomupdate="javascript: toggle_inputs();"/>
                    <apex:actionFunction name="saveReqDraft1" action="{!saveDraft}" oncomplete="toggleGLoader();showDraftAlert();" />
                    
                    <apex:actionFunction name="cancelRq" action="{!CancelR}" reRender="errmsg,msg" oncomplete="toggleGLoader();" />
                    <apex:actionFunction name="svRDrft" action="{!saveDraft}" status="theStatus" rerender="msg"  oncomplete="toggleGLoader();showDraftAlert('{!JSENCODE(req.Name)}')"/>
                    
                    <apex:actionFunction name="boSave" action="{!saveBO}" oncomplete="hideGLoader();showDraftAlert2('{!JSENCODE(req.Name)}');" />
                    <apex:outputPanel rendered="{!AND(NOT(ispu),NOT(isgu))}">
                        <c:guheader heading="{!srv.lbl__c}" />
                    </apex:outputPanel>
                    
                    <body class="base">
                        
                        <div id="main">
                            <div class="container pt-2 pb-2">
                                <div class="text-right">
                                    <span class="d-inline-block mr-2 align-middle" style="font-size: 1.875rem;line-height: 1;">
                                        SR # <span class="text-000">{!req.Name} </span>
                                    </span> 
                                    <!-- <a href="#" onclick="saveReqDraft()" class="btn btn-black"> SAVE DRAFT </a>-->
                                    <c:drftCnclBtns req="{!req}" shwCncl="true" shwDraft="{!IF(OR(req.id=='',req.STA__c=='Draft',req.STA__c=='Open'),true,false)}"/>
                                </div>
                            </div>
                            
                            
                            
                            <div class="container">
                                
                                <div class="base-layout">
                                    <!--left-side pannel start-->   
                                    <div class="base-side">
                                        <div class="base-side-content">
                                            <div>
                                                
                                                <c:grqupd PageControllerBaseCalling="{!this}" keyAssigned="componentOne" Dim="V" id="comp" PayDone="{!if(req.AP__c>0,true,false)}"/>
                                                
                                            </div>
                                        </div>
                                        <!-- .base-side-content -->
                                    </div>
                                    <!--left-side pannel- end -->  
                                    <div class="base-main">
                                        
                                        <div class="base-main-content">
                                            <c:grqbrdcrumbs req="{!req}" applicant="active" addon="" payment=""/> 
                                            <div class="steps steps-mobile">
                                                
                                                <div class="step-item active">
                                                    <div class="step-item-inner">
                                                        <i class="step-icon icon-members"></i>
                                                        <div class="step-title">Applicant</div>
                                                    </div>
                                                </div>
                                                <!--  -->
                                                <div class="step-item">
                                                    <div class="step-item-inner">
                                                        <i class="step-icon icon-addon"></i>
                                                    </div>
                                                </div>
                                                <!--  -->
                                                <div class="step-item">
                                                    <div class="step-item-inner">
                                                        <i class="step-icon icon-cash-deposit"></i>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- .steps-mobile -->
                                            
                                            
                                            <b><apex:pageMessages id="msg"  />
                                                
                                                
                                            </b>
                                            
                                            <c:passportdetails req="{!req}" id="ppdCmp"/>
                                            <c:emiratesidinfo req="{!req}" id="EinfoCmp"/>
                                            <!-- .base-collapse -->
                                            <div class="base-collapse">
                                                <a href="#" class="collapse-toggle" data-toggle="collapse" data-target="#application_details">
                                                    <div class="collapse-title">Applicant Details</div>
                                                </a>
                                                <div id="application_details" class="collapse show">
                                                    <div class="collapse-content">
                                                        
                                                        <form class="form-style" id="app_details_form" action="">
                                                            <div class="row row-lg">
                                                                <div class="col-lg-6">
                                                                    <div class="form-group">
                                                                        <label>Previous Visa No </label>
                                                                        <apex:inputField onkeydown="ecCheck(this,event)" styleClass="forDraft requiredFld form-control" value="{!req.e__c}" id="e__c" />
                                                                        <apex:inputHidden id="xctp__c" value="{!req.xctp__c}" />
                                                                        <script type="text/javascript">
                                                                        cs['e__c']=document.getElementById('{!$Component.e__c}');
                                                                        cs['xctp__c']=document.getElementById('{!$Component.xctp__c}');
                                                                        cs['xctp__c'].value = 'Dependent Transfer';
                                                                        </script>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <c:personaldetailsBO req="{!req}"     
                                                                              Salutations="{!salutations}"  
                                                                              MartialStatus="{!MartialStatus}" 
                                                                              SpokenLanguages="{!spokenLanguages}" id="perDetail" />
                                                            <c:contactinformation req="{!req}" id="conInfoCmp"/>
                                                            <c:educationqualification req="{!req}" id="qualificationCmp"/>
                                                            <c:collectionanddeliveryinfo req="{!req}" id="collDelcmp"/> 
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- .base-main-content -->
                                            <c:saveBtn ispu="{!ispu}" isgu="{!isgu}"/>
                                        </div>
                                        <!-- .base-main -->
                                        
                                    </div>
                                    <!-- .base-layout -->
                                    
                                </div>
                                <!-- .container -->
                                
                                
                                <!-- .site-footer-wrapper -->
                            </div>
                            
                            <!-- Modal -->
                            
                        </div>
                    </body>
                </apex:pageBlock>
            </div>
        </apex:form>
        <apex:form id="uploadFrm">
            <div class="slds-align_absolute-center">
                <c:fileuploadpopupnew13 R="{!req}" /> 
            </div>
        </apex:form>
    </html>    
</apex:page>