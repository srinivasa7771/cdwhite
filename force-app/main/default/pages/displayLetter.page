<apex:page standardController="g_Req__c" extensions="displayLetterCtl" >
    <script>
    window.onload = function() {
        document.getElementById('hnavC').style.display='none';
    };
    
    </script>
    
    <style>
        input[type=text], select {
        width: 15%;
        height: 12px;
        padding: 12px 20px;
        margin: 8px 0;
        display: inline-block;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
        
        }
        .rc-anchor-checkbox-label { font-size: 10px!important; }
    </style>
    
    <apex:form id="pgplck">
        
        <apex:actionPoller action="{!init}" reRender="pgplck" interval="20"  enabled="{!NOT(displayflag)}"  />
        <apex:outputPanel rendered="{!NOT(displayflag)}">
            <div style="text-align: center;" >
                <apex:image url="{!URLFOR($Resource.letterLoad)}" width="50" height="50"/> <br/>
                Letter is getting generated
            </div>
        </apex:outputPanel>
        <apex:outputPanel rendered="{!displayflag}">
            <div style="text-align: center;width: 100%;height: 800px;"> 
                <embed src="{!urlLetter}" width="80%" height="100%" type='application/pdf'/>
            </div>
        </apex:outputPanel>
        
    </apex:form>
</apex:page>