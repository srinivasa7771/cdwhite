        <script>
        
        function imgError(elem,g){
            elem.onerror = "";
            var gen = (g=="Female")?g:"Male";
            elem.src = "./resource/assets_NUI/images/"+gen+"-Default.png";
            return true;
        }
        $('.forActions').unbind().on('click',function(){
            //console.log($(this).index());
            var f = $(this).attr('for');
            $('#panel_actions').find('.actionsElem').hide();
            $('#panel_actions').find('[for="'+f+'"]').show();
        });
        
        
        $('.data-value').each(function(){
            var v = $(this).html().trim();
            if(!v)
                $(this).html('<b>-</b>');
        });
        $('.comNum').each(function(){
            $(this).text($(this).text().toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","));
        });
        </script>
        
