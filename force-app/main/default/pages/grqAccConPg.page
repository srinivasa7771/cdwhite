                <apex:actionFunction name="callCancelOutCounWP"  action="{!CancelOutCounWPR}"/>
                <apex:actionFunction name="callCancelOutCounWoP"  action="{!CancelOutCounWoPR}"/>
                <apex:actionFunction name="callAbsDec"  action="{!AbsDecR}"/>
                <apex:actionFunction name="callNoSpoID"  action="{!cancelNonSPonsorId}"/>
                <apex:actionFunction name="callWithDraw"  action="{!WithdrawR}"/>
                <apex:actionFunction id="callAction" name="callAction"  action="{!callAction}">
