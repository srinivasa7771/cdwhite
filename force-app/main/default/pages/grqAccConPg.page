    <style>
        i.selectPay {
        position: relative;
        padding: 5px 5px 0px 0px;
        cursor: pointer;
        }
        .box.box-block {
        width: 100% !important;
        }
    </style>
    <script>
    
    function openLetter(e){
        let accId = '';
        accId = document.getElementById('j_id0:pmain:j_id42:j_id43:accountCh_lkid').value;
        if(!accId || accId=='000000000000000'){
            alert('Please select Account!');
            return;
        }
        let url = '/apex/grql?sid=a0L2000000YpO5lEAF&aid='+accId;
        window.open(url,'_blank');
    }
    function callCancelInCoun(str){
        
        callCancelInCoun();
        
    }
    function callCancelOutCounWP(str){
        callCancelOutCounWP();
    }
    function callCancelOutCounWoP(str){
        callCancelOutCounWoP();
    }
    function callAbsDec(str){
        callCancellation();
    }
    function callNoSpoID(str){
        callNonSpon();
    }
    function callWithDraw(str){
        callCancellation();
    }
    function callAction(srvName){
        console.log(srvName);
        callAction(srvName);
    }
    function callNoSpoDeposit(str) {
        console.log('::str::',str);
        callNoSpoDepositAction();
    }
    </script>
    <head>
