                        <apex:inputField value="{!rq.Acc__c}" id="accountCh" label="Account:" styleClass="slds-form-element__label"/>
                        <apex:inputField value="{!rq.Con__c}" id="contactCh" label="Contact:" styleClass="slds-form-element__label"/>
                    </apex:pageBlockSection>
                    <br/>
                    <apex:pageBlockSection columns="1">
                        <div style="text-align: center;">
                            <a href="#" style="color:#FFF;" onclick="callCancelInCoun('Cancellation Inside UAE');" class="btn btn-primary ml-3">Cancellation Inside UAE</a>
                            <a href="#" style="color:#FFF;" onclick="callCancelOutCounWP('Cancellation Outside UAE with Passport');" class="btn btn-primary ml-3">Cancellation Outside UAE with Passport</a>
                            <a href="#" style="color:#FFF;" onclick="callCancelOutCounWoP('Cancellation Outside UAE without Passport');" class="btn btn-primary ml-3">Cancellation Outside UAE without Passport</a>
                            <a href="#" style="color:#FFF;" onclick="callNoSpoID('Cancellation Non Sponsor Id');" class="btn btn-primary ml-3">Cancellation Non Sponsor Id</a>
