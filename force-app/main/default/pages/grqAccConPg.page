                            <a href="#" style="color:#FFF;" onclick="callWithDraw('Withdrawal');" class="btn btn-primary ml-3">Withdrawal</a>
                            <a href="#" style="color:#FFF;" onclick="callNoSpoDeposit('Non Sponsored ID - Security Deposit');" class="btn btn-primary ml-3">Golden Visa Non-Sponsored ID Deposit</a>
                            <br/>
                        </div>
                    </apex:pageBlockSection>
                    <!--<apex:pageBlockSection columns="1">
