                        <a href="#" onclick="openLetter()" style="color:#FFF;" class="btn btn-primary ml-3">Request a letter</a>
                        <a href="/apex/grnbgr?sid=a0L2000000YQVK9EAP" target="_blank" style="color:#FFF;" class="btn btn-primary ml-3">Bank Grantee Refund</a>
