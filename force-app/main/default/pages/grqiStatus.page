            <script type="text/javascript">
           
            
            var cs = {};
            var GCC_Nations = ['Bahrain', 'Kuwait', 'Oman', 'Qatar', 'Saudi Arabia', 'United Arab Emirates'];
            function dformat(dt,id){
                var d = new Date(dt);//alert(d);
                var m=d.getMonth()+1;
                var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
                var mm=m>9?m:'0'+m;
                var yy=d.getFullYear();
                document.getElementById(id).value=dd+'/'+mm+'/'+yy;
            }
            function scrollToDiv(e){
                $('html,body').animate({
                    scrollTop: (e.offset().top-60)
                }, 100);
                e.focus();
            }
            //Validate Data on click of next button
            function validateData(){
                let elem = '';
                let validated = true;
                $('#serachVal').addClass('requiredFld');
                if($('.frmErrMsg').is(':visible')){
                    scrollToDiv($('.frmErrMsg').eq(0).parent());
                    return;
                }
                if(GCC_Nations.includes(cs["xcnc__c"].value)){
                    validated =false;
                    addValError(cs["xcnc__c"],'GCC nationals are not allowed !!');
                    scrollToDiv($(cs["xcnc__c"]));
                }
                $('.requiredFld').each(function(){
                    if(!$(this).is(':visible'))
                        return;
                    var v = $(this).val();
                    if(v==''||v==null||v==undefined||v.lenght<1){
                        if(elem=='')
                            elem = $(this);
                        addValError($(this),'This field is required');
                        validated =  false;
                    }
                    else
                        removeValError($(this));
                    var onc = $(this).attr('onchange');
                    if(onc){ $(this).trigger('onchange')}
                });
                //alert('requiredFld v:'+validated);
                console.log('validated::::'+validated);
                if(elem!=''){
                    scrollToDiv(elem);
                }
                
                
                if(validated == true){
                    //showTempLoader(event.target);
                    //toggleGLoader();
                    //console.log('Expiry Date:::'+cs['xcped__c'].value);
                    //console.log('DOB:::'+cs['xcbd__c'].value);
                    // next();
                    //alert("Req Updated::::::::::");
                    addItm('');
                }
            }
            
            function enableItm(itmCd){
                
                if(itmCd == 'eci' || itmCd == 'eca'){
                    cs["itmCdId"].value=itmCd;
                   
                    $('#modal_item_information').modal('show');
                }
                else{
                     $('#preloader').fadeIn();
                    createItm(itmCd); 
                }
                /*else if(itmCd == 'exu') {
                                  cs["itmCdId"].value=itmCd;
                                  $('#modal_Cancel').modal('show');
                              }*/
                
            }
            function createItem(){
                
                addItm('');$('#preloader').fadeIn();
            }
            function addItm(itmCd){
                if(itmCd == null || itmCd == ''){
                    itmCd = cs["itmCdId"].value;
                }
                if($('#xcbd1__c').val() != null)
                {
                    cs["xcbd2__c"].value=$('#xcbd1__c').val();
                }
                
                $('#modal_item_information').modal('hide');
                $('#modal_Cancel').modal('hide');
                
                if(itmCd == 'ai'){
                    var invalData = false;
                    if($('#datepicker1').val() == null || $('#datepicker1').val() == ''){
                        axsAlert('Validation Error.','Please update Arrival Date.');
                        return;
                    } 
                    if($('.frmErrMsg').length >1  || $('.frmErrMsg').is(':visible')){
                        invalData = true; 
                    }
                    if(invalData){
                        axsAlert('Validation Error.','Arrival Date should not be today/future date.');
                        return;
                    }
                    
                    cs["xad__c"].value=$('#datepicker1').val();
                    
                }
                if(itmCd == 'exu'){
                    cs["xad__c"].value=$('#datepicker2').val();
                }
                $('#preloader').fadeIn();
                console.log('xad__c::'+cs["xad__c"].value);
                createItm(itmCd);
            }
            
            function downloadDoc(){    
                var srv_uid = '{!rq.srvc__r.uid__c}';
                if(srv_uid =='apt' && new Date('{!rq.xcped__c}')>=new Date()){
                    window.open('/apex/grqAPPdf?id={!rq.id}','_blank');
                }else if(srv_uid=='162' || srv_uid=='198' || srv_uid=='199' || srv_uid=='212' ){
                    window.open(polLink,'_blank');
                }else{
                    $('[href="#documents_tab_this"]').trigger('click');
                }
            }
            
            /*function downloadDoc(){
