                                </tr>
                                <apex:repeat id="r1" value="{!rq.Transactions__r}" var="t">
                                    <apex:outputpanel layout="none" rendered="{!IF(AND(t.TP__c='Payment',t.STA__c='Open'),true,false)}">
                                        <tr class="dataRow">                                                        
                                            <td class="actionColumn c1">
                                                <apex:outputpanel layout="none" rendered="{!AND(t.STA__c='Open',t.md__c!='Credit / Debit Card',t.TP__c='Payment')}">
