                                                </apex:outputpanel>
                                            </td>
                                            <td class="dataCell"><apex:outputField value="{!t.Name}"/></td>
                                            <td class="dataCell"><apex:outputField value="{!t.STA__c}"/></td>
                                            <td class="dataCell"><apex:outputField value="{!t.TP__c}"/></td>
                                            <td class="dataCell"><apex:outputField value="{!t.dt__c}"/></td>
                                            <td class="dataCell"><apex:outputField value="{!t.md__c}"/></td>
                                            <td class="dataCell CurrencyElement"><apex:outputField value="{!t.A__c}"/></td>
                                        </tr>
                                    </apex:outputpanel>
                                    
                                </apex:repeat>
                            </tbody>
                        </table>
                    </apex:outputpanel>
