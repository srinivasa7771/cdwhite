                                               AD += {!IF(ISNULL(I.I.su__c), 0, I.I.su__c)}+{!IF(ISNULL(I.I.vsu__c), 0, I.I.vsu__c)}; 
                                               VAT += {!IF(ISNULL(I.I.vsu__c), 0, I.I.vsu__c)};
                                             }*/
                                             </script>
                                           
                                        </td>
