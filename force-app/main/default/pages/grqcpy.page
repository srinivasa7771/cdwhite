                                            AD += {!IF(ISNULL(I.I.AV__c), 0, I.I.AV__c)};AD += {!IF(ISNULL(I.I.tvatp__c), 0, I.I.tvatp__c)};AD += {!IF(ISNULL(I.I.tvngp__c), 0, I.I.tvngp__c)};VAT += {!IF(ISNULL(I.I.AV__c), 0, I.I.AV__c)};
