    function validateSwiftCode(swift) {
        swift = swift.replace(/\s+/g, '').toUpperCase();
        const swiftRegex = /^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$/;
        if (!swiftRegex.test(swift)) {
            return false;
        }
        if (swift.length !== 8 && swift.length !== 11) {
            return false;
        }
        return true;
    }    
    
