    function runOnKeypressfn(ev,id,arid){
        var username = document.getElementById(id).value;
        if(username.length >1){ 
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.gctlReq_L.getArabicName}',
                username,
                function(result, event){
                    if (event.status) {
                        // Get DOM IDs for HTML and Visualforce elements like this
                        document.getElementById(arid).value = result;
                    } else if (event.type === 'exception') {
                        document.getElementById("responseErrors").innerHTML = 
                            event.message + "<br/>\n<pre>" + event.where + "</pre>";
                    } else {
                        document.getElementById("responseErrors").innerHTML = event.message;
                    }
                }, 
                {escape: true}
            );
        }
    } 
    
    function vfrm(nSTA){return hsSnc(nSTA)?!1:!0} 
    
    /*function vfrm(nSTA){
        fnxPg = 'grqup';
        //return hsSnc(nSTA)?!1:hRq(nSTA)?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):nRefd()?(alrt("Terms & Conditions","Please read and agree to Ramadan Permit Guidelines in order to process with your application."),!1):hErr(nSTA)?(alrt("{!$Label.msgCRR}","{!$Label.msgCRRD}"),!1):hErr(nSTA)?(alrt("{!$Label.msgCRR}","{!$Label.msgCRRD}"),!1):valDates()?(alrt("{!$Label.msgRF}","{!$Label.msgRFD}"),!1):!0
        
    }*/
