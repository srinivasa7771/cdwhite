    $(document).ready(function(){
        if(cs['xcfn__c'].value){
            runOnKeypressfn(event,'{!$Component.xcfn__c}','{!$Component.xcfnar__c}');
        }
        if(cs['xcmn__c'].value){
            runOnKeypressfn(event,'{!$Component.xcmn__c}','{!$Component.xcmnar__c}');
        }
        if(cs['xcln__c'].value){
            runOnKeypressfn(event,'{!$Component.xcln__c}','{!$Component.xclnar__c}');
        }
        if(!Array.prototype.includes){
            Array.prototype.includes = function(a){return-1!=this.indexOf(a)}
        }
        displayXla2d(getC(cs['xltr__c'].id).value);  hideXla2d(cs['xla2__c2'].value);
    });
    
    function ifrm(){cs['xlt__c'].value="Non Sponsored Student";}
    function assignfldVal(val,fldId){cs[fldId].value=val;}

    function pvc(){var a=document.getElementById(cif);void 0!=a&&""!=a.value&&"000000000000000"!=a.value&&window.open("/apex/gcp?id="+a.value,"gcp","menubar=0,toolbar=0,titlebar=0,status=0,location=0,scrollbars=0,resizable=1,top=28,left=0,width=580,height=580",!1)}
    
    function uac(){var a=document.getElementById(cif),b=document.getElementById(cnf);void 0!=a&&""!=a.value&&"000000000000000"!=a.value&&void 0!=b&&""!=b.value&&""!=b.value&&(window.location.href="{!$Label.urlUA}&cid="+a.value+"&cnm="+b.value)}
    
    function pvc2(){window.open("/apex/gcp?id={!rq.Con__c}","gcp","menubar=0,toolbar=0,titlebar=0,status=0,location=0,scrollbars=0,resizable=1,top=28,left=0,width=580,height=580",false);}
    
    function uac2(){window.location.href= "{!$Label.urlUA}&cid={!rq.Con__c}&cnm={!rq.Con__r.Name}";}
    
    function dftA2(){cs['xla2__c']=getC(aif);if(2==cs['xla2__c'].options.length){cs['xla2__c'].value=cs['xla2__c'].options[1].value;af=cs['xla2__c'].value;}}
    
    function dftA2d(){cs['xla2d__c']=getC(adif);if(2==cs['xla2d__c'].options.length){cs['xla2d__c'].value=cs['xla2d__c'].options[1].value;adf=cs['xla2d__c'].value;}}
    
    function letterclick(){
        var rqId = '{!rq.id}';
        window.open("/apex/displayLetter?id="+rqId, "_blank", "directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=no,resizable=no,width=950, height=600,top=50, left=200");
    }     
    
    function checkFields(){
        var brk = vflds();        
        if(!brk){brk = !vfrm();}
        if(!brk){showTempLoader(event.target);toggleGLoader(); afso(); }
    }
    
    
     // varibles for letterAddressedTo_2 field
    var label2 = {"Authorities":"an authority","Banks":"a bank","Consulates":"a consulate","Government Departments":"the Government Department","Ministries":"a ministry","Others":"a language","Telecom":"a telecom","Embassies":"an embassy","Airports and Security Offices":"an airport/security office","Free Zone":"a free zone","Port":"a port","Emirate":"an emirate","RTA":"an emirate","Emirates Group":"the Emirates Group","Ministry of Labour":"a ministry"};
    var showXla2d = ['Employment Letter', 'Entry Pass New / Renewal', 'Letter to Economic Dept (Employee)', 'Letter to Economic Dept (Licencee/Shareholder)', 'No Objection Temporary Work Permit Letter', 'Salary Certificate', 'Visa Multi Entry', 'Visa Single Entry','Bonafide student certificate'];
    
    function displayXla2d(ltr){
        //var hideXla2d = ['Boat Driving License', 'Boat Registration Personal', 'Letter to Dubai Customs', 'Liquor License', 'Lost Driving License', 'Lost EIDA Card', 'Lost Passport', 'Lost Wallet', 'RTA Bike Driving License New / Renewal', 'RTA Bus Driving License New / Renewal', 'RTA Driving License New / Renewal', 'RTA Truck Driving License New / Renewal - Hide', 'Selling or Purchasing Boat']; 
        if(showXla2d.includes(ltr) && af!=""){ 
            getC("xla2d_l").style.display='block';$('#label_ad2').text("Select " + label2[af]); 
            
        }else{
            getC("xla2d_l").style.display='none';
        }
        
        var xla2  = ["Active Employees List","Letter to Dubai Police","Tax Exemption Letter","Permit for Catering Service","NOC To DED (Partake as Shareholder)","Letter to Dubai Customs"];
        if(xla2.includes(ltr) || ltr==""){ getC("xla2_l").style.display='none';}else{getC("xla2_l").style.display='block';}
        assignVals(ltr);
    }
    
    function hideXla2d(ltr){       
        if(getC(cs['xltr__c'].id).value=="Bonafide student certificate"){
            var hideXla2d = ['General Directorate of Residence and Foreigners Affairs'];
            if(hideXla2d.includes(ltr)){ 
                getC("xla2d_l").style.display='none';
            }else if(ltr!=""){
                getC("xla2d_l").style.display='block';
            }
        }
    }
    
    function assignVals(ltr){
        if(af!=undefined && af!='' && showXla2d.includes(ltr) && af!="Others" ){
            //cs['xla2__c'].onchange();
            var ltraddto = (af=="Consulates")?"Consulate of " : (af=="Embassies") ? "Embassy of " : (af=="Emirates Group") ? "Emirates Group- " :"";
            if(adf!=undefined && adf!=""){ltraddto += adf;}
            cs['rtacn__c'].value = ltraddto;
        }else if(af!=undefined && af!='' && af!="Others"){ 
            cs['rtacn__c'].value = af;
        }else if(af=="Others"){
            cs['rtacn__c'].value = aO +'-'+adf;
        }
        
         if(cs['rtacn__c'].value ==""){cs['rtacn__c'].value =af;}
    }
    
    function removeLtr2Val(){
        adf=''; if(cs['xla2d__c']!=undefined && cs['xla2d__c']!=null){cs['xla2d__c'].value ="" ; $(cs['xla2d__c']).trigger("change");}
    }
    
    
    function vflds(){
        var brk = false;var elem = '';
        $('.requiredFld').each(function(){
            var v = $(this).val();
            //if($(this).is(':visible')){         
                if(v==''||v==null||v==undefined||v.length<1){
                    brk=true; addValError(this,'This field is required!');
                    if(elem==''){ elem = $(this);}
                }else{ removeValError(this);  }
                
                if(elem!=''){$('html,body').animate({ scrollTop: (elem.offset().top-60)}, 100); elem.focus();}
            //}
        });
        return brk;
    }
    
    
    function removeValError(thiselem){
        var elem = $(thiselem);
        elem.parent().find('.frmErrMsg').remove();
        elem.parent().parent().find('.frmErrMsg').remove();
    }
    
    function addValError(thiselem,message){
        var elem = $(thiselem);
        elem.parent().find('.frmErrMsg').remove();
        elem.parent().parent().find('.frmErrMsg').remove();
        var errElem = '<div class="frmErrMsg">'+message+'</div>';
        if($(thiselem).attr('data-toggle') == 'datetimepicker'){
            elem.parent().parent().append(errElem);
        }else{
            elem.parent().append(errElem);
        }
    }
    
    function showTempLoader(e){
        var loader = '<span class="loader_temp">';
        loader += '<img width="20" src="/resource/1583658416000/assets_NUI/images/ip_loader.gif" />';
        loader += '</span>';
        $(e).find('.loader_temp').remove();
        $(e).append(loader);
        $('*').addClass('loadingProgress');
    }
    
    function removeTempLoader(){
        $('*').removeClass('loadingProgress');
        $('.loader_temp').remove();
    }    
    
    function salutionOnChange(){
        var salutation = $("input[name='salutation']:checked").val();
        $("input[name='salutation']").parent().parent().parent().find('.option-error').hide(); 
        cs['xcslt__c'].value=salutation;
        console.log('salutionOnChange >>'+ cs['xcslt__c'].value);
    }
    
    function dformat(dt,id){
        var d = new Date(dt); console.log(dt);
        var m=d.getMonth()+1;
        var dd=d.getDate()>9?d.getDate(): '0'+d.getDate();
        var mm=m>9?m:'0'+m;
        var yy=d.getFullYear();
        
        getC(id).value=dd+'/'+mm+'/'+yy;
        
    }
    
    function createDepDds(){
        setTimeout(function(){
            $('.depDD').select2();
            $('.ddValidation').on('change',function(){
                //debugger;
                if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                    return;
                if(!$(this).is(':visible'))
                    return;
                showErrMsg($(this),'rqrd',true);
                var v = $(this).val();
                if(v==''||v==null||v==undefined||v.lenght<1){
                    if($(this).is('select'))
                        showErrMsg($(this).next().find('.select2-selection'),'rqrd','invalid');
                    else
                        showErrMsg($(this),'rqrd','invalid');
                    return false;
                }
            });
        },400);
    }
    </script> 
    
