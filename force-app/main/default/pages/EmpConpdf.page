<apex:page sidebar="false" showHeader="{!IF(ISNULL(req),'true','false')}" applyBodyTag="false" controller="EmpConpdfController" renderAs="{!IF(ISNULL(req),'','pdf')}">
    <head>
        <apex:includeScript value="{!URLFOR($Resource.AXS2Vendors, '/jquery/dist/jquery.min.js')}"/>
        <style>
            @page {
            margin: 0.3cm 0.2cm;
            size: A4;
            padding: 10px;
            }
            body { font-family: 'Arial Unicode MS'; }
            .imgContainer img {
            width: 100%;
            }
            .dataContainer, .dataContainer1, .dataContainer2 {
            width:330px;
            height:215px;
            position: absolute;
            top: 160px;
            font-size: 10px;
            font-weight:bold;
            left: 210px;
            text-align: center;
            /*border:1px solid;*/
            }
            .dataContainer{
            height:210px;
            }
            .dataContainer1 {
            height:150px;
            top: 425px;
            }
            .dataContainer2 {
            height:150px;
            top: 1350px;
            }
            
            .empVals div {
            margin: 2px 0 0 0;
            position: relative;
            padding-top: 11px;
            min-height:13px;
            /*margin: 4px 0 0 0;*/
            }
            .sign{
            height:38px;
            width:100%;
            }
            .dates{
            position: absolute;
            top: 93px;
            font-size: 10px;
            display: flex;
            width: 100%;
            }
            #engDate{
            left:260px;
            text-align:left;
            position: inherit;
            }
            #arDate{
            right: 240px;
            text-align: right;
            position: inherit;
            }
        </style> 
    </head>
    <body>
        <apex:outputText rendered="{!ISNULL(req)}">
            <h1>
                Request is missing
            </h1>
        </apex:outputText>
        <apex:outputText rendered="{!Not(ISNULL(req))}">
            <div class="container">
                <div class="firstPage">
                    <div class="imgContainer" id="imgContainer1">
                        <img src="{!URLFOR($Resource.Emp_Contract,'/first.png')}" />
                    </div>
                    <div class="dates">
                        <div id="engDate">
                            <apex:outputText value="{0,date,dd/MM/yyyy}">
                                <apex:param value="{!TODAY()}" />
                            </apex:outputText>
                        </div>
                        <div id="arDate">
                            <apex:outputText value="{0,date,dd/MM/yyyy}">
                                <apex:param value="{!TODAY()}" />
                            </apex:outputText>
                        </div>
                    </div>
                    <div class="dataContainer">
                        <div class="empVals">
                            <div>
                                <span>{!req.Acc__r.name}</span>
                            </div>
                            <div>
                                <span>{!req.Acc__r.lc__c}</span>
                            </div>
                            <div>
                                <span>{!req.Con__r.name}</span>
                            </div>
                            <div>
                                <span>{!req.xcp__c}</span>
                            </div>
                            <div>
                                <span>
                                    <apex:outputText value="{0,date,dd'/'MM'/'yyyy}" >  
                                        <apex:param value="{!req.xcped__c}"/>  
                                    </apex:outputText>
                                </span>
                            </div>
                            <div>
                                <span>
                                    <apex:outputText value="{0,date,dd'/'MM'/'yyyy}" >  
                                        <apex:param value="{!doj}"/> 
                                        
                                    </apex:outputText>
                                </span>
                            </div>
                            <div>
                                <span>{!req.xcjb__r.name}</span>
                            </div>
                            <div>
                                <span>{!empDuration}</span>
                            </div>
                        </div>
                    </div>
                    <div class="dataContainer1">
                        <div class="empVals">
                            <div>
                                <span>{!req.xcmbs__c}</span>
                            </div>
                            <div>
                                <span>{!othAllowances}</span>
                            </div>
                            
                        </div>
                    </div>
                </div>
                <div class="secondPage">
                    <div class="imgContainer" id="imgContainer2">
                        <img src="{!URLFOR($Resource.Emp_Contract,'/second.png')}" />
                    </div>
                    <div class="dataContainer2">
                        <div class="empVals">
                            <div>
                                <span>{!req.acc__r.name}</span>
                            </div>
                            <div class="sign" id="sign2">
                                <span></span>
                            </div>
                            <div>
                                <span>{!req.Con__r.name}</span>
                            </div>
                            <div class="sign" id="sign2">
                                <span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </apex:outputText>
    </body>
</apex:page>