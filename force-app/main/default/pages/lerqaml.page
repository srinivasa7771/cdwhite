            console.log(' at date '+validDateInput);
        }
        //console.log('atfersave' +validDateInput + cs['newSubmissionDate'].value + ' '+ wrongDateInput );
        var elem = '';
        var validated  = true;  
        $('.requiredFld:visible').each(function(){
            
            if($(this).attr('disabled')=='true'||$(this).attr('disabled')=='disabled')
                return;
            var v = $(this).val();
            if(!v){
                addValError(this,'**This field is required!');
                validated=false;
                if(elem=='') elem = $(this);
            }else {
                if(isNaN(v) && $(this).hasClass('numbOnly')){
