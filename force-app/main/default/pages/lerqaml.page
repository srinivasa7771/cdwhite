    function checkValidDate(thisElement){
        console.log('validDate:::');
        if(!$(thisElement) || !$(thisElement).is(":visible"))
        return true;
        var date = $(thisElement).val();
        console.log('date:::'+date);
        var date_regex =/^([0-2][0-9]|(3)[0-1])(\/)(((0)[0-9])|((1)[0-2]))(\/)\d{4}$/;
        var r = (date_regex.test(date))?true:'invalid';
        console.log('r::::'+r);
        if(r == 'invalid'){
            removeWarningMsg(thisElement);
            removeValError(thisElement);   
            addValError(thisElement,'Invalid date format');
            return false;    
        }else{
            removeValError(thisElement);   
            return r;
        }
    }
    function validateData(){
        //----------------new logic---------------
        const checkboxes = document.querySelectorAll('.afsCheckbox');
        let isChecked = false;

        // Loop through all checkboxes to check if at least one is selected
        checkboxes.forEach(function(checkbox) {
            if (checkbox.checked) {
                isChecked = true;
            }
        });

        // If no checkbox is selected, show alert and stop execution
