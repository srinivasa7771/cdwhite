            axsAlert('Alert!', 'Please select at least one checkbox to proceed.');
            return false; // Stop further execution
        }
        
        //----------------end new logic----------
        //showGLoader();
        if(document.getElementById('newsd__c').value !== '' && document.getElementById('newsd__c').value !== undefined && document.getElementById('newsd__c').value !== null){
