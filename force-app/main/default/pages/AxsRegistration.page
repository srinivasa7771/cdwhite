<apex:page title="AxsRegisteration" applyHtmlTag="false" showHeader="false" cache="true" readOnly="true" renderAs="PDF">
    <apex:stylesheet value="{!$Resource.gCss}" />
    <html>
        <head>
            <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
            <style type="text/css">
                body { font-family: Arial Unicode MS;font-size:11px; }
                @page {size: A4 portrait;margin-right: 1cm;margin-left: 1cm; border: 2px solid gray; }                
            </style>
        </head>
        <body>
            <apex:pageBlock >
                <table border="0" cellspacing="5" cellpadding="5" width="100%" align="center" style="border-color:#bee6ff;font-family: Arial Unicode MS; font-size: 11pt;">
                    <tr><td align='left' colspan="2"><apex:image url="{!URLFOR($Resource.axsRS, '/images/axs_logo.png')}" /></td></tr>
                    <tr><td><br/></td></tr>
                    <tr><td colspan="2" align="center" style="font-size: 15pt;"><b><u>Request for Correcting Manager In-Charge (Licensee) Details</u></b></td></tr>
                    <tr><td><br/><br/></td></tr>
                    <tr><td>
                    <table width="100%" border="0" cellspacing="4" cellpadding="4" align="center">
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Company Name</b></td><td width="70%" ><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Trade License Number</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Trade License Expiry Date</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Manager In charge (Licensee)</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Contact Number(Mobile)</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Nationality</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Passport #</b></td><td width="70%"><apex:outputText value="" /></td></tr>                        
                        <tr style="background: #F8F8F8;"><td width="40%"><b>Email Address</b></td><td width="70%"><apex:outputText value="" /></td></tr>
                        
                    </table>    
                        <tr><td colspan="2"><br/><br/></td></tr>                       
                        <tr><td colspan="2">I hereby confirm that the above information pertaining to my manager –in charge (licensee) is correct and to the best of my knowledge; kindly arrange to send the AXS Admin user credentials to his/her email address as specified above.<br/><br/></td></tr>
                        <tr><td colspan="2"><br/><br/><br/><br/></td></tr>
                        <tr><td colspan="2" align="left">Authorized Signatory (Name and Signature)</td></tr>                    
                    </td></tr>
                </table>
            </apex:pageBlock>
        </body>
    </html>
</apex:page>